          <Item class="ModuleScript" referent="47">
            <Properties>
              <string name="Name">MazeRoomTemplates</string>
              <string name="Source"><![CDATA[local MazePassageTemplates = require(script.Parent.MazePassageTemplates)

local MazeRoomTemplates = {}

local function freezeRange(minDepth, maxDepth)
    return table.freeze({
        Min = minDepth,
        Max = maxDepth,
    })
end

local function freezeProfile(mode, lootBias, pressure, affordance)
    return table.freeze({
        Mode = mode,
        LootBias = lootBias,
        Pressure = pressure,
        Affordance = affordance,
    })
end

local DEFINITIONS_BY_ID = {
    EntrySafe = table.freeze({
        Id = 'EntrySafe',
        Category = 'EntrySafe',
        DisplayName = 'Entry Safe Room',
        SearchProfile = freezeProfile('staging', 'low', 'low', 'orientation'),
        RiskTier = 0,
        LandmarkWeight = 3,
        AllowedDepthBand = freezeRange(0, 0.15),
        SupportsExternalShellModel = true,
        EndpointType = MazePassageTemplates.EndpointType.Hall,
        WidthClass = 'Wide',
        HeightClass = 'Tall',
        AuthoringAssetId = 'EntrySafe',
    }),
    TransitHall = table.freeze({
        Id = 'TransitHall',
        Category = 'TransitHall',
        DisplayName = 'Transit Hall',
        SearchProfile = freezeProfile('transit', 'low', 'low', 'route_choice'),
        RiskTier = 1,
        LandmarkWeight = 1,
        AllowedDepthBand = freezeRange(0.1, 0.9),
        SupportsExternalShellModel = true,
        EndpointType = MazePassageTemplates.EndpointType.Hall,
        WidthClass = 'Standard',
        HeightClass = 'Standard',
        AuthoringAssetId = 'TransitHall',
    }),
    SearchCluster = table.freeze({
        Id = 'SearchCluster',
        Category = 'SearchCluster',
        DisplayName = 'Search Cluster',
        SearchProfile = freezeProfile('search', 'medium', 'medium', 'room_sweep'),
        RiskTier = 2,
        LandmarkWeight = 1,
        AllowedDepthBand = freezeRange(0.15, 0.95),
        SupportsExternalShellModel = true,
        EndpointType = MazePassageTemplates.EndpointType.Hall,
        WidthClass = 'Standard',
        HeightClass = 'Standard',
        AuthoringAssetId = 'SearchCluster',
    }),
    HighValueRisk = table.freeze({
        Id = 'HighValueRisk',
        Category = 'HighValueRisk',
        DisplayName = 'High Value Risk Room',
        SearchProfile = freezeProfile('high_value', 'high', 'high', 'deep_commit'),
        RiskTier = 4,
        LandmarkWeight = 2,
        AllowedDepthBand = freezeRange(0.55, 1),
        SupportsExternalShellModel = true,
        EndpointType = MazePassageTemplates.EndpointType.Hall,
        WidthClass = 'Narrow',
        HeightClass = 'Standard',
        AuthoringAssetId = 'HighValueRisk',
    }),
    LandmarkFacility = table.freeze({
        Id = 'LandmarkFacility',
        Category = 'LandmarkFacility',
        DisplayName = 'Landmark Facility',
        SearchProfile = freezeProfile('landmark', 'medium', 'medium', 'navigation_anchor'),
        RiskTier = 2,
        LandmarkWeight = 4,
        AllowedDepthBand = freezeRange(0.25, 0.8),
        SupportsExternalShellModel = true,
        EndpointType = MazePassageTemplates.EndpointType.Service,
        WidthClass = 'Wide',
        HeightClass = 'Tall',
        AuthoringAssetId = 'LandmarkFacility',
    }),
    ExtractionReturn = table.freeze({
        Id = 'ExtractionReturn',
        Category = 'ExtractionReturn',
        DisplayName = 'Extraction Return Room',
        SearchProfile = freezeProfile('return', 'low', 'high', 'homeward_decision'),
        RiskTier = 3,
        LandmarkWeight = 3,
        AllowedDepthBand = freezeRange(0.65, 1),
        SupportsExternalShellModel = true,
        EndpointType = MazePassageTemplates.EndpointType.Service,
        WidthClass = 'Wide',
        HeightClass = 'Tall',
        AuthoringAssetId = 'ExtractionReturn',
    }),
    BulkheadGate = table.freeze({
        Id = 'BulkheadGate',
        Category = 'BulkheadGate',
        DisplayName = 'Bulkhead Gate Room',
        SearchProfile = freezeProfile('gate', 'low', 'high', 'threshold_control'),
        RiskTier = 3,
        LandmarkWeight = 2,
        AllowedDepthBand = freezeRange(0.25, 0.75),
        SupportsExternalShellModel = true,
        EndpointType = MazePassageTemplates.EndpointType.Bulkhead,
        WidthClass = 'Wide',
        HeightClass = 'Standard',
        AuthoringAssetId = 'BulkheadGate',
    }),
    ShortcutLoop = table.freeze({
        Id = 'ShortcutLoop',
        Category = 'ShortcutLoop',
        DisplayName = 'Shortcut Loop Room',
        SearchProfile = freezeProfile('shortcut', 'medium', 'medium', 'repathing'),
        RiskTier = 2,
        LandmarkWeight = 2,
        AllowedDepthBand = freezeRange(0.2, 0.85),
        SupportsExternalShellModel = true,
        EndpointType = MazePassageTemplates.EndpointType.Service,
        WidthClass = 'Standard',
        HeightClass = 'Standard',
        AuthoringAssetId = 'ShortcutLoop',
    }),
}

local ORDERED_TEMPLATE_IDS = table.freeze({
    'EntrySafe',
    'TransitHall',
    'SearchCluster',
    'HighValueRisk',
    'LandmarkFacility',
    'ExtractionReturn',
    'BulkheadGate',
    'ShortcutLoop',
})

local function buildEndpointDef(room, definition, directionIndex)
    return {
        Id = string.format('%s_%d', room.Id, directionIndex),
        Direction = directionIndex,
        EndpointType = definition.EndpointType,
        Facing = directionIndex,
        Orientation = 'Outward',
        WidthClass = definition.WidthClass,
        HeightClass = definition.HeightClass,
        IsExternal = false,
        ConnectionRule = {
            AllowedEndpointTypes = MazePassageTemplates.getAllowedEndpointTypes(
                definition.EndpointType
            ),
        },
        PassageArchetypeId = MazePassageTemplates.getDefinition(
            if definition.EndpointType == 'service'
                then 'ServiceSpine'
                else if definition.EndpointType == 'bulkhead'
                    then 'BulkheadConnector'
                    else 'IndustrialHall'
        ).Id,
    }
end

function MazeRoomTemplates.getDefinition(templateId)
    return DEFINITIONS_BY_ID[templateId]
end

function MazeRoomTemplates.getOrderedTemplateIds()
    return ORDERED_TEMPLATE_IDS
end

function MazeRoomTemplates.applyTemplate(room, templateId)
    local definition = DEFINITIONS_BY_ID[templateId]
    if not definition then
        error(string.format('Unknown maze room template: %s', tostring(templateId)), 0)
    end

    room.RoomTemplateId = definition.Id
    room.RoomCategory = definition.Category
    room.SearchProfile = definition.SearchProfile
    room.RiskTier = definition.RiskTier
    room.LandmarkWeight = definition.LandmarkWeight
    room.AllowedDepthBand = definition.AllowedDepthBand
    room.SupportsExternalShellModel = definition.SupportsExternalShellModel == true
    room.AuthoringAssetId = definition.AuthoringAssetId

    return room
end

function MazeRoomTemplates.buildEndpointDefs(room)
    local definition = DEFINITIONS_BY_ID[room.RoomTemplateId]
    if not definition then
        return {}
    end

    local endpointDefs = {}
    local connectedDirections = {}
    for directionIndex in pairs(room.Neighbors or {}) do
        table.insert(connectedDirections, directionIndex)
    end
    table.sort(connectedDirections)

    for _, directionIndex in ipairs(connectedDirections) do
        table.insert(endpointDefs, buildEndpointDef(room, definition, directionIndex))
    end

    table.sort(endpointDefs, function(left, right)
        return left.Direction < right.Direction
    end)

    return endpointDefs
end

return MazeRoomTemplates
]]></string>
            </Properties>
          </Item>
        </Item>
        <Item class="ModuleScript" referent="48">
          <Properties>
            <string name="Name">Roles</string>
            <string name="Source"><![CDATA[return {
    RoleAllocator = require(script.RoleAllocator),
}
]]></string>
          </Properties>
          <Item class="ModuleScript" referent="49">
            <Properties>
              <string name="Name">RoleAllocator</string>
              <string name="Source"><![CDATA[local RoleAllocator = {}

function RoleAllocator.assign(players, roleDefinitions)
    table.sort(players, function(left, right)
        return left.UserId < right.UserId
    end)

    local assignments = {}

    for index, player in ipairs(players) do
        local roleDefinition = roleDefinitions[((index - 1) % #roleDefinitions) + 1]

        assignments[player.UserId] = {
            UserId = player.UserId,
            Name = player.DisplayName,
            RoleId = roleDefinition.Id,
            PublicRole = roleDefinition.PublicRole,
            PrivateRole = roleDefinition.PrivateRole,
            PermissionTags = table.clone(roleDefinition.PermissionTags),
        }
    end

    return assignments
end

return RoleAllocator
]]></string>
            </Properties>
          </Item>
        </Item>
        <Item class="ModuleScript" referent="50">
          <Properties>
            <string name="Name">Session</string>
            <string name="Source"><![CDATA[return {
    MazeRunTracker = require(script.MazeRunTracker),
    SessionStateMachine = require(script.SessionStateMachine),
}
]]></string>
          </Properties>
          <Item class="ModuleScript" referent="51">
            <Properties>
              <string name="Name">MazeRunTracker</string>
              <string name="Source"><![CDATA[local SessionStateMachine = require(script.Parent.SessionStateMachine)

local MazeRunTracker = {}
MazeRunTracker.__index = MazeRunTracker

local function cloneSummary(summary)
    return {
        UserId = summary.UserId,
        Name = summary.Name,
        ReturnReason = summary.ReturnReason,
        Value = summary.Value or 0,
        ItemCount = summary.ItemCount or 0,
        Weight = summary.Weight or 0,
        WasExtracted = summary.WasExtracted == true,
        WasSettled = summary.WasSettled == true,
    }
end

function MazeRunTracker.new()
    return setmetatable({
        StateMachine = SessionStateMachine.new('Camp'),
        ActivePlayersByUserId = {},
        ReturnedSummaries = {},
        IsCompleted = false,
    }, MazeRunTracker)
end

function MazeRunTracker:addPlayer(playerInfo)
    if self.IsCompleted then
        return false, 'Completed'
    end

    self.ActivePlayersByUserId[playerInfo.UserId] = {
        UserId = playerInfo.UserId,
        Name = playerInfo.Name,
    }

    return true
end

function MazeRunTracker:removePlayer(userId)
    self.ActivePlayersByUserId[userId] = nil
end

function MazeRunTracker:isPlayerActive(userId)
    return self.ActivePlayersByUserId[userId] ~= nil
end

function MazeRunTracker:getActiveCount()
    local count = 0
    for _ in pairs(self.ActivePlayersByUserId) do
        count += 1
    end

    return count
end

function MazeRunTracker:getState()
    return self.StateMachine.Current
end

function MazeRunTracker:getReturnedSummaries()
    local summaries = {}

    for index, summary in ipairs(self.ReturnedSummaries) do
        summaries[index] = cloneSummary(summary)
    end

    return summaries
end

function MazeRunTracker:beginExpedition()
    if self.StateMachine.Current ~= 'Camp' then
        return false, 'InvalidState'
    end

    self.StateMachine:transition('Expedition')
    return true
end

function MazeRunTracker:beginExtraction()
    if self.StateMachine.Current ~= 'Expedition' then
        return false, 'InvalidState'
    end

    self.StateMachine:transition('Extraction')
    return true
end

function MazeRunTracker:recordReturn(summary)
    if not self:isPlayerActive(summary.UserId) then
        return false, 'MissingActivePlayer'
    end

    self.ActivePlayersByUserId[summary.UserId] = nil
    table.insert(self.ReturnedSummaries, cloneSummary(summary))

    return true
end

function MazeRunTracker:completeExpedition()
    if self.StateMachine.Current ~= 'Expedition' then
        return false, 'InvalidState'
    end

    if self:getActiveCount() ~= 0 then
        return false, 'ActivePlayersRemaining'
    end

    self.StateMachine:transition('Settlement')
    self.IsCompleted = true

    return true
end

function MazeRunTracker:completeSettlement(summaries)
    if self.StateMachine.Current ~= 'Extraction' then
        return false, 'InvalidState'
    end

    for _, summary in ipairs(summaries) do
        if not self:isPlayerActive(summary.UserId) then
            return false, 'MissingActivePlayer'
        end
    end

    self.StateMachine:transition('Settlement')

    for _, summary in ipairs(summaries) do
        self:recordReturn(summary)
    end

    self.IsCompleted = true
    return true
end

return MazeRunTracker
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="52">
            <Properties>
              <string name="Name">SessionStateMachine</string>
              <string name="Source"><![CDATA[local TRANSITIONS = {
    Camp = {
        Expedition = true,
    },
    Expedition = {
        Extraction = true,
        Settlement = true,
    },
    Extraction = {
        Settlement = true,
    },
    Settlement = {
        Camp = true,
    },
}

local SessionStateMachine = {}
SessionStateMachine.__index = SessionStateMachine

function SessionStateMachine.new(initialState)
    return setmetatable({
        Current = initialState,
    }, SessionStateMachine)
end

function SessionStateMachine:canTransition(nextState)
    local allowedTransitions = TRANSITIONS[self.Current]
    return allowedTransitions ~= nil and allowedTransitions[nextState] == true
end

function SessionStateMachine:transition(nextState)
    if not self:canTransition(nextState) then
        error(string.format('Invalid session transition: %s -> %s', self.Current, nextState))
    end

    self.Current = nextState
    return self.Current
end

return SessionStateMachine
]]></string>
            </Properties>
          </Item>
        </Item>
      </Item>
