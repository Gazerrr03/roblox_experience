      </Properties>
      <Item class="ModuleScript" referent="126">
        <Properties>
          <string name="Name">BackpackUI</string>
          <string name="Source"><![CDATA[--!strict
--#region Services

local Players = game:GetService('Players')
local UserInputService = game:GetService('UserInputService')
local ReplicatedStorage = game:GetService('ReplicatedStorage')

--#endregion

--#region Requires

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Shared = require(Packages:WaitForChild('Shared'))
local Remotes = Shared.Network.Remotes.waitForScope(Shared.Network.Remotes.Scope.Run)

--#endregion

--#region Module

local BackpackUI = {}

-- 道具描述映射
local ItemDescriptions = {
    BurningTorch = '点燃倒塌的灯塔',
    Flashlight = '照亮黑暗区域（按F键开关）',
    Rope = '攀爬高处、跨越断层、固定怪物',
    Crowbar = '撬开锁住的箱子/门',
}

-- 创建背包 UI
function BackpackUI.createUI()
    -- ScreenGui
    local screenGui = Instance.new('ScreenGui')
    screenGui.Name = 'BackpackUI'
    screenGui.ResetOnSpawn = false
    screenGui.Parent = Players.LocalPlayer:WaitForChild('PlayerGui')

    -- 背包主框架（默认隐藏）
    local backpackFrame = Instance.new('Frame')
    backpackFrame.Name = 'BackpackFrame'
    backpackFrame.Size = UDim2.new(0, 500, 0, 400)
    backpackFrame.Position = UDim2.new(0.5, -250, 0.5, -200)
    backpackFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    backpackFrame.BorderSizePixel = 0
    backpackFrame.Visible = false
    backpackFrame.Parent = screenGui

    -- 背包标题
    local titleLabel = Instance.new('TextLabel')
    titleLabel.Name = 'TitleLabel'
    titleLabel.Size = UDim2.new(1, 0, 0, 50)
    titleLabel.Position = UDim2.new(0, 0, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = '背包'
    titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleLabel.TextSize = 28
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.Parent = backpackFrame

    -- 关闭按钮
    local closeButton = Instance.new('TextButton')
    closeButton.Name = 'CloseButton'
    closeButton.Size = UDim2.new(0, 50, 0, 50)
    closeButton.Position = UDim2.new(1, -50, 0, 0)
    closeButton.BackgroundTransparency = 1
    closeButton.Text = '✕'
    closeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeButton.TextSize = 28
    closeButton.Font = Enum.Font.GothamBold
    closeButton.Parent = backpackFrame

    closeButton.MouseButton1Click:Connect(function()
        BackpackUI.hide()
    end)

    -- 道具容器
    local itemContainer = Instance.new('ScrollingFrame')
    itemContainer.Name = 'ItemContainer'
    itemContainer.Size = UDim2.new(1, -20, 1, -60)
    itemContainer.Position = UDim2.new(0, 10, 0, 60)
    itemContainer.BackgroundTransparency = 1
    itemContainer.ScrollBarThickness = 8
    itemContainer.ScrollBarImageColor3 = Color3.fromRGB(100, 100, 100)
    itemContainer.Parent = backpackFrame

    -- 分隔线
    local divider = Instance.new('Frame')
    divider.Name = 'Divider'
    divider.Size = UDim2.new(1, 0, 0, 2)
    divider.Position = UDim2.new(0, 0, 0, 50)
    divider.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    divider.BorderSizePixel = 0
    divider.Parent = backpackFrame

    -- 保存引用
    BackpackUI.ScreenGui = screenGui
    BackpackUI.BackpackFrame = backpackFrame
    BackpackUI.ItemContainer = itemContainer
    BackpackUI.CloseButton = closeButton

    return screenGui
end

-- 创建道具卡片
function BackpackUI.createItemCard(itemName: string, itemData: { [string]: any }): Frame
    local card = Instance.new('Frame')
    card.Name = itemName .. 'Card'
    card.Size = UDim2.new(1, -10, 0, 80)
    card.Position = UDim2.new(0, 5, 0, 0)
    card.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    card.BorderSizePixel = 0
    card.Parent = BackpackUI.ItemContainer

    -- 道具图标（占位）
    local icon = Instance.new('Frame')
    icon.Name = 'Icon'
    icon.Size = UDim2.new(0, 60, 0, 60)
    icon.Position = UDim2.new(0, 10, 0.5, -30)
    icon.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
    icon.BorderSizePixel = 0
    icon.Parent = card

    -- 道具名称
    local nameLabel = Instance.new('TextLabel')
    nameLabel.Name = 'NameLabel'
    nameLabel.Size = UDim2.new(1, -80, 0, 30)
    nameLabel.Position = UDim2.new(0, 80, 0, 10)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = itemData.Name or itemName
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextSize = 20
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = card

    -- 道具描述
    local descLabel = Instance.new('TextLabel')
    descLabel.Name = 'DescLabel'
    descLabel.Size = UDim2.new(1, -80, 0, 20)
    descLabel.Position = UDim2.new(0, 80, 0, 35)
    descLabel.BackgroundTransparency = 1
    descLabel.Text = ItemDescriptions[itemName] or itemData.Description or ''
    descLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
    descLabel.TextSize = 14
    descLabel.Font = Enum.Font.Gotham
    descLabel.TextXAlignment = Enum.TextXAlignment.Left
    descLabel.Parent = card

    -- 装备状态
    local statusLabel = Instance.new('TextLabel')
    statusLabel.Name = 'StatusLabel'
    statusLabel.Size = UDim2.new(0, 80, 0, 30)
    statusLabel.Position = UDim2.new(1, -90, 0, 10)
    statusLabel.BackgroundColor3 = itemData.IsEquipped and Color3.fromRGB(100, 200, 100)
        or Color3.fromRGB(80, 80, 90)
    statusLabel.BorderSizePixel = 0
    statusLabel.Text = itemData.IsEquipped and '已装备' or '未装备'
    statusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    statusLabel.TextSize = 14
    statusLabel.Font = Enum.Font.GothamBold
    statusLabel.Parent = card

    -- 装备/卸下按钮
    local equipButton = Instance.new('TextButton')
    equipButton.Name = 'EquipButton'
    equipButton.Size = UDim2.new(0, 80, 0, 30)
    equipButton.Position = UDim2.new(1, -90, 0, 45)
    equipButton.BackgroundColor3 = Color3.fromRGB(100, 100, 120)
    equipButton.BorderSizePixel = 0
    equipButton.Text = itemData.IsEquipped and '卸下' or '装备'
    equipButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    equipButton.TextSize = 14
    equipButton.Font = Enum.Font.GothamBold
    equipButton.Parent = card

    equipButton.MouseButton1Click:Connect(function()
        if itemData.IsEquipped then
            Remotes.EquipItem:FireServer(itemName, false)
        else
            Remotes.EquipItem:FireServer(itemName, true)
        end
        -- 刷新背包显示
        BackpackUI.refresh()
    end)

    return card
end

-- 刷新背包显示
function BackpackUI.refresh()
    if not BackpackUI.ScreenGui then
        return
    end

    -- 清空道具容器
    for _, child in ipairs(BackpackUI.ItemContainer:GetChildren()) do
        if child:IsA('Frame') then
            child:Destroy()
        end
    end

    -- 从服务器获取背包数据
    local inventory = Remotes.GetInventory:InvokeServer()

    if not inventory or next(inventory) == nil then
        -- 背包为空提示
        local emptyLabel = Instance.new('TextLabel')
        emptyLabel.Size = UDim2.new(1, 0, 0, 50)
        emptyLabel.Position = UDim2.new(0, 0, 0.5, -25)
        emptyLabel.BackgroundTransparency = 1
        emptyLabel.Text = '背包是空的，去收集道具吧！'
        emptyLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        emptyLabel.TextSize = 18
        emptyLabel.Font = Enum.Font.Gotham
        emptyLabel.Parent = BackpackUI.ItemContainer
        return
    end

    -- 显示道具列表
    local yOffset = 0
    for itemName, itemData in pairs(inventory) do
        local card = BackpackUI.createItemCard(itemName, itemData)
        card.Position = UDim2.new(0, 5, 0, yOffset)
        yOffset = yOffset + 90
    end

    -- 更新容器大小
    BackpackUI.ItemContainer.CanvasSize = UDim2.new(1, 0, 0, yOffset)
end

-- 显示背包
function BackpackUI.show()
    if not BackpackUI.ScreenGui then
        BackpackUI.createUI()
    end

    BackpackUI.BackpackFrame.Visible = true
    BackpackUI.refresh()
end

-- 隐藏背包
function BackpackUI.hide()
    if BackpackUI.ScreenGui then
        BackpackUI.BackpackFrame.Visible = false
    end
end

-- 切换背包显示状态
function BackpackUI.toggle()
    if BackpackUI.BackpackFrame and BackpackUI.BackpackFrame.Visible then
        BackpackUI.hide()
    else
        BackpackUI.show()
    end
end

-- 初始化
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then
        return
    end

    if input.KeyCode == Enum.KeyCode.B then
        BackpackUI.toggle()
    end

    if input.KeyCode == Enum.KeyCode.ButtonY then -- 手柄 Y 键
        BackpackUI.toggle()
    end
end)

return BackpackUI
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="127">
        <Properties>
          <string name="Name">ItemClient</string>
          <string name="Source"><![CDATA[--!strict
--#region Services

local Players = game:GetService('Players')
local ReplicatedStorage = game:GetService('ReplicatedStorage')
local UserInputService = game:GetService('UserInputService')
local RunService = game:GetService('RunService')

--#endregion

--#region Requires

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Shared = require(Packages:WaitForChild('Shared'))
local Remotes = Shared.Network.Remotes.waitForScope(Shared.Network.Remotes.Scope.Run)

--#endregion

--#region Module

local ItemClient = {}

local player = Players.LocalPlayer
local currentInteractionTarget = nil
local _interactionProximityPrompts = {}

-- ====================
-- 道具功能输入处理
-- ====================

-- 设置手电筒
local function setupFlashlightInput()
    -- F 键切换手电筒
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then
            return
        end

        if input.KeyCode == Enum.KeyCode.F then
            local itemData = Remotes.GetItemData:InvokeServer('Flashlight')
            if itemData and itemData.IsEquipped then
                Remotes.UseItemFunction:FireServer('Flashlight', nil, 'toggle')
            end
        end
    end)
end

-- 设置绳索交互
local function setupRopeInput()
    -- E 键触发绳索交互
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then
            return
        end

        if
            input.KeyCode == Enum.KeyCode.E and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
        then
            local itemData = Remotes.GetItemData:InvokeServer('Rope')
            if itemData and itemData.IsEquipped then
                -- 检测最近的交互对象
                local interactables = Remotes.GetInteractables:InvokeServer(10)

                for _, interactable in ipairs(interactables) do
                    local interactionType = interactable:GetAttribute('InteractionType')

                    if interactionType == 'Climbable' then
                        Remotes.UseItemFunction:FireServer('Rope', interactable, 'climb')
                        break
                    elseif interactionType == 'Crossable' then
                        local targetCFrame = interactable:GetAttribute('TargetCFrame')
                        Remotes.UseItemFunction:FireServer('Rope', targetCFrame, 'cross')
                        break
                    end
                end
            end
        end
    end)
end

-- 设置撬棍交互
local function setupCrowbarInput()
    local lastUpdateTime = 0
    local UPDATE_INTERVAL = 0.5

    -- 靠近锁住的对象时自动检测
    RunService.Heartbeat:Connect(function()
        local currentTime = os.clock()

        -- 降低检测频率，避免高频服务器调用
        if currentTime - lastUpdateTime < UPDATE_INTERVAL then
            return
        end
        lastUpdateTime = currentTime

        local itemData = Remotes.GetItemData:InvokeServer('Crowbar')

        if itemData and itemData.IsEquipped then
            local character = player.Character
            if not character or not character.HumanoidRootPart then
                return
            end

            local interactables = Remotes.GetInteractables:InvokeServer(5)
            local hasPryable = false

            for _, interactable in ipairs(interactables) do
                local interactionType = interactable:GetAttribute('InteractionType')

                if interactionType == 'Pryable' and not interactable:GetAttribute('PriedOpen') then
                    hasPryable = true
                    currentInteractionTarget = interactable
                    break
                end
            end

            if not hasPryable then
                currentInteractionTarget = nil
            end
        end
    end)

    -- 按键触发撬开
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then
            return
        end

        if input.KeyCode == Enum.KeyCode.E and currentInteractionTarget then
            Remotes.UseItemFunction:FireServer('Crowbar', currentInteractionTarget, 'pry')
        end
    end)
end

-- ====================
-- 视觉提示系统
-- ====================

-- 显示交互提示
local function _showInteractionPrompt(_part: BasePart, promptText: string)
    -- 创建屏幕提示
    local playerGui = player:WaitForChild('PlayerGui')

    local screenGui = Instance.new('ScreenGui')
    screenGui.Name = 'InteractionPrompt'
    screenGui.Parent = playerGui

    local frame = Instance.new('Frame')
    frame.Name = 'PromptFrame'
    frame.Size = UDim2.new(0, 300, 0, 60)
    frame.Position = UDim2.new(0.5, -150, 0.8, 0)
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 0.3
    frame.BorderSizePixel = 0
    frame.Parent = screenGui

    local corner = Instance.new('UICorner')
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = frame

    local textLabel = Instance.new('TextLabel')
    textLabel.Name = 'PromptText'
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = promptText
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    textLabel.TextSize = 18
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextWrapped = true
    textLabel.Parent = frame

    -- 3秒后自动消失
    task.delay(3, function()
        screenGui:Destroy()
    end)
end

-- 显示道具使用提示
local function showItemUsageFeedback(itemName: string, _action: string, success: boolean)
    local playerGui = player:WaitForChild('PlayerGui')

    local screenGui = Instance.new('ScreenGui')
    screenGui.Name = 'UsageFeedback'
    screenGui.Parent = playerGui

    local frame = Instance.new('Frame')
    frame.Name = 'FeedbackFrame'
    frame.Size = UDim2.new(0, 400, 0, 80)
    frame.Position = UDim2.new(0.5, -200, 0.2, 0)
    frame.BackgroundColor3 = success and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
    frame.BackgroundTransparency = 0.3
    frame.BorderSizePixel = 0
    frame.Parent = screenGui

    local corner = Instance.new('UICorner')
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = frame

    local textLabel = Instance.new('TextLabel')
    textLabel.Name = 'FeedbackText'
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = success and (itemName .. ' 使用成功!') or (itemName .. ' 使用失败!')
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    textLabel.TextSize = 20
    textLabel.Font = Enum.Font.GothamBold
    textLabel.Parent = frame

    -- 淡出动画
    local tween = game:GetService('TweenService'):Create(
        screenGui,
        TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { BackgroundTransparency = 1 }
    )
    tween:Play()

    task.delay(2, function()
        screenGui:Destroy()
    end)
end

-- ====================
-- 初始化
-- ====================

function ItemClient.initialize()
    setupFlashlightInput()
    setupRopeInput()
    setupCrowbarInput()

    print('ItemClient 已初始化')
end

-- 监听服务器反馈
Remotes.ItemUsageFeedback.OnClientEvent:Connect(
    function(itemName: string, _action: string, success: boolean)
        showItemUsageFeedback(itemName, _action, success)
    end
)

return ItemClient
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="128">
        <Properties>
          <string name="Name">NarrativeUI</string>
          <string name="Source"><![CDATA[-- NarrativeUI
-- 处理叙事文本的UI显示

local Players = game:GetService('Players')
local TweenService = game:GetService('TweenService')

local localPlayer = Players.LocalPlayer
local playerGui = localPlayer:WaitForChild('PlayerGui')

local NarrativeUI = {}

-- UI配置
local UI_CONFIG = {
    BackgroundColor = Color3.fromRGB(20, 20, 30),
    TextColor = Color3.fromRGB(220, 220, 220),
    AccentColor = Color3.fromRGB(154, 113, 214),
    Font = Enum.Font.Gotham,
    TextSize = 18,
    TitleSize = 24,
    Padding = 30,
    AnimationDuration = 0.3,
}

local currentNarrativeGui = nil
local isNarrativeVisible = false

-- 创建叙事UI
function NarrativeUI.create()
    if currentNarrativeGui then
        currentNarrativeGui:Destroy()
    end

    local screenGui = Instance.new('ScreenGui')
    screenGui.Name = 'NarrativeUI'
    screenGui.IgnoreGuiInset = true
    screenGui.ResetOnSpawn = false
    screenGui.Parent = playerGui

    -- 背景遮罩
    local background = Instance.new('Frame')
    background.Name = 'Background'
    background.Size = UDim2.fromScale(1, 1)
    background.BackgroundColor3 = Color3.new(0, 0, 0)
    background.BackgroundTransparency = 0.7
    background.BorderSizePixel = 0
    background.Parent = screenGui

    local backgroundFade = Instance.new('UIGradient')
    backgroundFade.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(10, 10, 20)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0)),
    })
    backgroundFade.Rotation = 45
    backgroundFade.Parent = background

    -- 主面板
    local panel = Instance.new('Frame')
    panel.Name = 'Panel'
    panel.AnchorPoint = Vector2.new(0.5, 0.5)
    panel.Position = UDim2.fromScale(0.5, 0.5)
    panel.Size = UDim2.fromOffset(600, 500)
    panel.BackgroundColor3 = UI_CONFIG.BackgroundColor
    panel.BorderSizePixel = 0
    panel.Parent = screenGui

    local corner = Instance.new('UICorner')
    corner.CornerRadius = UDim.new(0, 16)
    corner.Parent = panel

    local padding = Instance.new('UIPadding')
    padding.PaddingTop = UDim.new(0, UI_CONFIG.Padding)
    padding.PaddingLeft = UDim.new(0, UI_CONFIG.Padding)
    padding.PaddingRight = UDim.new(0, UI_CONFIG.Padding)
    padding.PaddingBottom = UDim.new(0, UI_CONFIG.Padding)
    padding.Parent = panel

    local list = Instance.new('UIListLayout')
    list.Padding = UDim.new(0, 16)
    list.Parent = panel

    -- 标题
    local title = Instance.new('TextLabel')
    title.Name = 'Title'
    title.Size = UDim2.new(1, 0, 0, 40)
    title.BackgroundTransparency = 1
    title.Font = Enum.Font.GothamBold
    title.TextColor3 = UI_CONFIG.AccentColor
    title.TextSize = UI_CONFIG.TitleSize
    title.Text = 'Fragment of Truth'
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = panel

    -- 内容容器
    local contentContainer = Instance.new('Frame')
    contentContainer.Name = 'ContentContainer'
    contentContainer.Size = UDim2.new(1, 0, 1, -100)
    contentContainer.BackgroundTransparency = 1
    contentContainer.Parent = panel

    local contentList = Instance.new('UIListLayout')
    contentList.Padding = UDim.new(0, 20)
    contentList.Parent = contentContainer

    -- 滚动框
    local scrollFrame = Instance.new('ScrollingFrame')
    scrollFrame.Name = 'ScrollFrame'
    scrollFrame.Size = UDim2.new(1, 0, 1, 0)
    scrollFrame.BackgroundTransparency = 1
    scrollFrame.ScrollBarThickness = 6
    scrollFrame.ScrollBarImageColor3 = Color3.fromRGB(100, 100, 100)
    scrollFrame.Parent = contentContainer

    local contentPadding = Instance.new('UIPadding')
    contentPadding.PaddingBottom = UDim.new(0, 20)
    contentPadding.Parent = scrollFrame

    local scrollList = Instance.new('UIListLayout')
    scrollList.Padding = UDim.new(0, 24)
    scrollList.Parent = scrollFrame

    -- 关闭按钮
    local closeButton = Instance.new('TextButton')
    closeButton.Name = 'CloseButton'
    closeButton.Size = UDim2.new(1, 0, 0, 44)
    closeButton.BackgroundColor3 = UI_CONFIG.AccentColor
    closeButton.TextColor3 = Color3.new(1, 1, 1)
    closeButton.Font = Enum.Font.GothamBold
    closeButton.TextSize = 18
    closeButton.Text = 'Continue'
    closeButton.Parent = panel

    local closeCorner = Instance.new('UICorner')
    closeCorner.CornerRadius = UDim.new(0, 10)
    closeCorner.Parent = closeButton

    currentNarrativeGui = screenGui

    return {
        Gui = screenGui,
        Panel = panel,
        Title = title,
        ScrollFrame = scrollFrame,
        ScrollList = scrollList,
        CloseButton = closeButton,
        Background = background,
    }
end

-- 显示叙事文本
function NarrativeUI.show(layer1, layer2, layer3)
    if isNarrativeVisible then
        return
    end

    isNarrativeVisible = true
    local ui = NarrativeUI.create()

    -- 初始状态：完全透明
    ui.Panel.BackgroundTransparency = 1
    ui.Background.BackgroundTransparency = 1
    ui.Background.ImageTransparency = 1
    ui.CloseButton.BackgroundTransparency = 1

    -- 创建文本块
    local textBlocks = {}

    local function createTextBlock(text, isEmphasis)
        local textBlock = Instance.new('TextLabel')
        textBlock.Name = 'TextBlock'
        textBlock.Size = UDim2.new(1, 0, 0, 0)
        textBlock.AutomaticSize = Enum.AutomaticSize.Y
        textBlock.BackgroundTransparency = 1
        textBlock.Font = isEmphasis and Enum.Font.GothamBold or UI_CONFIG.Font
        textBlock.TextColor3 = isEmphasis and UI_CONFIG.AccentColor or UI_CONFIG.TextColor
        textBlock.TextSize = UI_CONFIG.TextSize
        textBlock.Text = text
        textBlock.TextWrapped = true
        textBlock.TextXAlignment = Enum.TextXAlignment.Left
        textBlock.TextYAlignment = Enum.TextYAlignment.Top
        textBlock.Parent = ui.ScrollFrame

        -- 添加分隔线（除了第一个）
        if #textBlocks > 0 then
            local separator = Instance.new('Frame')
            separator.Name = 'Separator'
            separator.Size = UDim2.new(1, 0, 0, 1)
            separator.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
            separator.BackgroundTransparency = 0.5
            separator.BorderSizePixel = 0
            separator.Parent = ui.ScrollFrame
        end

        table.insert(textBlocks, textBlock)
        return textBlock
    end

    -- 显示第一层
    local layer1Text = createTextBlock(layer1 or '')
    layer1Text.Visible = false

    -- 显示第二层（如果有的话）
    local layer2Text = nil
    if layer2 and layer2 ~= '' then
        layer2Text = createTextBlock(layer2, true)
        layer2Text.Visible = false
    end

    -- 显示第三层（如果有的话）
    local layer3Text = nil
    if layer3 and layer3 ~= '' then
        layer3Text = createTextBlock(layer3, true)
        layer3Text.Visible = false
    end

    -- 更新滚动框大小
    ui.ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, ui.ScrollList.AbsoluteContentSize.Y)

    -- 淡入动画
    local fadeInTween = TweenService:Create(
        ui.Panel,
        TweenInfo.new(UI_CONFIG.AnimationDuration, Enum.EasingStyle.Quad),
        {
            BackgroundTransparency = 0,
        }
    )
    local backgroundFadeIn = TweenService:Create(
        ui.Background,
        TweenInfo.new(UI_CONFIG.AnimationDuration, Enum.EasingStyle.Quad),
        {
            BackgroundTransparency = 0.7,
        }
    )
    local buttonFadeIn = TweenService:Create(
        ui.CloseButton,
        TweenInfo.new(UI_CONFIG.AnimationDuration, Enum.EasingStyle.Quad),
        {
            BackgroundTransparency = 0,
        }
    )

    fadeInTween:Play()
    backgroundFadeIn:Play()
    buttonFadeIn:Play()

    -- 显示第一层文本
    task.wait(0.2)
    layer1Text.Visible = true

    -- 显示第二层文本（延迟）
    if layer2Text then
        task.delay(1.5, function()
            layer2Text.Visible = true
            ui.ScrollFrame.CanvasPosition =
                Vector2.new(0, ui.ScrollFrame.CanvasSize.Y.Offset - ui.ScrollFrame.AbsoluteSize.Y)
        end)
    end

    -- 显示第三层文本（延迟）
    if layer3Text then
        task.delay(3.0, function()
            layer3Text.Visible = true
            ui.ScrollFrame.CanvasPosition =
                Vector2.new(0, ui.ScrollFrame.CanvasSize.Y.Offset - ui.ScrollFrame.AbsoluteSize.Y)
        end)
    end

    -- 关闭按钮处理
    local function closeNarrative()
        isNarrativeVisible = false

        -- 淡出动画
        local fadeOutTween = TweenService:Create(
            ui.Panel,
            TweenInfo.new(UI_CONFIG.AnimationDuration, Enum.EasingStyle.Quad),
            {
                BackgroundTransparency = 1,
            }
        )
        local backgroundFadeOut = TweenService:Create(
            ui.Background,
            TweenInfo.new(UI_CONFIG.AnimationDuration, Enum.EasingStyle.Quad),
            {
                BackgroundTransparency = 1,
            }
        )
        local buttonFadeOut = TweenService:Create(
            ui.CloseButton,
            TweenInfo.new(UI_CONFIG.AnimationDuration, Enum.EasingStyle.Quad),
            {
                BackgroundTransparency = 1,
            }
        )

        fadeOutTween:Play()
        backgroundFadeOut:Play()
        buttonFadeOut:Play()

        task.wait(UI_CONFIG.AnimationDuration)
        if currentNarrativeGui then
            currentNarrativeGui:Destroy()
            currentNarrativeGui = nil
        end
    end

    ui.CloseButton.MouseButton1Click:Connect(closeNarrative)

    -- ESC键关闭
    local inputConnection = game:GetService('UserInputService').InputBegan
        :Connect(function(input, gameProcessed)
            if gameProcessed then
                return
            end
            if
                input.KeyCode == Enum.KeyCode.Escape
                or input.KeyCode == Enum.KeyCode.Space
                or input.KeyCode == Enum.KeyCode.Return
            then
                closeNarrative()
            end
        end)

    -- 清理
    ui.Gui.Destroying:Connect(function()
        inputConnection:Disconnect()
    end)
end

return NarrativeUI
]]></string>
        </Properties>
      </Item>
      <Item class="LocalScript" referent="129">
        <Properties>
          <string name="Name">RunClient</string>
          <string name="Source"><![CDATA[local Players = game:GetService('Players')
local ReplicatedStorage = game:GetService('ReplicatedStorage')
local RunService = game:GetService('RunService')
local UserInputService = game:GetService('UserInputService')

local localPlayer = Players.LocalPlayer
local playerGui = localPlayer:WaitForChild('PlayerGui')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Shared = require(Packages:WaitForChild('Shared'))
local UI = require(Packages:WaitForChild('UI'))

local Remotes = Shared.Network.Remotes.waitForScope(Shared.Network.Remotes.Scope.Run)
local FormalLocomotion = Shared.Runtime.FormalLocomotion
local heldItemController = Shared.Client.HeldItemController.new(localPlayer)
local Theme = UI.Hud.Theme

local TEMPLE_LABEL = 'Temple'
local PAGE_LABEL = 'Pages'
local SAND_BOOK_LABEL = 'Book of Sand'
local SAND_BOOK_PROGRESS_LABEL = 'Book of Sand Progress'

local disconnectFirstPersonLock
local ensureFirstPersonLock
local canRequestMazeEntry = false
local isRunLaunched = false
local isCampPanelVisible = true
local isMouseFree = false
local actionInputConnection
local sprintInputEndedConnection
local isMenuMouseUnlockBound = false
local visibleBackpackItems = {}
local MENU_MOUSE_UNLOCK_STEP = 'RunMenuMouseUnlock'
local MOUSE_TOGGLE_KEY = Enum.KeyCode.LeftAlt
local teamPages = 0
local goalAmount = 120
local goalProgress = 0
local inventorySummary = nil
local activeShopItems = {}
local activeSalvageItems = {}
local activeModal = nil
ensureFirstPersonLock = function()
    disconnectFirstPersonLock = Shared.Client.FirstPersonController.start(localPlayer)
    ensureFirstPersonLock = function() end
end

local function bindMenuMouseUnlock()
    if isMenuMouseUnlockBound then
        return
    end

    isMenuMouseUnlockBound = true
    RunService:BindToRenderStep(
        MENU_MOUSE_UNLOCK_STEP,
        Enum.RenderPriority.Camera.Value + 1,
        function()
            localPlayer.CameraMode = Enum.CameraMode.Classic
            localPlayer.CameraMinZoomDistance = 0.5
            localPlayer.CameraMaxZoomDistance = 12
            UserInputService.MouseBehavior = Enum.MouseBehavior.Default
            UserInputService.MouseIconEnabled = true
        end
    )
end

local function unbindMenuMouseUnlock()
    if not isMenuMouseUnlockBound then
        return
    end

    isMenuMouseUnlockBound = false
    RunService:UnbindFromRenderStep(MENU_MOUSE_UNLOCK_STEP)
end

local function releaseFirstPersonLockForMenu()
    if disconnectFirstPersonLock ~= nil then
        disconnectFirstPersonLock()
        disconnectFirstPersonLock = nil
        ensureFirstPersonLock = function()
            disconnectFirstPersonLock = Shared.Client.FirstPersonController.start(localPlayer)
            ensureFirstPersonLock = function() end
        end
    end

    localPlayer.CameraMode = Enum.CameraMode.Classic
    localPlayer.CameraMinZoomDistance = 0.5
    localPlayer.CameraMaxZoomDistance = 12
    UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    UserInputService.MouseIconEnabled = true
end

local function syncMouseMode()
    if not isRunLaunched or isMouseFree or activeModal ~= nil then
        releaseFirstPersonLockForMenu()
        bindMenuMouseUnlock()
        return
    end

    unbindMenuMouseUnlock()
    ensureFirstPersonLock()
end

script.Destroying:Connect(function()
    if disconnectFirstPersonLock ~= nil then
        disconnectFirstPersonLock()
        disconnectFirstPersonLock = nil
    end

    if actionInputConnection ~= nil then
        actionInputConnection:Disconnect()
        actionInputConnection = nil
    end

    if sprintInputEndedConnection ~= nil then
        sprintInputEndedConnection:Disconnect()
        sprintInputEndedConnection = nil
    end

    heldItemController:destroy()
    unbindMenuMouseUnlock()
end)

local screenGui = Instance.new('ScreenGui')
screenGui.Name = 'RunHud'
screenGui.IgnoreGuiInset = true
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local function makeTextLabel(parent, size, color, textSize, bold)
    local label = Instance.new('TextLabel')
    label.Size = size
    label.BackgroundTransparency = 1
    label.Font = bold and Enum.Font.GothamBold or Theme.Font
    label.TextColor3 = color
    label.TextSize = textSize
    label.TextWrapped = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Top
    label.Parent = parent
    return label
end

local function makeButton(parent, text, height, backgroundColor)
    local button = Instance.new('TextButton')
    button.Size = UDim2.new(1, 0, 0, height)
    button.BackgroundColor3 = backgroundColor
    button.TextColor3 = Theme.Background
    button.Font = Enum.Font.GothamBold
    button.TextSize = 18
    button.Text = text
    button.AutoButtonColor = true
    button.Parent = parent

    local corner = Instance.new('UICorner')
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = button

    local stroke = Instance.new('UIStroke')
    stroke.Color = Theme.Background
    stroke.Transparency = 0.65
    stroke.Thickness = 1
    stroke.Parent = button

    local gradient = Instance.new('UIGradient')
    gradient.Rotation = 90
    local base = button.BackgroundColor3
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, base:Lerp(Color3.new(1, 1, 1), 0.08)),
        ColorSequenceKeypoint.new(1, base:Lerp(Color3.new(0, 0, 0), 0.12)),
    })
    gradient.Parent = button

    return button
end

local function clearLayoutChildren(container)
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA('TextButton') or child:IsA('TextLabel') or child:IsA('Frame') then
            if child.Name ~= 'UIListLayout' and child.Name ~= 'UICorner' then
                child:Destroy()
            end
        end
    end
end

local function applyPanelStyle(frame, cornerRadius, strokeTransparency)
    local corner = Instance.new('UICorner')
    corner.CornerRadius = UDim.new(0, cornerRadius)
    corner.Parent = frame

    local stroke = Instance.new('UIStroke')
    stroke.Color = Theme.Text
    stroke.Transparency = strokeTransparency or 0.86
    stroke.Thickness = 1
    stroke.Parent = frame

    local gradient = Instance.new('UIGradient')
    gradient.Rotation = 90
    local base = frame.BackgroundColor3
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, base:Lerp(Color3.new(1, 1, 1), 0.03)),
        ColorSequenceKeypoint.new(1, base:Lerp(Color3.new(0, 0, 0), 0.08)),
    })
    gradient.Parent = frame
end

local function buildMazeEntryText(snapshot)
    local mode = snapshot.MazeEntryMode or 'Blocked'
    local reasonCode = snapshot.MazeEntryReasonCode or 'Unknown'
    local reason = snapshot.MazeEntryReason
    if type(reason) == 'string' and reason ~= '' then
        return string.format('%s [%s] (%s)', mode, reasonCode, reason)
    end

    return string.format('%s [%s]', mode, reasonCode)
end

