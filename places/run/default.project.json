    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$path": "src/ServerScriptService"
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$properties": {
        "CameraMode": "Classic",
        "CameraMinZoomDistance": 0.5,
        "CameraMaxZoomDistance": 12,
        "EnableMouseLockOption": false
