        <Item class="ModuleScript" referent="12">
          <Properties>
            <string name="Name">ControlState</string>
            <string name="Source"><![CDATA[local MODE = table.freeze({
    Walk = 'Walk',
    Sprint = 'Sprint',
})

local ControlState = {}
ControlState.__index = ControlState

ControlState.Mode = MODE

function ControlState.new()
    return setmetatable({
        Mode = MODE.Walk,
        SprintRequested = false,
        SprintEnabled = true,
        CrouchEnabled = false,
    }, ControlState)
end

function ControlState:getSummary()
    return {
        Mode = self.Mode,
        SprintRequested = self.SprintRequested,
        SprintEnabled = self.SprintEnabled,
        CrouchEnabled = self.CrouchEnabled,
    }
end

function ControlState:requestSprintStart(playerStateSummary)
    if type(playerStateSummary) ~= 'table' then
        self.SprintRequested = false
        self.Mode = MODE.Walk
        return false, 'MissingPlayerState'
    end

    if playerStateSummary.IsDead then
        self.SprintRequested = false
        self.Mode = MODE.Walk
        return false, 'Dead'
    end

    if not playerStateSummary.CanSprint then
        self.SprintRequested = false
        self.Mode = MODE.Walk
        return false, 'StaminaDepleted'
    end

    self.SprintRequested = true
    self.Mode = MODE.Sprint
    return true, self:getSummary()
end

function ControlState:requestSprintStop()
    self.SprintRequested = false
    self.Mode = MODE.Walk
    return true, self:getSummary()
end

function ControlState:syncPlayerState(playerStateSummary)
    if type(playerStateSummary) ~= 'table' then
        self.SprintRequested = false
        self.Mode = MODE.Walk
        return self:getSummary()
    end

    if playerStateSummary.IsDead then
        self.SprintRequested = false
        self.Mode = MODE.Walk
        return self:getSummary()
    end

    if playerStateSummary.CanSprint ~= true then
        self.SprintRequested = false
        self.Mode = MODE.Walk
        return self:getSummary()
    end

    if self.SprintRequested and playerStateSummary.CanSprint then
        self.Mode = MODE.Sprint
    else
        self.Mode = MODE.Walk
    end

    return self:getSummary()
end

return ControlState
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="13">
          <Properties>
            <string name="Name">Inventory</string>
            <string name="Source"><![CDATA[local Inventory = {}
Inventory.__index = Inventory

local function cloneLightConfig(lightConfig)
    if type(lightConfig) ~= 'table' then
        return nil
    end

    return {
        Brightness = lightConfig.Brightness,
        Range = lightConfig.Range,
        Color = lightConfig.Color,
    }
end

-- ItemEntry field groups aligned to the live item payload shape:
-- Core (must-have): InstanceId (handled separately), Id, Name, Value
-- Optional — Weight
-- Optional — Tool state: InitialState, CurrentState, ConsumePerUse, CooldownSeconds, LastUsedAt, ToolCategory, StateModel
-- Optional — Light: Color (Light handled separately via cloneLightConfig)
-- Optional — Melee tool: SwingRange, SwingArcDegrees, KnockbackStrength, MeleeDamage
-- Optional — Consumable: ItemKind, ConsumableEffect, MaxCarryPerId
local ITEM_COPY_FIELDS = table.freeze({
    -- Core
    'Id',
    'Name',
    'Value',
    -- Optional: Weight
    'Weight',
    -- Optional: Tool state
    'InitialState',
    'CurrentState',
    'ConsumePerUse',
    'CooldownSeconds',
    'LastUsedAt',
    'ToolCategory',
    'StateModel',
    -- Optional: Light
    'Color',
    -- Optional: Melee tool
    'SwingRange',
    'SwingArcDegrees',
    'KnockbackStrength',
    'MeleeDamage',
    -- Optional: Consumable
    'ItemKind',
    'ConsumableEffect',
    'MaxCarryPerId',
    -- UI
    'IconLabel',
})

local function copyItemFields(source, target)
    for _, field in ipairs(ITEM_COPY_FIELDS) do
        target[field] = source[field]
    end
    target.Light = cloneLightConfig(source.Light)
    return target
end

local function cloneItemEntry(itemEntry)
    return copyItemFields(itemEntry, {
        InstanceId = itemEntry.InstanceId,
    })
end

local function cloneArray(items)
    local result = {}

    for index, itemEntry in ipairs(items) do
        result[index] = cloneItemEntry(itemEntry)
    end

    return result
end

function Inventory.new(capacity)
    local backpackItems = {}

    return setmetatable({
        Capacity = capacity,
        Weight = 0,
        BackpackItems = backpackItems,
        EquipSlots = table.create(4, nil), -- 4个装备槽，table.create 保证长度为4
        HeldItem = nil,
        NextItemInstanceId = 1,
    }, Inventory)
end

function Inventory:getCount()
    local heldCount = self.HeldItem and 1 or 0
    return #self.BackpackItems + heldCount
end

function Inventory:_buildItemEntry(itemDef)
    local itemEntry = copyItemFields(itemDef, {
        InstanceId = self.NextItemInstanceId,
    })
    itemEntry.CurrentState = itemDef.InitialState

    self.NextItemInstanceId += 1

    return itemEntry
end

local function normalizeItemEntry(rawItemEntry)
    if type(rawItemEntry) ~= 'table' or type(rawItemEntry.InstanceId) ~= 'number' then
        return nil
    end

    local normalized = copyItemFields(rawItemEntry, {
        InstanceId = rawItemEntry.InstanceId,
    })
    normalized.Weight = rawItemEntry.Weight or 0
    normalized.Value = rawItemEntry.Value or 0
    return normalized
end

function Inventory:add(itemDef)
    if self.Weight + itemDef.Weight > self.Capacity then
        return false, 'OverCapacity'
    end

    local itemEntry = self:_buildItemEntry(itemDef)
    table.insert(self.BackpackItems, itemEntry)
    self.Weight += itemDef.Weight
    -- 返回4个值以匹配 autoEquipToFirstEmpty 的返回格式
    return true, 'backpack', itemEntry.InstanceId, cloneItemEntry(itemEntry)
end

function Inventory:equip(itemInstanceId)
    if type(itemInstanceId) ~= 'number' then
        return false, 'MissingItemInstanceId'
    end

    local nextIndex = nil
    for index, itemEntry in ipairs(self.BackpackItems) do
        if itemEntry.InstanceId == itemInstanceId then
            nextIndex = index
            break
        end
    end

    if nextIndex == nil then
        return false, 'ItemNotFound'
    end

    local nextHeldItem = table.remove(self.BackpackItems, nextIndex)
    if self.HeldItem ~= nil then
        table.insert(self.BackpackItems, self.HeldItem)
    end

    self.HeldItem = nextHeldItem
    return true, cloneItemEntry(nextHeldItem)
end

function Inventory:unequip()
    if self.HeldItem == nil then
        return false, 'NothingHeld'
    end

    local previousHeldItem = self.HeldItem
    table.insert(self.BackpackItems, previousHeldItem)
    self.HeldItem = nil

    return true, cloneItemEntry(previousHeldItem)
end

-- 购买时自动填充装备槽
-- 返回: (成功, 槽类型, 槽索引或物品实例ID, 物品详情)
-- 槽类型: 'equip' = 装备槽, 'backpack' = 背包
function Inventory:autoEquipToFirstEmpty(itemDef)
    warn('[Inventory.autoEquipToFirstEmpty] starting, EquipSlots count:', #self.EquipSlots)
    warn('[Inventory.autoEquipToFirstEmpty] EquipSlots:', self.EquipSlots[1], self.EquipSlots[2], self.EquipSlots[3], self.EquipSlots[4])
    
    -- 查找第一个空装备槽
    for i = 1, #self.EquipSlots do
        warn('[Inventory.autoEquipToFirstEmpty] checking slot', i, '=', self.EquipSlots[i])
        if self.EquipSlots[i] == nil then
            warn('[Inventory.autoEquipToFirstEmpty] slot', i, 'is nil, placing item')
            local item = copyItemFields(itemDef, {
                InstanceId = self.NextItemInstanceId,
            })
            item.CurrentState = itemDef.InitialState
            self.EquipSlots[i] = item
            self.NextItemInstanceId += 1
            return true, 'equip', i, cloneItemEntry(item)
        end
    end

    warn('[Inventory.autoEquipToFirstEmpty] all slots full, going to backpack')
    -- 装备槽满了，放到背包
    return self:add(itemDef)
end

-- 从装备槽卸下物品到背包
function Inventory:unequipFromSlot(slotIndex)
    if slotIndex < 1 or slotIndex > #self.EquipSlots then
        return false, 'InvalidSlot'
    end

    local item = self.EquipSlots[slotIndex]
    if not item then
        return false, 'SlotEmpty'
    end

    -- 放入背包
    if self.Weight + item.Weight > self.Capacity then
        return false, 'OverCapacity'
    end

    self.EquipSlots[slotIndex] = nil
    table.insert(self.BackpackItems, item)
    self.Weight += item.Weight

    return true, cloneItemEntry(item)
end

-- 移动背包物品到另一个格子（支持空格子UI索引）
function Inventory:moveBackpackItem(fromIndex, toIndex)
    local itemCount = #self.BackpackItems
    
    if fromIndex < 1 or fromIndex > itemCount then
        return false, 'InvalidFromSlot'
    end
    if toIndex < 1 then
        return false, 'InvalidToSlot'
    end
    
    if fromIndex == toIndex then
        return true
    end

    if toIndex > itemCount then
        -- 移动到空位置（超过物品数量）
        -- 移除原位置的物品，然后插入到数组末尾
        local item = table.remove(self.BackpackItems, fromIndex)
        table.insert(self.BackpackItems, item)
    else
        -- 交换两个位置的物品
        local temp = self.BackpackItems[fromIndex]
        self.BackpackItems[fromIndex] = self.BackpackItems[toIndex]
        self.BackpackItems[toIndex] = temp
    end

    return true
end

function Inventory:consumeHeldItemState(nowSeconds)
    local heldItem = self.HeldItem
    if heldItem == nil then
        return false, 'NothingHeld'
    end

    if type(heldItem.CurrentState) ~= 'number' or type(heldItem.ConsumePerUse) ~= 'number' then
        return false, 'NotConsumable'
    end

    -- Cooldown check applies to all tools (including zero-consume)
    local cooldownSeconds = heldItem.CooldownSeconds
    if type(cooldownSeconds) == 'number' and cooldownSeconds > 0 then
        local now = type(nowSeconds) == 'number' and nowSeconds or os.clock()
        local lastUsedAt = heldItem.LastUsedAt
        if type(lastUsedAt) == 'number' and now - lastUsedAt < cooldownSeconds then
            return false, 'Cooldown', cooldownSeconds - (now - lastUsedAt)
        end
    end

    local now = type(nowSeconds) == 'number' and nowSeconds or os.clock()

    -- Consume state only when ConsumePerUse > 0
    if heldItem.ConsumePerUse > 0 then
        if heldItem.CurrentState < heldItem.ConsumePerUse then
            return false, 'Depleted'
        end

        heldItem.CurrentState -= heldItem.ConsumePerUse
    end

    heldItem.LastUsedAt = now

    return true, cloneItemEntry(heldItem)
end

function Inventory:getTotalValue()
    local totalValue = 0

    for _, itemEntry in ipairs(self.BackpackItems) do
        totalValue += itemEntry.Value
    end

    if self.HeldItem ~= nil then
        totalValue += self.HeldItem.Value
    end

    return totalValue
end

function Inventory:getSummary()
    -- 克隆装备槽数据
    local equipSlotsData = {}
    for i, item in ipairs(self.EquipSlots) do
        equipSlotsData[i] = item and cloneItemEntry(item) or nil
    end

    return {
        Capacity = self.Capacity,
        Weight = self.Weight,
        Count = self:getCount(),
        BackpackCount = #self.BackpackItems,
        HeldCount = self.HeldItem and 1 or 0,
        Value = self:getTotalValue(),
        BackpackItems = cloneArray(self.BackpackItems),
        EquipSlots = equipSlotsData,
        HeldItem = self.HeldItem and cloneItemEntry(self.HeldItem) or nil,
    }
end

function Inventory:loadSummary(summary)
    if type(summary) ~= 'table' then
        return false, 'InvalidSummary'
    end

    self.Weight = 0
    table.clear(self.BackpackItems)
    self.EquipSlots = table.create(4, nil)
    self.HeldItem = nil
    self.NextItemInstanceId = 1

    local maxItemInstanceId = 0
    local function processItem(rawItemEntry)
        local itemEntry = normalizeItemEntry(rawItemEntry)
        if itemEntry ~= nil then
            self.Weight += itemEntry.Weight
            if itemEntry.InstanceId > maxItemInstanceId then
                maxItemInstanceId = itemEntry.InstanceId
            end
        end

        return itemEntry
    end

    for _, rawItemEntry in ipairs(summary.BackpackItems or {}) do
        local itemEntry = processItem(rawItemEntry)
        if itemEntry ~= nil then
            table.insert(self.BackpackItems, itemEntry)
        end
    end

    -- 加载装备槽
    for i, rawItemEntry in ipairs(summary.EquipSlots or {}) do
        if i <= 4 then
            self.EquipSlots[i] = processItem(rawItemEntry)
        end
    end

    local heldItem = processItem(summary.HeldItem)
    if heldItem ~= nil then
        self.HeldItem = heldItem
    end

    self.NextItemInstanceId = maxItemInstanceId + 1
    return true
end

function Inventory:clear()
    self.Weight = 0
    table.clear(self.BackpackItems)
    self.EquipSlots = table.create(4, nil)
    self.HeldItem = nil
end

function Inventory:countById(itemId)
    if type(itemId) ~= 'string' or itemId == '' then
        return 0
    end

    local count = 0
    for _, itemEntry in ipairs(self.BackpackItems) do
        if itemEntry.Id == itemId then
            count += 1
        end
    end

    if self.HeldItem and self.HeldItem.Id == itemId then
        count += 1
    end

    return count
end

function Inventory:consumeById(itemId)
    if type(itemId) ~= 'string' or itemId == '' then
        return false, 'MissingItemId'
    end

    for index, itemEntry in ipairs(self.BackpackItems) do
        if itemEntry.Id == itemId then
            local consumed = table.remove(self.BackpackItems, index)
            self.Weight -= consumed.Weight
            return true, cloneItemEntry(consumed)
        end
    end

    if self.HeldItem and self.HeldItem.Id == itemId then
        local consumed = self.HeldItem
        self.HeldItem = nil
        self.Weight -= consumed.Weight
        return true, cloneItemEntry(consumed)
    end

    return false, 'ItemNotFound'
end

function Inventory:sell(itemId)
    if type(itemId) ~= 'string' or itemId == '' then
        return false, 'MissingItemId'
    end

    for index, itemEntry in ipairs(self.BackpackItems) do
        if itemEntry.Id == itemId then
            local sold = table.remove(self.BackpackItems, index)
            self.Weight -= sold.Weight or 0
            return true, cloneItemEntry(sold), sold.Value or 0
        end
    end

    if self.HeldItem and self.HeldItem.Id == itemId then
        local sold = self.HeldItem
        self.HeldItem = nil
        self.Weight -= sold.Weight or 0
        return true, cloneItemEntry(sold), sold.Value or 0
    end

    return false, 'ItemNotFound'
end

return Inventory
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="14">
          <Properties>
            <string name="Name">Monsters</string>
            <string name="Source"><![CDATA[local MonsterCompiler = require(script.MonsterCompiler)

return {
    MonsterComponentConfig = require(script.MonsterComponentConfig),
    Enemy = require(script.Enemy),
    EnemyBlackboard = require(script.EnemyBlackboard),
    EnemyStateMachine = require(script.EnemyStateMachine),
    MonsterAuthorProfile = require(script.MonsterAuthorProfile),
    MonsterAssetIds = require(script.MonsterAssetIds),
    MonsterBehaviorCatalog = require(script.MonsterBehaviorCatalog),
    MonsterCompiler = MonsterCompiler,
    MonsterEffectCatalog = require(script.MonsterEffectCatalog),
    MonsterLogic = require(script.MonsterLogic),
    MonsterPresentationCatalog = require(script.MonsterPresentationCatalog),
    MonsterUgcPipeline = require(script.MonsterUgcPipeline),
    MonsterUgcReviewQueue = require(script.MonsterUgcReviewQueue),
    MazeMonsterSpawnPolicy = require(script.MazeMonsterSpawnPolicy),
    MonsterRuntimeProfile = require(script.MonsterRuntimeProfile),
    compileMonsterForMaze = MonsterCompiler.compileMonsterForMaze,
}
]]></string>
          </Properties>
          <Item class="Folder" referent="15">
            <Properties>
              <string name="Name">Components</string>
            </Properties>
            <Item class="ModuleScript" referent="16">
              <Properties>
                <string name="Name">AttackComponent</string>
                <string name="Source"><![CDATA[local MonsterBehaviorCatalog = require(script.Parent.Parent.MonsterBehaviorCatalog)

local AttackComponent = {}
AttackComponent.__index = AttackComponent

local DEFAULT_ATTACK_ARC_DEGREES = 100
local DEFAULT_ATTACK_COOLDOWN_SECONDS = 1
local DEFAULT_ATTACK_DAMAGE_PIPS = 1
local DEFAULT_ATTACK_MARKER_NAME = 'Hit'
local DEFAULT_ATTACK_RANGE = 4

local function readAttackConfig(context)
    local componentConfig = context.ComponentConfig
    if type(componentConfig) == 'table' and type(componentConfig.Attack) == 'table' then
        return componentConfig.Attack
    end

    return {}
end

function AttackComponent.new()
    return setmetatable({
        CooldownRemaining = 0,
    }, AttackComponent)
end

function AttackComponent:init(_blackboard)
    self.CooldownRemaining = 0
end

function AttackComponent:update(blackboard, dt)
    local deltaTime = math.max(0, dt or 0)
    self.CooldownRemaining = math.max(0, self.CooldownRemaining - deltaTime)

    blackboard.Transient.AttackIntent = nil
    local behaviors = blackboard.Context.Behaviors or {}
    if not behaviors[MonsterBehaviorCatalog.Behavior.Attack] then
        return
    end

    local hasTarget = blackboard.Transient.HasTarget == true
    if not hasTarget then
        return
    end

    local currentPosition = blackboard.Context.CurrentPosition
    local targetPlayer = blackboard.Transient.TargetPlayer
    local targetPosition = blackboard.Transient.TargetPosition
    if
        typeof(currentPosition) ~= 'Vector3'
        or targetPlayer == nil
        or typeof(targetPosition) ~= 'Vector3'
    then
        return
    end

    local attackConfig = readAttackConfig(blackboard.Context)
    local attackRange = attackConfig.Range or DEFAULT_ATTACK_RANGE
    if (targetPosition - currentPosition).Magnitude > attackRange then
        return
    end

    if self.CooldownRemaining > 0 then
        return
    end

    self.CooldownRemaining = attackConfig.CooldownSeconds or DEFAULT_ATTACK_COOLDOWN_SECONDS
    blackboard.Transient.AttackIntent = {
        ArcDegrees = attackConfig.ArcDegrees or DEFAULT_ATTACK_ARC_DEGREES,
        DamagePips = attackConfig.DamagePips or DEFAULT_ATTACK_DAMAGE_PIPS,
        MarkerName = attackConfig.HitMarkerName or DEFAULT_ATTACK_MARKER_NAME,
        Range = attackRange,
        TargetPlayer = targetPlayer,
    }
end

function AttackComponent:destroy(_blackboard) end

return AttackComponent
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="17">
              <Properties>
                <string name="Name">MovementComponent</string>
                <string name="Source"><![CDATA[local MonsterBehaviorCatalog = require(script.Parent.Parent.MonsterBehaviorCatalog)
local MonsterLogic = require(script.Parent.Parent.MonsterLogic)

local MovementComponent = {}
MovementComponent.__index = MovementComponent

function MovementComponent.new()
    return setmetatable({}, MovementComponent)
end

function MovementComponent:init(_blackboard) end

function MovementComponent:update(blackboard, dt)
    local componentConfig = blackboard.Context.ComponentConfig
    local movementConfig = if type(componentConfig) == 'table'
            and type(componentConfig.Movement) == 'table'
        then componentConfig.Movement
        else {}

    local currentPosition = blackboard.Context.CurrentPosition
    if typeof(currentPosition) ~= 'Vector3' then
        blackboard.Transient.NextPosition = nil
        blackboard.Transient.DesiredAnimation = 'Idle'
        blackboard.Transient.DesiredAnimationSpeed = 1
        blackboard.Transient.ShouldPlayChaseLoop = false
        return
    end

    local behaviors = blackboard.Context.Behaviors or {}
    local hasTarget = blackboard.Transient.HasTarget == true
    local targetPosition = blackboard.Transient.TargetPosition
    local nextPosition = nil
    local shouldAdvancePatrol = false

    if
        hasTarget
        and behaviors[MonsterBehaviorCatalog.Behavior.Chase]
        and typeof(targetPosition) == 'Vector3'
    then
        nextPosition = MonsterLogic.stepToward(
            currentPosition,
            targetPosition,
            movementConfig.Speed or blackboard.Context.Speed,
            dt
        )
    elseif
        behaviors[MonsterBehaviorCatalog.Behavior.Patrol]
        and typeof(blackboard.Context.PatrolTargetPosition) == 'Vector3'
    then
        local patrolTarget = blackboard.Context.PatrolTargetPosition
        nextPosition = MonsterLogic.stepToward(
            currentPosition,
            patrolTarget,
            (movementConfig.Speed or blackboard.Context.Speed)
                * (movementConfig.PatrolSpeedMultiplier or blackboard.Context.PatrolSpeedMultiplier),
            dt
        )

        if
            (nextPosition - patrolTarget).Magnitude
            <= (movementConfig.PatrolReachDistance or blackboard.Context.PatrolReachDistance or 2)
        then
            shouldAdvancePatrol = true
        end
    end

    local travelOffset = if nextPosition then nextPosition - currentPosition else Vector3.zero
    local isMoving = travelOffset.Magnitude > 0

    blackboard.Transient.NextPosition = nextPosition
    blackboard.Transient.ShouldAdvancePatrol = shouldAdvancePatrol
    blackboard.Transient.TravelOffset = travelOffset
    blackboard.Transient.DesiredAnimation = if hasTarget and isMoving
        then 'Run'
        elseif isMoving then 'Walk'
        else 'Idle'
    blackboard.Transient.DesiredAnimationSpeed = if hasTarget and isMoving then 1.15 else 1
    blackboard.Transient.ShouldPlayChaseLoop = hasTarget and isMoving
end

function MovementComponent:destroy(_blackboard) end

return MovementComponent
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="18">
              <Properties>
                <string name="Name">PerceptionComponent</string>
                <string name="Source"><![CDATA[local MonsterBehaviorCatalog = require(script.Parent.Parent.MonsterBehaviorCatalog)
local MonsterLogic = require(script.Parent.Parent.MonsterLogic)

local PerceptionComponent = {}
PerceptionComponent.__index = PerceptionComponent

function PerceptionComponent.new()
    return setmetatable({}, PerceptionComponent)
end

function PerceptionComponent:init(_blackboard) end

function PerceptionComponent:update(blackboard, _dt)
    local componentConfig = blackboard.Context.ComponentConfig
    local perceptionConfig = if type(componentConfig) == 'table'
            and type(componentConfig.Perception) == 'table'
        then componentConfig.Perception
        else {}

    local behaviors = blackboard.Context.Behaviors or {}
    if not behaviors[MonsterBehaviorCatalog.Behavior.SenseNearestTarget] then
        blackboard.Transient.HasTarget = false
        blackboard.Transient.TargetPlayer = nil
        blackboard.Transient.TargetPosition = nil
        return
    end

    local currentPosition = blackboard.Context.CurrentPosition
    if typeof(currentPosition) ~= 'Vector3' then
        blackboard.Transient.HasTarget = false
        blackboard.Transient.TargetPlayer = nil
        blackboard.Transient.TargetPosition = nil
        return
    end

    local playerPositions = blackboard.Context.PlayerPositions or {}
    local sightRange = perceptionConfig.SightRange or blackboard.Context.SightRange
    local targetPlayer =
        MonsterLogic.pickNearestTarget(currentPosition, playerPositions, sightRange)

    blackboard.Transient.HasTarget = targetPlayer ~= nil
    blackboard.Transient.TargetPlayer = targetPlayer
    blackboard.Transient.TargetPosition = if targetPlayer
        then playerPositions[targetPlayer]
        else nil
end

function PerceptionComponent:destroy(_blackboard) end

return PerceptionComponent
]]></string>
              </Properties>
            </Item>
          </Item>
          <Item class="ModuleScript" referent="19">
            <Properties>
              <string name="Name">Enemy</string>
              <string name="Source"><![CDATA[local EnemyBlackboard = require(script.Parent.EnemyBlackboard)
local EnemyStateMachine = require(script.Parent.EnemyStateMachine)

local AttackComponent = require(script.Parent.Components.AttackComponent)
local MovementComponent = require(script.Parent.Components.MovementComponent)
local PerceptionComponent = require(script.Parent.Components.PerceptionComponent)

local Enemy = {}
Enemy.__index = Enemy

local UPDATE_ORDER = table.freeze({
    'Perception',
    'FSM',
    'Movement',
    'Attack',
})

local function defaultComponents()
    return {
        Perception = PerceptionComponent.new(),
        Movement = MovementComponent.new(),
        Attack = AttackComponent.new(),
    }
end

local function cloneContext(context)
    return table.clone(context or {})
end

function Enemy.new(definition, options)
    local enemyOptions = options or {}
    local blackboard = enemyOptions.Blackboard or EnemyBlackboard.new(definition)
    local stateMachine = enemyOptions.StateMachine or EnemyStateMachine.new()
    local components = enemyOptions.Components or defaultComponents()

    return setmetatable({
        Blackboard = blackboard,
        ComponentConfig = enemyOptions.ComponentConfig or {},
        StateMachine = stateMachine,
        Components = components,
        StageObserver = enemyOptions.StageObserver,
    }, Enemy)
end

function Enemy:_emitStage(stageName)
    if self.StageObserver then
        self.StageObserver(stageName, self.Blackboard)
    end
end

function Enemy:spawn()
    self.Blackboard:setState(self.StateMachine:getState())
    for _, component in pairs(self.Components) do
        if component.init then
            component:init(self.Blackboard)
        end
    end
end

function Enemy:update(dt, context)
    local blackboardContext = cloneContext(context)
    blackboardContext.ComponentConfig = self.ComponentConfig
    self.Blackboard:beginTick(blackboardContext)

    self:_emitStage('Perception')
    self.Components.Perception:update(self.Blackboard, dt)

    self:_emitStage('FSM')
    self.StateMachine:update(self.Blackboard)

    self:_emitStage('Movement')
    self.Components.Movement:update(self.Blackboard, dt)

    self:_emitStage('Attack')
    self.Components.Attack:update(self.Blackboard, dt)

    return {
        AttackIntent = self.Blackboard.Transient.AttackIntent,
        State = self.Blackboard:getState(),
        TargetPlayer = self.Blackboard.Transient.TargetPlayer,
        NextPosition = self.Blackboard.Transient.NextPosition,
        ShouldAdvancePatrol = self.Blackboard.Transient.ShouldAdvancePatrol == true,
        DesiredAnimation = self.Blackboard.Transient.DesiredAnimation or 'Idle',
        DesiredAnimationSpeed = self.Blackboard.Transient.DesiredAnimationSpeed or 1,
        ShouldPlayChaseLoop = self.Blackboard.Transient.ShouldPlayChaseLoop == true,
        TravelOffset = self.Blackboard.Transient.TravelOffset or Vector3.zero,
    }
end

function Enemy:destroy()
    for _, component in pairs(self.Components) do
        if component.destroy then
            component:destroy(self.Blackboard)
        end
    end
end

Enemy.UpdateOrder = UPDATE_ORDER

return Enemy
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="20">
            <Properties>
              <string name="Name">EnemyBlackboard</string>
              <string name="Source"><![CDATA[local EnemyBlackboard = {}
EnemyBlackboard.__index = EnemyBlackboard

local function cloneTable(source)
    local clone = {}
    if type(source) ~= 'table' then
        return clone
    end

    for key, value in pairs(source) do
        clone[key] = value
    end

    return clone
end

function EnemyBlackboard.new(definition)
    return setmetatable({
        Definition = definition,
        State = nil,
        Context = {},
        Transient = {},
    }, EnemyBlackboard)
end

function EnemyBlackboard:beginTick(context)
    self.Context = cloneTable(context)
    self.Transient = {}
end

function EnemyBlackboard:setState(state)
    self.State = state
end

function EnemyBlackboard:getState()
    return self.State
end

return EnemyBlackboard
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="21">
            <Properties>
              <string name="Name">EnemyStateMachine</string>
              <string name="Source"><![CDATA[local EnemyStateMachine = {}
EnemyStateMachine.__index = EnemyStateMachine

local STATE = table.freeze({
    Idle = 'Idle',
    Suspect = 'Suspect',
    Alert = 'Alert',
    Search = 'Search',
})

function EnemyStateMachine.new(initialState)
    return setmetatable({
        Current = initialState or STATE.Idle,
        LostTargetTicks = 0,
    }, EnemyStateMachine)
end

function EnemyStateMachine:getState()
    return self.Current
end

function EnemyStateMachine:update(blackboard)
    local hasTarget = blackboard.Transient.HasTarget == true

    if hasTarget then
        self.Current = STATE.Alert
        self.LostTargetTicks = 0
        blackboard:setState(self.Current)
        return self.Current
    end

    if self.Current == STATE.Alert then
        self.Current = STATE.Search
        self.LostTargetTicks = 1
        blackboard:setState(self.Current)
        return self.Current
    end

    if self.Current == STATE.Search then
        self.LostTargetTicks += 1
        if self.LostTargetTicks >= 2 then
            self.Current = STATE.Idle
        end
        blackboard:setState(self.Current)
        return self.Current
    end

    self.Current = STATE.Idle
    blackboard:setState(self.Current)
    return self.Current
end

EnemyStateMachine.State = STATE

return EnemyStateMachine
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="22">
            <Properties>
              <string name="Name">MazeMonsterSpawnPolicy</string>
              <string name="Source"><![CDATA[local MazeMonsterSpawnPolicy = {}

function MazeMonsterSpawnPolicy.buildInitialSpawnExcludedRoomIds(roomById, campRoomId)
    local excludedRoomIds = {}
    local campRoom = roomById and roomById[campRoomId]
    if campRoom == nil then
        return excludedRoomIds
    end

    excludedRoomIds[campRoomId] = true
    for _, neighborRoomId in pairs(campRoom.Neighbors or {}) do
        excludedRoomIds[neighborRoomId] = true
    end

    return excludedRoomIds
end

function MazeMonsterSpawnPolicy.selectInitialPatrolIndex(
    roomIds,
    roomAffordances,
    roomById,
    campRoomId
)
    local excludedRoomIds =
        MazeMonsterSpawnPolicy.buildInitialSpawnExcludedRoomIds(roomById, campRoomId)
    local patrolIndex = 0

    for _, roomId in ipairs(roomIds or {}) do
        local affordance = roomAffordances and roomAffordances[roomId]
        for _ in ipairs(affordance and affordance.PatrolAnchors or {}) do
            patrolIndex += 1
            if not excludedRoomIds[roomId] then
                return patrolIndex, roomId
            end
        end
    end

    return nil, nil
end

function MazeMonsterSpawnPolicy.buildEligibleRoomIds(roomIds, roomById, campRoomId)
    local excludedRoomIds =
        MazeMonsterSpawnPolicy.buildInitialSpawnExcludedRoomIds(roomById, campRoomId)
    local eligibleRoomIds = {}

    for _, roomId in ipairs(roomIds or {}) do
        if not excludedRoomIds[roomId] then
            table.insert(eligibleRoomIds, roomId)
        end
    end

    return eligibleRoomIds
end

function MazeMonsterSpawnPolicy.selectRandomEligiblePatrolIndex(
    roomIds,
    roomAffordances,
    roomById,
    campRoomId,
    randomSource
)
    local eligibleRoomIds =
        MazeMonsterSpawnPolicy.buildEligibleRoomIds(roomIds, roomById, campRoomId)
    if #eligibleRoomIds == 0 then
        return nil, nil
    end

    local eligibleRoomSet = {}
    for _, roomId in ipairs(eligibleRoomIds) do
        eligibleRoomSet[roomId] = true
    end

    local roomsWithPatrolAnchors = {}
    for _, roomId in ipairs(roomIds or {}) do
        local affordance = roomAffordances and roomAffordances[roomId]
        if
            eligibleRoomSet[roomId]
            and affordance
            and #((affordance and affordance.PatrolAnchors) or {}) > 0
        then
            table.insert(roomsWithPatrolAnchors, roomId)
        end
    end

    if #roomsWithPatrolAnchors == 0 then
        return nil, nil
    end

    local random = randomSource or Random.new()
    local selectedRoomId = roomsWithPatrolAnchors[random:NextInteger(1, #roomsWithPatrolAnchors)]
    local selectedPatrolIndex = 0

    for _, roomId in ipairs(roomIds or {}) do
        local affordance = roomAffordances and roomAffordances[roomId]
        for _ in ipairs(affordance and affordance.PatrolAnchors or {}) do
            selectedPatrolIndex += 1
            if roomId == selectedRoomId then
                return selectedPatrolIndex, selectedRoomId
            end
        end
    end

    return nil, selectedRoomId
end

return MazeMonsterSpawnPolicy
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="23">
            <Properties>
              <string name="Name">MonsterAssetIds</string>
              <string name="Source"><![CDATA[local MonsterAssetIds = table.freeze({
    DefaultModelAssetId = 9492320977,
    DefaultChaseLoopSoundAssetId = 9118823108,
})

return MonsterAssetIds
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="24">
            <Properties>
              <string name="Name">MonsterAuthorProfile</string>
              <string name="Source"><![CDATA[local MonsterBehaviorCatalog = require(script.Parent.MonsterBehaviorCatalog)
local MonsterEffectCatalog = require(script.Parent.MonsterEffectCatalog)
local MonsterPresentationCatalog = require(script.Parent.MonsterPresentationCatalog)

local MonsterAuthorProfile = {}
local ERROR_CATEGORY = table.freeze({
    Schema = 'SchemaError',
    Boundary = 'BoundaryError',
})
local SCHEMA_MODE = table.freeze({
    Layered = 'Layered',
})
local SEMANTIC_FIELDS = table.freeze({
    Lore = true,
    Atmosphere = true,
    TriggerIntent = true,
    CounterplayIntent = true,
})
local TUNING_FIELDS = table.freeze({
    AttackCooldownSeconds = true,
    AttackDamagePips = true,
    AttackRange = true,
    Speed = true,
    SightRange = true,
    PatrolSpeedMultiplier = true,
    SpawnOffset = true,
})
local EXECUTABLE_FIELDS = table.freeze({
    Presentation = true,
    BehaviorIntents = true,
    EffectIntents = true,
})
local BOUNDARY_REASONS = table.freeze({
    BoundaryLegacySemanticFieldAtRoot = true,
    BoundaryLegacyTuningFieldAtRoot = true,
    BoundaryLegacyExecutableFieldAtRoot = true,
    BoundarySemanticsContainsNonSemanticField = true,
    BoundaryTuningContainsNonTuningField = true,
    BoundaryExecutableContainsNonExecutableField = true,
})

MonsterAuthorProfile.ErrorCategory = ERROR_CATEGORY
MonsterAuthorProfile.SchemaMode = SCHEMA_MODE

local function isNonEmptyString(value)
    return type(value) == 'string' and value ~= ''
end

local function hasAnyField(payload, fields)
    for fieldName in pairs(fields) do
        if payload[fieldName] ~= nil then
            return true
        end
    end

    return false
end

local function validateSummaryTable(summaryTable, missingReason)
    if type(summaryTable) ~= 'table' then
        return false, missingReason
    end

    if not isNonEmptyString(summaryTable.Summary) then
        return false, missingReason
    end

    return true
end

local function validatePresentation(presentation)
    if type(presentation) ~= 'table' then
        return false, 'MissingPresentation'
    end

    if type(presentation.ModelAssetId) ~= 'number' or presentation.ModelAssetId <= 0 then
        return false, 'InvalidModelAssetId'
    end

    if not MonsterPresentationCatalog.KnownRigType[presentation.RigType] then
        return false, 'InvalidRigType'
    end

    if not MonsterPresentationCatalog.KnownAnimationMode[presentation.AnimationMode] then
        return false, 'InvalidAnimationMode'
    end

    if
        presentation.ChaseLoopSoundAssetId ~= nil
        and (
            type(presentation.ChaseLoopSoundAssetId) ~= 'number'
            or presentation.ChaseLoopSoundAssetId <= 0
        )
    then
        return false, 'InvalidChaseLoopSoundAssetId'
    end

    return true
end

local function normalizeSections(profile)
    local hasLayeredSections = profile.Semantics ~= nil
        or profile.Tuning ~= nil
        or profile.Executable ~= nil
    if not hasLayeredSections then
        return nil, 'LegacySchemaUnsupported'
    end

    local semantics = profile.Semantics
    if type(semantics) ~= 'table' then
        return nil, 'MissingSemantics'
    end

    local tuning = profile.Tuning
    if type(tuning) ~= 'table' then
        return nil, 'MissingTuning'
    end

    local executable = profile.Executable
    if type(executable) ~= 'table' then
        return nil, 'MissingExecutable'
    end

    if hasAnyField(profile, SEMANTIC_FIELDS) then
        return nil, 'BoundaryLegacySemanticFieldAtRoot'
    end

    if profile.NumericProfile ~= nil or hasAnyField(profile, TUNING_FIELDS) then
        return nil, 'BoundaryLegacyTuningFieldAtRoot'
    end

    if hasAnyField(profile, EXECUTABLE_FIELDS) then
        return nil, 'BoundaryLegacyExecutableFieldAtRoot'
    end

    if
        semantics.NumericProfile ~= nil
        or hasAnyField(semantics, TUNING_FIELDS)
        or hasAnyField(semantics, EXECUTABLE_FIELDS)
    then
        return nil, 'BoundarySemanticsContainsNonSemanticField'
    end

    if
        tuning.NumericProfile ~= nil
        or hasAnyField(tuning, SEMANTIC_FIELDS)
        or hasAnyField(tuning, EXECUTABLE_FIELDS)
    then
        return nil, 'BoundaryTuningContainsNonTuningField'
    end

    if
        executable.NumericProfile ~= nil
        or hasAnyField(executable, SEMANTIC_FIELDS)
        or hasAnyField(executable, TUNING_FIELDS)
    then
        return nil, 'BoundaryExecutableContainsNonExecutableField'
    end

    return {
        SchemaMode = SCHEMA_MODE.Layered,
        Semantics = semantics,
        Tuning = tuning,
        Executable = executable,
    }
end

function MonsterAuthorProfile.classifyReason(reason)
    if BOUNDARY_REASONS[reason] then
        return ERROR_CATEGORY.Boundary
    end

    return ERROR_CATEGORY.Schema
end

function MonsterAuthorProfile.validate(profile)
    if type(profile) ~= 'table' then
        return false, 'MalformedMonsterAuthorProfile'
    end

    if not isNonEmptyString(profile.Id) then
        return false, 'MissingId'
    end

    if not isNonEmptyString(profile.Name) then
        return false, 'MissingName'
    end

    local normalizedSections, sectionReason = normalizeSections(profile)
    if not normalizedSections then
        return false, sectionReason
    end

    local semantics = normalizedSections.Semantics
    if not isNonEmptyString(semantics.Lore) then
        return false, 'MissingLore'
    end

    if not isNonEmptyString(semantics.Atmosphere) then
        return false, 'MissingAtmosphere'
    end

    local triggerOk, triggerReason =
        validateSummaryTable(semantics.TriggerIntent, 'MissingTriggerIntentSummary')
    if not triggerOk then
        return false, triggerReason
    end

    local counterplayOk, counterplayReason =
        validateSummaryTable(semantics.CounterplayIntent, 'MissingCounterplayIntentSummary')
    if not counterplayOk then
        return false, counterplayReason
    end

    local executable = normalizedSections.Executable
    local presentationOk, presentationReason = validatePresentation(executable.Presentation)
    if not presentationOk then
        return false, presentationReason
    end

    local tuning = normalizedSections.Tuning
    if type(tuning.Speed) ~= 'number' or tuning.Speed <= 0 then
        return false, 'InvalidSpeed'
    end

    if type(tuning.SightRange) ~= 'number' or tuning.SightRange <= 0 then
        return false, 'InvalidSightRange'
    end

    if type(tuning.PatrolSpeedMultiplier) ~= 'number' or tuning.PatrolSpeedMultiplier <= 0 then
        return false, 'InvalidPatrolSpeedMultiplier'
    end

    if
        tuning.AttackRange ~= nil
        and (type(tuning.AttackRange) ~= 'number' or tuning.AttackRange <= 0)
    then
        return false, 'InvalidAttackRange'
    end

    if tuning.AttackCooldownSeconds ~= nil then
        if type(tuning.AttackCooldownSeconds) ~= 'number' or tuning.AttackCooldownSeconds <= 0 then
            return false, 'InvalidAttackCooldownSeconds'
        end
    end

    if
        tuning.AttackDamagePips ~= nil
        and tuning.AttackDamagePips ~= 1
        and tuning.AttackDamagePips ~= 2
    then
        return false, 'InvalidAttackDamagePips'
    end

    if tuning.SpawnOffset ~= nil and typeof(tuning.SpawnOffset) ~= 'Vector3' then
        return false, 'InvalidSpawnOffset'
    end

    if tuning.CombatHitPoints ~= nil then
        if
            type(tuning.CombatHitPoints) ~= 'number'
            or tuning.CombatHitPoints < 1
            or math.floor(tuning.CombatHitPoints) ~= tuning.CombatHitPoints
        then
            return false, 'InvalidCombatHitPoints'
        end
    end

    if type(executable.BehaviorIntents) ~= 'table' or #executable.BehaviorIntents == 0 then
        return false, 'MissingBehaviorIntents'
    end

    for _, behaviorIntent in ipairs(executable.BehaviorIntents) do
        if type(behaviorIntent) ~= 'table' then
            return false, 'MalformedBehaviorIntent'
        end

        if type(behaviorIntent.Id) ~= 'string' or behaviorIntent.Id == '' then
            return false, 'MissingBehaviorIntentId'
        end

        if not MonsterBehaviorCatalog.Known[behaviorIntent.Id] then
            return false, 'UnknownBehaviorIntent'
        end
    end

    local effectIntents = executable.EffectIntents
    if effectIntents ~= nil then
        if type(effectIntents) ~= 'table' then
            return false, 'MalformedEffectIntents'
        end

        for _, effectIntent in ipairs(effectIntents) do
            local validEffect, effectReason = MonsterEffectCatalog.validateIntent(effectIntent)
            if not validEffect then
                return false, effectReason
            end
        end
    end

    return true,
        {
            Id = profile.Id,
            Name = profile.Name,
            SchemaMode = normalizedSections.SchemaMode,
            Semantics = semantics,
            Tuning = tuning,
            Executable = executable,
        }
end

return MonsterAuthorProfile
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="25">
            <Properties>
              <string name="Name">MonsterBehaviorCatalog</string>
              <string name="Source"><![CDATA[local BEHAVIOR = table.freeze({
    Patrol = 'Patrol',
    SenseNearestTarget = 'SenseNearestTarget',
    Chase = 'Chase',
    LoseTarget = 'LoseTarget',
    Attack = 'Attack',
    Suppressed = 'Suppressed',
})

local knownBehaviorIds = {}
for _, behaviorId in pairs(BEHAVIOR) do
    knownBehaviorIds[behaviorId] = true
end

local MonsterBehaviorCatalog = table.freeze({
    Behavior = BEHAVIOR,
    Known = table.freeze(knownBehaviorIds),
    MazeExecutable = table.freeze({
        [BEHAVIOR.Patrol] = true,
        [BEHAVIOR.SenseNearestTarget] = true,
        [BEHAVIOR.Chase] = true,
        [BEHAVIOR.Attack] = true,
    }),
})

return MonsterBehaviorCatalog
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="26">
            <Properties>
              <string name="Name">MonsterCompiler</string>
              <string name="Source"><![CDATA[local MonsterAuthorProfile = require(script.Parent.MonsterAuthorProfile)
local MonsterBehaviorCatalog = require(script.Parent.MonsterBehaviorCatalog)
local MonsterComponentConfig = require(script.Parent.MonsterComponentConfig)
local MonsterEffectCatalog = require(script.Parent.MonsterEffectCatalog)
local MonsterRuntimeProfile = require(script.Parent.MonsterRuntimeProfile)

local DEFAULT_SPAWN_OFFSET = Vector3.new(0, 4, 0)
local DEFAULT_ATTACK_COOLDOWN_SECONDS = 1
local DEFAULT_ATTACK_DAMAGE_PIPS = 1
local DEFAULT_ATTACK_RANGE = 4
local DEFAULT_COMBAT_HIT_POINTS = 1

local MonsterCompiler = {}

local function buildErrorDiagnostic(category, code)
    return table.freeze({
        Category = category,
        Code = code,
    })
end

local function cloneRuntimeEffect(effectIntent)
    local runtimeEffect = {
        Id = effectIntent.Id,
    }

    if type(effectIntent.DurationSeconds) == 'number' then
        runtimeEffect.DurationSeconds = effectIntent.DurationSeconds
    end

    return table.freeze(runtimeEffect)
end

local function cloneRuntimePresentation(presentation)
    return table.freeze({
        ModelAssetId = presentation.ModelAssetId,
        RigType = presentation.RigType,
        AnimationMode = presentation.AnimationMode,
        ChaseLoopSoundAssetId = presentation.ChaseLoopSoundAssetId,
    })
end

function MonsterCompiler.compileMonsterForMaze(authorProfile)
    local validAuthorProfile, normalizedOrReason = MonsterAuthorProfile.validate(authorProfile)
    if not validAuthorProfile then
        local category = MonsterAuthorProfile.classifyReason(normalizedOrReason)
        return false, normalizedOrReason, buildErrorDiagnostic(category, normalizedOrReason)
    end
    local normalizedProfile = normalizedOrReason

    local behaviors = {}
    local skippedBehaviorIds = {}
    for _, behaviorIntent in ipairs(normalizedProfile.Executable.BehaviorIntents) do
        if behaviorIntent.Enabled ~= false then
            if MonsterBehaviorCatalog.MazeExecutable[behaviorIntent.Id] then
                behaviors[behaviorIntent.Id] = true
            else
                table.insert(skippedBehaviorIds, behaviorIntent.Id)
            end
        end
    end

    local runtimeEffects = {}
    local skippedEffectIds = {}
    for _, effectIntent in ipairs(normalizedProfile.Executable.EffectIntents or {}) do
        if effectIntent.Enabled ~= false then
            if MonsterEffectCatalog.MazeExecutable[effectIntent.Id] then
                table.insert(runtimeEffects, cloneRuntimeEffect(effectIntent))
            else
                table.insert(skippedEffectIds, effectIntent.Id)
            end
        end
    end

    local combatHitPoints = normalizedProfile.Tuning.CombatHitPoints
    if
        type(combatHitPoints) ~= 'number'
        or combatHitPoints < 1
        or math.floor(combatHitPoints) ~= combatHitPoints
    then
        combatHitPoints = DEFAULT_COMBAT_HIT_POINTS
    end

    local runtimeProfile = {
        Id = normalizedProfile.Id,
        Name = normalizedProfile.Name,
        Presentation = cloneRuntimePresentation(normalizedProfile.Executable.Presentation),
        AttackCooldownSeconds = normalizedProfile.Tuning.AttackCooldownSeconds
            or DEFAULT_ATTACK_COOLDOWN_SECONDS,
        AttackDamagePips = normalizedProfile.Tuning.AttackDamagePips or DEFAULT_ATTACK_DAMAGE_PIPS,
        AttackRange = normalizedProfile.Tuning.AttackRange or DEFAULT_ATTACK_RANGE,
        Speed = normalizedProfile.Tuning.Speed,
        SightRange = normalizedProfile.Tuning.SightRange,
        PatrolSpeedMultiplier = normalizedProfile.Tuning.PatrolSpeedMultiplier,
        SpawnOffset = normalizedProfile.Tuning.SpawnOffset or DEFAULT_SPAWN_OFFSET,
        CombatHitPoints = combatHitPoints,
        Behaviors = table.freeze(behaviors),
        Effects = table.freeze(runtimeEffects),
    }
    runtimeProfile.Components = MonsterComponentConfig.fromRuntimeProfile(runtimeProfile)
    runtimeProfile = table.freeze(runtimeProfile)

    local validRuntimeProfile, runtimeReason = MonsterRuntimeProfile.validate(runtimeProfile)
    if not validRuntimeProfile then
        return false,
            runtimeReason,
            buildErrorDiagnostic(MonsterAuthorProfile.ErrorCategory.Schema, runtimeReason)
    end

    local compileReport = table.freeze({
        SchemaMode = normalizedProfile.SchemaMode,
        SkippedBehaviorIds = table.freeze(skippedBehaviorIds),
        SkippedEffectIds = table.freeze(skippedEffectIds),
        Warnings = table.freeze({}),
    })

    return true, runtimeProfile, compileReport
end

return MonsterCompiler
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="27">
            <Properties>
              <string name="Name">MonsterComponentConfig</string>
              <string name="Source"><![CDATA[local DEFAULT_ATTACK_COOLDOWN_SECONDS = 1
local DEFAULT_ATTACK_DAMAGE_PIPS = 1
local DEFAULT_ATTACK_HIT_MARKER_NAME = 'Hit'
local DEFAULT_ATTACK_RANGE = 4
local DEFAULT_ATTACK_ARC_DEGREES = 100
local DEFAULT_PATROL_REACH_DISTANCE = 2
local DEFAULT_SPAWN_OFFSET = Vector3.new(0, 4, 0)

local MonsterComponentConfig = {}

local function getPositiveNumber(value, fallback, defaultValue)
    if type(value) == 'number' and value > 0 then
        return value
    end
    if type(fallback) == 'number' and fallback > 0 then
        return fallback
    end
    return defaultValue
end

local function getSpawnOffset(primary, fallback)
    if typeof(primary) == 'Vector3' then
        return primary
    end
    if typeof(fallback) == 'Vector3' then
        return fallback
    end
    return DEFAULT_SPAWN_OFFSET
end

local function getAttackDamagePips(value, fallback)
    if value == 1 or value == 2 then
        return value
    end
    if fallback == 1 or fallback == 2 then
        return fallback
    end
    return DEFAULT_ATTACK_DAMAGE_PIPS
end

function MonsterComponentConfig.fromRuntimeProfile(runtimeProfile)
    local profile = runtimeProfile or {}
    local components = if type(profile.Components) == 'table' then profile.Components else {}

    local perception = if type(components.Perception) == 'table' then components.Perception else {}
    local movement = if type(components.Movement) == 'table' then components.Movement else {}
    local attack = if type(components.Attack) == 'table' then components.Attack else {}

    local componentConfig = {
        Perception = table.freeze({
            SightRange = getPositiveNumber(perception.SightRange, profile.SightRange, 30),
        }),
        Movement = table.freeze({
            PatrolReachDistance = getPositiveNumber(
                movement.PatrolReachDistance,
                nil,
                DEFAULT_PATROL_REACH_DISTANCE
            ),
            PatrolSpeedMultiplier = getPositiveNumber(
                movement.PatrolSpeedMultiplier,
                profile.PatrolSpeedMultiplier,
                0.45
            ),
            SpawnOffset = getSpawnOffset(movement.SpawnOffset, profile.SpawnOffset),
            Speed = getPositiveNumber(movement.Speed, profile.Speed, 14),
        }),
        Attack = table.freeze({
            ArcDegrees = getPositiveNumber(attack.ArcDegrees, nil, DEFAULT_ATTACK_ARC_DEGREES),
            CooldownSeconds = getPositiveNumber(
                attack.CooldownSeconds,
                profile.AttackCooldownSeconds,
                DEFAULT_ATTACK_COOLDOWN_SECONDS
            ),
            DamagePips = getAttackDamagePips(attack.DamagePips, profile.AttackDamagePips),
            HitMarkerName = if type(attack.HitMarkerName) == 'string'
                    and attack.HitMarkerName ~= ''
                then attack.HitMarkerName
                else DEFAULT_ATTACK_HIT_MARKER_NAME,
            Range = getPositiveNumber(attack.Range, profile.AttackRange, DEFAULT_ATTACK_RANGE),
        }),
    }

    return table.freeze(componentConfig)
end

return MonsterComponentConfig
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="28">
            <Properties>
              <string name="Name">MonsterEffectCatalog</string>
              <string name="Source"><![CDATA[local CATEGORY = table.freeze({
    Damage = 'Damage',
    PlayerStatus = 'PlayerStatus',
    MonsterStatus = 'MonsterStatus',
})

local EFFECT = table.freeze({
    DamageLight = 'DamageLight',
    DamageHeavy = 'DamageHeavy',
    SprintSuppressed = 'SprintSuppressed',
    MonsterStunned = 'MonsterStunned',
})

local knownEffectIds = {}
for _, effectId in pairs(EFFECT) do
    knownEffectIds[effectId] = true
end

local DURATION_EFFECTS = table.freeze({
    [EFFECT.SprintSuppressed] = true,
    [EFFECT.MonsterStunned] = true,
})

local MonsterEffectCatalog = {
    Category = CATEGORY,
    Effect = EFFECT,
    Known = table.freeze(knownEffectIds),
    MazeExecutable = table.freeze({
        [EFFECT.DamageLight] = true,
        [EFFECT.DamageHeavy] = true,
    }),
}

function MonsterEffectCatalog.validateIntent(effectIntent)
    if type(effectIntent) ~= 'table' then
        return false, 'MalformedEffectIntent'
    end

    if type(effectIntent.Id) ~= 'string' or effectIntent.Id == '' then
        return false, 'MissingEffectIntentId'
    end

    if not MonsterEffectCatalog.Known[effectIntent.Id] then
        return false, 'UnknownEffectIntent'
    end

    if DURATION_EFFECTS[effectIntent.Id] then
        local durationSeconds = effectIntent.DurationSeconds
        if type(durationSeconds) ~= 'number' or durationSeconds <= 0 then
            return false, 'InvalidEffectPayload'
        end
    end

    return true
end

return table.freeze(MonsterEffectCatalog)
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="29">
            <Properties>
              <string name="Name">MonsterLogic</string>
              <string name="Source"><![CDATA[local MonsterLogic = {}

function MonsterLogic.pickNearestTarget(currentPosition, playerPositions, sightRange)
    local closestPlayer = nil
    local closestDistance = sightRange

    for player, position in pairs(playerPositions) do
        local distance = (position - currentPosition).Magnitude
        if distance <= closestDistance then
            closestPlayer = player
            closestDistance = distance
        end
    end

    return closestPlayer
end

function MonsterLogic.stepToward(currentPosition, targetPosition, speed, dt)
    local offset = targetPosition - currentPosition
    local distance = offset.Magnitude

    if distance == 0 then
        return currentPosition
    end

    local stepDistance = math.min(speed * dt, distance)
    return currentPosition + offset.Unit * stepDistance
end

return MonsterLogic
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="30">
            <Properties>
              <string name="Name">MonsterPresentationCatalog</string>
              <string name="Source"><![CDATA[local MonsterPresentationCatalog = {}

MonsterPresentationCatalog.RigType = table.freeze({
    R6 = 'R6',
})

MonsterPresentationCatalog.AnimationMode = table.freeze({
    DefaultR6 = 'defaultR6',
})

MonsterPresentationCatalog.KnownRigType = table.freeze({
    [MonsterPresentationCatalog.RigType.R6] = true,
})

MonsterPresentationCatalog.KnownAnimationMode = table.freeze({
    [MonsterPresentationCatalog.AnimationMode.DefaultR6] = true,
})

return MonsterPresentationCatalog
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="31">
            <Properties>
              <string name="Name">MonsterRuntimeProfile</string>
              <string name="Source"><![CDATA[local MonsterPresentationCatalog = require(script.Parent.MonsterPresentationCatalog)

local MonsterRuntimeProfile = {}

local function isNonEmptyString(value)
    return type(value) == 'string' and value ~= ''
end

local function isPositiveNumber(value)
    return type(value) == 'number' and value > 0
end

local function isValidDamagePips(value)
    return value == 1 or value == 2
end

local function readComponentTable(profile, name)
    local components = profile.Components
    if components == nil then
        return nil, nil
    end
    if type(components) ~= 'table' then
        return nil, 'InvalidRuntimeComponents'
    end

    local component = components[name]
    if component == nil then
        return nil, nil
    end
    if type(component) ~= 'table' then
        return nil, string.format('InvalidRuntimeComponent%s', name)
    end

    return component, nil
end

function MonsterRuntimeProfile.validate(profile)
    if type(profile) ~= 'table' then
        return false, 'MalformedMonsterRuntimeProfile'
    end

    if not isNonEmptyString(profile.Id) then
        return false, 'MissingRuntimeId'
    end

    if not isNonEmptyString(profile.Name) then
        return false, 'MissingRuntimeName'
    end

    local presentation = profile.Presentation
    if type(presentation) ~= 'table' then
        return false, 'MissingRuntimePresentation'
    end

    if type(presentation.ModelAssetId) ~= 'number' or presentation.ModelAssetId <= 0 then
        return false, 'InvalidRuntimeModelAssetId'
    end

    if not MonsterPresentationCatalog.KnownRigType[presentation.RigType] then
        return false, 'InvalidRuntimeRigType'
    end

    if not MonsterPresentationCatalog.KnownAnimationMode[presentation.AnimationMode] then
        return false, 'InvalidRuntimeAnimationMode'
    end

    if
        presentation.ChaseLoopSoundAssetId ~= nil
        and (
            type(presentation.ChaseLoopSoundAssetId) ~= 'number'
            or presentation.ChaseLoopSoundAssetId <= 0
        )
    then
        return false, 'InvalidRuntimeChaseLoopSoundAssetId'
    end

    local perceptionConfig, perceptionConfigErr = readComponentTable(profile, 'Perception')
    if perceptionConfigErr then
        return false, perceptionConfigErr
    end
    local movementConfig, movementConfigErr = readComponentTable(profile, 'Movement')
    if movementConfigErr then
        return false, movementConfigErr
    end
    local attackConfig, attackConfigErr = readComponentTable(profile, 'Attack')
    if attackConfigErr then
        return false, attackConfigErr
    end

    if
        perceptionConfig
        and perceptionConfig.SightRange ~= nil
        and not isPositiveNumber(perceptionConfig.SightRange)
    then
        return false, 'InvalidRuntimeComponentPerceptionSightRange'
    end

    if movementConfig then
        if movementConfig.Speed ~= nil and not isPositiveNumber(movementConfig.Speed) then
            return false, 'InvalidRuntimeComponentMovementSpeed'
        end
        if
            movementConfig.PatrolSpeedMultiplier ~= nil
            and not isPositiveNumber(movementConfig.PatrolSpeedMultiplier)
        then
            return false, 'InvalidRuntimeComponentMovementPatrolSpeedMultiplier'
        end
        if
            movementConfig.PatrolReachDistance ~= nil
            and not isPositiveNumber(movementConfig.PatrolReachDistance)
        then
            return false, 'InvalidRuntimeComponentMovementPatrolReachDistance'
        end
        if
            movementConfig.SpawnOffset ~= nil
            and typeof(movementConfig.SpawnOffset) ~= 'Vector3'
        then
            return false, 'InvalidRuntimeComponentMovementSpawnOffset'
        end
    end

    if attackConfig then
        if attackConfig.Range ~= nil and not isPositiveNumber(attackConfig.Range) then
            return false, 'InvalidRuntimeComponentAttackRange'
        end
        if
            attackConfig.CooldownSeconds ~= nil
            and not isPositiveNumber(attackConfig.CooldownSeconds)
        then
            return false, 'InvalidRuntimeComponentAttackCooldown'
        end
        if attackConfig.DamagePips ~= nil and not isValidDamagePips(attackConfig.DamagePips) then
            return false, 'InvalidRuntimeComponentAttackDamagePips'
        end
    end

    local runtimeSpeed = profile.Speed
    if runtimeSpeed == nil and movementConfig then
        runtimeSpeed = movementConfig.Speed
    end
    if not isPositiveNumber(runtimeSpeed) then
        return false, 'InvalidRuntimeSpeed'
    end

    local runtimeSightRange = profile.SightRange
    if runtimeSightRange == nil and perceptionConfig then
        runtimeSightRange = perceptionConfig.SightRange
    end
    if not isPositiveNumber(runtimeSightRange) then
        return false, 'InvalidRuntimeSightRange'
    end

    local runtimePatrolSpeedMultiplier = profile.PatrolSpeedMultiplier
    if runtimePatrolSpeedMultiplier == nil and movementConfig then
        runtimePatrolSpeedMultiplier = movementConfig.PatrolSpeedMultiplier
    end
    if not isPositiveNumber(runtimePatrolSpeedMultiplier) then
        return false, 'InvalidRuntimePatrolSpeedMultiplier'
    end

    local runtimeSpawnOffset = profile.SpawnOffset
    if runtimeSpawnOffset == nil and movementConfig then
        runtimeSpawnOffset = movementConfig.SpawnOffset
    end
    if typeof(runtimeSpawnOffset) ~= 'Vector3' then
        return false, 'InvalidRuntimeSpawnOffset'
    end

    local runtimeAttackRange = profile.AttackRange
    if runtimeAttackRange == nil and attackConfig then
        runtimeAttackRange = attackConfig.Range
    end
    if runtimeAttackRange == nil then
        runtimeAttackRange = 4
    end
    if not isPositiveNumber(runtimeAttackRange) then
        return false, 'InvalidRuntimeAttackRange'
    end

    local runtimeAttackCooldownSeconds = profile.AttackCooldownSeconds
    if runtimeAttackCooldownSeconds == nil and attackConfig then
        runtimeAttackCooldownSeconds = attackConfig.CooldownSeconds
    end
    if runtimeAttackCooldownSeconds == nil then
        runtimeAttackCooldownSeconds = 1
    end
    if not isPositiveNumber(runtimeAttackCooldownSeconds) then
        return false, 'InvalidRuntimeAttackCooldownSeconds'
    end

    local runtimeAttackDamagePips = profile.AttackDamagePips
    if runtimeAttackDamagePips == nil and attackConfig then
        runtimeAttackDamagePips = attackConfig.DamagePips
    end
    if runtimeAttackDamagePips == nil then
        runtimeAttackDamagePips = 1
    end
    if not isValidDamagePips(runtimeAttackDamagePips) then
        return false, 'InvalidRuntimeAttackDamagePips'
    end

    if type(profile.Behaviors) ~= 'table' then
        return false, 'MissingRuntimeBehaviors'
    end

    if type(profile.Effects) ~= 'table' then
        return false, 'MissingRuntimeEffects'
    end

    local combatHitPoints = profile.CombatHitPoints
    if
        type(combatHitPoints) ~= 'number'
        or combatHitPoints < 1
        or math.floor(combatHitPoints) ~= combatHitPoints
    then
        return false, 'InvalidRuntimeCombatHitPoints'
    end

    return true
end

return MonsterRuntimeProfile
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="32">
            <Properties>
              <string name="Name">MonsterUgcPipeline</string>
              <string name="Source"><![CDATA[local MonsterBehaviorCatalog = require(script.Parent.MonsterBehaviorCatalog)
local MonsterCompiler = require(script.Parent.MonsterCompiler)
local MonsterEffectCatalog = require(script.Parent.MonsterEffectCatalog)
local MonsterAssetIds = require(script.Parent.MonsterAssetIds)
local MonsterPresentationCatalog = require(script.Parent.MonsterPresentationCatalog)

local MonsterUgcPipeline = {}

MonsterUgcPipeline.Status = table.freeze({
    WaitingForUser = 'waiting_for_user',
    ReadyToGenerate = 'ready_to_generate',
    SandboxReady = 'sandbox_ready',
    Rejected = 'rejected',
})

MonsterUgcPipeline.RejectionCode = table.freeze({
    MalformedBrief = 'MalformedBrief',
    MissingBriefFields = 'MissingBriefFields',
    UnknownBehaviorIntent = 'UnknownBehaviorIntent',
    InvalidEffectIntent = 'InvalidEffectIntent',
    AssetValidationFailed = 'AssetValidationFailed',
    CompileFailed = 'CompileFailed',
    InvalidGenerationResult = 'InvalidGenerationResult',
})

MonsterUgcPipeline.TuningRange = table.freeze({
    Speed = table.freeze({ Min = 8, Max = 20 }),
    SightRange = table.freeze({ Min = 20, Max = 60 }),
    PatrolSpeedMultiplier = table.freeze({ Min = 0.2, Max = 0.9 }),
})

local DEFAULT_ASSET_IDS = table.freeze({
    ModelAssetId = MonsterAssetIds.DefaultModelAssetId,
    ChaseLoopSoundAssetId = MonsterAssetIds.DefaultChaseLoopSoundAssetId,
})

local DEFAULT_PREFAB_ID = 'stalker-hunt'

local TUNING_PREFABS = table.freeze({
    ['stalker-hunt'] = table.freeze({
        Speed = 14,
        SightRange = 36,
        PatrolSpeedMultiplier = 0.45,
        SpawnOffset = Vector3.new(0, 4, 0),
    }),
    ['ambusher-rush'] = table.freeze({
        Speed = 16,
        SightRange = 30,
        PatrolSpeedMultiplier = 0.35,
        SpawnOffset = Vector3.new(0, 4, 0),
    }),
    ['bruiser-pressure'] = table.freeze({
        Speed = 11,
        SightRange = 32,
        PatrolSpeedMultiplier = 0.5,
        SpawnOffset = Vector3.new(0, 4, 0),
    }),
})

local BEHAVIOR_PREFABS = table.freeze({
    ['stalker-hunt'] = table.freeze({
        {
            Id = MonsterBehaviorCatalog.Behavior.Patrol,
            Enabled = false,
        },
        {
            Id = MonsterBehaviorCatalog.Behavior.SenseNearestTarget,
        },
        {
            Id = MonsterBehaviorCatalog.Behavior.Chase,
        },
        {
            Id = MonsterBehaviorCatalog.Behavior.LoseTarget,
        },
    }),
    ['ambusher-rush'] = table.freeze({
        {
            Id = MonsterBehaviorCatalog.Behavior.Patrol,
        },
        {
            Id = MonsterBehaviorCatalog.Behavior.SenseNearestTarget,
        },
        {
            Id = MonsterBehaviorCatalog.Behavior.Chase,
        },
    }),
    ['bruiser-pressure'] = table.freeze({
        {
            Id = MonsterBehaviorCatalog.Behavior.SenseNearestTarget,
        },
        {
            Id = MonsterBehaviorCatalog.Behavior.Chase,
        },
        {
            Id = MonsterBehaviorCatalog.Behavior.Attack,
        },
    }),
})

local EFFECT_PREFABS = table.freeze({
    ['stalker-hunt'] = table.freeze({
        {
            Id = MonsterEffectCatalog.Effect.DamageLight,
        },
    }),
    ['ambusher-rush'] = table.freeze({
        {
            Id = MonsterEffectCatalog.Effect.DamageLight,
        },
    }),
    ['bruiser-pressure'] = table.freeze({
        {
            Id = MonsterEffectCatalog.Effect.DamageHeavy,
        },
    }),
})

local ATMOSPHERE_PREFAB_MAP = table.freeze({
    Dread = 'stalker-hunt',
    Horror = 'stalker-hunt',
    Tense = 'stalker-hunt',
    Rush = 'ambusher-rush',
    Pressure = 'bruiser-pressure',
    Brutal = 'bruiser-pressure',
})

local SAFE_SPAWN_OFFSETS = table.freeze({
    Vector3.new(0, 4, 0),
    Vector3.new(0, 3, 0),
    Vector3.new(0, 5, 0),
})

local CLARIFYING_QUESTION_BY_FIELD = table.freeze({
    Goal = '这个怪物的核心目标是什么？例如压迫追逐、区域封锁或团队分割。',
    Experience = '你希望玩家遇到它时，最强烈的体验感受是什么？',
    ['Semantics.Lore'] = '给这个怪物补一段背景描述（1-2句即可）。',
    ['Semantics.Atmosphere'] = '这个怪物更偏向哪种氛围？例如 Dread、Rush 或 Brutal。',
    ['Semantics.TriggerIntentSummary'] = '它会在什么条件下主动进入追击？',
    ['Semantics.CounterplayIntentSummary'] = '玩家可以通过什么方式与它周旋或反制？',
    SuccessCriteria = '成功标准是什么？至少给出一条可观察的验收条件。',
})

local function trimText(value)
    if type(value) ~= 'string' then
        return ''
    end

    return string.match(value, '^%s*(.-)%s*$') or ''
end

local function normalizeStringList(values)
    if type(values) ~= 'table' then
        return {}
    end

    local normalized = {}
    for _, value in ipairs(values) do
        local text = trimText(value)
        if text ~= '' then
            table.insert(normalized, text)
        end
    end

    return normalized
end

local function cloneShallowTable(values)
    return table.clone(values)
end

local function deepFreeze(value, seen)
    if type(value) ~= 'table' then
        return value
    end

    if table.isfrozen(value) then
        return value
    end

    local visited = seen or {}
    if visited[value] then
        return value
    end
    visited[value] = true

    for _, nested in pairs(value) do
        deepFreeze(nested, visited)
    end

    table.freeze(value)
    return value
end

local function sanitizeName(value)
    local text = trimText(value)
    if text == '' then
        return ''
    end

    text = string.gsub(text, '[%c\n\r\t]', ' ')
    text = string.gsub(text, '%s+', ' ')
    text = trimText(text)

    if #text > 48 then
        text = string.sub(text, 1, 48)
    end

    return text
end

local function nextClarifyingQuestion(missingField)
    return CLARIFYING_QUESTION_BY_FIELD[missingField]
        or '为了继续生成怪物，请先补充缺失字段：' .. tostring(missingField)
end

local function normalizeBrief(rawBrief)
    if type(rawBrief) ~= 'table' then
        return nil, { 'Brief' }
    end

    local semantics = rawBrief.Semantics
    local boundaries = rawBrief.Boundaries
    local preferences = rawBrief.Preferences

    local brief = {
        Prompt = trimText(rawBrief.Prompt),
        Goal = trimText(rawBrief.Goal),
        Experience = trimText(rawBrief.Experience),
        Boundaries = {
            InScope = normalizeStringList(boundaries and boundaries.InScope),
            OutOfScope = normalizeStringList(boundaries and boundaries.OutOfScope),
        },
        SuccessCriteria = normalizeStringList(rawBrief.SuccessCriteria),
        Semantics = {
            Lore = trimText(semantics and semantics.Lore),
            Atmosphere = trimText(semantics and semantics.Atmosphere),
            TriggerIntentSummary = trimText(semantics and semantics.TriggerIntentSummary),
            CounterplayIntentSummary = trimText(semantics and semantics.CounterplayIntentSummary),
        },
        Preferences = {
            Name = sanitizeName(preferences and preferences.Name),
            ModelAssetId = if preferences then preferences.ModelAssetId else nil,
            ChaseLoopSoundAssetId = if preferences then preferences.ChaseLoopSoundAssetId else nil,
            BehaviorIntents = if preferences then preferences.BehaviorIntents else nil,
            EffectIntents = if preferences then preferences.EffectIntents else nil,
            Tuning = if preferences then preferences.Tuning else nil,
        },
    }

    if brief.Prompt == '' then
        brief.Prompt = brief.Goal
    end

    local missingFields = {}
    if brief.Goal == '' then
        table.insert(missingFields, 'Goal')
    end
    if brief.Experience == '' then
        table.insert(missingFields, 'Experience')
    end
    if brief.Semantics.Lore == '' then
        table.insert(missingFields, 'Semantics.Lore')
    end
    if brief.Semantics.Atmosphere == '' then
        table.insert(missingFields, 'Semantics.Atmosphere')
    end
    if brief.Semantics.TriggerIntentSummary == '' then
        table.insert(missingFields, 'Semantics.TriggerIntentSummary')
    end
    if brief.Semantics.CounterplayIntentSummary == '' then
        table.insert(missingFields, 'Semantics.CounterplayIntentSummary')
    end
    if #brief.SuccessCriteria == 0 then
        table.insert(missingFields, 'SuccessCriteria')
    end

    if #missingFields > 0 then
        return nil, missingFields
    end

    return deepFreeze(brief)
end

local function defaultAssetValidator(_assetId, _assetKind)
    return true, 'UncheckedAsset'
end

local function isSafeSpawnOffset(offset)
    if typeof(offset) ~= 'Vector3' then
        return false
    end

    for _, safeOffset in ipairs(SAFE_SPAWN_OFFSETS) do
        if safeOffset == offset then
            return true
        end
    end

    return false
end

local function normalizeIntentList(rawIntents)
    if type(rawIntents) ~= 'table' then
        return nil
    end

    local intents = {}
    for _, rawIntent in ipairs(rawIntents) do
        if type(rawIntent) == 'string' then
            table.insert(intents, { Id = rawIntent })
        elseif type(rawIntent) == 'table' then
            table.insert(intents, cloneShallowTable(rawIntent))
        else
            return nil
        end
    end

    return intents
end

local function clampNumber(value, minValue, maxValue)
    local clamped = math.clamp(value, minValue, maxValue)
    return clamped
end

local function applyRequestedTuning(baseTuning, requestedTuning, diagnostics, sourceByField)
    local tuning = cloneShallowTable(baseTuning)
    local tuningSource = if type(requestedTuning) == 'table' then 'prefab+micro_tune' else 'prefab'

    local function assignNumber(fieldName, minValue, maxValue)
        local requested = if type(requestedTuning) == 'table'
            then requestedTuning[fieldName]
            else nil
        local finalValue = tuning[fieldName]
        if type(requested) == 'number' then
            finalValue = clampNumber(requested, minValue, maxValue)
            if finalValue ~= requested then
                table.insert(diagnostics.ClampedFields, 'Tuning.' .. fieldName)
            end
        end

        tuning[fieldName] = finalValue
        sourceByField['Tuning.' .. fieldName] = tuningSource
    end

    assignNumber(
        'Speed',
        MonsterUgcPipeline.TuningRange.Speed.Min,
        MonsterUgcPipeline.TuningRange.Speed.Max
    )
    assignNumber(
        'SightRange',
        MonsterUgcPipeline.TuningRange.SightRange.Min,
        MonsterUgcPipeline.TuningRange.SightRange.Max
    )
    assignNumber(
        'PatrolSpeedMultiplier',
        MonsterUgcPipeline.TuningRange.PatrolSpeedMultiplier.Min,
        MonsterUgcPipeline.TuningRange.PatrolSpeedMultiplier.Max
    )

    local requestedSpawnOffset = if type(requestedTuning) == 'table'
        then requestedTuning.SpawnOffset
        else nil
    if requestedSpawnOffset ~= nil then
        if isSafeSpawnOffset(requestedSpawnOffset) then
            tuning.SpawnOffset = requestedSpawnOffset
            sourceByField['Tuning.SpawnOffset'] = 'prefab+micro_tune'
        else
            table.insert(diagnostics.ClampedFields, 'Tuning.SpawnOffset')
            sourceByField['Tuning.SpawnOffset'] = 'prefab_safe_offset'
        end
    else
        sourceByField['Tuning.SpawnOffset'] = 'prefab'
    end

    return tuning
end

local function normalizeBehaviorIntents(rawBehaviorIntents)
    local behaviorIntents = normalizeIntentList(rawBehaviorIntents)
    if behaviorIntents == nil then
        return false, 'MalformedBehaviorIntent'
    end

    for _, intent in ipairs(behaviorIntents) do
        if type(intent.Id) ~= 'string' or intent.Id == '' then
            return false, 'MissingBehaviorIntentId'
        end
        if not MonsterBehaviorCatalog.Known[intent.Id] then
            return false, 'UnknownBehaviorIntent'
        end
    end

    return true, behaviorIntents
end

local function normalizeEffectIntents(rawEffectIntents)
    local effectIntents = normalizeIntentList(rawEffectIntents)
    if effectIntents == nil then
        return false, 'MalformedEffectIntent'
    end

    for _, effectIntent in ipairs(effectIntents) do
        local validEffectIntent, reason = MonsterEffectCatalog.validateIntent(effectIntent)
        if not validEffectIntent then
            return false, reason
        end
    end

    return true, effectIntents
end

local function validateAsset(assetId, assetKind, assetValidator, diagnostics)
    if assetId == nil then
        diagnostics.AssetChecks[assetKind] = {
            Status = 'Skipped',
            Reason = 'NoAssetRequested',
        }
        return true
    end

    if type(assetId) ~= 'number' or assetId <= 0 then
        diagnostics.AssetChecks[assetKind] = {
            Status = 'Rejected',
            Reason = 'InvalidAssetId',
        }
        return false, 'InvalidAssetId'
    end

    local ok, allowed, reason = pcall(assetValidator, assetId, assetKind)
    if not ok then
        diagnostics.AssetChecks[assetKind] = {
            AssetId = assetId,
            Status = 'Rejected',
            Reason = 'AssetValidatorError',
        }
        return false, 'AssetValidatorError'
    end

    if allowed ~= true then
        diagnostics.AssetChecks[assetKind] = {
            AssetId = assetId,
            Status = 'Rejected',
            Reason = reason or 'AssetPolicyRejected',
        }
        return false, reason or 'AssetPolicyRejected'
    end

    diagnostics.AssetChecks[assetKind] = {
        AssetId = assetId,
        Status = 'Pass',
        Reason = reason or 'AssetPolicyPass',
    }
    return true
end

local function normalizeSeed(seed)
    if type(seed) ~= 'number' then
        seed = Random.new():NextInteger(1, 2147483646)
    end

    local normalizedSeed = math.floor(math.abs(seed))
    if normalizedSeed <= 0 then
        normalizedSeed = 1
    end

    return normalizedSeed
end

local function buildMonsterName(brief, rng)
    local preferredName = brief.Preferences.Name
    if preferredName ~= '' then
        return preferredName, 'template_fill'
    end

    local goalSnippet = sanitizeName(brief.Goal)
    if goalSnippet ~= '' then
        local titlePool = {
            'Wisp',
            'Hunter',
            'Stalker',
            'Shade',
        }
        local title = titlePool[rng:NextInteger(1, #titlePool)]
        local fallbackName = string.format('%s %s', goalSnippet, title)
        return sanitizeName(fallbackName), 'template_fill'
    end

    return 'UGC Wisp', 'template_fill'
end

local function buildMonsterId(playerUserId, seed)
    local owner = if type(playerUserId) == 'number' and playerUserId > 0 then playerUserId else 0
    return string.format('ugc-%d-%d', owner, seed)
end

local function buildBehaviorIntents(prefabId, brief, sourceByField)
    local requestedBehaviorIntents = brief.Preferences.BehaviorIntents
    if requestedBehaviorIntents ~= nil then
        local behaviorOk, normalizedBehaviorIntents =
            normalizeBehaviorIntents(requestedBehaviorIntents)
        if not behaviorOk then
            return false, normalizedBehaviorIntents
        end

        sourceByField['Executable.BehaviorIntents'] = 'prefab_template_fill'
        return true, normalizedBehaviorIntents
    end

    sourceByField['Executable.BehaviorIntents'] = 'prefab'
    return true, normalizeIntentList(BEHAVIOR_PREFABS[prefabId])
end

local function buildEffectIntents(prefabId, brief, sourceByField)
    local requestedEffectIntents = brief.Preferences.EffectIntents
    if requestedEffectIntents ~= nil then
        local effectOk, normalizedEffectIntents = normalizeEffectIntents(requestedEffectIntents)
        if not effectOk then
            return false, normalizedEffectIntents
        end

        sourceByField['Executable.EffectIntents'] = 'prefab_template_fill'
        return true, normalizedEffectIntents
    end

    sourceByField['Executable.EffectIntents'] = 'prefab'
    return true, normalizeIntentList(EFFECT_PREFABS[prefabId])
end

local function buildRecipeHash(recipe)
    local hashInputParts = {
        recipe.Id,
        recipe.Name,
        recipe.Semantics.Atmosphere,
        recipe.Semantics.Lore,
        string.format('%.4f', recipe.Tuning.Speed),
        string.format('%.4f', recipe.Tuning.SightRange),
        string.format('%.4f', recipe.Tuning.PatrolSpeedMultiplier),
        string.format(
            '%.4f,%.4f,%.4f',
            recipe.Tuning.SpawnOffset.X,
            recipe.Tuning.SpawnOffset.Y,
            recipe.Tuning.SpawnOffset.Z
        ),
        tostring(recipe.Executable.Presentation.ModelAssetId),
        tostring(recipe.Executable.Presentation.ChaseLoopSoundAssetId),
        tostring(recipe.Meta.Seed),
    }

    local behaviorIds = {}
    for _, intent in ipairs(recipe.Executable.BehaviorIntents) do
        local suffix = if intent.Enabled == false then ':off' else ':on'
        table.insert(behaviorIds, intent.Id .. suffix)
    end
    table.sort(behaviorIds)
    for _, behaviorId in ipairs(behaviorIds) do
        table.insert(hashInputParts, behaviorId)
    end

    local effectIds = {}
    for _, effectIntent in ipairs(recipe.Executable.EffectIntents) do
        local durationText = if type(effectIntent.DurationSeconds) == 'number'
            then string.format(':%.4f', effectIntent.DurationSeconds)
            else ''
        table.insert(effectIds, effectIntent.Id .. durationText)
    end
    table.sort(effectIds)
    for _, effectId in ipairs(effectIds) do
        table.insert(hashInputParts, effectId)
    end

    local hashInput = table.concat(hashInputParts, '|')

    local hash = 2166136261
    for i = 1, #hashInput do
        hash = bit32.bxor(hash, string.byte(hashInput, i))
        hash = (hash * 16777619) % 4294967296
    end

    return string.format('recipe-%08x', hash)
end

function MonsterUgcPipeline.evaluateBrief(rawBrief)
    local normalizedBrief, missingFields = normalizeBrief(rawBrief)
    if not normalizedBrief then
        return false,
            table.freeze({
                Status = MonsterUgcPipeline.Status.WaitingForUser,
                RejectionCode = MonsterUgcPipeline.RejectionCode.MissingBriefFields,
                MissingFields = table.freeze(missingFields),
                Question = nextClarifyingQuestion(missingFields[1]),
            })
    end

    return true,
        table.freeze({
            Status = MonsterUgcPipeline.Status.ReadyToGenerate,
            Brief = normalizedBrief,
        })
end

function MonsterUgcPipeline.generateForSandbox(rawBrief, options)
    local generationOptions = options or {}

    local briefOk, briefState = MonsterUgcPipeline.evaluateBrief(rawBrief)
    if not briefOk then
        return false, briefState
    end
    local brief = briefState.Brief

    local now = generationOptions.Now or os.time
    local seed = normalizeSeed(generationOptions.Seed)
    local rng = Random.new(seed)
    local mappedPrefabId = ATMOSPHERE_PREFAB_MAP[brief.Semantics.Atmosphere]
    local prefabId = mappedPrefabId or DEFAULT_PREFAB_ID
    local sourceByField = {
        ['Semantics.Lore'] = 'template_fill',
        ['Semantics.Atmosphere'] = 'brief_tag_map',
        ['Semantics.TriggerIntent.Summary'] = 'template_fill',
        ['Semantics.CounterplayIntent.Summary'] = 'template_fill',
    }

    local diagnostics = {
        ClampedFields = {},
        AssetChecks = {},
        Notes = {},
        SkippedBehaviorIds = {},
        SkippedEffectIds = {},
    }

    if mappedPrefabId == nil then
        table.insert(diagnostics.Notes, 'AtmosphereFallbackPrefab')
    end

    local monsterName, nameSource = buildMonsterName(brief, rng)
    sourceByField.Name = nameSource
    sourceByField.Id = 'server_generated'

    local tuning = applyRequestedTuning(
        TUNING_PREFABS[prefabId],
        brief.Preferences.Tuning,
        diagnostics,
        sourceByField
    )

    local modelAssetId = brief.Preferences.ModelAssetId or DEFAULT_ASSET_IDS.ModelAssetId
    local chaseLoopSoundAssetId = brief.Preferences.ChaseLoopSoundAssetId
        or DEFAULT_ASSET_IDS.ChaseLoopSoundAssetId
    sourceByField['Executable.Presentation.ModelAssetId'] = if brief.Preferences.ModelAssetId
            ~= nil
        then 'brief_template_fill'
        else 'prefab_default'
    sourceByField['Executable.Presentation.ChaseLoopSoundAssetId'] = if brief.Preferences.ChaseLoopSoundAssetId
            ~= nil
        then 'brief_template_fill'
        else 'prefab_default'
    sourceByField['Executable.Presentation.RigType'] = 'system_fixed'
    sourceByField['Executable.Presentation.AnimationMode'] = 'system_fixed'

    local assetValidator = generationOptions.AssetValidator or defaultAssetValidator
    local modelAssetOk, modelAssetReason =
        validateAsset(modelAssetId, 'ModelAssetId', assetValidator, diagnostics)
    if not modelAssetOk then
        return false,
            table.freeze({
                Status = MonsterUgcPipeline.Status.Rejected,
                RejectionCode = MonsterUgcPipeline.RejectionCode.AssetValidationFailed,
                Reason = modelAssetReason,
                Diagnostics = deepFreeze(diagnostics),
            })
    end

    local soundAssetOk, soundAssetReason =
        validateAsset(chaseLoopSoundAssetId, 'ChaseLoopSoundAssetId', assetValidator, diagnostics)
    if not soundAssetOk then
        return false,
            table.freeze({
                Status = MonsterUgcPipeline.Status.Rejected,
                RejectionCode = MonsterUgcPipeline.RejectionCode.AssetValidationFailed,
                Reason = soundAssetReason,
                Diagnostics = deepFreeze(diagnostics),
            })
    end

    local behaviorIntentsOk, behaviorIntentsOrReason =
        buildBehaviorIntents(prefabId, brief, sourceByField)
    if not behaviorIntentsOk then
        return false,
            table.freeze({
                Status = MonsterUgcPipeline.Status.Rejected,
                RejectionCode = MonsterUgcPipeline.RejectionCode.UnknownBehaviorIntent,
                Reason = behaviorIntentsOrReason,
                Diagnostics = deepFreeze(diagnostics),
            })
    end
    local behaviorIntents = behaviorIntentsOrReason

    local effectIntentsOk, effectIntentsOrReason =
        buildEffectIntents(prefabId, brief, sourceByField)
    if not effectIntentsOk then
        return false,
            table.freeze({
                Status = MonsterUgcPipeline.Status.Rejected,
                RejectionCode = MonsterUgcPipeline.RejectionCode.InvalidEffectIntent,
                Reason = effectIntentsOrReason,
                Diagnostics = deepFreeze(diagnostics),
            })
    end
    local effectIntents = effectIntentsOrReason

    local layeredConfig = {
        Id = buildMonsterId(generationOptions.PlayerUserId, seed),
        Name = monsterName,
        Semantics = {
            Lore = brief.Semantics.Lore,
            Atmosphere = brief.Semantics.Atmosphere,
            TriggerIntent = {
                Summary = brief.Semantics.TriggerIntentSummary,
                Space = 'UGC sandbox maze rooms',
            },
            CounterplayIntent = {
                Summary = brief.Semantics.CounterplayIntentSummary,
                Tool = 'Player movement and route planning',
            },
        },
        Tuning = {
            Speed = tuning.Speed,
            SightRange = tuning.SightRange,
            PatrolSpeedMultiplier = tuning.PatrolSpeedMultiplier,
            SpawnOffset = tuning.SpawnOffset,
        },
        Executable = {
            Presentation = {
                ModelAssetId = modelAssetId,
                RigType = MonsterPresentationCatalog.RigType.R6,
                AnimationMode = MonsterPresentationCatalog.AnimationMode.DefaultR6,
                ChaseLoopSoundAssetId = chaseLoopSoundAssetId,
            },
            BehaviorIntents = behaviorIntents,
            EffectIntents = effectIntents,
        },
    }

    local compileOk, runtimeProfileOrReason, compileReportOrDiagnostic =
        MonsterCompiler.compileMonsterForMaze(layeredConfig)
    if not compileOk then
        return false,
            table.freeze({
                Status = MonsterUgcPipeline.Status.Rejected,
                RejectionCode = MonsterUgcPipeline.RejectionCode.CompileFailed,
                Reason = runtimeProfileOrReason,
                CompileDiagnostic = compileReportOrDiagnostic,
                Diagnostics = deepFreeze(diagnostics),
            })
    end

    local runtimeProfile = runtimeProfileOrReason
    local compileReport = compileReportOrDiagnostic
    diagnostics.SkippedBehaviorIds = table.clone(compileReport.SkippedBehaviorIds)
    diagnostics.SkippedEffectIds = table.clone(compileReport.SkippedEffectIds)

    local recipe = {
        Id = layeredConfig.Id,
        Name = layeredConfig.Name,
        Semantics = table.clone(layeredConfig.Semantics),
        Tuning = table.clone(layeredConfig.Tuning),
        Executable = table.clone(layeredConfig.Executable),
        Meta = {
            Seed = seed,
            PrefabId = prefabId,
            GeneratedAtEpochSeconds = now(),
            RequestedByUserId = generationOptions.PlayerUserId,
            SourceByField = sourceByField,
        },
    }

    local recipeHash = buildRecipeHash(recipe)

    local generationResult = {
        Status = MonsterUgcPipeline.Status.SandboxReady,
        Seed = seed,
        RecipeHash = recipeHash,
        Brief = brief,
        Recipe = recipe,
        LayeredConfig = layeredConfig,
        RuntimeProfile = runtimeProfile,
        CompileReport = compileReport,
        Diagnostics = diagnostics,
        SandboxPolicy = {
            Mode = 'SandboxOnly',
            AllowSubmitForReview = true,
            PlayerRateLimitKey = 'ugc_monster_generation',
        },
    }

    return true, deepFreeze(generationResult)
end

local function normalizeTelemetry(rawTelemetry)
    local telemetry = rawTelemetry or {}

    local function normalizeNonNegativeNumber(value)
        if type(value) ~= 'number' then
            return 0
        end
        if value < 0 then
            return 0
        end
        return value
    end

    return {
        EncounterCount = normalizeNonNegativeNumber(telemetry.EncounterCount),
        AverageChaseSeconds = normalizeNonNegativeNumber(telemetry.AverageChaseSeconds),
        PlayerReportCount = normalizeNonNegativeNumber(telemetry.PlayerReportCount),
        AverageSurvivalSeconds = normalizeNonNegativeNumber(telemetry.AverageSurvivalSeconds),
    }
end

function MonsterUgcPipeline.buildReviewBundle(generationResult, rawTelemetry, options)
    local bundleOptions = options or {}
    if
        type(generationResult) ~= 'table'
        or generationResult.Status ~= MonsterUgcPipeline.Status.SandboxReady
    then
        return false, MonsterUgcPipeline.RejectionCode.InvalidGenerationResult
    end

    local now = bundleOptions.Now or os.time
    local telemetry = normalizeTelemetry(rawTelemetry)

    local bundle = {
        BundleId = string.format('bundle-%s', generationResult.RecipeHash),
        Status = 'Pending',
        Moderation = {
            Status = 'Pending',
            RejectionCode = nil,
            Reviewer = nil,
        },
        SubmittedAtEpochSeconds = now(),
        SubmittedByUserId = bundleOptions.SubmittedByUserId,
        Brief = generationResult.Brief,
        Recipe = generationResult.Recipe,
        LayeredConfig = generationResult.LayeredConfig,
        RuntimeProfile = generationResult.RuntimeProfile,
        CompileReport = generationResult.CompileReport,
        Diagnostics = generationResult.Diagnostics,
        Seed = generationResult.Seed,
        RecipeHash = generationResult.RecipeHash,
        Telemetry = telemetry,
    }

    return true, deepFreeze(bundle)
end

function MonsterUgcPipeline.isSafeSpawnOffset(offset)
    return isSafeSpawnOffset(offset)
end

function MonsterUgcPipeline.isKnownBehaviorIntent(intentId)
    return MonsterBehaviorCatalog.Known[intentId] == true
end

function MonsterUgcPipeline.isKnownEffectIntent(intentId)
    return MonsterEffectCatalog.Known[intentId] == true
end

function MonsterUgcPipeline.canRunInMazeBehavior(intentId)
    return MonsterBehaviorCatalog.MazeExecutable[intentId] == true
end

function MonsterUgcPipeline.canRunInMazeEffect(intentId)
    return MonsterEffectCatalog.MazeExecutable[intentId] == true
end

return MonsterUgcPipeline
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="33">
            <Properties>
              <string name="Name">MonsterUgcReviewQueue</string>
              <string name="Source"><![CDATA[local MonsterUgcReviewQueue = {}
MonsterUgcReviewQueue.__index = MonsterUgcReviewQueue

MonsterUgcReviewQueue.Status = table.freeze({
    Pending = 'Pending',
    Approved = 'Approved',
    Rejected = 'Rejected',
})

local function freezeSnapshot(entry)
    local snapshot = {
        SubmissionId = entry.SubmissionId,
        Status = entry.Status,
        SubmittedAtEpochSeconds = entry.SubmittedAtEpochSeconds,
        SubmittedByUserId = entry.SubmittedByUserId,
        ReviewedAtEpochSeconds = entry.ReviewedAtEpochSeconds,
        ReviewedBy = entry.ReviewedBy,
        RejectionCode = entry.RejectionCode,
        DecisionReason = entry.DecisionReason,
        Bundle = entry.Bundle,
    }

    return table.freeze(snapshot)
end

function MonsterUgcReviewQueue.new(options)
    local queueOptions = options or {}

    return setmetatable({
        NextId = 1,
        MaxPending = queueOptions.MaxPending or 128,
        Entries = {},
    }, MonsterUgcReviewQueue)
end

function MonsterUgcReviewQueue:_countPending()
    local pending = 0
    for _, entry in pairs(self.Entries) do
        if entry.Status == MonsterUgcReviewQueue.Status.Pending then
            pending += 1
        end
    end

    return pending
end

function MonsterUgcReviewQueue:submit(bundle, options)
    if type(bundle) ~= 'table' then
        return false, 'MalformedReviewBundle'
    end

    if type(bundle.BundleId) ~= 'string' or bundle.BundleId == '' then
        return false, 'MissingBundleId'
    end

    if type(bundle.RecipeHash) ~= 'string' or bundle.RecipeHash == '' then
        return false, 'MissingRecipeHash'
    end

    if self:_countPending() >= self.MaxPending then
        return false, 'ReviewQueueFull'
    end

    local submitOptions = options or {}
    local now = submitOptions.Now or os.time
    local submittedByUserId = submitOptions.SubmittedByUserId
    if submittedByUserId == nil then
        submittedByUserId = bundle.SubmittedByUserId
    end

    local submissionId = string.format('ugc-submission-%04d', self.NextId)
    self.NextId += 1

    local entry = {
        SubmissionId = submissionId,
        Status = MonsterUgcReviewQueue.Status.Pending,
        SubmittedAtEpochSeconds = now(),
        SubmittedByUserId = submittedByUserId,
        ReviewedAtEpochSeconds = nil,
        ReviewedBy = nil,
        RejectionCode = nil,
        DecisionReason = nil,
        Bundle = bundle,
    }

    self.Entries[submissionId] = entry
    return true, freezeSnapshot(entry)
end

function MonsterUgcReviewQueue:getSubmission(submissionId)
    local entry = self.Entries[submissionId]
    if entry == nil then
        return false, 'SubmissionNotFound'
    end

    return true, freezeSnapshot(entry)
end

function MonsterUgcReviewQueue:listPending()
    local pending = {}
    for _, entry in pairs(self.Entries) do
        if entry.Status == MonsterUgcReviewQueue.Status.Pending then
            table.insert(pending, freezeSnapshot(entry))
        end
    end

    table.sort(pending, function(left, right)
        return left.SubmissionId < right.SubmissionId
    end)

    return table.freeze(pending)
end

function MonsterUgcReviewQueue:decide(submissionId, decision, options)
    local entry = self.Entries[submissionId]
    if entry == nil then
        return false, 'SubmissionNotFound'
    end

    if entry.Status ~= MonsterUgcReviewQueue.Status.Pending then
        return false, 'SubmissionAlreadyFinalized'
    end

    if type(decision) ~= 'table' then
        return false, 'MalformedDecision'
    end

    local approve = decision.Approved == true
    local now = (options and options.Now) or os.time
    local reviewer = decision.Reviewer
    if type(reviewer) ~= 'string' or reviewer == '' then
        reviewer = 'ugc-moderator'
    end

    entry.Status = if approve
        then MonsterUgcReviewQueue.Status.Approved
        else MonsterUgcReviewQueue.Status.Rejected
    entry.ReviewedBy = reviewer
    entry.ReviewedAtEpochSeconds = now()
    entry.DecisionReason = decision.Reason
    if not approve then
        entry.RejectionCode = decision.RejectionCode or 'ManualReject'
    end

    return true, freezeSnapshot(entry)
end

return MonsterUgcReviewQueue
]]></string>
            </Properties>
          </Item>
        </Item>
        <Item class="ModuleScript" referent="34">
          <Properties>
            <string name="Name">Player</string>
            <string name="Source"><![CDATA[return {
    PlayerComponentConfig = require(script.PlayerComponentConfig),
    Player = require(script.Player),
    PlayerBlackboard = require(script.PlayerBlackboard),
    PlayerStateMachine = require(script.PlayerStateMachine),
    HealthComponent = require(script.Components.HealthComponent),
    StaminaComponent = require(script.Components.StaminaComponent),
    MovementComponent = require(script.Components.MovementComponent),
    InventoryComponent = require(script.Components.InventoryComponent),
}
]]></string>
