          <Item class="ModuleScript" referent="71">
            <Properties>
              <string name="Name">ControlStateService</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService('ReplicatedStorage')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Gameplay = require(Packages:WaitForChild('Gameplay'))

local ControlState = Gameplay.ControlState

local ControlStateService = {}
ControlStateService.__index = ControlStateService

local function buildDefaultSummary()
    return ControlState.new():getSummary()
end

function ControlStateService.new()
    return setmetatable({
        ByUserId = {},
        DefaultSummary = buildDefaultSummary(),
    }, ControlStateService)
end

function ControlStateService:addPlayer(player)
    local state = ControlState.new()
    self.ByUserId[player.UserId] = state
    return state
end

function ControlStateService:removePlayer(player)
    self.ByUserId[player.UserId] = nil
end

function ControlStateService:get(player)
    return self.ByUserId[player.UserId]
end

function ControlStateService:getSummary(player)
    local state = self:get(player)
    if not state then
        return table.clone(self.DefaultSummary)
    end

    return state:getSummary()
end

function ControlStateService:requestSprintStart(player, playerStateSummary)
    local state = self:get(player)
    if not state then
        return false, 'MissingControlState'
    end

    return state:requestSprintStart(playerStateSummary)
end

function ControlStateService:requestSprintStop(player)
    local state = self:get(player)
    if not state then
        return false, 'MissingControlState'
    end

    return state:requestSprintStop()
end

function ControlStateService:syncPlayerState(player, playerStateSummary)
    local state = self:get(player)
    if not state then
        return false, 'MissingControlState'
    end

    return true, state:syncPlayerState(playerStateSummary)
end

function ControlStateService:reset()
    table.clear(self.ByUserId)
end

return ControlStateService
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="72">
            <Properties>
              <string name="Name">FormalLocomotion</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService('ReplicatedStorage')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Gameplay = require(Packages:WaitForChild('Gameplay'))

local MODE = Gameplay.ControlState.Mode

local FormalLocomotion = {}

FormalLocomotion.Mode = MODE
FormalLocomotion.WalkSpeed = 16
FormalLocomotion.SprintWalkSpeed = 24

function FormalLocomotion.summarize(playerStateSummary, controlStateSummary)
    local playerState = playerStateSummary or {}
    local controlState = controlStateSummary or {}
    local isDead = playerState.IsDead == true
    local canSprint = not isDead and playerState.CanSprint == true

    local mode = MODE.Walk
    if not isDead and controlState.Mode == MODE.Sprint then
        mode = MODE.Sprint
    end

    local walkSpeed = FormalLocomotion.WalkSpeed
    if isDead then
        walkSpeed = 0
    elseif mode == MODE.Sprint then
        walkSpeed = FormalLocomotion.SprintWalkSpeed
    end

    return {
        Mode = mode,
        WalkSpeed = walkSpeed,
        CanSprint = canSprint,
    }
end

function FormalLocomotion.formatStatus(playerStateSummary, movementSummary)
    local playerState = playerStateSummary or {}
    local movement = movementSummary or {}

    if playerState.IsDead then
        return 'Disabled'
    end

    if movement.CanSprint then
        return 'Ready'
    end

    return 'Recovering'
end

function FormalLocomotion.applyToHumanoid(humanoid, movementSummary)
    if not humanoid then
        return
    end

    humanoid.WalkSpeed = (movementSummary and movementSummary.WalkSpeed)
        or FormalLocomotion.WalkSpeed
end

return FormalLocomotion
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="73">
            <Properties>
              <string name="Name">HexMazeWorldRenderer</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService('ReplicatedStorage')
local Workspace = game:GetService('Workspace')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Gameplay = require(Packages:WaitForChild('Gameplay'))

local MazeModuleAssetContract = require(script.Parent.MazeModuleAssetContract)
local MazePassageTemplates = Gameplay.ProcGen.MazePassageTemplates

local bit32_band = bit32.band
local bit32_lshift = bit32.lshift
local bit32_bor = bit32.bor
local math_ceil = math.ceil
local math_floor = math.floor
local math_sqrt = math.sqrt
local math_rad = math.rad
local math_cos = math.cos
local math_sin = math.sin
local math_tan = math.tan
local math_abs = math.abs
local math_pi = math.pi
local math_huge = math.huge

local Vector3_new = Vector3.new
local Vector3_zero = Vector3.zero
local CFrame_new = CFrame.new
local CFrame_lookAt = CFrame.lookAt
local Instance_new = Instance.new

local HexMazeWorldRenderer = {}

local ROOM_CLEAR_HEIGHT = 14
local ROOM_APOTHEM_DEFAULT = 20
local SLAB_THICKNESS = 1
local FLOOR_TILE_SIZE = 4
local WALL_HEIGHT = ROOM_CLEAR_HEIGHT
local WALL_THICKNESS = 2
local DOORWAY_WIDTH = 6
local DOORWAY_HEIGHT = 10
local DOOR_LEAF_THICKNESS = 0.5
local DOOR_CLEARANCE = 0
local ROOM_DETECTION_BUFFER = 18
local EXIT_CORRIDOR_LENGTH = 6
local CONNECTOR_OVERLAP = 1
local TAN_PI_6 = math_tan(math_pi / 6)
local HEX_CIRCUMRADIUS_MULTIPLIER = 1 / math_cos(math_pi / 6)
local SIDE_ANGLE_OFFSET_DEGREES = 0

local SIDE_NORMALS_X = {}
local SIDE_NORMALS_Z = {}
local SIDE_VECTORS_NORMAL = {}
local SIDE_VECTORS_TANGENT = {}

for directionIndex = 1, 6 do
    local angle = math_rad((-(directionIndex - 1) * 60) + SIDE_ANGLE_OFFSET_DEGREES)
    local nx = math_cos(angle)
    local nz = math_sin(angle)
    SIDE_NORMALS_X[directionIndex] = nx
    SIDE_NORMALS_Z[directionIndex] = nz
    SIDE_VECTORS_NORMAL[directionIndex] = Vector3_new(nx, 0, nz)
    SIDE_VECTORS_TANGENT[directionIndex] = Vector3_new(-nz, 0, nx)
end

local TILE_BUFFER_A = FLOOR_TILE_SIZE / 2
local TILE_BUFFER_B = (FLOOR_TILE_SIZE / 2) * (math_cos(math_rad(60)) + math_sin(math_rad(60)))
local SIN_60 = math_sin(math_rad(60))

local DEFAULT_SURFACE_PALETTE = table.freeze({
    WallMaterial = Enum.Material.Concrete,
    WallColor = Color3.fromRGB(116, 114, 110),
    FloorMaterial = Enum.Material.Concrete,
    FloorColor = Color3.fromRGB(98, 96, 92),
    CeilingMaterial = Enum.Material.Concrete,
    CeilingColor = Color3.fromRGB(88, 86, 82),
    DoorMaterial = Enum.Material.Concrete,
    DoorColor = Color3.fromRGB(74, 72, 68),
    ExitFloorMaterial = Enum.Material.Concrete,
    ExitFloorColor = Color3.fromRGB(40, 36, 28),
})

local DEFAULT_ROOM_KIND_COLORS = {
    Camp = Color3.fromRGB(83, 126, 78),
    Loot = Color3.fromRGB(88, 92, 112),
    Extraction = Color3.fromRGB(145, 119, 73),
}

local function resolveSurfacePalette(surfacePalette)
    local resolvedPalette = {}

    for property, defaultValue in pairs(DEFAULT_SURFACE_PALETTE) do
        resolvedPalette[property] = surfacePalette and surfacePalette[property] or defaultValue
    end

    return resolvedPalette
end

local function createPart(config, parent)
    local part = Instance_new('Part')
    part.Name = config.Name
    part.Anchored = true
    part.Size = config.Size
    part.CFrame = config.CFrame
    part.Color = config.Color
    part.Material = config.Material or Enum.Material.SmoothPlastic
    part.Transparency = config.Transparency or 0
    part.CanCollide = config.CanCollide ~= false
    part.Shape = config.Shape or Enum.PartType.Block
    part.Parent = parent
    return part
end

local function createPromptPart(config, parent)
    local part = createPart({
        Name = config.Name,
        Size = config.Size or Vector3_new(4, 4, 4),
        CFrame = config.CFrame,
        Color = config.Color,
        Material = config.Material or Enum.Material.Metal,
        Transparency = config.Transparency or 0,
        CanCollide = config.CanCollide,
        Shape = config.Shape,
    }, parent)

    local prompt = Instance_new('ProximityPrompt')
    prompt.ActionText = config.ActionText
    prompt.ObjectText = config.ObjectText
    prompt.HoldDuration = 0
    prompt.MaxActivationDistance = config.MaxActivationDistance or 10
    prompt.RequiresLineOfSight = false
    prompt.Parent = part

    return part, prompt
end

local function applyArchetypeShellAsset(roomFolder, roomCenter, room, moduleAssetsRoot)
    local shellModel = MazeModuleAssetContract.getRoomArchetypeShellModel(
        moduleAssetsRoot,
        room.AuthoringAssetId or room.ArchetypeId
    )
    if shellModel == nil then
        return
    end

    local clone = shellModel:Clone()
    clone.Name = string.format('AuthoredShell_%s', room.AuthoringAssetId or room.ArchetypeId)
    clone.Parent = roomFolder

    if clone:IsA('Model') then
        clone:PivotTo(CFrame_new(roomCenter))
    elseif clone:IsA('BasePart') then
        clone.CFrame = CFrame_new(roomCenter)
    end
end

local function applyShellModel(cloneParent, cloneName, shellModel, pivotCFrame)
    if shellModel == nil then
        return nil
    end

    local clone = shellModel:Clone()
    clone.Name = cloneName
    clone.Parent = cloneParent

    if clone:IsA('Model') then
        clone:PivotTo(pivotCFrame)
    elseif clone:IsA('BasePart') then
        clone.CFrame = pivotCFrame
    end

    return clone
end

local function createAuthoringSockets(roomFolder, roomCenter)
    local authoringFolder = Instance_new('Folder')
    authoringFolder.Name = 'AuthoringSockets'
    authoringFolder.Parent = roomFolder

    createPart({
        Name = 'ShellModelSocket',
        Size = Vector3_new(2, 2, 2),
        CFrame = CFrame_new(roomCenter + Vector3_new(0, 4, 0)),
        Color = Color3.fromRGB(255, 255, 255),
        Material = Enum.Material.ForceField,
        Transparency = 1,
        CanCollide = false,
    }, authoringFolder)
end

local function createConnectorAuthoringSockets(connectorFolder, connectorPivot)
    local authoringFolder = Instance_new('Folder')
    authoringFolder.Name = 'AuthoringSockets'
    authoringFolder.Parent = connectorFolder

    createPart({
        Name = 'ShellModelSocket',
        Size = Vector3_new(2, 2, 2),
        CFrame = connectorPivot,
        Color = Color3.fromRGB(255, 255, 255),
        Material = Enum.Material.ForceField,
        Transparency = 1,
        CanCollide = false,
    }, authoringFolder)

    return authoringFolder
end

local function buildRoomTemplateDecor(roomFolder, room, roomCenter, roomApothem, surfacePalette)
    local decorFolder = Instance_new('Folder')
    decorFolder.Name = 'RoomTemplateDecor'
    decorFolder.Parent = roomFolder

    local function addDecorPart(name, size, offset, color, material, transparency)
        createPart({
            Name = name,
            Size = size,
            CFrame = CFrame_new(roomCenter + offset),
            Color = color,
            Material = material,
            Transparency = transparency or 0,
            CanCollide = false,
        }, decorFolder)
    end

    if room.RoomTemplateId == 'EntrySafe' then
        addDecorPart(
            'StagingPad',
            Vector3_new(roomApothem * 0.9, 0.4, roomApothem * 0.9),
            Vector3_new(0, 0.25, 0),
            Color3.fromRGB(98, 128, 112),
            Enum.Material.Metal
        )
        addDecorPart(
            'OrientationPylon',
            Vector3_new(2, 9, 2),
            Vector3_new(0, 4.5, roomApothem * 0.22),
            Color3.fromRGB(108, 152, 142),
            Enum.Material.Metal
        )
        return
    end

    if room.RoomTemplateId == 'TransitHall' then
        addDecorPart(
            'TransitBeam',
            Vector3_new(roomApothem * 1.05, 1.2, 3),
            Vector3_new(0, 10, 0),
            Color3.fromRGB(92, 102, 112),
            Enum.Material.Metal
        )
        addDecorPart(
            'TransitStripe',
            Vector3_new(roomApothem * 0.75, 0.15, 2),
            Vector3_new(0, 0.2, 0),
            Color3.fromRGB(124, 138, 150),
            Enum.Material.Neon,
            0.45
        )
        return
    end

    if room.RoomTemplateId == 'SearchCluster' then
        addDecorPart(
            'SearchCrateA',
            Vector3_new(5, 3, 4),
            Vector3_new(-roomApothem * 0.22, 1.5, 0),
            Color3.fromRGB(108, 100, 92),
            Enum.Material.WoodPlanks
        )
        addDecorPart(
            'SearchCrateB',
            Vector3_new(4, 2.2, 3),
            Vector3_new(roomApothem * 0.2, 1.1, roomApothem * 0.1),
            Color3.fromRGB(92, 90, 88),
            Enum.Material.Metal
        )
        return
    end

    if room.RoomTemplateId == 'HighValueRisk' then
        addDecorPart(
            'VaultCore',
            Vector3_new(7, 6, 7),
            Vector3_new(0, 3, 0),
            Color3.fromRGB(138, 118, 86),
            Enum.Material.Metal
        )
        addDecorPart(
            'HazardStrip',
            Vector3_new(roomApothem * 0.8, 0.2, 2),
            Vector3_new(0, 0.15, -roomApothem * 0.18),
            Color3.fromRGB(194, 156, 74),
            Enum.Material.Neon,
            0.3
        )
        return
    end

    if room.RoomTemplateId == 'LandmarkFacility' then
        addDecorPart(
            'LandmarkTower',
            Vector3_new(5, 12, 5),
            Vector3_new(0, 6, 0),
            Color3.fromRGB(82, 116, 136),
            Enum.Material.Metal
        )
        addDecorPart(
            'LandmarkRing',
            Vector3_new(roomApothem * 0.95, 0.2, roomApothem * 0.95),
            Vector3_new(0, 0.2, 0),
            Color3.fromRGB(96, 150, 184),
            Enum.Material.Neon,
            0.45
        )
        return
    end

    if room.RoomTemplateId == 'ExtractionReturn' then
        addDecorPart(
            'ExtractionFrame',
            Vector3_new(roomApothem * 0.95, 0.25, roomApothem * 0.95),
            Vector3_new(0, 0.2, 0),
            Color3.fromRGB(172, 142, 92),
            Enum.Material.Neon,
            0.35
        )
        addDecorPart(
            'ExtractionBeacon',
            Vector3_new(2.5, 10, 2.5),
            Vector3_new(0, 5, 0),
            Color3.fromRGB(184, 154, 98),
            Enum.Material.Metal
        )
        return
    end

    if room.RoomTemplateId == 'BulkheadGate' then
        addDecorPart(
            'BulkheadFrame',
            Vector3_new(roomApothem * 0.92, 7, 2),
            Vector3_new(0, 3.5, 0),
            Color3.fromRGB(126, 104, 88),
            Enum.Material.Metal
        )
        addDecorPart(
            'BulkheadThreshold',
            Vector3_new(roomApothem * 0.9, 0.2, 3),
            Vector3_new(0, 0.2, 0),
            Color3.fromRGB(154, 124, 92),
            Enum.Material.Neon,
            0.45
        )
        return
    end

    if room.RoomTemplateId == 'ShortcutLoop' then
        addDecorPart(
            'ShortcutBrace',
            Vector3_new(roomApothem * 0.8, 1.2, 3),
            Vector3_new(0, 9, 0),
            Color3.fromRGB(88, 118, 136),
            Enum.Material.Metal
        )
        addDecorPart(
            'ShortcutMarker',
            Vector3_new(roomApothem * 0.75, 0.15, 1.5),
            Vector3_new(0, 0.2, 0),
            surfacePalette.ExitFloorColor,
            Enum.Material.Neon,
            0.45
        )
    end
end

local function sideVectors(directionIndex)
    return SIDE_VECTORS_NORMAL[directionIndex], SIDE_VECTORS_TANGENT[directionIndex]
end

local function createHexTiledSlab(parent, name, center, apothem, yOffset, color, material)
    local slabFolder = Instance_new('Folder')
    slabFolder.Name = name
    slabFolder.Parent = parent

    local cx, cy, cz = center.X, center.Y, center.Z
    local tileSizeVector = Vector3_new(FLOOR_TILE_SIZE, SLAB_THICKNESS, FLOOR_TILE_SIZE)

    -- Bolt: Optimized loop bounds to eliminate redundant inner-loop condition checks.
    -- The hex boundary is defined by:
    --   |x| + TILE_BUFFER_A <= apothem
    --   |0.5x +/- SIN_60 * z| + TILE_BUFFER_B <= apothem
    local xLimit = apothem - TILE_BUFFER_A
    local xStart = math_ceil(-xLimit / FLOOR_TILE_SIZE) * FLOOR_TILE_SIZE
    local xEnd = math_floor(xLimit / FLOOR_TILE_SIZE) * FLOOR_TILE_SIZE
    local bPrime = apothem - TILE_BUFFER_B

    for x = xStart, xEnd, FLOOR_TILE_SIZE do
        -- Solve for z: |0.5x +/- SIN_60 * z| <= bPrime
        -- Yields: - (bPrime - 0.5|x|) / SIN_60 <= z <= (bPrime - 0.5|x|) / SIN_60
        local zMax = (bPrime - 0.5 * math_abs(x)) / SIN_60
        local zStart = math_ceil(-zMax / FLOOR_TILE_SIZE) * FLOOR_TILE_SIZE
        local zEnd = math_floor(zMax / FLOOR_TILE_SIZE) * FLOOR_TILE_SIZE

        for z = zStart, zEnd, FLOOR_TILE_SIZE do
            local part = Instance_new('Part')
            part.Name = 'Tile'
            part.Anchored = true
            part.Size = tileSizeVector
            part.CFrame = CFrame_new(cx + x, cy + yOffset, cz + z)
            part.Color = color
            part.Material = material
            part.Parent = slabFolder
        end
    end

    return slabFolder
end

local function createHexSideWall(
    parent,
    center,
    directionIndex,
    apothem,
    sideLength,
    hasDoorway,
    surfacePalette
)
    local normal, tangent = sideVectors(directionIndex)
    local wallCenter = center + normal * apothem + Vector3_new(0, WALL_HEIGHT / 2, 0)
    local wallForward = CFrame_lookAt(wallCenter, wallCenter + normal)

    if not hasDoorway then
        createPart({
            Name = string.format('Wall_%d', directionIndex),
            Size = Vector3_new(sideLength, WALL_HEIGHT, WALL_THICKNESS),
            CFrame = wallForward,
            Color = surfacePalette.WallColor,
            Material = surfacePalette.WallMaterial,
        }, parent)
        return
    end

    local segmentLength = (sideLength - DOORWAY_WIDTH) / 2
    local segmentOffset = (DOORWAY_WIDTH / 2) + (segmentLength / 2)

    for _, sign in ipairs({ -1, 1 }) do
        createPart({
            Name = string.format('Wall_%d_Segment', directionIndex),
            Size = Vector3_new(segmentLength, WALL_HEIGHT, WALL_THICKNESS),
            CFrame = wallForward + (tangent * (segmentOffset * sign)),
            Color = surfacePalette.WallColor,
            Material = surfacePalette.WallMaterial,
        }, parent)
    end

    local lintelHeight = WALL_HEIGHT - DOORWAY_HEIGHT
    if lintelHeight > 0 then
        createPart({
            Name = string.format('Wall_%d_Lintel', directionIndex),
            Size = Vector3_new(DOORWAY_WIDTH, lintelHeight, WALL_THICKNESS),
            CFrame = wallForward + Vector3_new(0, DOORWAY_HEIGHT + (lintelHeight / 2), 0),
            Color = surfacePalette.WallColor,
            Material = surfacePalette.WallMaterial,
        }, parent)
    end
end

local function applyDoorState(doorway, isOpen)
    doorway.IsOpen = isOpen
    if not doorway.HasDoorLeaves then
        return
    end

    doorway.Prompt.ActionText = isOpen and 'Close' or 'Open'
    doorway.LeftLeaf.CFrame = isOpen and doorway.OpenLeftCFrame or doorway.ClosedLeftCFrame
    doorway.RightLeaf.CFrame = isOpen and doorway.OpenRightCFrame or doorway.ClosedRightCFrame
    doorway.LeftLeaf.CanCollide = not isOpen
    doorway.RightLeaf.CanCollide = not isOpen
end

local function createDoorwayInstance(
    parent,
    doorwayId,
    center,
    directionIndex,
    apothem,
    hasDoorLeaves,
    surfacePalette
)
    local normal, tangent = sideVectors(directionIndex)
    local openingCenter = center + normal * (apothem - WALL_THICKNESS * 0.5)
    local doorway = {
        Id = doorwayId,
        HasDoorLeaves = hasDoorLeaves == true,
        IsOpen = hasDoorLeaves ~= true,
        Prompt = nil,
    }

    if not doorway.HasDoorLeaves then
        return doorway
    end

    local leafWidth = (DOORWAY_WIDTH - (DOOR_CLEARANCE * 3)) / 2
    local closedLeftCenter = openingCenter
        - tangent * ((leafWidth / 2) + (DOOR_CLEARANCE / 2))
        + Vector3_new(0, DOORWAY_HEIGHT / 2, 0)
    local closedRightCenter = openingCenter
        + tangent * ((leafWidth / 2) + (DOOR_CLEARANCE / 2))
        + Vector3_new(0, DOORWAY_HEIGHT / 2, 0)

    local openOffset = (DOORWAY_WIDTH / 2) + (leafWidth / 2) + DOOR_CLEARANCE
    local openLeftCenter = openingCenter
        - tangent * openOffset
        + Vector3_new(0, DOORWAY_HEIGHT / 2, 0)
    local openRightCenter = openingCenter
        + tangent * openOffset
        + Vector3_new(0, DOORWAY_HEIGHT / 2, 0)

    local leafOrientation = CFrame_lookAt(Vector3_zero, normal)
    doorway.ClosedLeftCFrame = CFrame_new(closedLeftCenter) * leafOrientation
    doorway.ClosedRightCFrame = CFrame_new(closedRightCenter) * leafOrientation
    doorway.OpenLeftCFrame = CFrame_new(openLeftCenter) * leafOrientation
    doorway.OpenRightCFrame = CFrame_new(openRightCenter) * leafOrientation

    doorway.LeftLeaf = createPart({
        Name = string.format('Door_%s_Left', doorwayId),
        Size = Vector3_new(leafWidth, DOORWAY_HEIGHT, DOOR_LEAF_THICKNESS),
        CFrame = doorway.ClosedLeftCFrame,
        Color = surfacePalette.DoorColor,
        Material = surfacePalette.DoorMaterial,
    }, parent)

    doorway.RightLeaf = createPart({
        Name = string.format('Door_%s_Right', doorwayId),
        Size = Vector3_new(leafWidth, DOORWAY_HEIGHT, DOOR_LEAF_THICKNESS),
        CFrame = doorway.ClosedRightCFrame,
        Color = surfacePalette.DoorColor,
        Material = surfacePalette.DoorMaterial,
    }, parent)

    local _, prompt = createPromptPart({
        Name = string.format('DoorPrompt_%s', doorwayId),
        Size = Vector3_new(2, 2, 2),
        CFrame = CFrame_new(openingCenter + Vector3_new(0, 2, 0)),
        Color = Color3.fromRGB(118, 136, 150),
        Material = Enum.Material.Metal,
        Transparency = 1,
        CanCollide = false,
        ActionText = 'Open',
        ObjectText = 'Double Door',
        MaxActivationDistance = 12,
    }, parent)
    doorway.Prompt = prompt

    applyDoorState(doorway, false)
    return doorway
end

local function buildRoom(parent, room, roomCenter, roomApothem, options)
    local roomFolder = Instance_new('Folder')
    roomFolder.Name = room.Id
    roomFolder.Parent = parent

    createHexTiledSlab(
        roomFolder,
        'FloorTiles',
        roomCenter,
        roomApothem,
        -(SLAB_THICKNESS / 2),
        options.SurfacePalette.FloorColor,
        options.SurfacePalette.FloorMaterial
    )
    createHexTiledSlab(
        roomFolder,
        'CeilingTiles',
        roomCenter,
        roomApothem,
        ROOM_CLEAR_HEIGHT + (SLAB_THICKNESS / 2),
        options.SurfacePalette.CeilingColor,
        options.SurfacePalette.CeilingMaterial
    )

    if options.IncludeRoomMarker then
        local floorDiameter = roomApothem * HEX_CIRCUMRADIUS_MULTIPLIER * 2
        local roomKindColors = options.RoomKindColors or DEFAULT_ROOM_KIND_COLORS
        createPart({
            Name = 'RoomMarker',
            Size = Vector3_new(floorDiameter - 6, 0.3, floorDiameter - 6),
            CFrame = CFrame_new(roomCenter + Vector3_new(0, 0.15, 0)),
            Color = roomKindColors[room.Kind] or Color3.fromRGB(112, 112, 112),
            Material = Enum.Material.SmoothPlastic,
            Transparency = options.RoomMarkerTransparency or 0.6,
            CanCollide = false,
        }, roomFolder)
    end

    local doorwayDirections = {}
    for directionIndex in pairs(room.Neighbors) do
        doorwayDirections[directionIndex] = true
    end

    local sideLength = 2 * roomApothem * TAN_PI_6
    for directionIndex = 1, 6 do
        createHexSideWall(
            roomFolder,
            roomCenter,
            directionIndex,
            roomApothem,
            sideLength,
            doorwayDirections[directionIndex] == true,
            options.SurfacePalette
        )
    end

    createAuthoringSockets(roomFolder, roomCenter)

    buildRoomTemplateDecor(roomFolder, room, roomCenter, roomApothem, options.SurfacePalette)

    applyArchetypeShellAsset(roomFolder, roomCenter, room, options.ModuleAssetsRoot)

    return roomFolder
end

local function resolvePassageDefinition(archetypeId)
    return MazePassageTemplates.getDefinition(archetypeId)
        or MazePassageTemplates.getDefinition('IndustrialHall')
end

local function buildPassageMock(
    passageFolder,
    namePrefix,
    corridorForward,
    passageLength,
    passageArchetypeId,
    surfacePalette,
    floorColor,
    floorMaterial
)
    local passageDefinition = resolvePassageDefinition(passageArchetypeId)
    local passageWidth = passageDefinition.Width or DOORWAY_WIDTH
    local passageHeight = passageDefinition.Height or ROOM_CLEAR_HEIGHT
    local wallThickness = WALL_THICKNESS * (passageDefinition.WallThicknessMultiplier or 1)

    createPart({
        Name = string.format('%sFloor', namePrefix),
        Size = Vector3_new(passageWidth, SLAB_THICKNESS, passageLength),
        CFrame = corridorForward,
        Color = floorColor or surfacePalette.FloorColor,
        Material = floorMaterial or surfacePalette.FloorMaterial,
    }, passageFolder)

    createPart({
        Name = string.format('%sCeiling', namePrefix),
        Size = Vector3_new(passageWidth, SLAB_THICKNESS, passageLength),
        CFrame = corridorForward + Vector3_new(0, passageHeight + SLAB_THICKNESS, 0),
        Color = surfacePalette.CeilingColor,
        Material = surfacePalette.CeilingMaterial,
    }, passageFolder)

    local normal = corridorForward.LookVector
    local tangent = Vector3_new(-normal.Z, 0, normal.X)

    for _, sign in ipairs({ -1, 1 }) do
        createPart({
            Name = string.format('%sWall', namePrefix),
            Size = Vector3_new(wallThickness, passageHeight, passageLength),
            CFrame = corridorForward
                + (tangent * ((passageWidth / 2) + (wallThickness / 2)) * sign)
                + Vector3_new(0, (passageHeight + SLAB_THICKNESS) / 2, 0),
            Color = surfacePalette.WallColor,
            Material = surfacePalette.WallMaterial,
        }, passageFolder)
    end

    createPart({
        Name = string.format('%sAccent', namePrefix),
        Size = Vector3_new(passageWidth * 0.85, 0.12, 1.5),
        CFrame = corridorForward + Vector3_new(0, (SLAB_THICKNESS / 2) + 0.06, 0),
        Color = passageDefinition.AccentColor,
        Material = Enum.Material.Neon,
        Transparency = 0.5,
        CanCollide = false,
    }, passageFolder)
end

local function buildPassageInstance(
    parent,
    folderName,
    namePrefix,
    pivotName,
    passageCenter,
    corridorForward,
    passageLength,
    passageArchetypeId,
    surfacePalette,
    moduleAssetsRoot,
    floorColor,
    floorMaterial
)
    local passageDefinition = resolvePassageDefinition(passageArchetypeId)
    local passagePivot = CFrame_new(
        passageCenter + Vector3_new(0, (passageDefinition.Height or ROOM_CLEAR_HEIGHT) / 2, 0)
    ) * CFrame_lookAt(Vector3_zero, corridorForward.LookVector)

    local passageFolder = Instance_new('Folder')
    passageFolder.Name = folderName
    passageFolder.Parent = parent

    local authoringSockets = createConnectorAuthoringSockets(passageFolder, passagePivot)
    local authoredShell = applyShellModel(
        passageFolder,
        string.format('AuthoredPassageShell_%s', passageArchetypeId),
        MazeModuleAssetContract.getConnectorShellModel(moduleAssetsRoot, passageArchetypeId),
        passagePivot
    )

    if authoredShell == nil then
        buildPassageMock(
            passageFolder,
            namePrefix,
            corridorForward,
            passageLength,
            passageArchetypeId,
            surfacePalette,
            floorColor,
            floorMaterial
        )
    end

    return {
        Id = pivotName,
        ArchetypeId = passageArchetypeId,
        Root = passageFolder,
        Shell = authoredShell,
        AuthoringSockets = authoringSockets,
        Length = passageLength,
    }
end

local function buildRoomConnector(
    parent,
    doorwayId,
    roomCenterA,
    roomCenterB,
    directionFromA,
    roomApothem,
    passageArchetypeId,
    surfacePalette,
    moduleAssetsRoot
)
    local normal = sideVectors(directionFromA)
    local centerDistance = (roomCenterB - roomCenterA).Magnitude
    local connectorLength = math.max(
        WALL_THICKNESS,
        centerDistance - (roomApothem * 2) + (WALL_THICKNESS + CONNECTOR_OVERLAP)
    )
    local connectorCenter = (roomCenterA + roomCenterB) * 0.5
    local floorCenter = connectorCenter + Vector3_new(0, -(SLAB_THICKNESS / 2), 0)
    local corridorForward = CFrame_lookAt(floorCenter, floorCenter + normal)

    return buildPassageInstance(
        parent,
        string.format('Connector_%s', doorwayId),
        string.format('Connector_%s_', doorwayId),
        doorwayId,
        connectorCenter,
        corridorForward,
        connectorLength,
        passageArchetypeId,
        surfacePalette,
        moduleAssetsRoot
    )
end

local function buildExitPassages(
    parent,
    room,
    roomCenter,
    roomApothem,
    roomExternalDoorways,
    surfacePalette,
    moduleAssetsRoot
)
    local exitPassages = {}

    for _, externalDoorway in ipairs(roomExternalDoorways or {}) do
        local directionIndex = externalDoorway.Direction
        local normal = sideVectors(directionIndex)
        local passageLength = EXIT_CORRIDOR_LENGTH + WALL_THICKNESS + CONNECTOR_OVERLAP
        local floorCenter = roomCenter
            + (normal * (roomApothem + (EXIT_CORRIDOR_LENGTH / 2)))
            + Vector3_new(0, -(SLAB_THICKNESS / 2), 0)
        local passageCenter = floorCenter + Vector3_new(0, SLAB_THICKNESS / 2, 0)
        local corridorForward = CFrame_lookAt(floorCenter, floorCenter + normal)
        local passageId = string.format('%s_%d', room.Id, directionIndex)

        exitPassages[passageId] = buildPassageInstance(
            parent,
            string.format('ExitPassage_%s', passageId),
            string.format('ExitPassage_%s_', passageId),
            passageId,
            passageCenter,
            corridorForward,
            passageLength,
            externalDoorway.PassageArchetypeId,
            surfacePalette,
            moduleAssetsRoot,
            surfacePalette.ExitFloorColor,
            surfacePalette.ExitFloorMaterial
        )
    end

    return exitPassages
end

function HexMazeWorldRenderer.build(params)
    local worldName = params.WorldName or 'GeneratedMazeWorld'
    local layout = params.Layout
    local originOffset = params.OriginOffset or Vector3_zero
    local roomApothem = math.max(8, params.RoomApothem or ROOM_APOTHEM_DEFAULT)
    local includeRoomMarker = params.IncludeRoomMarker ~= false
    local parent = params.Parent or Workspace
    local detectionBuffer = params.DetectionBuffer or ROOM_DETECTION_BUFFER
    local surfacePalette = resolveSurfacePalette(params.SurfacePalette)

    local existing = parent:FindFirstChild(worldName)
    if existing then
        existing:Destroy()
    end

    local worldFolder = Instance_new('Folder')
    worldFolder.Name = worldName
    worldFolder.Parent = parent

    local cellSize = roomApothem * 2
    local spatialHash = {}

    local roomCenters = {}
    local roomById = {}
    local roomIds = {}
    local roomFolders = {}
    local connectors = {}
    local exitPassages = {}
    local doorways = {}
    local doorwayByRoomIds = {}
    local externalDoorwaysByRoomId = {}

    for _, externalDoorway in ipairs(layout.ExternalDoorways or {}) do
        externalDoorwaysByRoomId[externalDoorway.RoomId] = externalDoorwaysByRoomId[externalDoorway.RoomId]
            or {}
        table.insert(externalDoorwaysByRoomId[externalDoorway.RoomId], externalDoorway)
    end

    for roomId in pairs(layout.Rooms) do
        table.insert(roomIds, roomId)
    end
    table.sort(roomIds)

    for _, roomId in ipairs(roomIds) do
        local room = layout.Rooms[roomId]
        local roomCenter = room.Position + originOffset
        roomCenters[roomId] = roomCenter
        roomById[roomId] = room

        local cq = math_floor(roomCenter.X / cellSize)
        local cr = math_floor(roomCenter.Z / cellSize)
        local key = bit32_bor(bit32_lshift(bit32_band(cq, 0xFFFF), 16), bit32_band(cr, 0xFFFF))

        if not spatialHash[key] then
            spatialHash[key] = {}
        end
        table.insert(spatialHash[key], roomId)

        roomFolders[roomId] = buildRoom(worldFolder, room, roomCenter, roomApothem, {
            IncludeRoomMarker = includeRoomMarker,
            RoomMarkerTransparency = params.RoomMarkerTransparency,
            RoomKindColors = params.RoomKindColors,
            ModuleAssetsRoot = params.ModuleAssetsRoot,
            SurfacePalette = surfacePalette,
        })
        for exitPassageId, exitPassage in
            pairs(
                buildExitPassages(
                    worldFolder,
                    room,
                    roomCenter,
                    roomApothem,
                    externalDoorwaysByRoomId[roomId],
                    surfacePalette,
                    params.ModuleAssetsRoot
                )
            )
        do
            exitPassages[exitPassageId] = exitPassage
        end
    end

    for doorwayId, doorwayLayout in pairs(layout.Doorways) do
        local roomCenter = roomCenters[doorwayLayout.RoomA]
        local otherRoomCenter = roomCenters[doorwayLayout.RoomB]
        if not roomCenter then
            continue
        end

        if otherRoomCenter then
            connectors[doorwayId] = buildRoomConnector(
                worldFolder,
                doorwayId,
                roomCenter,
                otherRoomCenter,
                doorwayLayout.DirectionFromA,
                roomApothem,
                doorwayLayout.PassageArchetypeId,
                surfacePalette,
                params.ModuleAssetsRoot
            )
        end

        local doorway = createDoorwayInstance(
            worldFolder,
            doorwayId,
            roomCenter,
            doorwayLayout.DirectionFromA,
            roomApothem,
            doorwayLayout.HasDoorLeaves,
            surfacePalette
        )
        doorway.RoomA = doorwayLayout.RoomA
        doorway.RoomB = doorwayLayout.RoomB
        doorway.DirectionFromA = doorwayLayout.DirectionFromA
        doorway.DirectionFromB = doorwayLayout.DirectionFromB
        doorways[doorwayId] = doorway

        local roomAId = doorwayLayout.RoomA
        local roomBId = doorwayLayout.RoomB

        if not doorwayByRoomIds[roomAId] then
            doorwayByRoomIds[roomAId] = {}
        end
        if not doorwayByRoomIds[roomBId] then
            doorwayByRoomIds[roomBId] = {}
        end
        doorwayByRoomIds[roomAId][roomBId] = doorway
        doorwayByRoomIds[roomBId][roomAId] = doorway
    end

    local detectionRadius = roomApothem + detectionBuffer
    local detectionRadiusSq = detectionRadius * detectionRadius
    local searchRadiusCells = math_ceil(detectionRadius / cellSize)
    if searchRadiusCells < 1 then
        searchRadiusCells = 1
    end

    local function findRoomByPosition(position)
        local nearestRoom = nil
        local nearestDistanceSq = math_huge

        local px, pz = position.X, position.Z
        local pq = math_floor(px / cellSize)
        local pr = math_floor(pz / cellSize)

        for dq = -searchRadiusCells, searchRadiusCells do
            -- Bolt: Hoist the bit-shifted component out of the inner dr loop
            local qPart = bit32_lshift(bit32_band(pq + dq, 0xFFFF), 16)

            for dr = -searchRadiusCells, searchRadiusCells do
                local key = bit32_bor(qPart, bit32_band(pr + dr, 0xFFFF))
                local cell = spatialHash[key]
                if cell then
                    for _, roomId in ipairs(cell) do
                        local roomCenter = roomCenters[roomId]
                        local dx = roomCenter.X - px
                        local dz = roomCenter.Z - pz
                        local distSq = dx * dx + dz * dz
                        if distSq < nearestDistanceSq then
                            nearestDistanceSq = distSq
                            nearestRoom = roomById[roomId]
                        end
                    end
                end
            end
        end

        if nearestDistanceSq <= detectionRadiusSq then
            return nearestRoom, math_sqrt(nearestDistanceSq)
        end

        return nil, math_sqrt(nearestDistanceSq)
    end

    local function canTraverseBetweenPositions(fromPosition, toPosition)
        local fromRoom = findRoomByPosition(fromPosition)
        local toRoom = findRoomByPosition(toPosition)

        if not fromRoom or not toRoom then
            return true
        end

        local fromRoomId = fromRoom.Id
        local toRoomId = toRoom.Id

        if fromRoomId == toRoomId then
            return true
        end

        -- Bolt: Replaced string-based edgeKey with O(1) nested table lookup
        local doorway = doorwayByRoomIds[fromRoom.Id] and doorwayByRoomIds[fromRoom.Id][toRoom.Id]
        if not doorway then
            return false
        end
        if doorway.HasDoorLeaves and not doorway.IsOpen then
            return false
        end

        return true
    end

    local function toggleDoor(doorwayId)
        local doorway = doorways[doorwayId]
        if not doorway or not doorway.HasDoorLeaves then
            return false
        end

        applyDoorState(doorway, not doorway.IsOpen)
        return true
    end

    return {
        Root = worldFolder,
        Layout = layout,
        RoomCenters = roomCenters,
        RoomById = roomById,
        RoomIds = roomIds,
        RoomFolders = roomFolders,
        Connectors = connectors,
        ExitPassages = exitPassages,
        Doorways = doorways,
        ToggleDoor = toggleDoor,
        FindRoomByPosition = findRoomByPosition,
        CanTraverseBetweenPositions = canTraverseBetweenPositions,
    }
end

return HexMazeWorldRenderer
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="74">
            <Properties>
              <string name="Name">InventoryService</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService('ReplicatedStorage')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Gameplay = require(Packages:WaitForChild('Gameplay'))

local Inventory = Gameplay.Inventory

local InventoryService = {}
InventoryService.__index = InventoryService

function InventoryService.new(capacity)
    return setmetatable({
        Capacity = capacity,
        ByUserId = {},
    }, InventoryService)
end

function InventoryService:addPlayer(player)
    self.ByUserId[player.UserId] = Inventory.new(self.Capacity)
end

function InventoryService:removePlayer(player)
    self.ByUserId[player.UserId] = nil
end

function InventoryService:get(player)
    return self.ByUserId[player.UserId]
end

function InventoryService:pickup(player, itemDef)
    local inventory = self:get(player)
    if not inventory then
        return false, 'MissingInventory'
    end

    return inventory:add(itemDef)
end

function InventoryService:equip(player, itemInstanceId)
    local inventory = self:get(player)
    if not inventory then
        return false, 'MissingInventory'
    end

    return inventory:equip(itemInstanceId)
end

function InventoryService:unequip(player)
    local inventory = self:get(player)
    if not inventory then
        return false, 'MissingInventory'
    end

    return inventory:unequip()
end

function InventoryService:consumeHeldItemState(player, nowSeconds)
    local inventory = self:get(player)
    if not inventory then
        return false, 'MissingInventory'
    end

    return inventory:consumeHeldItemState(nowSeconds)
end

function InventoryService:deposit(player)
    local inventory = self:get(player)
    if not inventory then
        return 0
    end

    local totalValue = inventory:getTotalValue()
    inventory:clear()
    return totalValue
end

function InventoryService:loadSummary(player, summary)
    local inventory = self:get(player)
    if not inventory then
        return false, 'MissingInventory'
    end

    return inventory:loadSummary(summary)
end

function InventoryService:getSummary(player)
    local inventory = self:get(player)
    if not inventory then
        return {
            Capacity = self.Capacity,
            Weight = 0,
            Count = 0,
            BackpackCount = 0,
            HeldCount = 0,
            Value = 0,
            BackpackItems = {},
            HeldItem = nil,
        }
    end

    return inventory:getSummary()
end

function InventoryService:countByItemId(player, itemId)
    local inventory = self:get(player)
    if not inventory then
        return 0
    end

    return inventory:countById(itemId)
end

function InventoryService:consumeByItemId(player, itemId)
    local inventory = self:get(player)
    if not inventory then
        return false, 'MissingInventory'
    end

    return inventory:consumeById(itemId)
end

function InventoryService:sell(player, itemId)
    local inventory = self:get(player)
    if not inventory then
        return false, 'MissingInventory'
    end

    return inventory:sell(itemId)
end

return InventoryService
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="75">
            <Properties>
              <string name="Name">MazeDebugWorldComposer</string>
              <string name="Source"><![CDATA[local MazeWorldShellBuilder = require(script.Parent.MazeWorldShellBuilder)
local MazeInteractionPartFactory = require(script.Parent.MazeInteractionPartFactory)

local MazeDebugWorldComposer = {}

function MazeDebugWorldComposer.build(seed, config, options)
    local resolvedOptions = options or {}
    local shell = MazeWorldShellBuilder.build(seed, config, {
        WorldName = resolvedOptions.WorldName or 'LocalDebugMazeWorld',
        Parent = resolvedOptions.Parent,
        OriginOffset = resolvedOptions.OriginOffset or Vector3.zero,
        IncludeRoomMarkers = resolvedOptions.IncludeRoomMarkers ~= false,
        RoomMarkerTransparency = resolvedOptions.RoomMarkerTransparency or 0.55,
        RoomKindColors = resolvedOptions.RoomKindColors,
        DetectionBuffer = resolvedOptions.DetectionBuffer,
    })

    local _, returnPrompt = MazeInteractionPartFactory.createPromptPart({
        Name = 'ReturnToCampMarker',
        CFrame = CFrame.new(shell.CampCenter + Vector3.new(6, 0.5, 0)),
        Color = Color3.fromRGB(77, 147, 196),
        ActionText = 'Return',
        ObjectText = resolvedOptions.ReturnObjectText or 'Return To Camp (Local Debug)',
        MaxActivationDistance = resolvedOptions.ReturnMaxActivationDistance or 14,
        CanCollide = false,
    }, shell.Root)

    shell.ReturnPrompt = returnPrompt

    return shell
end

return MazeDebugWorldComposer
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="76">
            <Properties>
              <string name="Name">MazeFormalWorldComposer</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService('ReplicatedStorage')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Gameplay = require(Packages:WaitForChild('Gameplay'))

local Items = Gameplay.Config.Items
local MazeMonsterSpawnPolicy = Gameplay.Monsters.MazeMonsterSpawnPolicy
local MazeInteractionPartFactory = require(script.Parent.MazeInteractionPartFactory)
local MazeModuleAssetContract = require(script.Parent.MazeModuleAssetContract)
local MazeWorldShellBuilder = require(script.Parent.MazeWorldShellBuilder)

local MazeFormalWorldComposer = {}
local LOOT_SOCKET_HEIGHT = 1.5

local function validateModuleAssetsIfConfigured(options)
    if options == nil then
        return nil
    end

    if options.ModuleAssetsRoot ~= nil then
        return MazeModuleAssetContract.validateRoot(options.ModuleAssetsRoot)
    end

    if options.RequireModuleAssets == true then
        error(
            'Formal maze world requested Studio module assets, but no asset root was supplied.',
            0
        )
    end

    return nil
end

local function buildThreatTags(roomKind)
    return {
        string.format('RoomKind:%s', roomKind),
    }
end

local function cloneSortedNumbers(values)
    local cloned = table.clone(values or {})
    table.sort(cloned)
    return cloned
end

local function buildSortedNeighborRoomIds(room)
    local neighborRoomIds = {}
    for _, neighborRoomId in pairs(room.Neighbors or {}) do
        table.insert(neighborRoomIds, neighborRoomId)
    end
    table.sort(neighborRoomIds)
    return neighborRoomIds
end

local function buildRoomAffordance(shell, roomId)
    local room = shell.RoomById[roomId]
    local roomCenter = shell.RoomCenters[roomId]

    local affordance = {
        RoomId = roomId,
        RoomKind = room.Kind,
        RoomCategory = room.RoomCategory,
        RoomTemplateId = room.RoomTemplateId,
        RoomCenter = roomCenter,
        SearchProfile = room.SearchProfile,
        RiskTier = room.RiskTier,
        LandmarkWeight = room.LandmarkWeight,
        SpawnSockets = {
            {
                Id = string.format('%s_Spawn_1', roomId),
                Kind = 'RoomCenter',
                Position = roomCenter + Vector3.new(0, LOOT_SOCKET_HEIGHT, 0),
            },
        },
        PatrolAnchors = {},
        SightBreakers = {},
        DoorControlPoints = {},
        ThreatTags = buildThreatTags(room.Kind),
        TraversalMask = {
            NeighborRoomIds = buildSortedNeighborRoomIds(room),
            DoorwayIds = {},
            ExitDirections = cloneSortedNumbers(room.ExitDirections),
        },
    }

    if room.Kind == 'Loot' then
        table.insert(affordance.PatrolAnchors, roomCenter)
    end

    return affordance
end

local function pickItemDefForRoom(items, itemIndex, room)
    if room.RoomTemplateId == 'HighValueRisk' then
        return items[#items], itemIndex
    end

    if room.RoomTemplateId == 'LandmarkFacility' then
        return items[math.min(2, #items)], itemIndex
    end

    if room.RoomTemplateId == 'TransitHall' or room.RoomTemplateId == 'BulkheadGate' then
        return items[1], itemIndex
    end

    local itemDef = items[itemIndex]
    local nextItemIndex = (itemIndex % #items) + 1
    return itemDef, nextItemIndex
end

local function appendDoorwayAffordances(roomAffordances, doorwayId, doorway)
    local roomIds = {
        doorway.RoomA,
        doorway.RoomB,
    }
    local neighborRoomIds = {
        [doorway.RoomA] = doorway.RoomB,
        [doorway.RoomB] = doorway.RoomA,
    }

    for _, roomId in ipairs(roomIds) do
        local affordance = roomAffordances[roomId]
        if affordance then
            table.insert(affordance.TraversalMask.DoorwayIds, doorwayId)

            if doorway.Prompt then
                table.insert(affordance.DoorControlPoints, {
                    DoorwayId = doorwayId,
                    NeighborRoomId = neighborRoomIds[roomId],
                    Position = doorway.Prompt.Parent.Position,
                })
            end
        end
    end
end

local function finalizeAffordances(roomAffordances)
    for _, affordance in pairs(roomAffordances) do
        table.sort(affordance.TraversalMask.DoorwayIds)
        table.sort(affordance.DoorControlPoints, function(left, right)
            return left.DoorwayId < right.DoorwayId
        end)
    end
end

local function collectPatrolPointsFromAffordances(roomIds, roomAffordances)
    local patrolPoints = {}

    for _, roomId in ipairs(roomIds) do
        local affordance = roomAffordances[roomId]
        if affordance then
            for _, patrolAnchor in ipairs(affordance.PatrolAnchors) do
                table.insert(patrolPoints, patrolAnchor)
            end
        end
    end

    return patrolPoints
end

function MazeFormalWorldComposer.build(seed, config, options)
    local resolvedOptions = options or {}
    validateModuleAssetsIfConfigured(resolvedOptions)

    local shell = MazeWorldShellBuilder.build(seed, config, {
        WorldName = resolvedOptions.WorldName or 'GeneratedMazeWorld',
        Parent = resolvedOptions.Parent,
        OriginOffset = resolvedOptions.OriginOffset or Vector3.zero,
        SurfacePalette = resolvedOptions.SurfacePalette,
        ModuleAssetsRoot = resolvedOptions.ModuleAssetsRoot,
        IncludeRoomMarkers = resolvedOptions.IncludeRoomMarkers ~= false,
        RoomMarkerTransparency = resolvedOptions.RoomMarkerTransparency or 0.5,
        RoomKindColors = resolvedOptions.RoomKindColors,
        DetectionBuffer = resolvedOptions.DetectionBuffer,
    })

    local roomAffordances = {}
    local lootNodes = {}
    local itemIndex = 1

    for _, roomId in ipairs(shell.RoomIds) do
        local affordance = buildRoomAffordance(shell, roomId)
        local room = shell.RoomById[roomId]
        local lootPosition = affordance.SpawnSockets[1].Position
        roomAffordances[roomId] = affordance

        if room.Kind == 'Loot' then
            local itemDef
            itemDef, itemIndex = pickItemDefForRoom(Items, itemIndex, room)

            local _, prompt = MazeInteractionPartFactory.createPromptPart({
                Name = string.format('Loot_%s', roomId),
                Size = Vector3.new(3, 3, 3),
                CFrame = CFrame.new(lootPosition),
                Color = itemDef.Color,
                Material = Enum.Material.Neon,
                ActionText = 'Collect',
                ObjectText = itemDef.Name,
                CanCollide = false,
            }, shell.Root)

            lootNodes[roomId] = {
                ItemDef = itemDef,
                RoomTemplateId = room.RoomTemplateId,
                SearchProfile = room.SearchProfile,
                Prompt = prompt,
                Position = lootPosition,
                Collected = false,
            }
        end
    end

    local returnHoldPadPosition = shell.CampCenter + Vector3.new(0, 0.5, -10)
    local _, returnHoldPrompt = MazeInteractionPartFactory.createPromptPart({
        Name = 'ReturnHoldPad',
        Size = Vector3.new(8, 1, 8),
        CFrame = CFrame.new(returnHoldPadPosition),
        Color = Color3.fromRGB(77, 147, 196),
        Material = Enum.Material.Neon,
        ActionText = 'Return',
        ObjectText = 'Run Entrance',
        Transparency = 0.2,
        CanCollide = false,
        MaxActivationDistance = 12,
    }, shell.Root)

    local extractionNodeId = 'PrimaryExtraction'
    local _, extractionPrompt = MazeInteractionPartFactory.createPromptPart({
        Name = 'ExtractionMarker',
        Size = Vector3.new(6, 1, 6),
        CFrame = CFrame.new(shell.ExtractionCenter + Vector3.new(0, 0.5, 0)),
        Color = Color3.fromRGB(214, 170, 94),
        Material = Enum.Material.Neon,
        ActionText = 'Return',
        ObjectText = resolvedOptions.ExtractionObjectText or 'Run Entrance',
        CanCollide = false,
        MaxActivationDistance = resolvedOptions.ExtractionMaxActivationDistance or 12,
    }, shell.Root)

    local extractionNodes = {
        [extractionNodeId] = {
            Id = extractionNodeId,
            Prompt = extractionPrompt,
            Position = shell.ExtractionCenter,
        },
    }

    local doorwayIds = {}
    for doorwayId in pairs(shell.Doorways or {}) do
        table.insert(doorwayIds, doorwayId)
    end
    table.sort(doorwayIds)

    for _, doorwayId in ipairs(doorwayIds) do
        appendDoorwayAffordances(roomAffordances, doorwayId, shell.Doorways[doorwayId])
    end

    finalizeAffordances(roomAffordances)

    local initialMonsterPatrolIndex, initialMonsterSpawnRoomId =
        MazeMonsterSpawnPolicy.selectInitialPatrolIndex(
            shell.RoomIds,
            roomAffordances,
            shell.RoomById,
            shell.CampRoomId
        )

    shell.LootNodes = lootNodes
    shell.RoomAffordances = roomAffordances
    shell.PatrolPoints = collectPatrolPointsFromAffordances(shell.RoomIds, roomAffordances)
    shell.InitialMonsterPatrolIndex = initialMonsterPatrolIndex
        or (#shell.PatrolPoints > 0 and 1 or nil)
    shell.InitialMonsterSpawnRoomId = initialMonsterSpawnRoomId
    shell.ReturnHoldPad = {
        Prompt = returnHoldPrompt,
        Position = returnHoldPadPosition,
    }
    shell.ExtractionNodes = extractionNodes

    return shell
end

return MazeFormalWorldComposer
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="77">
            <Properties>
              <string name="Name">MazeInteractionPartFactory</string>
              <string name="Source"><![CDATA[local MazeInteractionPartFactory = {}

local DEFAULT_PROMPT_PART_SIZE = Vector3.new(4, 4, 4)
local DEFAULT_PROMPT_PART_MATERIAL = Enum.Material.Metal
local DEFAULT_PROMPT_MAX_ACTIVATION_DISTANCE = 10

function MazeInteractionPartFactory.createPart(config, parent)
    local part = Instance.new('Part')
    part.Name = config.Name
    part.Anchored = true
    part.Size = config.Size
    part.CFrame = config.CFrame
    part.Color = config.Color
    part.Material = config.Material or Enum.Material.SmoothPlastic
    part.Transparency = config.Transparency or 0
    part.CanCollide = config.CanCollide ~= false
    if config.Shape then
        part.Shape = config.Shape
    end
    part.Parent = parent
    return part
end

function MazeInteractionPartFactory.createPromptPart(config, parent)
    local part = MazeInteractionPartFactory.createPart({
        Name = config.Name,
        Size = config.Size or DEFAULT_PROMPT_PART_SIZE,
        CFrame = config.CFrame,
        Color = config.Color,
        Material = config.Material or DEFAULT_PROMPT_PART_MATERIAL,
        Transparency = config.Transparency or 0,
        CanCollide = config.CanCollide,
        Shape = config.Shape,
    }, parent)

    local prompt = Instance.new('ProximityPrompt')
    prompt.ActionText = config.ActionText
    prompt.ObjectText = config.ObjectText
    prompt.HoldDuration = 0
    prompt.MaxActivationDistance = config.MaxActivationDistance
        or DEFAULT_PROMPT_MAX_ACTIVATION_DISTANCE
    prompt.RequiresLineOfSight = false
    prompt.Parent = part

    return part, prompt
end

return MazeInteractionPartFactory
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="78">
            <Properties>
              <string name="Name">MazeLightingProfile</string>
              <string name="Source"><![CDATA[local MazeLightingProfile = {}

local EFFECT_NAMES = table.freeze({
    Atmosphere = 'MazeAtmosphere',
    ColorCorrection = 'MazeColorCorrection',
    Bloom = 'MazeBloom',
    DepthOfField = 'MazeDepthOfField',
})

local FUTURE_SURFACE_PALETTE = table.freeze({
    WallColor = Color3.fromRGB(84, 88, 94),
    WallMaterial = Enum.Material.Slate,
    FloorColor = Color3.fromRGB(56, 60, 64),
    FloorMaterial = Enum.Material.Basalt,
    CeilingColor = Color3.fromRGB(42, 45, 50),
    CeilingMaterial = Enum.Material.Basalt,
    DoorColor = Color3.fromRGB(69, 73, 78),
    DoorMaterial = Enum.Material.Metal,
    ExitFloorColor = Color3.fromRGB(92, 74, 58),
    ExitFloorMaterial = Enum.Material.Slate,
})

local FALLBACK_SURFACE_PALETTE = table.freeze({
    WallColor = Color3.fromRGB(106, 112, 120),
    WallMaterial = Enum.Material.Slate,
    FloorColor = Color3.fromRGB(82, 88, 96),
    FloorMaterial = Enum.Material.Basalt,
    CeilingColor = Color3.fromRGB(68, 74, 82),
    CeilingMaterial = Enum.Material.Basalt,
    DoorColor = Color3.fromRGB(92, 98, 106),
    DoorMaterial = Enum.Material.Metal,
    ExitFloorColor = Color3.fromRGB(112, 92, 74),
    ExitFloorMaterial = Enum.Material.Slate,
})

MazeLightingProfile.SurfacePalette = FUTURE_SURFACE_PALETTE
MazeLightingProfile.FallbackSurfacePalette = FALLBACK_SURFACE_PALETTE
MazeLightingProfile.ProfileName = table.freeze({
    Future = 'Future',
    FallbackReadable = 'FallbackReadable',
})

local function ensureEffect(parent, className, name)
    local existing = parent:FindFirstChild(name)
    if existing and not existing:IsA(className) then
        existing:Destroy()
        existing = nil
    end

    if existing == nil then
        existing = Instance.new(className)
        existing.Name = name
        existing.Parent = parent
    end

    return existing
end

local function defaultPropertySetter(target, propertyName, value)
    target[propertyName] = value
end

local function applyProperty(
    target,
    propertyPath,
    propertyName,
    value,
    skippedProperties,
    propertySetter
)
    local ok, err = pcall(function()
        propertySetter(target, propertyName, value)
    end)

    if ok then
        return true
    end

    skippedProperties[propertyPath] = tostring(err)
    return false
end

local function applyLightingProperties(lighting, properties, skippedProperties, propertySetter)
    for _, propertyConfig in ipairs(properties) do
        applyProperty(
            lighting,
            propertyConfig.Path,
            propertyConfig.Name,
            propertyConfig.Value,
            skippedProperties,
            propertySetter
        )
    end
end

local function applyEffectProperties(effect, properties, skippedProperties, propertySetter)
    for _, propertyConfig in ipairs(properties) do
        applyProperty(
            effect,
            propertyConfig.Path,
            propertyConfig.Name,
            propertyConfig.Value,
            skippedProperties,
            propertySetter
        )
    end
end

local LIGHTING_PROPERTIES_BY_PROFILE = table.freeze({
    Future = table.freeze({
        { Path = 'Lighting.GlobalShadows', Name = 'GlobalShadows', Value = true },
        { Path = 'Lighting.Brightness', Name = 'Brightness', Value = 2 },
        { Path = 'Lighting.ClockTime', Name = 'ClockTime', Value = 1.25 },
        {
            Path = 'Lighting.ExposureCompensation',
            Name = 'ExposureCompensation',
            Value = -0.4,
        },
        { Path = 'Lighting.ShadowSoftness', Name = 'ShadowSoftness', Value = 0.35 },
        { Path = 'Lighting.Ambient', Name = 'Ambient', Value = Color3.fromRGB(8, 10, 14) },
        {
            Path = 'Lighting.OutdoorAmbient',
            Name = 'OutdoorAmbient',
            Value = Color3.fromRGB(30, 34, 40),
        },
        {
            Path = 'Lighting.EnvironmentDiffuseScale',
            Name = 'EnvironmentDiffuseScale',
            Value = 0.3,
        },
        {
            Path = 'Lighting.EnvironmentSpecularScale',
            Name = 'EnvironmentSpecularScale',
            Value = 0.2,
        },
    }),
    FallbackReadable = table.freeze({
        { Path = 'Lighting.GlobalShadows', Name = 'GlobalShadows', Value = true },
        { Path = 'Lighting.Brightness', Name = 'Brightness', Value = 3.1 },
        { Path = 'Lighting.ClockTime', Name = 'ClockTime', Value = 2.4 },
        {
            Path = 'Lighting.ExposureCompensation',
            Name = 'ExposureCompensation',
            Value = 0.1,
        },
        { Path = 'Lighting.ShadowSoftness', Name = 'ShadowSoftness', Value = 0.2 },
        { Path = 'Lighting.Ambient', Name = 'Ambient', Value = Color3.fromRGB(22, 26, 32) },
        {
            Path = 'Lighting.OutdoorAmbient',
            Name = 'OutdoorAmbient',
            Value = Color3.fromRGB(62, 68, 78),
        },
        {
            Path = 'Lighting.EnvironmentDiffuseScale',
            Name = 'EnvironmentDiffuseScale',
            Value = 0.5,
        },
        {
            Path = 'Lighting.EnvironmentSpecularScale',
            Name = 'EnvironmentSpecularScale',
            Value = 0.15,
        },
    }),
})

local ATMOSPHERE_PROPERTIES_BY_PROFILE = table.freeze({
    Future = table.freeze({
        {
            Path = 'MazeAtmosphere.Color',
            Name = 'Color',
            Value = Color3.fromRGB(92, 100, 112),
        },
        {
            Path = 'MazeAtmosphere.Decay',
            Name = 'Decay',
            Value = Color3.fromRGB(14, 16, 20),
        },
        { Path = 'MazeAtmosphere.Density', Name = 'Density', Value = 0.38 },
        { Path = 'MazeAtmosphere.Glare', Name = 'Glare', Value = 0.05 },
        { Path = 'MazeAtmosphere.Haze', Name = 'Haze', Value = 1.75 },
        { Path = 'MazeAtmosphere.Offset', Name = 'Offset', Value = -0.2 },
    }),
    FallbackReadable = table.freeze({
        {
            Path = 'MazeAtmosphere.Color',
            Name = 'Color',
            Value = Color3.fromRGB(108, 118, 132),
        },
        {
            Path = 'MazeAtmosphere.Decay',
            Name = 'Decay',
            Value = Color3.fromRGB(30, 34, 40),
        },
        { Path = 'MazeAtmosphere.Density', Name = 'Density', Value = 0.18 },
        { Path = 'MazeAtmosphere.Glare', Name = 'Glare', Value = 0.03 },
        { Path = 'MazeAtmosphere.Haze', Name = 'Haze', Value = 0.8 },
        { Path = 'MazeAtmosphere.Offset', Name = 'Offset', Value = -0.05 },
    }),
})

local COLOR_CORRECTION_PROPERTIES_BY_PROFILE = table.freeze({
    Future = table.freeze({
        {
            Path = 'MazeColorCorrection.Brightness',
            Name = 'Brightness',
            Value = -0.03,
        },
        { Path = 'MazeColorCorrection.Contrast', Name = 'Contrast', Value = 0.16 },
        { Path = 'MazeColorCorrection.Saturation', Name = 'Saturation', Value = -0.12 },
        {
            Path = 'MazeColorCorrection.TintColor',
            Name = 'TintColor',
            Value = Color3.fromRGB(214, 223, 255),
        },
    }),
    FallbackReadable = table.freeze({
        {
            Path = 'MazeColorCorrection.Brightness',
            Name = 'Brightness',
            Value = 0.03,
        },
        { Path = 'MazeColorCorrection.Contrast', Name = 'Contrast', Value = 0.08 },
        { Path = 'MazeColorCorrection.Saturation', Name = 'Saturation', Value = -0.08 },
        {
            Path = 'MazeColorCorrection.TintColor',
            Name = 'TintColor',
            Value = Color3.fromRGB(220, 228, 255),
        },
    }),
})

local BLOOM_PROPERTIES = table.freeze({
    { Path = 'MazeBloom.Intensity', Name = 'Intensity', Value = 0.18 },
    { Path = 'MazeBloom.Size', Name = 'Size', Value = 28 },
    { Path = 'MazeBloom.Threshold', Name = 'Threshold', Value = 1.35 },
})

local DEPTH_OF_FIELD_PROPERTIES = table.freeze({
    { Path = 'MazeDepthOfField.FarIntensity', Name = 'FarIntensity', Value = 0.08 },
    { Path = 'MazeDepthOfField.FocusDistance', Name = 'FocusDistance', Value = 30 },
    { Path = 'MazeDepthOfField.InFocusRadius', Name = 'InFocusRadius', Value = 18 },
    { Path = 'MazeDepthOfField.NearIntensity', Name = 'NearIntensity', Value = 0.12 },
})

function MazeLightingProfile.apply(lighting, options)
    local runtimeOptions = options or {}
    local skippedProperties = {}
    local propertySetter = runtimeOptions.PropertySetter or defaultPropertySetter
    local technologyApplied = applyProperty(
        lighting,
        'Lighting.Technology',
        'Technology',
        Enum.Technology.Future,
        skippedProperties,
        propertySetter
    )
    local appliedProfile = (
        if technologyApplied
            then MazeLightingProfile.ProfileName.Future
            else MazeLightingProfile.ProfileName.FallbackReadable
    )

    applyLightingProperties(
        lighting,
        LIGHTING_PROPERTIES_BY_PROFILE[appliedProfile],
        skippedProperties,
        propertySetter
    )

    local atmosphere = ensureEffect(lighting, 'Atmosphere', EFFECT_NAMES.Atmosphere)
    applyEffectProperties(
        atmosphere,
        ATMOSPHERE_PROPERTIES_BY_PROFILE[appliedProfile],
        skippedProperties,
        propertySetter
    )

    local colorCorrection =
        ensureEffect(lighting, 'ColorCorrectionEffect', EFFECT_NAMES.ColorCorrection)
    applyEffectProperties(
        colorCorrection,
        COLOR_CORRECTION_PROPERTIES_BY_PROFILE[appliedProfile],
        skippedProperties,
        propertySetter
    )

    local bloom = ensureEffect(lighting, 'BloomEffect', EFFECT_NAMES.Bloom)
    applyEffectProperties(bloom, BLOOM_PROPERTIES, skippedProperties, propertySetter)

    local depthOfField = ensureEffect(lighting, 'DepthOfFieldEffect', EFFECT_NAMES.DepthOfField)
    applyEffectProperties(
        depthOfField,
        DEPTH_OF_FIELD_PROPERTIES,
        skippedProperties,
        propertySetter
    )

    return {
        Atmosphere = atmosphere,
        ColorCorrection = colorCorrection,
        Bloom = bloom,
        DepthOfField = depthOfField,
        TechnologyApplied = technologyApplied,
        TechnologyError = skippedProperties['Lighting.Technology'],
        AppliedProfile = appliedProfile,
        SurfacePalette = (if technologyApplied
            then MazeLightingProfile.SurfacePalette
            else MazeLightingProfile.FallbackSurfacePalette),
        SkippedProperties = skippedProperties,
    }
end

return MazeLightingProfile
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="79">
            <Properties>
              <string name="Name">MazeModuleAssetContract</string>
              <string name="Source"><![CDATA[local MazeModuleAssetContract = {}

MazeModuleAssetContract.RequiredModuleNames = table.freeze({
    'WallSegment',
    'DoorFrame',
    'DoorLeaf',
    'FloorPanel',
    'ExtractionMarker',
})

MazeModuleAssetContract.OptionalAuthoringFolderName = 'RoomArchetypes'
MazeModuleAssetContract.OptionalConnectorAuthoringFolderName = 'ConnectorArchetypes'
MazeModuleAssetContract.OptionalShellModelName = 'ShellModel'

local function isContainer(instance)
    return instance:IsA('Folder') or instance:IsA('Model')
end

local function validateShellModel(shellModel, label)
    if shellModel ~= nil and not (shellModel:IsA('Model') or shellModel:IsA('BasePart')) then
        error(string.format('%s must be a Model or BasePart.', label), 0)
    end
end

local function validateOptionalAuthoringChildren(root, label)
    if root == nil then
        return
    end

    if not isContainer(root) then
        error(string.format('%s must be a Folder or Model.', label), 0)
    end

    for _, archetypeFolder in ipairs(root:GetChildren()) do
        if not isContainer(archetypeFolder) then
            error(
                string.format('%s asset %s must be a Folder or Model.', label, archetypeFolder.Name),
                0
            )
        end

        local shellModel =
            archetypeFolder:FindFirstChild(MazeModuleAssetContract.OptionalShellModelName)
        validateShellModel(
            shellModel,
            string.format(
                '%s shell asset %s/%s',
                label,
                archetypeFolder.Name,
                MazeModuleAssetContract.OptionalShellModelName
            )
        )
    end
end

function MazeModuleAssetContract.validateRoot(root)
    if typeof(root) ~= 'Instance' then
        error('Maze module asset root must be a Studio instance.', 0)
    end

    if not isContainer(root) then
        error('Maze module asset root must be a Folder or Model.', 0)
    end

    for _, moduleName in ipairs(MazeModuleAssetContract.RequiredModuleNames) do
        if root:FindFirstChild(moduleName) == nil then
            error(string.format('Missing maze module asset: %s', moduleName), 0)
        end
    end

    local roomArchetypesRoot =
        root:FindFirstChild(MazeModuleAssetContract.OptionalAuthoringFolderName)
    validateOptionalAuthoringChildren(roomArchetypesRoot, 'RoomArchetypes')

    local connectorArchetypesRoot =
        root:FindFirstChild(MazeModuleAssetContract.OptionalConnectorAuthoringFolderName)
    validateOptionalAuthoringChildren(connectorArchetypesRoot, 'ConnectorArchetypes')

    return root
end

function MazeModuleAssetContract.getRoomArchetypeShellModel(root, archetypeId)
    if typeof(root) ~= 'Instance' then
        return nil
    end

    local roomArchetypesRoot =
        root:FindFirstChild(MazeModuleAssetContract.OptionalAuthoringFolderName)
    local archetypeFolder = roomArchetypesRoot and roomArchetypesRoot:FindFirstChild(archetypeId)
    return archetypeFolder
        and archetypeFolder:FindFirstChild(MazeModuleAssetContract.OptionalShellModelName)
end

function MazeModuleAssetContract.getConnectorShellModel(root, connectorArchetypeId)
    if typeof(root) ~= 'Instance' then
        return nil
    end

    local connectorArchetypesRoot =
        root:FindFirstChild(MazeModuleAssetContract.OptionalConnectorAuthoringFolderName)
    local archetypeFolder = connectorArchetypesRoot
        and connectorArchetypesRoot:FindFirstChild(connectorArchetypeId)
    return archetypeFolder
        and archetypeFolder:FindFirstChild(MazeModuleAssetContract.OptionalShellModelName)
end

return MazeModuleAssetContract
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="80">
            <Properties>
              <string name="Name">MazeWorldScanner</string>
              <string name="Source"><![CDATA[--[[
    MazeWorldScanner
    运行时扫描 Workspace 中的静态房间实例，建立供 MazeSessionService 使用的数据结构。

    Authoring guide:
    - `Workspace/MazeStaticWorld` is the authored root for the maze place.
    - Each room is a Model tagged `RoomType/<TypeId>`.
    - Supported room metadata lives on Attributes such as `IsCamp`, `IsExtraction`,
      `DifficultyTier`, `MonsterBudget`, `LootBudget`, `DetectionRadius`,
      `RoomTemplateId`, and `RoomCategory`.
    - Supported authored child parts include `SpawnPoint_*`, `LootSocket_*`,
      `LootPrompt`, `Doorway_*`, and `ExtractionMarker`.
]]

local ReplicatedStorage = game:GetService('ReplicatedStorage')
local Workspace = game:GetService('Workspace')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Gameplay = require(Packages:WaitForChild('Gameplay'))

local MazeWorldScanner = {}
MazeWorldScanner.__index = MazeWorldScanner

local DEFAULT_SCAN_ROOT = Workspace
local STATIC_WORLD_ROOT_NAME = 'MazeStaticWorld'
local DEFAULT_ROOM_KIND = 'Loot'
local DEFAULT_RETURN_ACTION_TEXT = 'Return'
local DEFAULT_RETURN_OBJECT_TEXT = 'Run Entrance'

local NEIGHBOR_DISTANCE_THRESHOLD = 50
local DEFAULT_DETECTION_RADIUS = 18

local SCAN_CONFIG = {
    RoomTagPrefix = 'RoomType/',
    HasMonsterSpawnerTag = 'HasMonsterSpawner',
    HasLootSocketTag = 'HasLootSocket',
    DoorwayTagPrefix = 'Doorway/',
    SceneryFolderName = 'Scenery',
    SceneryAttribute = 'IsScenery',
}

local DEFAULT_ATTRIBUTES = {
    RoomType = 'Unknown',
    DifficultyTier = 1,
    MonsterBudget = 0,
    LootBudget = 0,
    IsCamp = false,
    IsExtraction = false,
    IsScenery = false,
}

local function readAttribute(instance, name, default)
    local value = instance:GetAttribute(name)
    return value ~= nil and value or default
end

local function hasTag(instance, tag)
    if instance:HasTag(tag) then
        return true
    end

    return readAttribute(instance, tag, false) == true
end

local function sortByName(instances)
    table.sort(instances, function(left, right)
        return left.Name < right.Name
    end)
    return instances
end

local function isSceneryInstance(instance)
    if readAttribute(instance, SCAN_CONFIG.SceneryAttribute, false) == true then
        return true
    end

    local parent = instance.Parent
    if parent and parent.Name == SCAN_CONFIG.SceneryFolderName and parent:IsA('Folder') then
        return true
    end

    return false
end

local function isRoomInstance(instance)
    if type(readAttribute(instance, 'RoomType', nil)) == 'string' then
        return true
    end

    for tag in instance:GetTags() do
        if
            string.sub(tag, 1, string.len(SCAN_CONFIG.RoomTagPrefix)) == SCAN_CONFIG.RoomTagPrefix
        then
            return true
        end
    end

    return false
end

local function extractRoomType(instance)
    local roomTypeAttribute = readAttribute(instance, 'RoomType', nil)
    if type(roomTypeAttribute) == 'string' and roomTypeAttribute ~= '' then
        return roomTypeAttribute
    end

    for tag in instance:GetTags() do
        if
            string.sub(tag, 1, string.len(SCAN_CONFIG.RoomTagPrefix)) == SCAN_CONFIG.RoomTagPrefix
        then
            return string.sub(tag, string.len(SCAN_CONFIG.RoomTagPrefix) + 1)
        end
    end

    return 'Unknown'
end

local function getPrimaryPosition(instance)
    if instance:IsA('Model') then
        return instance:GetPivot().Position
    end

    if instance:IsA('BasePart') then
        return instance.Position
    end

    return Vector3.zero
end

local function getBoundingRadius(instance)
    if instance:IsA('Model') then
        local _, size = instance:GetBoundingBox()
        return math.max(size.X, size.Z) * 0.5
    end

    if instance:IsA('BasePart') then
        return math.max(instance.Size.X, instance.Size.Z) * 0.5
    end

    return 18
end

local function collectNamedPoints(roomInstance, pattern, defaultDirection)
    local entries = {}

    for _, child in ipairs(sortByName(roomInstance:GetChildren())) do
        if string.find(child.Name, pattern) and child:IsA('BasePart') then
            table.insert(entries, {
                Name = child.Name,
                Position = child.Position,
                Direction = child:GetAttribute('Direction') or defaultDirection or 'Unknown',
            })
        end
    end

    return entries
end

local function collectSpawnPoints(roomInstance)
    return collectNamedPoints(roomInstance, 'SpawnPoint', 'Unknown')
end

local function collectLootSockets(roomInstance)
    return collectNamedPoints(roomInstance, 'LootSocket', 'Unknown')
end

local function collectDoorways(roomInstance)
    return collectNamedPoints(roomInstance, 'Doorway', 'Unknown')
end

local function pickRoomKind(instance)
    if readAttribute(instance, 'IsCamp', DEFAULT_ATTRIBUTES.IsCamp) == true then
        return 'Camp'
    end

    if readAttribute(instance, 'IsExtraction', DEFAULT_ATTRIBUTES.IsExtraction) == true then
        return 'Extraction'
    end

    return readAttribute(instance, 'RoomKind', DEFAULT_ROOM_KIND)
end

local function buildAffordance(instance)
    local roomKind = pickRoomKind(instance)

    return {
        RoomId = instance.Name,
        RoomType = extractRoomType(instance),
        RoomKind = roomKind,
        SpawnSockets = collectLootSockets(instance),
        PatrolAnchors = collectSpawnPoints(instance),
        SightBreakers = {},
        DoorControlPoints = collectDoorways(instance),
        ThreatTags = { string.format('RoomKind:%s', roomKind) },
        HasMonsterSpawner = hasTag(instance, SCAN_CONFIG.HasMonsterSpawnerTag),
        HasLootSocket = hasTag(instance, SCAN_CONFIG.HasLootSocketTag),
        TraversalMask = {
            NeighborRoomIds = {},
            DoorwayIds = {},
            ExitDirections = {},
        },
    }
end

local function buildRoomData(instance)
    local roomType = extractRoomType(instance)

    return {
        Id = instance.Name,
        Type = roomType,
        Kind = pickRoomKind(instance),
        Position = getPrimaryPosition(instance),
        DetectionRadius = readAttribute(instance, 'DetectionRadius', getBoundingRadius(instance)),
        DifficultyTier = readAttribute(
            instance,
            'DifficultyTier',
            DEFAULT_ATTRIBUTES.DifficultyTier
        ),
        MonsterBudget = readAttribute(instance, 'MonsterBudget', DEFAULT_ATTRIBUTES.MonsterBudget),
        LootBudget = readAttribute(instance, 'LootBudget', DEFAULT_ATTRIBUTES.LootBudget),
        IsCamp = readAttribute(instance, 'IsCamp', DEFAULT_ATTRIBUTES.IsCamp),
        IsExtraction = readAttribute(instance, 'IsExtraction', DEFAULT_ATTRIBUTES.IsExtraction),
        RoomTemplateId = readAttribute(instance, 'RoomTemplateId', roomType),
        RoomCategory = readAttribute(instance, 'RoomCategory', roomType),
        SearchProfile = {
            Mode = readAttribute(instance, 'SearchProfileMode', 'authored'),
        },
        RiskTier = readAttribute(instance, 'RiskTier', DEFAULT_ATTRIBUTES.DifficultyTier),
        LandmarkWeight = readAttribute(instance, 'LandmarkWeight', 1),
        Neighbors = {},
    }
end

local function scanRecursive(root, results, visited)
    if not root or visited[root] then
        return
    end
    visited[root] = true

    if root:IsA('Folder') and root.Name == SCAN_CONFIG.SceneryFolderName then
        return
    end

    if isSceneryInstance(root) then
        return
    end

    if isRoomInstance(root) then
        table.insert(results.rooms, root)
        return
    end

    for _, child in ipairs(sortByName(root:GetChildren())) do
        scanRecursive(child, results, visited)
    end
end

local function getNearestRoomId(roomIds, roomById, position)
    local bestRoomId = nil
    local bestDistance = math.huge

    for _, roomId in ipairs(roomIds) do
        local room = roomById[roomId]
        if room then
            local distance = (room.Position - position).Magnitude
            if distance < bestDistance then
                bestDistance = distance
                bestRoomId = roomId
            end
        end
    end

    return bestRoomId, bestDistance
end

local function findPromptOnPart(part)
    if not part or not part:IsA('BasePart') then
        return nil
    end

    return part:FindFirstChildOfClass('ProximityPrompt')
end

function MazeWorldScanner.Scan(scanRoot)
    local root = scanRoot or DEFAULT_SCAN_ROOT
    local results = {
        rooms = {},
    }
    local visited = {}

    for _, child in ipairs(sortByName(root:GetChildren())) do
        scanRecursive(child, results, visited)
    end

    sortByName(results.rooms)

    local roomById = {}
    local roomAffordances = {}
    local campRoomId = nil

    for _, roomInstance in ipairs(results.rooms) do
        local roomData = buildRoomData(roomInstance)
        local affordance = buildAffordance(roomInstance)

        roomById[roomInstance.Name] = roomData
        roomAffordances[roomInstance.Name] = affordance

        if roomData.IsCamp then
            campRoomId = roomInstance.Name
        end
    end

    local sortedIds = {}
    for roomId in pairs(roomById) do
        table.insert(sortedIds, roomId)
    end
    table.sort(sortedIds)

    for _, idA in ipairs(sortedIds) do
        local roomA = roomById[idA]
        for _, idB in ipairs(sortedIds) do
            local roomB = roomById[idB]
            if idA ~= idB then
                local distance = (roomB.Position - roomA.Position).Magnitude
                if distance < NEIGHBOR_DISTANCE_THRESHOLD then
                    table.insert(roomA.Neighbors, idB)
                    table.insert(roomAffordances[idA].TraversalMask.NeighborRoomIds, idB)
                end
            end
        end

        table.sort(roomA.Neighbors)
        table.sort(roomAffordances[idA].TraversalMask.NeighborRoomIds)
    end

    return {
        rooms = results.rooms,
        roomById = roomById,
        roomAffordances = roomAffordances,
        campRoomId = campRoomId,
    }
end

function MazeWorldScanner.ScanAsync(scanRoot)
    return MazeWorldScanner.Scan(scanRoot)
end

function MazeWorldScanner.GetRoomById(scanResult, roomId)
    return scanResult.roomById and scanResult.roomById[roomId]
end

function MazeWorldScanner.GetRoomIds(scanResult)
    local ids = {}
    if scanResult.roomById then
        for id in pairs(scanResult.roomById) do
            table.insert(ids, id)
        end
        table.sort(ids)
    end
    return ids
end

function MazeWorldScanner.GetEligibleMonsterRooms(scanResult)
    local eligible = {}
    if scanResult.roomAffordances then
        for roomId, affordance in pairs(scanResult.roomAffordances) do
            if affordance.HasMonsterSpawner then
                table.insert(eligible, roomId)
            end
        end
        table.sort(eligible)
    end
    return eligible
end

function MazeWorldScanner.GetRoomsByDifficultyTier(scanResult, tier)
    local rooms = {}
    if scanResult.roomById then
        for id, room in pairs(scanResult.roomById) do
            if room.DifficultyTier == tier then
                table.insert(rooms, id)
            end
        end
        table.sort(rooms)
    end
    return rooms
end

function MazeWorldScanner.IsSceneryInstance(instance)
    return isSceneryInstance(instance)
end

function MazeWorldScanner.GetRoomTypeFromInstance(instance)
    return extractRoomType(instance)
end

function MazeWorldScanner.ToWorldFormat(scanResult)
    local roomIds = MazeWorldScanner.GetRoomIds(scanResult)

    return {
        RoomIds = roomIds,
        RoomById = scanResult.roomById,
        RoomAffordances = scanResult.roomAffordances,
        CampRoomId = scanResult.campRoomId,
        PatrolPoints = {},
        InitialMonsterPatrolIndex = nil,
    }
end

function MazeWorldScanner.BuildStaticWorld(scanRoot)
    local root = scanRoot or Workspace:FindFirstChild(STATIC_WORLD_ROOT_NAME)
    if root == nil then
        return nil
    end

    local scanResult = MazeWorldScanner.Scan(root)
    local world = MazeWorldScanner.ToWorldFormat(scanResult)
    local items = Gameplay.Config.Items
    local itemIndex = 1

    local returnHoldPadPart = root:FindFirstChild('ReturnHoldPad', true)
    if not (returnHoldPadPart and returnHoldPadPart:IsA('BasePart')) then
        error(
            string.format('%s is missing required part "ReturnHoldPad".', STATIC_WORLD_ROOT_NAME),
            0
        )
    end

    local returnHoldPrompt = findPromptOnPart(returnHoldPadPart)
    if returnHoldPrompt == nil then
        error(
            string.format('%s ReturnHoldPad is missing a ProximityPrompt.', STATIC_WORLD_ROOT_NAME),
            0
        )
    end

    returnHoldPrompt.ActionText = returnHoldPrompt.ActionText ~= '' and returnHoldPrompt.ActionText
        or DEFAULT_RETURN_ACTION_TEXT
    returnHoldPrompt.ObjectText = returnHoldPrompt.ObjectText ~= '' and returnHoldPrompt.ObjectText
        or DEFAULT_RETURN_OBJECT_TEXT

    local spawnMarker = root:FindFirstChild('SpawnMarker', true)
    local spawnCFrame = spawnMarker and spawnMarker:IsA('BasePart') and spawnMarker.CFrame
        or returnHoldPadPart.CFrame

    local roomCenters = {}
    local lootNodes = {}
    local extractionNodes = {}
    local patrolPoints = {}
    local doorwayState = {}
    local roomInstancesById = {}

    for _, roomInstance in ipairs(scanResult.rooms or {}) do
        roomInstancesById[roomInstance.Name] = roomInstance
        roomCenters[roomInstance.Name] = getPrimaryPosition(roomInstance)
    end

    for _, roomId in ipairs(world.RoomIds) do
        local room = world.RoomById[roomId]
        local affordance = world.RoomAffordances[roomId]
        local roomInstance = roomInstancesById[roomId]

        affordance.RoomCenter = room.Position
        affordance.RoomTemplateId = room.RoomTemplateId
        affordance.RoomCategory = room.RoomCategory
        affordance.SearchProfile = room.SearchProfile
        affordance.RiskTier = room.RiskTier
        affordance.LandmarkWeight = room.LandmarkWeight

        if #affordance.SpawnSockets == 0 then
            table.insert(affordance.SpawnSockets, {
                Id = string.format('%s_Spawn_1', roomId),
                Kind = 'RoomCenter',
                Position = room.Position + Vector3.new(0, 1.5, 0),
            })
        else
            for index, spawnSocket in ipairs(affordance.SpawnSockets) do
                spawnSocket.Id = spawnSocket.Name or string.format('%s_Spawn_%d', roomId, index)
                spawnSocket.Kind = 'LootSocket'
            end
        end

        if room.MonsterBudget > 0 or affordance.HasMonsterSpawner then
            for _, patrolAnchor in ipairs(affordance.PatrolAnchors) do
                table.insert(patrolPoints, patrolAnchor.Position)
            end
        end

        local extractionPart = roomInstance
            and roomInstance:FindFirstChild('ExtractionMarker', true)
        local extractionPrompt = findPromptOnPart(extractionPart)
        if extractionPart and extractionPrompt then
            extractionPrompt.ActionText = extractionPrompt.ActionText ~= ''
                    and extractionPrompt.ActionText
                or DEFAULT_RETURN_ACTION_TEXT
            extractionPrompt.ObjectText = extractionPrompt.ObjectText ~= ''
                    and extractionPrompt.ObjectText
                or DEFAULT_RETURN_OBJECT_TEXT

            local extractionNodeId = extractionPart:GetAttribute('ExtractionNodeId')
                or string.format('%s_Extraction', roomId)
            extractionNodes[extractionNodeId] = {
                Id = extractionNodeId,
                Prompt = extractionPrompt,
                Position = extractionPart.Position,
            }
        end

        if room.Kind == 'Loot' then
            local lootSocket = affordance.SpawnSockets[1]
            local itemDef = items[itemIndex]
            itemIndex = (itemIndex % #items) + 1

            local lootPart = roomInstance and roomInstance:FindFirstChild('LootPrompt', true)
            if lootPart == nil and roomInstance then
                lootPart = roomInstance:FindFirstChild('LootSocket_1', true)
            end

            local lootPrompt = findPromptOnPart(lootPart)
            if lootPrompt ~= nil then
                lootPrompt.ActionText = lootPrompt.ActionText ~= '' and lootPrompt.ActionText
                    or 'Collect'
                lootPrompt.ObjectText = lootPrompt.ObjectText ~= '' and lootPrompt.ObjectText
                    or itemDef.Name

                lootNodes[roomId] = {
                    ItemDef = itemDef,
                    RoomTemplateId = room.RoomTemplateId,
                    SearchProfile = room.SearchProfile,
                    Prompt = lootPrompt,
                    Position = lootSocket.Position,
                    Collected = false,
                }
            end
        end

        for _, controlPoint in ipairs(affordance.DoorControlPoints) do
            local doorwayId = roomId .. ':' .. controlPoint.Name
            local doorwayPart = roomInstance and roomInstance:FindFirstChild(controlPoint.Name)
            local doorwayPrompt = findPromptOnPart(doorwayPart)
            table.insert(affordance.TraversalMask.DoorwayIds, doorwayId)

            if doorwayPart and doorwayPart:IsA('BasePart') then
                doorwayState[doorwayId] = {
                    Id = doorwayId,
                    Prompt = doorwayPrompt,
                    Position = doorwayPart.Position,
                    IsOpen = false,
                    Part = doorwayPart,
                    ClosedTransparency = doorwayPart.Transparency,
                }
            end
        end

        table.sort(affordance.TraversalMask.DoorwayIds)
    end

    local function findRoomByPosition(position)
        local nearestRoomId, nearestDistance =
            getNearestRoomId(world.RoomIds, world.RoomById, position)
        if nearestRoomId == nil then
            return nil
        end

        local room = world.RoomById[nearestRoomId]
        if nearestDistance > (room.DetectionRadius or DEFAULT_DETECTION_RADIUS) then
            return nil
        end

        return room, nearestDistance
    end

    local function toggleDoor(doorwayId)
        local doorway = doorwayState[doorwayId]
        if doorway == nil then
            return false
        end

        doorway.IsOpen = not doorway.IsOpen
        doorway.Part.CanCollide = not doorway.IsOpen
        doorway.Part.Transparency = doorway.IsOpen and 0.65 or doorway.ClosedTransparency

        if doorway.Prompt ~= nil then
            doorway.Prompt.ActionText = doorway.IsOpen and 'Close' or 'Open'
        end

        return true
    end

    world.Root = root
    world.RoomInstancesById = roomInstancesById
    world.RoomCenters = roomCenters
    world.SpawnCFrame = spawnCFrame
    world.ReturnHoldCFrame = returnHoldPadPart.CFrame + Vector3.new(0, 3, 0)
    world.ReturnHoldPad = {
        Prompt = returnHoldPrompt,
        Position = returnHoldPadPart.Position,
    }
    world.ExtractionNodes = extractionNodes
    world.LootNodes = lootNodes
    world.Doorways = doorwayState
    world.PatrolPoints = patrolPoints
    world.InitialMonsterPatrolIndex = #patrolPoints > 0 and 1 or nil
    world.InitialMonsterSpawnRoomId = #world.RoomIds > 0
            and world.RoomIds[math.min(2, #world.RoomIds)]
        or nil
    world.FindRoomByPosition = findRoomByPosition
    world.ToggleDoor = toggleDoor
    world.CanTraverseBetweenPositions = function()
        return true
    end

    return world
end

return MazeWorldScanner
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="81">
            <Properties>
              <string name="Name">MazeWorldShellBuilder</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService('ReplicatedStorage')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Gameplay = require(Packages:WaitForChild('Gameplay'))

local MazeBuilder = Gameplay.ProcGen.MazeBuilder
local HexMazeWorldRenderer = require(script.Parent.HexMazeWorldRenderer)

local MazeWorldShellBuilder = {}

function MazeWorldShellBuilder.build(seed, config, options)
    local resolvedOptions = options or {}
    local layout = MazeBuilder.build(seed, config)
    local rendered = HexMazeWorldRenderer.build({
        WorldName = resolvedOptions.WorldName or 'GeneratedMazeWorld',
        Layout = layout,
        Parent = resolvedOptions.Parent,
        OriginOffset = resolvedOptions.OriginOffset or Vector3.zero,
        SurfacePalette = resolvedOptions.SurfacePalette,
        ModuleAssetsRoot = resolvedOptions.ModuleAssetsRoot,
        RoomApothem = config.RoomApothem,
        IncludeRoomMarker = resolvedOptions.IncludeRoomMarkers ~= false,
        RoomMarkerTransparency = resolvedOptions.RoomMarkerTransparency,
        RoomKindColors = resolvedOptions.RoomKindColors,
        DetectionBuffer = resolvedOptions.DetectionBuffer,
    })

    local campCenter = rendered.RoomCenters[layout.CampRoomId]
    local extractionCenter = rendered.RoomCenters[layout.ExtractionRoomId]

    return {
        Root = rendered.Root,
        Layout = layout,
        RoomCenters = rendered.RoomCenters,
        RoomById = rendered.RoomById,
        RoomIds = rendered.RoomIds,
        RoomFolders = rendered.RoomFolders,
        Connectors = rendered.Connectors,
        ExitPassages = rendered.ExitPassages,
        MacroGraph = layout.MacroGraph,
        PlacedRooms = layout.PlacedRooms,
        PlacedPassages = layout.PlacedPassages,
        SearchDistribution = layout.SearchDistribution,
        LandmarkNodes = layout.LandmarkNodes,
        CampCenter = campCenter,
        ExtractionCenter = extractionCenter,
        SpawnCFrame = CFrame.new(campCenter + Vector3.new(0, 4, 0)),
        ReturnHoldCFrame = CFrame.new(campCenter + Vector3.new(0, 4, -10)),
        Doorways = rendered.Doorways,
        ToggleDoor = rendered.ToggleDoor,
        FindRoomByPosition = rendered.FindRoomByPosition,
        CanTraverseBetweenPositions = rendered.CanTraverseBetweenPositions,
    }
end

return MazeWorldShellBuilder
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="82">
            <Properties>
              <string name="Name">MonsterRuntime</string>
              <string name="Source"><![CDATA[return {
    EnemyBlackboard = require(script.EnemyBlackboard),
    EnemyRuntime = require(script.EnemyRuntime),
    EnemyStateMachine = require(script.EnemyStateMachine),
    PerceptionComponent = require(script.PerceptionComponent),
    MovementComponent = require(script.MovementComponent),
    AttackComponent = require(script.AttackComponent),
    HealthComponent = require(script.HealthComponent),
}
]]></string>
            </Properties>
            <Item class="ModuleScript" referent="83">
              <Properties>
                <string name="Name">AttackComponent</string>
                <string name="Source"><![CDATA[local AttackComponent = {}
AttackComponent.__index = AttackComponent

function AttackComponent.new(options)
    local runtimeOptions = options or {}

    return setmetatable({
        Clock = runtimeOptions.Clock or os.clock,
        AttackRange = runtimeOptions.AttackRange or 0,
        CooldownSeconds = runtimeOptions.CooldownSeconds or 0.8,
        LastAttackAt = -math.huge,
    }, AttackComponent)
end

function AttackComponent:tryQueueAttack(currentPosition, blackboard)
    local target = blackboard.CurrentTarget
    if target == nil then
        return false
    end

    local targetPosition = blackboard.TargetPositions[target]
    if targetPosition == nil then
        return false
    end

    local now = self.Clock()
    if (now - self.LastAttackAt) < self.CooldownSeconds then
        return false
    end

    if self.AttackRange <= 0 then
        return false
    end

    if (targetPosition - currentPosition).Magnitude > self.AttackRange then
        return false
    end

    self.LastAttackAt = now
    return true
end

return AttackComponent
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="84">
              <Properties>
                <string name="Name">EnemyBlackboard</string>
                <string name="Source"><![CDATA[local EnemyBlackboard = {}
EnemyBlackboard.__index = EnemyBlackboard

function EnemyBlackboard.new(options)
    local runtimeOptions = options or {}

    return setmetatable({
        CurrentTarget = nil,
        PreviousTarget = nil,
        TargetPositions = {},
        Awareness = 0,
        PerceptionState = 'Idle',
        LastSeenPosition = nil,
        LastSeenAt = nil,
        MemoryDurationSeconds = runtimeOptions.MemoryDurationSeconds or 3,
    }, EnemyBlackboard)
end

function EnemyBlackboard:setTarget(nextTarget, targetPosition, now)
    if self.CurrentTarget ~= nextTarget then
        self.PreviousTarget = self.CurrentTarget
    end

    self.CurrentTarget = nextTarget
    self.Awareness = if nextTarget ~= nil then 1 else 0

    if nextTarget ~= nil and targetPosition ~= nil then
        self.LastSeenPosition = targetPosition
        self.LastSeenAt = now
    end
end

function EnemyBlackboard:canUseLastSeen(now)
    if self.LastSeenPosition == nil or self.LastSeenAt == nil then
        return false
    end

    return (now - self.LastSeenAt) <= self.MemoryDurationSeconds
end

return EnemyBlackboard
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="85">
              <Properties>
                <string name="Name">EnemyRuntime</string>
                <string name="Source"><![CDATA[local EnemyBlackboard = require(script.Parent.EnemyBlackboard)
local EnemyStateMachine = require(script.Parent.EnemyStateMachine)
local PerceptionComponent = require(script.Parent.PerceptionComponent)
local MovementComponent = require(script.Parent.MovementComponent)
local AttackComponent = require(script.Parent.AttackComponent)
local HealthComponent = require(script.Parent.HealthComponent)

local EnemyRuntime = {}
EnemyRuntime.__index = EnemyRuntime

function EnemyRuntime.new(options)
    local runtimeOptions = options or {}

    local blackboard = EnemyBlackboard.new({
        MemoryDurationSeconds = runtimeOptions.MemoryDurationSeconds,
    })

    return setmetatable({
        Blackboard = blackboard,
        StateMachine = EnemyStateMachine.new(),
        Perception = PerceptionComponent.new(runtimeOptions.Perception),
        Movement = MovementComponent.new(runtimeOptions.Movement),
        Attack = AttackComponent.new(runtimeOptions.Attack),
        Health = HealthComponent.new(runtimeOptions.Health),
        Context = {
            PatrolPoints = {},
            PatrolIndex = 1,
        },
        Clock = runtimeOptions.Clock or os.clock,
    }, EnemyRuntime)
end

function EnemyRuntime:reset(patrolPoints, initialPatrolIndex)
    self.Context.PatrolPoints = patrolPoints or {}
    self.Context.PatrolIndex = initialPatrolIndex or 1
    self.Blackboard.CurrentTarget = nil
    self.Blackboard.PreviousTarget = nil
    self.Blackboard.TargetPositions = {}
    self.Blackboard.Awareness = 0
    self.Blackboard.PerceptionState = EnemyStateMachine.State.Idle
    self.Blackboard.LastSeenPosition = nil
    self.Blackboard.LastSeenAt = nil
    self.StateMachine.Current = EnemyStateMachine.State.Idle
    self.StateMachine.Previous = nil
end

function EnemyRuntime:update(dt)
    if not self.Health:isAlive() then
        return {
            NextPosition = nil,
            AnimationName = 'Idle',
            AnimationSpeed = 1,
            ShouldPlayChaseLoop = false,
            TargetChanged = false,
            StateChanged = false,
            AttackQueued = false,
            PerceptionState = self.Blackboard.PerceptionState,
        }
    end

    local targetChanged = self.Perception:update(self.Blackboard)
    local stateChanged, state = self.StateMachine:update(self.Blackboard, self.Clock())

    local movementDecision = self.Movement:update(self.Context, self.Blackboard, state, dt)

    local currentPosition = self.Movement.GetCurrentPosition()
    local attackQueued = self.Attack:tryQueueAttack(currentPosition, self.Blackboard)

    return {
        NextPosition = movementDecision.NextPosition,
        AnimationName = movementDecision.AnimationName,
        AnimationSpeed = movementDecision.AnimationSpeed,
        ShouldPlayChaseLoop = movementDecision.ShouldPlayChaseLoop,
        TargetChanged = targetChanged,
        StateChanged = stateChanged,
        AttackQueued = attackQueued,
        PerceptionState = state,
    }
end

return EnemyRuntime
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="86">
              <Properties>
                <string name="Name">EnemyStateMachine</string>
                <string name="Source"><![CDATA[local EnemyStateMachine = {}
EnemyStateMachine.__index = EnemyStateMachine

EnemyStateMachine.State = table.freeze({
    Idle = 'Idle',
    Suspect = 'Suspect',
    Alert = 'Alert',
    Search = 'Search',
})

function EnemyStateMachine.new()
    return setmetatable({
        Current = EnemyStateMachine.State.Idle,
        Previous = nil,
    }, EnemyStateMachine)
end

function EnemyStateMachine:update(blackboard, now)
    local nextState = EnemyStateMachine.State.Idle

    if blackboard.CurrentTarget ~= nil then
        nextState = EnemyStateMachine.State.Alert
    elseif blackboard:canUseLastSeen(now) then
        nextState = EnemyStateMachine.State.Search
    end

    local changed = nextState ~= self.Current
    if changed then
        self.Previous = self.Current
        self.Current = nextState
    end

    blackboard.PerceptionState = nextState
    return changed, nextState
end

return EnemyStateMachine
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="87">
              <Properties>
                <string name="Name">HealthComponent</string>
                <string name="Source"><![CDATA[local HealthComponent = {}
HealthComponent.__index = HealthComponent

function HealthComponent.new(options)
    local runtimeOptions = options or {}
    local maxHealth = runtimeOptions.MaxHealth or 1

    return setmetatable({
        MaxHealth = maxHealth,
        CurrentHealth = maxHealth,
    }, HealthComponent)
end

function HealthComponent:isAlive()
    return self.CurrentHealth > 0
end

function HealthComponent:applyDamage(amount)
    local damage = math.max(0, amount or 0)
    self.CurrentHealth = math.max(0, self.CurrentHealth - damage)
    return self.CurrentHealth
end

return HealthComponent
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="88">
              <Properties>
                <string name="Name">MovementComponent</string>
                <string name="Source"><![CDATA[local EnemyStateMachine = require(script.Parent.EnemyStateMachine)

local MovementComponent = {}
MovementComponent.__index = MovementComponent

function MovementComponent.new(options)
    local runtimeOptions = options or {}

    return setmetatable({
        StepToward = runtimeOptions.StepToward,
        GetCurrentPosition = runtimeOptions.GetCurrentPosition,
        SpawnOffset = runtimeOptions.SpawnOffset,
        Speed = runtimeOptions.Speed,
        PatrolSpeedMultiplier = runtimeOptions.PatrolSpeedMultiplier,
        EnableChase = runtimeOptions.EnableChase,
        EnablePatrol = runtimeOptions.EnablePatrol,
        ArrivalThreshold = runtimeOptions.ArrivalThreshold or 2,
    }, MovementComponent)
end

function MovementComponent:update(context, blackboard, state, dt)
    local currentPosition = self.GetCurrentPosition()
    local nextPosition
    local animationName = 'Idle'
    local animationSpeed = 1
    local shouldPlayChaseLoop = false

    if
        state == EnemyStateMachine.State.Alert
        and blackboard.CurrentTarget ~= nil
        and self.EnableChase
    then
        nextPosition = self.StepToward(
            currentPosition,
            blackboard.TargetPositions[blackboard.CurrentTarget],
            self.Speed,
            dt
        )
        animationName = 'Run'
        animationSpeed = 1.15
        shouldPlayChaseLoop = true
    elseif state == EnemyStateMachine.State.Search and blackboard.LastSeenPosition ~= nil then
        nextPosition = self.StepToward(currentPosition, blackboard.LastSeenPosition, self.Speed, dt)
        animationName = 'Walk'
    elseif self.EnablePatrol and #context.PatrolPoints > 0 then
        local patrolTarget = context.PatrolPoints[context.PatrolIndex] + self.SpawnOffset
        nextPosition = self.StepToward(
            currentPosition,
            patrolTarget,
            self.Speed * self.PatrolSpeedMultiplier,
            dt
        )
        animationName = 'Walk'

        if (nextPosition - patrolTarget).Magnitude <= self.ArrivalThreshold then
            context.PatrolIndex = (context.PatrolIndex % #context.PatrolPoints) + 1
        end
    end

    return {
        NextPosition = nextPosition,
        AnimationName = animationName,
        AnimationSpeed = animationSpeed,
        ShouldPlayChaseLoop = shouldPlayChaseLoop,
    }
end

return MovementComponent
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="89">
              <Properties>
                <string name="Name">PerceptionComponent</string>
                <string name="Source"><![CDATA[local PerceptionComponent = {}
PerceptionComponent.__index = PerceptionComponent

function PerceptionComponent.new(options)
    local runtimeOptions = options or {}

    return setmetatable({
        GetPlayers = runtimeOptions.GetPlayers,
        CanTargetPlayer = runtimeOptions.CanTargetPlayer,
        GetCurrentPosition = runtimeOptions.GetCurrentPosition,
        PickNearestTarget = runtimeOptions.PickNearestTarget,
        SightRange = runtimeOptions.SightRange,
        EnableSenseNearestTarget = runtimeOptions.EnableSenseNearestTarget,
        GetNow = runtimeOptions.GetNow,
    }, PerceptionComponent)
end

function PerceptionComponent:update(blackboard)
    local playerPositions = {}

    for _, player in ipairs(self.GetPlayers()) do
        if self.CanTargetPlayer(player) then
            local character = player.Character
            local rootPart = character and character:FindFirstChild('HumanoidRootPart')
            if rootPart then
                playerPositions[player] = rootPart.Position
            end
        end
    end

    blackboard.TargetPositions = playerPositions

    local targetPlayer
    if self.EnableSenseNearestTarget then
        targetPlayer =
            self.PickNearestTarget(self.GetCurrentPosition(), playerPositions, self.SightRange)
    end

    local previousTarget = blackboard.CurrentTarget
    local now = self.GetNow()
    blackboard:setTarget(targetPlayer, playerPositions[targetPlayer], now)

    return targetPlayer ~= previousTarget
end

return PerceptionComponent
]]></string>
              </Properties>
            </Item>
          </Item>
          <Item class="ModuleScript" referent="90">
            <Properties>
              <string name="Name">MonsterService</string>
              <string name="Source"><![CDATA[local InsertService = game:GetService('InsertService')
local Players = game:GetService('Players')
local ReplicatedStorage = game:GetService('ReplicatedStorage')
local RunService = game:GetService('RunService')
local Workspace = game:GetService('Workspace')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Gameplay = require(Packages:WaitForChild('Gameplay'))

local MonsterBehaviorCatalog = Gameplay.Monsters.MonsterBehaviorCatalog
local MonsterComponentConfig = Gameplay.Monsters.MonsterComponentConfig
local MonsterLogic = Gameplay.Monsters.MonsterLogic
local Enemy = Gameplay.Monsters.Enemy
local MonsterRuntimeProfile = Gameplay.Monsters.MonsterRuntimeProfile
local PlayerMonsterMelee = Gameplay.Combat.PlayerMonsterMelee
local EnemyRuntime = require(script.Parent.MonsterRuntime.EnemyRuntime)

local MonsterService = {}
MonsterService.__index = MonsterService

local DEFAULT_FALLBACK_SIZE = Vector3.new(4, 4, 4)
local DEFAULT_R6_ANIMATIONS = table.freeze({
    Idle = 180435571,
    Walk = 180426354,
    Run = 180426354,
    Attack = 10469493270,
})
local DEFAULT_CHASE_LOOP_VOLUME = 0.45
local DEFAULT_CHASE_LOOP_MIN_DISTANCE = 8
local DEFAULT_CHASE_LOOP_MAX_DISTANCE = 48
local DEFAULT_ATTACK_ARC_DEGREES = 100
local DEFAULT_ATTACK_MARKER_NAME = 'Hit'
local DEFAULT_ATTACK_MARKER_TIMEOUT_SECONDS = 1.5
local DEFAULT_VISUAL_SMOOTHING_SPEED = 12
local DEFAULT_LOGIC_TICK_RATE_HZ = 10
local DEFAULT_MAX_LOGIC_STEPS_PER_UPDATE = 6
local DEFAULT_DECISION_LOG_LIMIT = 128

local function defaultOnAttackHit(_player, _damagePips, _hitContext) end

local function defaultRaycast(origin, direction, raycastParams)
    return Workspace:Raycast(origin, direction, raycastParams)
end

local function defaultWarn(message)
    warn(message)
end

local function defaultLoadMonsterModel(assetId)
    local ok, assetContainer = pcall(function()
        return InsertService:LoadAsset(assetId)
    end)
    if not ok then
        return nil, assetContainer
    end

    local model = if assetContainer:IsA('Model')
        then assetContainer:FindFirstChildWhichIsA('Model') or assetContainer
        else assetContainer:FindFirstChildWhichIsA('Model')
    if not model then
        assetContainer:Destroy()
        return nil, 'MissingModelInAsset'
    end

    local clone = model:Clone()
    assetContainer:Destroy()
    return clone
end

local function defaultLoadAnimationTrack(animator, animationId, animationName)
    local animation = Instance.new('Animation')
    animation.Name = animationName
    animation.AnimationId = string.format('rbxassetid://%d', animationId)

    local track = animator:LoadAnimation(animation)
    animation:Destroy()

    return track
end

local function defaultCreateLoopSound(parent, soundAssetId, soundName)
    local sound = Instance.new('Sound')
    sound.Name = soundName
    sound.SoundId = string.format('rbxassetid://%d', soundAssetId)
    sound.Looped = true
    sound.Volume = DEFAULT_CHASE_LOOP_VOLUME
    sound.RollOffMode = Enum.RollOffMode.InverseTapered
    sound.RollOffMinDistance = DEFAULT_CHASE_LOOP_MIN_DISTANCE
    sound.RollOffMaxDistance = DEFAULT_CHASE_LOOP_MAX_DISTANCE
    sound.Parent = parent

    return sound
end

local function defaultEnemyFactory(monsterRuntimeProfile, options)
    return Enemy.new(monsterRuntimeProfile, options)
end

function MonsterService.new(
    monsterRuntimeProfile,
    isExpeditionActiveCallback,
    canTargetPlayerCallback,
    canTraverseCallback,
    options
)
    local validRuntimeProfile, runtimeReason = MonsterRuntimeProfile.validate(monsterRuntimeProfile)
    if not validRuntimeProfile then
        error(string.format('Monster runtime profile invalid: %s', tostring(runtimeReason)), 0)
    end

    local runtimeOptions = options or {}
    local logicTickRateHz = runtimeOptions.LogicTickRateHz or DEFAULT_LOGIC_TICK_RATE_HZ
    if type(logicTickRateHz) ~= 'number' or logicTickRateHz <= 0 then
        logicTickRateHz = DEFAULT_LOGIC_TICK_RATE_HZ
    end

    local randomSeed = runtimeOptions.RandomSeed
    if type(randomSeed) == 'number' then
        randomSeed = math.floor(randomSeed)
        if randomSeed <= 0 then
            randomSeed = nil
        end
    else
        randomSeed = nil
    end

    local service = setmetatable({
        Definition = monsterRuntimeProfile,
        IsExpeditionActive = isExpeditionActiveCallback,
        CanTargetPlayer = canTargetPlayerCallback or function()
            return true
        end,
        CanTraverse = canTraverseCallback or function()
            return true
        end,
        PatrolPoints = {},
        PatrolIndex = 1,
        MonsterRoot = nil,
        MonsterPositionPart = nil,
        MonsterHumanoid = nil,
        ChaseLoopSound = nil,
        IsChaseLoopSoundPlaying = false,
        AnimationTracks = {},
        AttackAnimationTrack = nil,
        AttackMarkerConnection = nil,
        PendingAttack = nil,
        ActiveAnimation = nil,
        Connection = nil,
        LogicalPosition = nil,
        EnemyRuntime = nil,
        ComponentConfig = MonsterComponentConfig.fromRuntimeProfile(monsterRuntimeProfile),
        Warn = runtimeOptions.Warn or defaultWarn,
        LoadMonsterModel = runtimeOptions.AssetLoader or defaultLoadMonsterModel,
        LoadAnimationTrack = runtimeOptions.LoadAnimationTrack or defaultLoadAnimationTrack,
        CreateLoopSound = runtimeOptions.CreateLoopSound or defaultCreateLoopSound,
        EnemyFactory = runtimeOptions.EnemyFactory or defaultEnemyFactory,
        OnAttackHit = runtimeOptions.OnAttackHit or defaultOnAttackHit,
        Raycast = runtimeOptions.Raycast or defaultRaycast,
        GetPlayers = runtimeOptions.GetPlayers or function()
            return Players:GetPlayers()
        end,
        AttackMarkerTimeoutSeconds = runtimeOptions.AttackMarkerTimeoutSeconds
            or DEFAULT_ATTACK_MARKER_TIMEOUT_SECONDS,
        VisualSmoothingSpeed = runtimeOptions.VisualSmoothingSpeed
            or DEFAULT_VISUAL_SMOOTHING_SPEED,
        AutoUpdateOnHeartbeat = if runtimeOptions.AutoUpdateOnHeartbeat == nil
            then true
            else runtimeOptions.AutoUpdateOnHeartbeat == true,
        LogicTickRateHz = logicTickRateHz,
        LogicTickSeconds = 1 / logicTickRateHz,
        MaxLogicStepsPerUpdate = runtimeOptions.MaxLogicStepsPerUpdate
            or DEFAULT_MAX_LOGIC_STEPS_PER_UPDATE,
        LogicAccumulator = 0,
        LogicTickCount = 0,
        LastState = nil,
        LastTargetUserId = nil,
        PendingVisualCFrame = nil,
        DecisionLogLimit = runtimeOptions.DecisionLogLimit or DEFAULT_DECISION_LOG_LIMIT,
        DecisionLog = {},
        DecisionLogSink = runtimeOptions.DecisionLogSink,
        DecisionLogSequence = 0,
        RandomSeed = randomSeed,
        RandomSource = runtimeOptions.RandomSource
            or if randomSeed ~= nil then Random.new(randomSeed) else Random.new(),
        CombatHitPointsRemaining = nil,
    }, MonsterService)

    service.EnemyRuntime = EnemyRuntime.new({
        MemoryDurationSeconds = runtimeOptions.MemoryDurationSeconds,
        Perception = {
            GetPlayers = function()
                return service.GetPlayers()
            end,
            CanTargetPlayer = function(player)
                return service.CanTargetPlayer(player)
            end,
            GetCurrentPosition = function()
                return service:_getCurrentPosition()
            end,
            PickNearestTarget = MonsterLogic.pickNearestTarget,
            SightRange = monsterRuntimeProfile.SightRange,
            EnableSenseNearestTarget = monsterRuntimeProfile.Behaviors[MonsterBehaviorCatalog.Behavior.SenseNearestTarget]
                == true,
            GetNow = os.clock,
        },
        Movement = {
            StepToward = MonsterLogic.stepToward,
            GetCurrentPosition = function()
                return service:_getCurrentPosition()
            end,
            SpawnOffset = monsterRuntimeProfile.SpawnOffset,
            Speed = monsterRuntimeProfile.Speed,
            PatrolSpeedMultiplier = monsterRuntimeProfile.PatrolSpeedMultiplier,
            EnableChase = monsterRuntimeProfile.Behaviors[MonsterBehaviorCatalog.Behavior.Chase]
                == true,
            EnablePatrol = monsterRuntimeProfile.Behaviors[MonsterBehaviorCatalog.Behavior.Patrol]
                == true,
        },
        Attack = {
            AttackRange = monsterRuntimeProfile.AttackRange or 0,
            CooldownSeconds = monsterRuntimeProfile.AttackCooldownSeconds,
        },
    })

    local combatHp = monsterRuntimeProfile.CombatHitPoints
    if type(combatHp) ~= 'number' or combatHp < 1 or math.floor(combatHp) ~= combatHp then
        combatHp = 1
    else
        combatHp = math.floor(combatHp)
    end
    service.CombatMaxHealth = combatHp
    service.CombatCurrentHealth = combatHp

    return service
end

function MonsterService:_emitDecisionLog(eventName, fields)
    self:_recordDecisionEvent(eventName, fields)
end

function MonsterService:destroy()
    if self.Connection then
        self.Connection:Disconnect()
        self.Connection = nil
    end

    if self.AttackMarkerConnection then
        self.AttackMarkerConnection:Disconnect()
        self.AttackMarkerConnection = nil
    end

    for _, track in pairs(self.AnimationTracks) do
        if track.Stop then
            track:Stop(0)
        end
    end
    if self.AttackAnimationTrack and self.AttackAnimationTrack.Stop then
        self.AttackAnimationTrack:Stop(0)
    end

    self.AnimationTracks = {}
    self.AttackAnimationTrack = nil
    self.PendingAttack = nil
    self.ActiveAnimation = nil
    self.MonsterHumanoid = nil
    self.CombatHitPointsRemaining = nil
    self.MonsterPositionPart = nil
    self.LogicalPosition = nil
    self.LogicAccumulator = 0
    self.LogicTickCount = 0
    self.LastState = nil
    self.LastTargetUserId = nil
    self.PendingVisualCFrame = nil
    if self.EnemyRuntime then
        self.EnemyRuntime:destroy()
        self.EnemyRuntime = nil
    end

    if self.ChaseLoopSound then
        if self.ChaseLoopSound.Stop then
            self.ChaseLoopSound:Stop()
        end
        if self.ChaseLoopSound.Destroy then
            self.ChaseLoopSound:Destroy()
        end
        self.ChaseLoopSound = nil
    end
    self.IsChaseLoopSoundPlaying = false

    if self.MonsterRoot then
        self.MonsterRoot:Destroy()
        self.MonsterRoot = nil
    end
end

function MonsterService:_warnFallback(reason)
    self.Warn(
        string.format(
            '[MonsterService] Falling back to placeholder for %s: %s',
            tostring(self.Definition.Id),
            tostring(reason)
        )
    )
end

function MonsterService:_createFallbackPart(spawnPosition)
    local monster = Instance.new('Part')
    monster.Name = self.Definition.Name
    monster.Shape = Enum.PartType.Ball
    monster.Size = DEFAULT_FALLBACK_SIZE
    monster.Anchored = true
    monster.CanCollide = false
    monster.CanTouch = false
    monster.Material = Enum.Material.Neon
    monster.Color = Color3.fromRGB(214, 91, 91)
    monster.Position = spawnPosition
    monster.Parent = Workspace

    self.MonsterRoot = monster
    self.MonsterPositionPart = monster
    self.LogicalPosition = spawnPosition
    self:_attachChaseLoopSound(monster)
end

function MonsterService:_prepareModelForRuntime(model)
    if not model or not model:IsA('Model') then
        return nil, nil, nil, 'MonsterAssetMustBeModel'
    end

    local humanoid = model:FindFirstChildOfClass('Humanoid')
    if humanoid == nil then
        return nil, nil, nil, 'MonsterAssetMissingHumanoid'
    end

    local rootPart = model:FindFirstChild('HumanoidRootPart')
    if rootPart == nil then
        rootPart = model.PrimaryPart or model:FindFirstChildWhichIsA('BasePart')
    end

    if rootPart == nil or not rootPart:IsA('BasePart') then
        return nil, nil, nil, 'MonsterAssetMissingRootPart'
    end

    for _, descendant in ipairs(model:GetDescendants()) do
        if descendant:IsA('BasePart') then
            descendant.Anchored = true
            descendant.CanCollide = false
            descendant.CanTouch = false
            descendant.CanQuery = false
        end
    end

    model.PrimaryPart = rootPart
    model.Name = self.Definition.Name

    return model, rootPart, humanoid
end

function MonsterService:_loadAnimationTracks(humanoid)
    local animator = humanoid:FindFirstChildOfClass('Animator')
    if animator == nil then
        animator = Instance.new('Animator')
        animator.Parent = humanoid
    end

    local animationTracks = {
        Idle = self.LoadAnimationTrack(animator, DEFAULT_R6_ANIMATIONS.Idle, 'MonsterIdle'),
        Walk = self.LoadAnimationTrack(animator, DEFAULT_R6_ANIMATIONS.Walk, 'MonsterWalk'),
        Run = self.LoadAnimationTrack(animator, DEFAULT_R6_ANIMATIONS.Run, 'MonsterRun'),
    }

    if animationTracks.Idle then
        animationTracks.Idle.Looped = true
        animationTracks.Idle.Priority = Enum.AnimationPriority.Idle
    end

    if animationTracks.Walk then
        animationTracks.Walk.Looped = true
        animationTracks.Walk.Priority = Enum.AnimationPriority.Movement
    end

    if animationTracks.Run then
        animationTracks.Run.Looped = true
        animationTracks.Run.Priority = Enum.AnimationPriority.Movement
    end

    local attackTrack =
        self.LoadAnimationTrack(animator, DEFAULT_R6_ANIMATIONS.Attack, 'MonsterAttack')
    if attackTrack then
        attackTrack.Looped = false
        attackTrack.Priority = Enum.AnimationPriority.Action
        if attackTrack.GetMarkerReachedSignal then
            local markerSignal = attackTrack:GetMarkerReachedSignal(DEFAULT_ATTACK_MARKER_NAME)
            if markerSignal then
                self.AttackMarkerConnection = markerSignal:Connect(function()
                    self:_onAttackMarkerReached(DEFAULT_ATTACK_MARKER_NAME)
                end)
            end
        end
    end

    self.AnimationTracks = animationTracks
    self.AttackAnimationTrack = attackTrack
    self.MonsterHumanoid = humanoid
end

function MonsterService:_attachChaseLoopSound(parent)
    local soundAssetId = self.Definition.Presentation.ChaseLoopSoundAssetId
    if parent == nil or type(soundAssetId) ~= 'number' or soundAssetId <= 0 then
        return
    end

    local soundOk, soundOrErr = pcall(function()
        return self.CreateLoopSound(parent, soundAssetId, 'MonsterChaseLoop')
    end)
    if not soundOk then
        self:_warnFallback(string.format('ChaseLoopSoundFailed (%s)', tostring(soundOrErr)))
        return
    end

    self.ChaseLoopSound = soundOrErr
    self.IsChaseLoopSoundPlaying = false
end

function MonsterService:_spawnModel(spawnPosition)
    local presentation = self.Definition.Presentation
    local model, loadReason = self.LoadMonsterModel(presentation.ModelAssetId)
    if not model then
        return false, loadReason
    end

    local preparedModel, rootPart, humanoid, prepareReason = self:_prepareModelForRuntime(model)
    if not preparedModel then
        model:Destroy()
        return false, prepareReason
    end

    preparedModel.Parent = Workspace
    preparedModel:PivotTo(CFrame.new(spawnPosition))

    if presentation.AnimationMode == 'defaultR6' then
        local animationOk, animationErr = pcall(function()
            self:_loadAnimationTracks(humanoid)
        end)
        if not animationOk then
            self:_warnFallback(string.format('AnimationLoadFailed (%s)', tostring(animationErr)))
        end
    end

    self.MonsterRoot = preparedModel
    self.MonsterPositionPart = rootPart
    self.LogicalPosition = spawnPosition
    if self.MonsterHumanoid == nil then
        self.MonsterHumanoid = humanoid
    end
    self:_attachChaseLoopSound(rootPart)

    return true
end

function MonsterService:_applyDefinitionCombatHealth()
    local maxPips = self.Definition.CombatHitPoints
    if type(maxPips) ~= 'number' or maxPips < 1 or math.floor(maxPips) ~= maxPips then
        maxPips = 1
    end

    self.CombatMaxHealth = maxPips

    local humanoid = self.MonsterHumanoid
    if humanoid then
        humanoid.MaxHealth = maxPips
        humanoid.Health = maxPips
        self.CombatCurrentHealth = maxPips
        self.CombatHitPointsRemaining = nil
        return
    end

    self.CombatHitPointsRemaining = maxPips
    self.CombatCurrentHealth = maxPips
end

function MonsterService:_setAnimationState(animationName, speedMultiplier)
    if self.ActiveAnimation == animationName then
        local activeTrack = self.AnimationTracks[animationName]
        if activeTrack and activeTrack.AdjustSpeed then
            activeTrack:AdjustSpeed(speedMultiplier or 1)
        end
        return
    end

    for trackName, track in pairs(self.AnimationTracks) do
        if trackName ~= animationName and track and track.Stop then
            track:Stop(0.1)
        end
    end

    local nextTrack = self.AnimationTracks[animationName]
    if nextTrack then
        if nextTrack.Play then
            nextTrack:Play(0.1)
        end
        if nextTrack.AdjustSpeed then
            nextTrack:AdjustSpeed(speedMultiplier or 1)
        end
    end

    self.ActiveAnimation = animationName
end

function MonsterService:_getCurrentPosition()
    if self.LogicalPosition then
        return self.LogicalPosition
    end

    if not self.MonsterPositionPart then
        return nil
    end

    return self.MonsterPositionPart.Position
end

function MonsterService:_setChaseLoopSoundPlaying(shouldPlay)
    if not self.ChaseLoopSound then
        return
    end

    local isPlaying = self.IsChaseLoopSoundPlaying == true or self.ChaseLoopSound.IsPlaying == true
    if shouldPlay then
        if not isPlaying and self.ChaseLoopSound.Play then
            self.ChaseLoopSound:Play()
        end
        self.IsChaseLoopSoundPlaying = true
        return
    end

    if isPlaying and self.ChaseLoopSound.Stop then
        self.ChaseLoopSound:Stop()
    end
    self.IsChaseLoopSoundPlaying = false
end

function MonsterService:_applyVisualCFrame(nextCFrame, dt)
    if self.MonsterRoot == nil then
        return
    end

    local appliedCFrame = nextCFrame
    local smoothingAlpha = 1
    if type(dt) == 'number' and dt > 0 then
        smoothingAlpha = 1 - math.exp(-self.VisualSmoothingSpeed * dt)
        smoothingAlpha = math.clamp(smoothingAlpha, 0, 1)
    end

    local currentCFrame
    if self.MonsterRoot:IsA('Model') then
        currentCFrame = self.MonsterRoot:GetPivot()
    elseif self.MonsterRoot:IsA('BasePart') then
        currentCFrame = self.MonsterRoot.CFrame
    end

    if currentCFrame and smoothingAlpha < 1 then
        appliedCFrame = currentCFrame:Lerp(nextCFrame, smoothingAlpha)
    end

    if self.MonsterRoot:IsA('Model') then
        self.MonsterRoot:PivotTo(appliedCFrame)
    elseif self.MonsterRoot:IsA('BasePart') then
        self.MonsterRoot.CFrame = appliedCFrame
    end
end

function MonsterService:_recordDecisionEvent(eventName, fields)
    self.DecisionLogSequence += 1

    local entry = {
        Event = eventName,
        MonsterId = self.Definition.Id,
        Sequence = self.DecisionLogSequence,
        Tick = self.LogicTickCount,
    }

    for key, value in pairs(fields or {}) do
        entry[key] = value
    end

    table.insert(self.DecisionLog, entry)
    if #self.DecisionLog > self.DecisionLogLimit then
        table.remove(self.DecisionLog, 1)
    end

    if self.DecisionLogSink then
        self.DecisionLogSink(entry)
    end
end

function MonsterService:getDecisionLogSnapshot()
    local snapshot = {}
    for index, entry in ipairs(self.DecisionLog) do
        snapshot[index] = table.clone(entry)
    end
    return snapshot
end

function MonsterService:clearDecisionLog()
    table.clear(self.DecisionLog)
    self.DecisionLogSequence = 0
end

function MonsterService:setDeterministicSeed(seed, randomSource)
    local normalizedSeed = seed
    if type(normalizedSeed) == 'number' then
        normalizedSeed = math.floor(normalizedSeed)
        if normalizedSeed <= 0 then
            normalizedSeed = nil
        end
    else
        normalizedSeed = nil
    end

    self.RandomSeed = normalizedSeed
    self.RandomSource = randomSource
        or if normalizedSeed ~= nil then Random.new(normalizedSeed) else Random.new()
    self:_recordDecisionEvent('SeedUpdated', {
        Seed = self.RandomSeed,
    })
end

function MonsterService:_nextRandomInteger(minimum, maximum, reason)
    local result = self.RandomSource:NextInteger(minimum, maximum)
    self:_recordDecisionEvent('RandomRoll', {
        Maximum = maximum,
        Minimum = minimum,
        Reason = reason or 'unspecified',
        Result = result,
        Seed = self.RandomSeed,
    })
    return result
end

function MonsterService:_resolveTargetUserId(targetPlayer)
    if targetPlayer == nil then
        return nil
    end

    if typeof(targetPlayer) == 'Instance' and targetPlayer:IsA('Player') then
        return targetPlayer.UserId
    end

    if type(targetPlayer) == 'table' and type(targetPlayer.UserId) == 'number' then
        return targetPlayer.UserId
    end

    return tostring(targetPlayer)
end

function MonsterService:_recordDecisionTransitions(decision)
    local state = decision.State
    if type(state) == 'string' and state ~= self.LastState then
        self:_recordDecisionEvent('StateTransition', {
            FromState = self.LastState,
            ToState = state,
        })
        self.LastState = state
    end

    local targetUserId = self:_resolveTargetUserId(decision.TargetPlayer)
    if targetUserId ~= self.LastTargetUserId then
        self:_recordDecisionEvent('TargetSwitch', {
            FromTargetUserId = self.LastTargetUserId,
            ToTargetUserId = targetUserId,
        })
        self.LastTargetUserId = targetUserId
    end

    if decision.AttackResult ~= nil then
        self:_recordDecisionEvent('AttackResult', {
            Result = decision.AttackResult,
        })
    end
end

function MonsterService:_getAttackFacingDirection()
    local lookVector = nil
    if self.MonsterRoot and self.MonsterRoot:IsA('Model') then
        lookVector = self.MonsterRoot:GetPivot().LookVector
    elseif self.MonsterPositionPart then
        lookVector = self.MonsterPositionPart.CFrame.LookVector
    end

    if typeof(lookVector) ~= 'Vector3' then
        return Vector3.new(0, 0, -1)
    end

    local horizontalLook = Vector3.new(lookVector.X, 0, lookVector.Z)
    if horizontalLook.Magnitude <= 1e-5 then
        return lookVector.Unit
    end

    return horizontalLook.Unit
end

function MonsterService:_isWithinAttackArc(monsterPosition, targetPosition, arcDegrees)
    local toTarget = targetPosition - monsterPosition
    local horizontalToTarget = Vector3.new(toTarget.X, 0, toTarget.Z)
    if horizontalToTarget.Magnitude <= 1e-5 then
        return true
    end

    local facingDirection = self:_getAttackFacingDirection()
    local facingHorizontal = Vector3.new(facingDirection.X, 0, facingDirection.Z)
    if facingHorizontal.Magnitude <= 1e-5 then
        return true
    end
    facingHorizontal = facingHorizontal.Unit

    local targetDirection = horizontalToTarget.Unit
    local halfArcCosine = math.cos(math.rad((arcDegrees or DEFAULT_ATTACK_ARC_DEGREES) * 0.5))
    local dot = facingHorizontal:Dot(targetDirection)
    return dot + 1e-6 >= halfArcCosine
end

function MonsterService:_hasLineOfSight(targetPlayer, originPosition, targetPosition)
    local direction = targetPosition - originPosition
    if direction.Magnitude <= 1e-5 then
        return true
    end

    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.IgnoreWater = true
    if self.MonsterRoot then
        raycastParams.FilterDescendantsInstances = { self.MonsterRoot }
    end

    local raycastResult = self.Raycast(originPosition, direction, raycastParams)
    if raycastResult == nil then
        return true
    end

    local character = targetPlayer and targetPlayer.Character
    if
        character
        and raycastResult.Instance
        and raycastResult.Instance:IsDescendantOf(character)
    then
        return true
    end

    return false
end

function MonsterService:_resolveAttackHitContext(pendingAttack)
    local targetPlayer = pendingAttack.TargetPlayer
    if targetPlayer == nil or not self.CanTargetPlayer(targetPlayer) then
        return {
            Hit = false,
            Reason = 'InvalidTarget',
        }
    end

    local targetCharacter = targetPlayer.Character
    local targetRoot = targetCharacter and targetCharacter:FindFirstChild('HumanoidRootPart')
    if not targetRoot then
        return {
            Hit = false,
            Reason = 'MissingTargetRoot',
        }
    end

    local monsterPosition = self:_getCurrentPosition()
    if typeof(monsterPosition) ~= 'Vector3' then
        return {
            Hit = false,
            Reason = 'MissingMonsterPosition',
        }
    end

    local targetPosition = targetRoot.Position
    local distance = (targetPosition - monsterPosition).Magnitude
    if distance > pendingAttack.Range then
        return {
            Hit = false,
            Reason = 'OutOfRange',
        }
    end

    if not self:_isWithinAttackArc(monsterPosition, targetPosition, pendingAttack.ArcDegrees) then
        return {
            Hit = false,
            Reason = 'OutOfArc',
        }
    end

    if not self:_hasLineOfSight(targetPlayer, monsterPosition, targetPosition) then
        return {
            Hit = false,
            Reason = 'BlockedLineOfSight',
        }
    end

    return {
        Hit = true,
        Reason = 'HitConfirmed',
        Distance = distance,
    }
end

function MonsterService:_playAttackAnimation()
    local attackTrack = self.AttackAnimationTrack
    if not attackTrack then
        return false
    end

    if attackTrack.Stop then
        attackTrack:Stop(0)
    end
    if attackTrack.Play then
        attackTrack:Play(0.05)
    else
        return false
    end
    if attackTrack.AdjustSpeed then
        attackTrack:AdjustSpeed(1)
    end

    return true
end

function MonsterService:_queueAttackIntent(attackIntent)
    if type(attackIntent) ~= 'table' then
        return
    end

    local targetPlayer = attackIntent.TargetPlayer
    if targetPlayer == nil or not self.CanTargetPlayer(targetPlayer) then
        return
    end

    local damagePips = attackIntent.DamagePips
    if damagePips ~= 1 and damagePips ~= 2 then
        return
    end

    local range = attackIntent.Range
    if type(range) ~= 'number' or range <= 0 then
        return
    end

    local markerName = if type(attackIntent.MarkerName) == 'string'
            and attackIntent.MarkerName ~= ''
        then attackIntent.MarkerName
        else DEFAULT_ATTACK_MARKER_NAME

    local hasMarkerConnection = self.AttackMarkerConnection ~= nil
    if hasMarkerConnection then
        if self.PendingAttack ~= nil then
            return
        end

        self.PendingAttack = {
            ArcDegrees = attackIntent.ArcDegrees or DEFAULT_ATTACK_ARC_DEGREES,
            DamagePips = damagePips,
            MarkerName = markerName,
            Range = range,
            RemainingWindowSeconds = self.AttackMarkerTimeoutSeconds,
            TargetPlayer = targetPlayer,
        }
    end

    local animationPlayed = self:_playAttackAnimation()
    if hasMarkerConnection and not animationPlayed then
        self.PendingAttack = nil
    end
end

function MonsterService:_stepPendingAttack(dt)
    if self.PendingAttack == nil then
        return
    end

    self.PendingAttack.RemainingWindowSeconds -= math.max(0, dt or 0)
    if self.PendingAttack.RemainingWindowSeconds <= 0 then
        self.PendingAttack = nil
    end
end

function MonsterService:_onAttackMarkerReached(markerName)
    local pendingAttack = self.PendingAttack
    if pendingAttack == nil then
        return
    end

    if markerName ~= pendingAttack.MarkerName then
        return
    end

    self.PendingAttack = nil

    local hitContext = self:_resolveAttackHitContext(pendingAttack)
    if hitContext.Hit ~= true then
        return
    end

    self.OnAttackHit(pendingAttack.TargetPlayer, pendingAttack.DamagePips, hitContext)
end

function MonsterService:_playerMeleeLineOfSightClear(player, playerPosition, monsterPosition)
    local offset = monsterPosition - playerPosition
    local distance = offset.Magnitude
    if distance <= 1e-3 then
        return true
    end

    local character = player and player.Character
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.IgnoreWater = true
    if character then
        raycastParams.FilterDescendantsInstances = { character }
    end

    local direction = offset.Unit * (distance + 0.25)
    local result = self.Raycast(playerPosition, direction, raycastParams)
    if result == nil then
        return true
    end

    if
        self.MonsterRoot
        and result.Instance
        and result.Instance:IsDescendantOf(self.MonsterRoot)
    then
        return true
    end

    return false
end

function MonsterService:tryApplyPlayerMeleeHit(player, meleeOptions)
    if not self.IsExpeditionActive() then
        return false, 'ExpeditionInactive'
    end

    if self.MonsterRoot == nil then
        return false, 'NoMonster'
    end

    local isPlayerInstance = typeof(player) == 'Instance' and player:IsA('Player')
    local isTestStub = type(player) == 'table' and type(player.UserId) == 'number'
    if not isPlayerInstance and not isTestStub then
        return false, 'InvalidPlayer'
    end

    local character = player.Character
    if character == nil then
        return false, 'NoCharacter'
    end

    local humanoidRoot = character:FindFirstChild('HumanoidRootPart')
    if humanoidRoot == nil or not humanoidRoot:IsA('BasePart') then
        return false, 'MissingHumanoidRoot'
    end

    local options = meleeOptions or {}
    local swingRange = options.SwingRange
    if type(swingRange) ~= 'number' or swingRange <= 0 then
        swingRange = 6
    end

    local swingArcDegrees = options.SwingArcDegrees
    if type(swingArcDegrees) ~= 'number' or swingArcDegrees <= 0 then
        swingArcDegrees = 70
    end

    local damagePips = options.DamagePips
    if type(damagePips) ~= 'number' or damagePips < 1 then
        damagePips = 1
    end
    damagePips = math.floor(damagePips)

    local monsterPosition = self:_getCurrentPosition()
    if typeof(monsterPosition) ~= 'Vector3' then
        return false, 'MissingMonsterPosition'
    end

    local playerPosition = humanoidRoot.Position
    local playerLook = humanoidRoot.CFrame.LookVector

    local geometryOk, geometryReason = PlayerMonsterMelee.evaluateSwing(
        playerPosition,
        playerLook,
        monsterPosition,
        swingRange,
        swingArcDegrees
    )
    if geometryOk ~= true then
        return false, geometryReason
    end

    if not self.CanTraverse(playerPosition, monsterPosition) then
        return false, 'PathBlocked'
    end

    if not self:_playerMeleeLineOfSightClear(player, playerPosition, monsterPosition) then
        return false, 'BlockedLineOfSight'
    end

    local monsterHumanoid = self.MonsterHumanoid
    local killed = false
    local remainingHitPoints

    if monsterHumanoid then
        local nextHealth = math.max(0, monsterHumanoid.Health - damagePips)
        monsterHumanoid.Health = nextHealth
        remainingHitPoints = math.ceil(nextHealth)
        self.CombatCurrentHealth = remainingHitPoints
        if nextHealth <= 0 then
            killed = true
        end
    elseif type(self.CombatHitPointsRemaining) == 'number' then
        self.CombatHitPointsRemaining -= damagePips
        remainingHitPoints = math.max(0, self.CombatHitPointsRemaining)
        self.CombatCurrentHealth = remainingHitPoints
        if remainingHitPoints <= 0 then
            killed = true
        end
    else
        return false, 'MonsterCombatStateMissing'
    end

    self:_recordDecisionEvent('PlayerMeleeHit', {
        DamagePips = damagePips,
        Killed = killed,
        RemainingHitPoints = remainingHitPoints,
        TargetUserId = player.UserId,
    })

    if killed then
        self:destroy()
    end

    return true, {
        Killed = killed,
        RemainingHitPoints = remainingHitPoints,
    }
end

function MonsterService:spawn(patrolPoints, initialPatrolIndex)
    self:destroy()
    self.PatrolPoints = patrolPoints
    self.PatrolIndex = 1
    self.LogicAccumulator = 0
    self.LogicTickCount = 0
    self.LastState = nil
    self.LastTargetUserId = nil
    self.PendingVisualCFrame = nil
    self:clearDecisionLog()

    if #patrolPoints == 0 then
        return
    end

    self.PatrolIndex = math.clamp(initialPatrolIndex or 1, 1, #patrolPoints)
    self.EnemyRuntime:reset(self.PatrolPoints, self.PatrolIndex)
    local spawnPosition = patrolPoints[self.PatrolIndex] + self.Definition.SpawnOffset
    local spawnOk, spawnReason = self:_spawnModel(spawnPosition)
    if not spawnOk then
        self:_warnFallback(spawnReason)
        self:_createFallbackPart(spawnPosition)
    else
        self:_setAnimationState('Idle', 1)
    end

    self:_applyDefinitionCombatHealth()

    self.EnemyRuntime = self.EnemyFactory(self.Definition, {
        ComponentConfig = self.ComponentConfig,
    })
    if self.EnemyRuntime and self.EnemyRuntime.spawn then
        self.EnemyRuntime:spawn()
    end

    if self.AutoUpdateOnHeartbeat then
        self.Connection = RunService.Heartbeat:Connect(function(dt)
            self:update(dt)
        end)
    end
end

function MonsterService:_runLogicStep(dt)
    local currentPosition = self:_getCurrentPosition()
    if currentPosition == nil then
        return
    end

    local decision = self.EnemyRuntime:update(dt)
    self.PatrolIndex = self.EnemyRuntime.Context.PatrolIndex

    if decision.TargetChanged then
        self:_emitDecisionLog('TargetChanged', {
            MonsterId = self.Definition.Id,
            State = decision.PerceptionState,
        })
    end
    if decision.StateChanged then
        self:_emitDecisionLog('StateChanged', {
            MonsterId = self.Definition.Id,
            State = decision.PerceptionState,
        })
    end
    if decision.AttackQueued then
        self:_emitDecisionLog('AttackQueued', {
            MonsterId = self.Definition.Id,
        })
    end

    local nextPosition = decision.NextPosition
    if nextPosition and self.CanTraverse(currentPosition, nextPosition) then
        local travelOffset = nextPosition - currentPosition
        self.LogicalPosition = nextPosition
        local currentRotation = CFrame.identity
        if self.MonsterRoot and self.MonsterRoot:IsA('Model') then
            currentRotation = self.MonsterRoot:GetPivot().Rotation
        elseif self.MonsterRoot and self.MonsterRoot:IsA('BasePart') then
            currentRotation = self.MonsterRoot.CFrame.Rotation
        end
        local facingCFrame = if travelOffset.Magnitude > 0
            then CFrame.lookAt(nextPosition, nextPosition + travelOffset.Unit)
            else currentRotation + nextPosition
        self.PendingVisualCFrame = facingCFrame

        self:_setAnimationState(decision.AnimationName or 'Idle', decision.AnimationSpeed or 1)
        self:_setChaseLoopSoundPlaying(decision.ShouldPlayChaseLoop == true)
    else
        self.PendingVisualCFrame = nil
        self:_setAnimationState('Idle', 1)
        self:_setChaseLoopSoundPlaying(false)
    end

    self:_recordDecisionTransitions(decision)
end

function MonsterService:update(dt)
    if not self.MonsterPositionPart or not self.IsExpeditionActive() or not self.EnemyRuntime then
        return
    end

    local elapsed = if type(dt) == 'number' and dt > 0 then dt else 0
    self:_stepPendingAttack(elapsed)
    self.LogicAccumulator += elapsed

    local maxSteps = self.MaxLogicStepsPerUpdate
    if type(maxSteps) ~= 'number' or maxSteps < 1 then
        maxSteps = DEFAULT_MAX_LOGIC_STEPS_PER_UPDATE
    end
    maxSteps = math.max(1, math.floor(maxSteps))

    local executed = 0
    while self.LogicAccumulator >= self.LogicTickSeconds and executed < maxSteps do
        self.LogicAccumulator -= self.LogicTickSeconds
        self.LogicTickCount += 1
        executed += 1
        self:_runLogicStep(self.LogicTickSeconds)
    end

    if self.LogicAccumulator >= self.LogicTickSeconds then
        local droppedTime = self.LogicAccumulator - (self.LogicAccumulator % self.LogicTickSeconds)
        self.LogicAccumulator = self.LogicAccumulator % self.LogicTickSeconds
        self:_recordDecisionEvent('TickDrop', {
            DroppedTime = droppedTime,
            Elapsed = elapsed,
            ExecutedSteps = executed,
            MaxStepsPerUpdate = maxSteps,
        })
    end

    if self.PendingVisualCFrame then
        self:_applyVisualCFrame(self.PendingVisualCFrame, elapsed)
    end
end

return MonsterService
]]></string>
