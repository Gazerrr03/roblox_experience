          <Item class="ModuleScript" referent="37">
            <Properties>
              <string name="Name">Player</string>
              <string name="Source"><![CDATA[local PlayerBlackboard = require(script.Parent.PlayerBlackboard)
local PlayerStateMachine = require(script.Parent.PlayerStateMachine)

local Player = {}
Player.__index = Player

local UPDATE_ORDER = table.freeze({
    'Health',
    'Stamina',
    'Movement',
    'Inventory',
})

local function cloneContext(context)
    return table.clone(context or {})
end

function Player.new(definition, options)
    local playerOptions = options or {}
    local blackboard = playerOptions.Blackboard or PlayerBlackboard.new(definition)
    local stateMachine = playerOptions.StateMachine or PlayerStateMachine.new()
    local components = playerOptions.Components or {}

    return setmetatable({
        Blackboard = blackboard,
        ComponentConfig = playerOptions.ComponentConfig or {},
        StateMachine = stateMachine,
        Components = components,
        StageObserver = playerOptions.StageObserver,
    }, Player)
end

function Player:_emitStage(stageName)
    if self.StageObserver then
        self.StageObserver(stageName, self.Blackboard)
    end
end

function Player:spawn()
    self.Blackboard:setState(self.StateMachine:getState())
    for _, component in pairs(self.Components) do
        if component.init then
            component:init(self.Blackboard)
        end
    end
end

function Player:update(dt, context)
    local blackboardContext = cloneContext(context)
    blackboardContext.ComponentConfig = self.ComponentConfig
    self.Blackboard:beginTick(blackboardContext)

    self:_emitStage('Health')
    if self.Components.Health then
        self.Components.Health:update(self.Blackboard, dt)
    end

    self:_emitStage('Stamina')
    if self.Components.Stamina then
        self.Components.Stamina:update(self.Blackboard, dt)
    end

    self:_emitStage('FSM')
    self.StateMachine:update(self.Blackboard)

    self:_emitStage('Movement')
    if self.Components.Movement then
        self.Components.Movement:update(self.Blackboard, dt)
    end

    self:_emitStage('Inventory')
    if self.Components.Inventory then
        self.Components.Inventory:update(self.Blackboard, dt)
    end

    return {
        State = self.Blackboard:getState(),
        Health = {
            CurrentHealthPips = self.Blackboard.Transient.CurrentHealthPips,
            MaxHealthPips = self.Blackboard.Transient.MaxHealthPips,
            IsDead = self.Blackboard.Transient.IsDead == true,
        },
        Stamina = {
            CurrentStamina = self.Blackboard.Transient.CurrentStamina,
            MaxStamina = self.Blackboard.Transient.MaxStamina,
            CanSprint = self.Blackboard.Transient.CanSprint ~= false,
        },
        Movement = {
            NextPosition = self.Blackboard.Transient.NextPosition,
            DesiredAnimation = self.Blackboard.Transient.DesiredAnimation or 'Idle',
        },
        Inventory = {
            Slots = self.Blackboard.Transient.Slots,
            EquippedSlot = self.Blackboard.Transient.EquippedSlot,
        },
    }
end

function Player:destroy()
    for _, component in pairs(self.Components) do
        if component.destroy then
            component:destroy(self.Blackboard)
        end
    end
end

Player.UpdateOrder = UPDATE_ORDER

return Player
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="38">
            <Properties>
              <string name="Name">PlayerBlackboard</string>
              <string name="Source"><![CDATA[local PlayerBlackboard = {}
PlayerBlackboard.__index = PlayerBlackboard

local function cloneTable(source)
    local clone = {}
    if type(source) ~= 'table' then
        return clone
    end

    for key, value in pairs(source) do
        clone[key] = value
    end

    return clone
end

function PlayerBlackboard.new(definition)
    return setmetatable({
        Definition = definition,
        State = nil,
        Context = {},
        Transient = {},
    }, PlayerBlackboard)
end

function PlayerBlackboard:beginTick(context)
    self.Context = cloneTable(context)
    self.Transient = {}
end

function PlayerBlackboard:setState(state)
    self.State = state
end

function PlayerBlackboard:getState()
    return self.State
end

return PlayerBlackboard
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="39">
            <Properties>
              <string name="Name">PlayerComponentConfig</string>
              <string name="Source"><![CDATA[local PlayerComponentConfig = {}

local DEFAULT_MAX_HEALTH_PIPS = 2
local DEFAULT_MAX_STAMINA = 100
local DEFAULT_STAMINA_DRAIN_PER_SECOND = 35
local DEFAULT_STAMINA_RECOVERY_PER_SECOND = 20
local DEFAULT_STAMINA_RECOVERY_DELAY_SECONDS = 1.5
local DEFAULT_SPRINT_RESUME_THRESHOLD = 20
local DEFAULT_WALK_SPEED = 16
local DEFAULT_SPRINT_SPEED = 24
local DEFAULT_JUMP_VELOCITY = 50
local DEFAULT_INTERACTION_RANGE = 5
local DEFAULT_SLOT_COUNT = 8

local function getPositiveNumber(value, defaultValue)
    if type(value) == 'number' and value > 0 then
        return value
    end
    return defaultValue
end

function PlayerComponentConfig.fromDefinition(definition)
    local def = definition or {}
    local components = if type(def.Components) == 'table' then def.Components else {}
    local health = if type(components.Health) == 'table' then components.Health else {}
    local stamina = if type(components.Stamina) == 'table' then components.Stamina else {}
    local movement = if type(components.Movement) == 'table' then components.Movement else {}
    local inventory = if type(components.Inventory) == 'table' then components.Inventory else {}

    local componentConfig = {
        Health = table.freeze({
            MaxHealthPips = getPositiveNumber(health.MaxHealthPips, DEFAULT_MAX_HEALTH_PIPS),
        }),
        Stamina = table.freeze({
            MaxStamina = getPositiveNumber(stamina.MaxStamina, DEFAULT_MAX_STAMINA),
            DrainPerSecond = getPositiveNumber(
                stamina.DrainPerSecond,
                DEFAULT_STAMINA_DRAIN_PER_SECOND
            ),
            RecoveryPerSecond = getPositiveNumber(
                stamina.RecoveryPerSecond,
                DEFAULT_STAMINA_RECOVERY_PER_SECOND
            ),
            RecoveryDelaySeconds = getPositiveNumber(
                stamina.RecoveryDelaySeconds,
                DEFAULT_STAMINA_RECOVERY_DELAY_SECONDS
            ),
            ResumeThreshold = getPositiveNumber(
                stamina.ResumeThreshold,
                DEFAULT_SPRINT_RESUME_THRESHOLD
            ),
        }),
        Movement = table.freeze({
            MaxWalkSpeed = getPositiveNumber(movement.MaxWalkSpeed, DEFAULT_WALK_SPEED),
            MaxSprintSpeed = getPositiveNumber(movement.MaxSprintSpeed, DEFAULT_SPRINT_SPEED),
            JumpVelocity = getPositiveNumber(movement.JumpVelocity, DEFAULT_JUMP_VELOCITY),
        }),
        Inventory = table.freeze({
            SlotCount = getPositiveNumber(inventory.SlotCount, DEFAULT_SLOT_COUNT),
            InteractionRange = getPositiveNumber(
                inventory.InteractionRange,
                DEFAULT_INTERACTION_RANGE
            ),
        }),
    }

    return table.freeze(componentConfig)
end

function PlayerComponentConfig.getDefaults()
    return table.freeze({
        Health = table.freeze({
            MaxHealthPips = DEFAULT_MAX_HEALTH_PIPS,
        }),
        Stamina = table.freeze({
            MaxStamina = DEFAULT_MAX_STAMINA,
            DrainPerSecond = DEFAULT_STAMINA_DRAIN_PER_SECOND,
            RecoveryPerSecond = DEFAULT_STAMINA_RECOVERY_PER_SECOND,
            RecoveryDelaySeconds = DEFAULT_STAMINA_RECOVERY_DELAY_SECONDS,
            ResumeThreshold = DEFAULT_SPRINT_RESUME_THRESHOLD,
        }),
        Movement = table.freeze({
            MaxWalkSpeed = DEFAULT_WALK_SPEED,
            MaxSprintSpeed = DEFAULT_SPRINT_SPEED,
            JumpVelocity = DEFAULT_JUMP_VELOCITY,
        }),
        Inventory = table.freeze({
            SlotCount = DEFAULT_SLOT_COUNT,
            InteractionRange = DEFAULT_INTERACTION_RANGE,
        }),
    })
end

return PlayerComponentConfig
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="40">
            <Properties>
              <string name="Name">PlayerStateMachine</string>
              <string name="Source"><![CDATA[local PlayerStateMachine = {}
PlayerStateMachine.__index = PlayerStateMachine

local STATE = table.freeze({
    Idle = 'Idle',
    Walking = 'Walking',
    Sprinting = 'Sprinting',
    Jumping = 'Jumping',
    Dead = 'Dead',
})

function PlayerStateMachine.new(initialState)
    return setmetatable({
        Current = initialState or STATE.Idle,
    }, PlayerStateMachine)
end

function PlayerStateMachine:getState()
    return self.Current
end

function PlayerStateMachine:update(blackboard)
    local isDead = blackboard.Transient.IsDead == true
    local isSprinting = blackboard.Transient.IsSprinting == true
    local isMoving = blackboard.Transient.IsMoving == true
    local isJumping = blackboard.Transient.IsJumping == true

    if isDead then
        self.Current = STATE.Dead
        blackboard:setState(self.Current)
        return self.Current
    end

    if isJumping then
        self.Current = STATE.Jumping
        blackboard:setState(self.Current)
        return self.Current
    end

    if isSprinting and isMoving then
        self.Current = STATE.Sprinting
        blackboard:setState(self.Current)
        return self.Current
    end

    if isMoving then
        self.Current = STATE.Walking
        blackboard:setState(self.Current)
        return self.Current
    end

    self.Current = STATE.Idle
    blackboard:setState(self.Current)
    return self.Current
end

PlayerStateMachine.State = STATE

return PlayerStateMachine
]]></string>
            </Properties>
          </Item>
        </Item>
        <Item class="ModuleScript" referent="41">
          <Properties>
            <string name="Name">PlayerState</string>
            <string name="Source"><![CDATA[local DEFAULT_MAX_HEALTH_PIPS = 2
local DEFAULT_MAX_STAMINA = 100
local DEFAULT_STAMINA_DRAIN_PER_SECOND = 35
local DEFAULT_STAMINA_RECOVERY_PER_SECOND = 20
local DEFAULT_SPRINT_RESUME_THRESHOLD = 20

local DAMAGE_PIP_COST = table.freeze({
    Light = 1,
    Heavy = 2,
})

local PlayerState = {}
PlayerState.__index = PlayerState

PlayerState.DamageKind = table.freeze({
    Light = 'Light',
    Heavy = 'Heavy',
})

PlayerState.Defaults = table.freeze({
    MaxHealthPips = DEFAULT_MAX_HEALTH_PIPS,
    MaxStamina = DEFAULT_MAX_STAMINA,
    StaminaDrainPerSecond = DEFAULT_STAMINA_DRAIN_PER_SECOND,
    StaminaRecoveryPerSecond = DEFAULT_STAMINA_RECOVERY_PER_SECOND,
    SprintResumeThreshold = DEFAULT_SPRINT_RESUME_THRESHOLD,
})

local function clamp(value, minValue, maxValue)
    return math.max(minValue, math.min(maxValue, value))
end

function PlayerState.new(config)
    local resolvedConfig = config or {}
    local maxHealthPips = resolvedConfig.MaxHealthPips or DEFAULT_MAX_HEALTH_PIPS
    local maxStamina = resolvedConfig.MaxStamina or DEFAULT_MAX_STAMINA

    return setmetatable({
        HealthPips = maxHealthPips,
        MaxHealthPips = maxHealthPips,
        CurrentStamina = maxStamina,
        MaxStamina = maxStamina,
        StaminaDrainPerSecond = resolvedConfig.StaminaDrainPerSecond
            or DEFAULT_STAMINA_DRAIN_PER_SECOND,
        StaminaRecoveryPerSecond = resolvedConfig.StaminaRecoveryPerSecond
            or DEFAULT_STAMINA_RECOVERY_PER_SECOND,
        SprintResumeThreshold = resolvedConfig.SprintResumeThreshold
            or DEFAULT_SPRINT_RESUME_THRESHOLD,
        IsDead = false,
        CanSprint = true,
        CorpseActive = false,
        IsSprinting = false,
    }, PlayerState)
end

function PlayerState:getSummary()
    return {
        HealthPips = self.HealthPips,
        MaxHealthPips = self.MaxHealthPips,
        CurrentStamina = self.CurrentStamina,
        MaxStamina = self.MaxStamina,
        IsDead = self.IsDead,
        CanSprint = self.CanSprint,
        CorpseActive = self.CorpseActive,
    }
end

function PlayerState:setSprinting(isSprinting)
    if self.IsDead then
        self.IsSprinting = false
        return false, 'Dead'
    end

    if isSprinting == true and not self.CanSprint then
        self.IsSprinting = false
        return false, 'StaminaDepleted'
    end

    self.IsSprinting = isSprinting == true
    return true, self:getSummary()
end

function PlayerState:applyDamage(damageKind)
    local pipCost = DAMAGE_PIP_COST[damageKind]
    if pipCost == nil then
        return false, 'UnknownDamageKind'
    end

    self.HealthPips = clamp(self.HealthPips - pipCost, 0, self.MaxHealthPips)
    if self.HealthPips == 0 then
        self.IsDead = true
        self.IsSprinting = false
        self.CanSprint = false
        self.CorpseActive = true
    end

    return true, self:getSummary()
end

function PlayerState:step(dt)
    if self.IsDead then
        return self:getSummary()
    end

    local deltaTime = math.max(0, dt or 0)
    if self.IsSprinting and self.CanSprint then
        self.CurrentStamina =
            clamp(self.CurrentStamina - self.StaminaDrainPerSecond * deltaTime, 0, self.MaxStamina)

        if self.CurrentStamina <= 0 then
            self.CurrentStamina = 0
            self.CanSprint = false
            self.IsSprinting = false
        end
    else
        self.CurrentStamina = clamp(
            self.CurrentStamina + self.StaminaRecoveryPerSecond * deltaTime,
            0,
            self.MaxStamina
        )

        if not self.CanSprint and self.CurrentStamina >= self.SprintResumeThreshold then
            self.CanSprint = true
        end
    end

    return self:getSummary()
end

return PlayerState
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="42">
          <Properties>
            <string name="Name">ProcGen</string>
            <string name="Source"><![CDATA[return {
    HexRoomPrefabs = require(script.HexRoomPrefabs),
    MazeBuilder = require(script.MazeBuilder),
    MazePassageTemplates = require(script.MazePassageTemplates),
    MazeRoomArchetypes = require(script.MazeRoomArchetypes),
    MazeRoomTemplates = require(script.MazeRoomTemplates),
}
]]></string>
          </Properties>
          <Item class="ModuleScript" referent="43">
            <Properties>
              <string name="Name">HexRoomPrefabs</string>
              <string name="Source"><![CDATA[local HexRoomPrefabs = {}

HexRoomPrefabs.Directions = table.freeze({
    A = 1,
    B = 2,
    C = 3,
    D = 4,
    E = 5,
    F = 6,
})

HexRoomPrefabs.DirectionBitmasks = table.freeze({ 1, 2, 4, 8, 16, 32 })

local ORDERED_DEFINITIONS = {
    {
        TypeId = 'T1',
        PrefabId = 'Hex_T1_DeadEnd',
        OpenDirections = { HexRoomPrefabs.Directions.B },
        RotationSteps = { 0, 1, 2, 3, 4, 5 },
    },
    {
        TypeId = 'T2',
        PrefabId = 'Hex_T2_Straight',
        OpenDirections = { HexRoomPrefabs.Directions.B, HexRoomPrefabs.Directions.E },
        RotationSteps = { 0, 1, 2 },
    },
    {
        TypeId = 'T3',
        PrefabId = 'Hex_T3_ObtuseTurn',
        OpenDirections = { HexRoomPrefabs.Directions.B, HexRoomPrefabs.Directions.C },
        RotationSteps = { 0, 2, 4 },
    },
    {
        TypeId = 'T4',
        PrefabId = 'Hex_T4_AcuteTurn',
        OpenDirections = { HexRoomPrefabs.Directions.A, HexRoomPrefabs.Directions.B },
        RotationSteps = { 0, 2, 4 },
    },
    {
        TypeId = 'T5',
        PrefabId = 'Hex_T5_SymmetricY',
        OpenDirections = {
            HexRoomPrefabs.Directions.B,
            HexRoomPrefabs.Directions.D,
            HexRoomPrefabs.Directions.F,
        },
        RotationSteps = { 0, 1 },
    },
    {
        TypeId = 'T6',
        PrefabId = 'Hex_T6_T',
        OpenDirections = {
            HexRoomPrefabs.Directions.B,
            HexRoomPrefabs.Directions.C,
            HexRoomPrefabs.Directions.E,
        },
        RotationSteps = { 0, 1, 2, 3, 4, 5 },
    },
    {
        TypeId = 'T7',
        PrefabId = 'Hex_T7_Cross4',
        OpenDirections = {
            HexRoomPrefabs.Directions.A,
            HexRoomPrefabs.Directions.B,
            HexRoomPrefabs.Directions.D,
            HexRoomPrefabs.Directions.E,
        },
        RotationSteps = { 0, 1, 2 },
    },
    {
        TypeId = 'T8',
        PrefabId = 'Hex_T8_OpenHub',
        OpenDirections = {
            HexRoomPrefabs.Directions.A,
            HexRoomPrefabs.Directions.B,
            HexRoomPrefabs.Directions.C,
            HexRoomPrefabs.Directions.D,
            HexRoomPrefabs.Directions.E,
            HexRoomPrefabs.Directions.F,
        },
        RotationSteps = { 0 },
    },
}

local function sortDirections(directions)
    local copy = table.clone(directions)
    table.sort(copy)
    return copy
end

local function directionToMaskBit(directionIndex)
    return bit32.lshift(1, directionIndex - 1)
end

function HexRoomPrefabs.computeDoorMask(directions)
    local mask = 0
    for _, directionIndex in ipairs(directions) do
        mask = bit32.bor(mask, directionToMaskBit(directionIndex))
    end
    return mask
end

function HexRoomPrefabs.maskToDirections(mask)
    local directions = {}
    for directionIndex = 1, 6 do
        if bit32.band(mask, directionToMaskBit(directionIndex)) ~= 0 then
            table.insert(directions, directionIndex)
        end
    end
    return directions
end

local function rotateDirection(directionIndex, steps)
    return ((directionIndex - 1 + steps) % 6) + 1
end

local function rotateDirections(directions, steps)
    local rotated = table.create(#directions)
    for index, directionIndex in ipairs(directions) do
        rotated[index] = rotateDirection(directionIndex, steps)
    end
    table.sort(rotated)
    return rotated
end

local PREFAB_VARIANTS_BY_MASK = {}
local PREFAB_DEFINITIONS_BY_TYPE = {}

for _, definition in ipairs(ORDERED_DEFINITIONS) do
    PREFAB_DEFINITIONS_BY_TYPE[definition.TypeId] = definition

    for _, rotationSteps in ipairs(definition.RotationSteps) do
        local rotatedDirections = rotateDirections(definition.OpenDirections, rotationSteps)
        local doorMask = HexRoomPrefabs.computeDoorMask(rotatedDirections)
        local existing = PREFAB_VARIANTS_BY_MASK[doorMask]
        if not existing then
            PREFAB_VARIANTS_BY_MASK[doorMask] = table.freeze({
                TypeId = definition.TypeId,
                PrefabId = definition.PrefabId,
                RotationSteps = rotationSteps,
                DoorMask = doorMask,
                OpenDirections = table.freeze(rotatedDirections),
            })
        elseif existing.TypeId ~= definition.TypeId then
            error(
                string.format(
                    'Hex prefab mask collision between %s and %s',
                    existing.TypeId,
                    definition.TypeId
                ),
                0
            )
        end
    end
end

function HexRoomPrefabs.classifyDoorMask(doorMask)
    return PREFAB_VARIANTS_BY_MASK[doorMask]
end

function HexRoomPrefabs.classifyDoorDirections(directions)
    local doorMask = HexRoomPrefabs.computeDoorMask(directions)
    return HexRoomPrefabs.classifyDoorMask(doorMask)
end

function HexRoomPrefabs.getDefinition(typeId)
    local definition = PREFAB_DEFINITIONS_BY_TYPE[typeId]
    if not definition then
        return nil
    end

    return table.freeze({
        TypeId = typeId,
        PrefabId = definition.PrefabId,
        OpenDirections = table.freeze(sortDirections(definition.OpenDirections)),
    })
end

return HexRoomPrefabs
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="44">
            <Properties>
              <string name="Name">MazeBuilder</string>
              <string name="Source"><![CDATA[local MazeBuilder = {}

local HexRoomPrefabs = require(script.Parent.HexRoomPrefabs)
local MazePassageTemplates = require(script.Parent.MazePassageTemplates)
local MazeRoomArchetypes = require(script.Parent.MazeRoomArchetypes)
local MazeRoomTemplates = require(script.Parent.MazeRoomTemplates)

local bit32_band = bit32.band
local bit32_bor = bit32.bor
local bit32_lshift = bit32.lshift

local table_insert = table.insert
local table_sort = table.sort
local table_clone = table.clone
local table_freeze = table.freeze
local table_create = table.create
local math_floor = math.floor
local math_max = math.max
local math_abs = math.abs
local string_format = string.format

local HEX_DIRECTION_BITMASKS = HexRoomPrefabs.DirectionBitmasks

local Vector3_new = Vector3.new

local SQRT3 = math.sqrt(3)

local HEX_DIRECTIONS = {
    { Q = 1, R = 0 },
    { Q = 1, R = -1 },
    { Q = 0, R = -1 },
    { Q = -1, R = 0 },
    { Q = -1, R = 1 },
    { Q = 0, R = 1 },
}

local OPPOSITE_DIRECTIONS = { 4, 5, 6, 1, 2, 3 }

local START_TYPE_IDS = { 'T5', 'T6', 'T7' }
local BASE_RATIO_COUNTS = {
    T1 = 4,
    T2 = 5,
    T3 = 2,
    T4 = 2,
    T5 = 3,
    T6 = 2,
    T7 = 1,
    T8 = 1,
}
local RATIO_TYPE_ORDER = { 'T1', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'T8' }

local DEFAULT_ROOM_COUNT = 20
local DEFAULT_DOOR_LEAF_CHANCE = 0.6
local DEFAULT_MAX_ATTEMPTS = 200

local function rotateDirection(directionIndex, steps)
    return ((directionIndex - 1 + steps) % 6) + 1
end

local function rotateDirections(directions, steps)
    local rotated = table_create(#directions)
    for index, directionIndex in ipairs(directions) do
        rotated[index] = rotateDirection(directionIndex, steps)
    end
    table_sort(rotated)
    return rotated
end

local PREFAB_VARIANTS_BY_TYPE = {}
for _, typeId in ipairs(RATIO_TYPE_ORDER) do
    local variants = {}
    local seenMasks = {}
    local definition = HexRoomPrefabs.getDefinition(typeId)
    if definition then
        for steps = 0, 5 do
            local openDirections = rotateDirections(definition.OpenDirections, steps)
            local doorMask = HexRoomPrefabs.computeDoorMask(openDirections)
            if not seenMasks[doorMask] then
                seenMasks[doorMask] = true
                table_insert(
                    variants,
                    table_freeze({
                        TypeId = typeId,
                        RotationSteps = steps,
                        OpenDirections = table_freeze(openDirections),
                        DoorMask = doorMask,
                    })
                )
            end
        end
    end
    PREFAB_VARIANTS_BY_TYPE[typeId] = table_freeze(variants)
end

local function oppositeDirection(directionIndex)
    return OPPOSITE_DIRECTIONS[directionIndex]
end

local function axialKey(q, r)
    return bit32_bor(bit32_lshift(bit32_band(q, 0xFFFF), 16), bit32_band(r, 0xFFFF))
end

local function axialToWorld(q, r, roomSpacing)
    local x = roomSpacing * (SQRT3 * q + (SQRT3 / 2) * r)
    local z = roomSpacing * ((3 / 2) * r)
    return Vector3_new(x, 0, z)
end

local function buildDirectionSet(directions)
    local directionSet = {}
    for _, directionIndex in ipairs(directions) do
        directionSet[directionIndex] = true
    end
    return directionSet
end

local function countEntries(map)
    local count = 0
    for _ in pairs(map or {}) do
        count += 1
    end
    return count
end

local function cloneSortedArray(values)
    local cloned = table_clone(values or {})
    table_sort(cloned)
    return cloned
end

local function buildSet(values)
    local lookup = {}
    for _, value in ipairs(values or {}) do
        lookup[value] = true
    end
    return lookup
end

local function sortedRoomIds(rooms)
    local roomIds = {}
    for roomId in pairs(rooms) do
        table_insert(roomIds, roomId)
    end
    table_sort(roomIds)
    return roomIds
end

local function sortedDoorwayIds(doorways)
    local doorwayIds = {}
    for doorwayId in pairs(doorways or {}) do
        table_insert(doorwayIds, doorwayId)
    end
    table_sort(doorwayIds)
    return doorwayIds
end

local function collectSortedNeighborRoomIds(room)
    local neighborRoomIds = {}
    for _, neighborRoomId in pairs(room.Neighbors or {}) do
        table_insert(neighborRoomIds, neighborRoomId)
    end
    table_sort(neighborRoomIds)
    return neighborRoomIds
end

local function createRoom(
    roomId,
    q,
    r,
    roomSpacing,
    typeId,
    rotationSteps,
    openDirections,
    doorMaskOverride
)
    local definition = HexRoomPrefabs.getDefinition(typeId)
    local doorMask = doorMaskOverride or HexRoomPrefabs.computeDoorMask(openDirections)

    return {
        Id = roomId,
        Kind = 'Loot',
        Grid = {
            Q = q,
            R = r,
        },
        Position = axialToWorld(q, r, roomSpacing),
        DoorMask = doorMask,
        DoorCount = #openDirections,
        DoorDirections = table_clone(openDirections),
        OpenDirections = table_clone(openDirections),
        Neighbors = {},
        ExitDirections = {},
        PrefabId = definition and definition.PrefabId or string_format('Hex_%s', typeId),
        PrefabTypeId = typeId,
        PrefabRotationSteps = rotationSteps,
    }
end

local function addFrontier(frontier, frontierIndexByKey, roomId, directionIndex)
    local key = roomId .. ':' .. directionIndex
    if frontierIndexByKey[key] then
        return
    end

    table_insert(frontier, {
        RoomId = roomId,
        Direction = directionIndex,
    })
    frontierIndexByKey[key] = #frontier
end

local function removeFrontier(frontier, frontierIndexByKey, roomId, directionIndex)
    local key = roomId .. ':' .. directionIndex
    local index = frontierIndexByKey[key]
    if not index then
        return
    end

    local lastIndex = #frontier
    local swapped = frontier[lastIndex]
    frontier[index] = swapped
    frontier[lastIndex] = nil
    frontierIndexByKey[key] = nil

    if swapped and index <= #frontier then
        frontierIndexByKey[swapped.RoomId .. ':' .. swapped.Direction] = index
    end
end

local function popRandomFrontier(frontier, frontierIndexByKey, random)
    if #frontier == 0 then
        return nil
    end

    local index = random:NextInteger(1, #frontier)
    local entry = frontier[index]
    removeFrontier(frontier, frontierIndexByKey, entry.RoomId, entry.Direction)
    return entry
end

local function buildPrefabQuotas(roomCount)
    local baseTotal = 0
    for _, typeId in ipairs(RATIO_TYPE_ORDER) do
        baseTotal += BASE_RATIO_COUNTS[typeId]
    end

    local quotas = {}
    local remainders = {}
    local assigned = 0

    for _, typeId in ipairs(RATIO_TYPE_ORDER) do
        local scaled = (roomCount * BASE_RATIO_COUNTS[typeId]) / baseTotal
        local baseCount = math_floor(scaled)
        quotas[typeId] = baseCount
        assigned += baseCount

        table_insert(remainders, {
            TypeId = typeId,
            Value = scaled - baseCount,
            Weight = BASE_RATIO_COUNTS[typeId],
        })
    end

    table_sort(remainders, function(left, right)
        if left.Value ~= right.Value then
            return left.Value > right.Value
        end

        if left.Weight ~= right.Weight then
            return left.Weight > right.Weight
        end

        return left.TypeId < right.TypeId
    end)

    local remaining = roomCount - assigned
    local remainderIndex = 1
    while remaining > 0 do
        local remainder = remainders[remainderIndex]
        quotas[remainder.TypeId] += 1
        remaining -= 1

        remainderIndex += 1
        if remainderIndex > #remainders then
            remainderIndex = 1
        end
    end

    local hasStartType = false
    for _, typeId in ipairs(START_TYPE_IDS) do
        if quotas[typeId] > 0 then
            hasStartType = true
            break
        end
    end

    if not hasStartType then
        for _, donorTypeId in ipairs(RATIO_TYPE_ORDER) do
            if quotas[donorTypeId] > 1 then
                quotas[donorTypeId] -= 1
                quotas[START_TYPE_IDS[1]] += 1
                hasStartType = true
                break
            end
        end
    end

    if not hasStartType then
        error('MazeBuilder could not allocate a valid start-room prefab quota', 0)
    end

    return quotas
end

local function pickWeightedType(random, quotas, typeIds)
    local totalWeight = 0
    for _, typeId in ipairs(typeIds) do
        totalWeight += math.max(0, quotas[typeId] or 0)
    end

    if totalWeight <= 0 then
        return nil
    end

    local roll = random:NextNumber(0, totalWeight)
    local running = 0
    for _, typeId in ipairs(typeIds) do
        running += math.max(0, quotas[typeId] or 0)
        if roll <= running then
            return typeId
        end
    end

    return typeIds[#typeIds]
end

local function enumeratePlacementCandidates(
    random,
    quotas,
    rooms,
    roomsByAxialKey,
    blockedAxialKeys,
    targetQ,
    targetR,
    requiredDirection
)
    local positionKey = axialKey(targetQ, targetR)
    if roomsByAxialKey[positionKey] or blockedAxialKeys[positionKey] then
        return nil
    end

    local requiredMask = HEX_DIRECTION_BITMASKS[requiredDirection]
    local mustHaveMask = 0
    local mustNotHaveMask = 0

    -- Pre-calculate door constraints from neighbors once per candidate search
    for directionIndex, direction in ipairs(HEX_DIRECTIONS) do
        local neighborQ = targetQ + direction.Q
        local neighborR = targetR + direction.R
        local neighborRoomId = roomsByAxialKey[axialKey(neighborQ, neighborR)]
        if not neighborRoomId then
            continue
        end

        local neighbor = rooms[neighborRoomId]
        local opposite = OPPOSITE_DIRECTIONS[directionIndex]
        local neighborHasDoor = bit32_band(neighbor.DoorMask, HEX_DIRECTION_BITMASKS[opposite]) ~= 0

        if neighborHasDoor then
            -- We must have a door to match neighbor, and neighbor must not already be connected
            if neighbor.Neighbors[opposite] ~= nil then
                return nil -- Already occupied path
            end
            mustHaveMask = bit32_bor(mustHaveMask, HEX_DIRECTION_BITMASKS[directionIndex])
        else
            mustNotHaveMask = bit32_bor(mustNotHaveMask, HEX_DIRECTION_BITMASKS[directionIndex])
        end
    end

    mustHaveMask = bit32_bor(mustHaveMask, requiredMask)

    -- Optimization: Two-pass selection to avoid temporary candidate table allocations
    local totalWeight = 0
    for _, typeId in ipairs(RATIO_TYPE_ORDER) do
        local quota = quotas[typeId] or 0
        if quota <= 0 then
            continue
        end

        for _, variant in ipairs(PREFAB_VARIANTS_BY_TYPE[typeId]) do
            local mask = variant.DoorMask
            if
                bit32_band(mask, mustHaveMask) == mustHaveMask
                and bit32_band(mask, mustNotHaveMask) == 0
            then
                totalWeight += quota
            end
        end
    end

    if totalWeight <= 0 then
        return nil
    end

    local roll = random:NextNumber(0, totalWeight)
    local running = 0
    for _, typeId in ipairs(RATIO_TYPE_ORDER) do
        local quota = quotas[typeId] or 0
        if quota <= 0 then
            continue
        end

        for _, variant in ipairs(PREFAB_VARIANTS_BY_TYPE[typeId]) do
            local mask = variant.DoorMask
            if
                bit32_band(mask, mustHaveMask) == mustHaveMask
                and bit32_band(mask, mustNotHaveMask) == 0
            then
                running += quota
                if roll <= running then
                    return variant
                end
            end
        end
    end

    -- Fallback for floating point precision issues
    for _, typeId in ipairs(RATIO_TYPE_ORDER) do
        local quota = quotas[typeId] or 0
        if quota <= 0 then
            continue
        end

        for _, variant in ipairs(PREFAB_VARIANTS_BY_TYPE[typeId]) do
            local mask = variant.DoorMask
            if
                bit32_band(mask, mustHaveMask) == mustHaveMask
                and bit32_band(mask, mustNotHaveMask) == 0
            then
                return variant
            end
        end
    end

    return nil
end

local function computeDistances(rooms, startRoomId)
    local distances = {
        [startRoomId] = 0,
    }
    local queue = { startRoomId }
    local queueIndex = 1

    while queueIndex <= #queue do
        local roomId = queue[queueIndex]
        queueIndex += 1

        local room = rooms[roomId]
        local distance = distances[roomId]

        for _, neighborRoomId in ipairs(collectSortedNeighborRoomIds(room)) do
            if distances[neighborRoomId] == nil then
                distances[neighborRoomId] = distance + 1
                table_insert(queue, neighborRoomId)
            end
        end
    end

    return distances
end

local function selectExtractionRoom(rooms, campRoomId)
    local distances = computeDistances(rooms, campRoomId)
    local selectedRoomId = campRoomId
    local selectedDistance = -1

    for roomId, distance in pairs(distances) do
        if
            distance > selectedDistance
            or (distance == selectedDistance and roomId < selectedRoomId)
        then
            selectedDistance = distance
            selectedRoomId = roomId
        end
    end

    return selectedRoomId
end

local function buildMainPath(rooms, startRoomId, targetRoomId)
    local parents = {}
    local visited = {
        [startRoomId] = true,
    }
    local queue = { startRoomId }
    local queueIndex = 1

    while queueIndex <= #queue do
        local roomId = queue[queueIndex]
        queueIndex += 1

        if roomId == targetRoomId then
            break
        end

        local room = rooms[roomId]
        for _, neighborRoomId in ipairs(collectSortedNeighborRoomIds(room)) do
            if not visited[neighborRoomId] then
                visited[neighborRoomId] = true
                parents[neighborRoomId] = roomId
                table_insert(queue, neighborRoomId)
            end
        end
    end

    local path = {}
    local cursor = targetRoomId
    while cursor do
        table_insert(path, 1, cursor)
        if cursor == startRoomId then
            break
        end
        cursor = parents[cursor]
    end

    if path[1] ~= startRoomId then
        return { startRoomId, targetRoomId }
    end

    return path
end

local function finalizeRoomConnectivity(rooms)
    for _, room in pairs(rooms) do
        local connectedDirections = {}
        for directionIndex in pairs(room.Neighbors or {}) do
            table_insert(connectedDirections, directionIndex)
        end
        table_sort(connectedDirections)

        room.OpenDirections = table_clone(connectedDirections)
        room.DoorDirections = table_clone(connectedDirections)
        room.OpenDirectionSet = buildDirectionSet(connectedDirections)
        room.DoorCount = #connectedDirections
        room.DoorMask = HexRoomPrefabs.computeDoorMask(connectedDirections)
        room.ExitDirections = {}
        room.StartExternalDirection = nil
    end
end

local function validateRoomConnections(rooms)
    for roomId, room in pairs(rooms) do
        local exitDirectionMask = 0
        for _, directionIndex in ipairs(room.ExitDirections or {}) do
            exitDirectionMask = bit32_bor(exitDirectionMask, HEX_DIRECTION_BITMASKS[directionIndex])
        end

        for directionIndex, neighborRoomId in pairs(room.Neighbors) do
            if bit32_band(room.DoorMask, HEX_DIRECTION_BITMASKS[directionIndex]) == 0 then
                return false, string.format('NeighborOnClosedEdge(%s:%d)', roomId, directionIndex)
            end

            local neighbor = rooms[neighborRoomId]
            if not neighbor then
                return false,
                    string.format('MissingNeighborRoom(%s:%s)', roomId, tostring(neighborRoomId))
            end

            local opposite = OPPOSITE_DIRECTIONS[directionIndex]
            if neighbor.Neighbors[opposite] ~= roomId then
                return false, string.format('NonMirrorNeighbor(%s:%s)', roomId, neighborRoomId)
            end
            if bit32_band(neighbor.DoorMask, HEX_DIRECTION_BITMASKS[opposite]) == 0 then
                return false,
                    string.format('NeighborClosedMirrorEdge(%s:%s)', roomId, neighborRoomId)
            end
        end

        for _, directionIndex in ipairs(room.OpenDirections) do
            local neighborRoomId = room.Neighbors[directionIndex]
            if
                neighborRoomId == nil
                and bit32.band(
                        exitDirectionMask,
                        HexRoomPrefabs.DirectionBitmasks[directionIndex]
                    )
                    == 0
            then
                return false, string.format('UnclassifiedOpenEdge(%s:%d)', roomId, directionIndex)
            end
        end

        for directionIndex = 1, 6 do
            local directionBit = HEX_DIRECTION_BITMASKS[directionIndex]
            if bit32_band(exitDirectionMask, directionBit) ~= 0 then
                if room.Neighbors[directionIndex] ~= nil then
                    return false,
                        string.format('ExitCollidesWithNeighbor(%s:%d)', roomId, directionIndex)
                end
                if bit32_band(room.DoorMask, directionBit) == 0 then
                    return false, string.format('ExitOnClosedEdge(%s:%d)', roomId, directionIndex)
                end
            end
        end
    end

    return true, nil
end

local function buildLoopMetadata(rooms, doorways, campRoomId)
    local visited = {
        [campRoomId] = true,
    }
    local queue = { campRoomId }
    local queueIndex = 1
    local treeEdges = {}

    while queueIndex <= #queue do
        local roomId = queue[queueIndex]
        queueIndex += 1
        local room = rooms[roomId]

        for _, neighborRoomId in ipairs(collectSortedNeighborRoomIds(room)) do
            if not visited[neighborRoomId] then
                visited[neighborRoomId] = true
                local edgeKey = if roomId < neighborRoomId
                    then roomId .. '|' .. neighborRoomId
                    else neighborRoomId .. '|' .. roomId
                treeEdges[edgeKey] = true
                table_insert(queue, neighborRoomId)
            end
        end
    end

    local loopDoorwayIds = {}
    local loopDoorwaySet = {}
    local loopRoomSet = {}

    for _, doorwayId in ipairs(sortedDoorwayIds(doorways)) do
        if not treeEdges[doorwayId] then
            table_insert(loopDoorwayIds, doorwayId)
            loopDoorwaySet[doorwayId] = true
            local doorway = doorways[doorwayId]
            loopRoomSet[doorway.RoomA] = true
            loopRoomSet[doorway.RoomB] = true
        end
    end

    return {
        LoopCount = #loopDoorwayIds,
        LoopDoorwayIds = loopDoorwayIds,
        LoopDoorwaySet = loopDoorwaySet,
        LoopRoomSet = loopRoomSet,
    }
end

local function selectScoredRoomId(roomIds, rooms, excludedRoomIds, predicate, scoreFn)
    local bestRoomId = nil
    local bestScore = nil

    for _, roomId in ipairs(roomIds) do
        if excludedRoomIds[roomId] ~= true then
            local room = rooms[roomId]
            if predicate(roomId, room) then
                local score = scoreFn(roomId, room)
                if
                    bestScore == nil
                    or score > bestScore
                    or (score == bestScore and roomId < bestRoomId)
                then
                    bestRoomId = roomId
                    bestScore = score
                end
            end
        end
    end

    return bestRoomId
end

local function applyArchetype(room)
    local archetype = MazeRoomArchetypes.classifyRoom(room)
    room.ArchetypeId = archetype.Id
    room.AuthoringAssetId = archetype.AuthoringAssetId
    room.SupportsExternalShellModel = archetype.SupportsExternalShellModel == true
    room.VisualLanguage = archetype.VisualLanguage
end

local function assignRoomTemplates(rooms, campRoomId, extractionRoomId, mainPath, loopMetadata)
    local roomIds = sortedRoomIds(rooms)
    local distances = computeDistances(rooms, campRoomId)
    local mainPathSet = buildSet(mainPath)
    local maxDistance = 0
    for _, distance in pairs(distances) do
        maxDistance = math.max(maxDistance, distance)
    end

    local assignedRoomIds = {}

    local function assign(roomId, templateId)
        if roomId == nil then
            return
        end
        MazeRoomTemplates.applyTemplate(rooms[roomId], templateId)
        applyArchetype(rooms[roomId])
        assignedRoomIds[roomId] = true
    end

    assign(campRoomId, 'EntrySafe')
    assign(extractionRoomId, 'ExtractionReturn')

    local midDepth = maxDistance / 2
    local landmarkRoomId = selectScoredRoomId(
        roomIds,
        rooms,
        assignedRoomIds,
        function(roomId, room)
            return room.Kind == 'Loot'
                and distances[roomId] >= 2
                and countEntries(room.Neighbors) >= 2
        end,
        function(roomId, room)
            local distanceScore = math_max(0, 10 - math_abs(distances[roomId] - midDepth) * 2)
            local loopBonus = loopMetadata.LoopRoomSet[roomId] and 8 or 0
            local pathBonus = mainPathSet[roomId] and 6 or 0
            return (countEntries(room.Neighbors) * 10) + distanceScore + loopBonus + pathBonus
        end
    )
    assign(landmarkRoomId, 'LandmarkFacility')

    local highValueRiskRoomId = selectScoredRoomId(
        roomIds,
        rooms,
        assignedRoomIds,
        function(roomId, room)
            return room.Kind == 'Loot' and distances[roomId] >= 2
        end,
        function(roomId, room)
            local deadEndBonus = room.DoorCount == 1 and 25 or 0
            local offMainPathBonus = mainPathSet[roomId] and 0 or 10
            return (distances[roomId] * 15) + deadEndBonus + offMainPathBonus - room.DoorCount
        end
    )
    assign(highValueRiskRoomId, 'HighValueRisk')

    local bulkheadRoomId = selectScoredRoomId(
        roomIds,
        rooms,
        assignedRoomIds,
        function(roomId, room)
            return room.Kind == 'Loot'
                and mainPathSet[roomId]
                and distances[roomId] >= 1
                and distances[roomId] < maxDistance
                and countEntries(room.Neighbors) >= 2
        end,
        function(roomId, room)
            local targetDepth = math_max(1, math_floor(maxDistance * 0.45))
            local depthScore = math_max(0, 18 - math_abs(distances[roomId] - targetDepth) * 6)
            local degreeScore = room.DoorCount == 2 and 14 or (room.DoorCount == 3 and 10 or 4)
            return depthScore + degreeScore
        end
    )
    assign(bulkheadRoomId, 'BulkheadGate')

    local shortcutRoomId = selectScoredRoomId(
        roomIds,
        rooms,
        assignedRoomIds,
        function(roomId, room)
            return room.Kind == 'Loot'
                and (loopMetadata.LoopRoomSet[roomId] or countEntries(room.Neighbors) >= 3)
                and distances[roomId] >= 2
        end,
        function(roomId, room)
            local loopBonus = loopMetadata.LoopRoomSet[roomId] and 20 or 0
            local offMainPathBonus = mainPathSet[roomId] and 0 or 12
            return loopBonus
                + offMainPathBonus
                + (countEntries(room.Neighbors) * 4)
                + distances[roomId]
        end
    )
    assign(shortcutRoomId, 'ShortcutLoop')

    local remainingLootRoomIds = {}
    for _, roomId in ipairs(roomIds) do
        if assignedRoomIds[roomId] ~= true and rooms[roomId].Kind == 'Loot' then
            table_insert(remainingLootRoomIds, roomId)
        end
    end

    table_sort(remainingLootRoomIds, function(left, right)
        local leftRoom = rooms[left]
        local rightRoom = rooms[right]
        local leftScore = (mainPathSet[left] and 20 or 0)
            + (countEntries(leftRoom.Neighbors) * 4)
            - distances[left]
        local rightScore = (mainPathSet[right] and 20 or 0)
            + (countEntries(rightRoom.Neighbors) * 4)
            - distances[right]
        if leftScore ~= rightScore then
            return leftScore > rightScore
        end
        return left < right
    end)

    local transitTarget = 0
    if #remainingLootRoomIds > 1 then
        transitTarget = math_max(
            1,
            math.min(math_floor(#remainingLootRoomIds * 0.35), #remainingLootRoomIds - 1)
        )
    end

    for index, roomId in ipairs(remainingLootRoomIds) do
        if index <= transitTarget then
            assign(roomId, 'TransitHall')
        else
            assign(roomId, 'SearchCluster')
        end
    end

    for _, roomId in ipairs(roomIds) do
        if rooms[roomId].RoomTemplateId == nil then
            local fallbackTemplateId = if roomId == campRoomId
                then 'EntrySafe'
                elseif roomId == extractionRoomId then 'ExtractionReturn'
                else 'SearchCluster'
            assign(roomId, fallbackTemplateId)
        end

        rooms[roomId].EndpointDefs = MazeRoomTemplates.buildEndpointDefs(rooms[roomId])
    end

    return {
        Distances = distances,
        LandmarkRoomId = landmarkRoomId,
        HighValueRiskRoomId = highValueRiskRoomId,
        BulkheadRoomId = bulkheadRoomId,
        ShortcutRoomId = shortcutRoomId,
    }
end

local function indexEndpointDefsByDirection(room)
    local endpointsByDirection = {}
    for _, endpointDef in ipairs(room.EndpointDefs or {}) do
        endpointsByDirection[endpointDef.Direction] = endpointDef
    end
    return endpointsByDirection
end

local function enrichDoorwayMetadata(rooms, doorways, loopMetadata)
    for doorwayId, doorway in pairs(doorways) do
        local roomA = rooms[doorway.RoomA]
        local roomB = rooms[doorway.RoomB]
        local endpointDefsA = indexEndpointDefsByDirection(roomA)
        local endpointDefsB = indexEndpointDefsByDirection(roomB)
        local passageDefinition = MazePassageTemplates.resolveDoorwayArchetype(
            roomA,
            roomB,
            loopMetadata.LoopDoorwaySet[doorwayId] == true
        )
        doorway.PassageArchetypeId = passageDefinition.Id
        doorway.EndpointTypeA = endpointDefsA[doorway.DirectionFromA]
                and endpointDefsA[doorway.DirectionFromA].EndpointType
            or MazePassageTemplates.EndpointType.Hall
        doorway.EndpointTypeB = endpointDefsB[doorway.DirectionFromB]
                and endpointDefsB[doorway.DirectionFromB].EndpointType
            or MazePassageTemplates.EndpointType.Hall
        doorway.RoomCategoryA = roomA.RoomCategory
        doorway.RoomCategoryB = roomB.RoomCategory
        doorway.IsLoopDoorway = loopMetadata.LoopDoorwaySet[doorwayId] == true
    end
end

local function buildMacroGraph(roomIds, rooms, mainPath, loopMetadata, assignmentMetadata)
    local branchRoomIds = {}
    local mainPathSet = buildSet(mainPath)
    for _, roomId in ipairs(roomIds) do
        if mainPathSet[roomId] ~= true then
            table_insert(branchRoomIds, roomId)
        end
    end

    local anchorRoomIds = {}
    for _, roomId in ipairs({
        mainPath[1],
        assignmentMetadata.LandmarkRoomId,
        assignmentMetadata.HighValueRiskRoomId,
        mainPath[#mainPath],
    }) do
        if roomId ~= nil and not table.find(anchorRoomIds, roomId) then
            table_insert(anchorRoomIds, roomId)
        end
    end

    local loopRoomIds = {}
    for roomId in pairs(loopMetadata.LoopRoomSet) do
        table_insert(loopRoomIds, roomId)
    end
    table_sort(loopRoomIds)

    local landmarkRoomIds = {}
    for _, roomId in ipairs(roomIds) do
        if (rooms[roomId].LandmarkWeight or 0) >= 3 then
            table_insert(landmarkRoomIds, roomId)
        end
    end

    return {
        Style = 'AnchoredLoopingFacility',
        AnchorRoomIds = anchorRoomIds,
        LandmarkRoomIds = landmarkRoomIds,
        ShortcutRoomIds = assignmentMetadata.ShortcutRoomId and {
            assignmentMetadata.ShortcutRoomId,
        } or {},
        MainPathRoomIds = cloneSortedArray(mainPath),
        BranchRoomIds = branchRoomIds,
        LoopDoorwayIds = cloneSortedArray(loopMetadata.LoopDoorwayIds),
        LoopRoomIds = loopRoomIds,
        LoopCount = loopMetadata.LoopCount,
        DepthByRoomId = assignmentMetadata.Distances,
    }
end

local function buildPlacedRooms(roomIds, rooms)
    local placedRooms = {}
    for _, roomId in ipairs(roomIds) do
        local room = rooms[roomId]
        table_insert(placedRooms, {
            Id = roomId,
            Category = room.RoomCategory,
            RoomTemplateId = room.RoomTemplateId,
            RiskTier = room.RiskTier,
            LandmarkWeight = room.LandmarkWeight,
            SearchProfile = room.SearchProfile,
            Position = room.Position,
        })
    end
    return placedRooms
end

local function buildPlacedPassages(doorways, externalDoorways)
    local placedDoorways = {}
    for _, doorwayId in ipairs(sortedDoorwayIds(doorways)) do
        local doorway = doorways[doorwayId]
        table_insert(placedDoorways, {
            Id = doorwayId,
            Kind = 'Doorway',
            RoomA = doorway.RoomA,
            RoomB = doorway.RoomB,
            DirectionFromA = doorway.DirectionFromA,
            DirectionFromB = doorway.DirectionFromB,
            PassageArchetypeId = doorway.PassageArchetypeId,
            EndpointTypeA = doorway.EndpointTypeA,
            EndpointTypeB = doorway.EndpointTypeB,
            IsLoopDoorway = doorway.IsLoopDoorway,
        })
    end

    local placedExits = {}
    for _, externalDoorway in ipairs(externalDoorways or {}) do
        table_insert(placedExits, {
            Id = externalDoorway.RoomId .. '_' .. externalDoorway.Direction,
            Kind = externalDoorway.Kind,
            RoomId = externalDoorway.RoomId,
            Direction = externalDoorway.Direction,
            PassageArchetypeId = externalDoorway.PassageArchetypeId,
            EndpointType = externalDoorway.EndpointType,
        })
    end

    return {
        Doorways = placedDoorways,
        Exits = placedExits,
    }
end

local function buildSearchDistribution(roomIds, rooms)
    local roomIdsByTemplate = {}
    for _, templateId in ipairs(MazeRoomTemplates.getOrderedTemplateIds()) do
        roomIdsByTemplate[templateId] = {}
    end

    local riskRoomIds = {}
    for _, roomId in ipairs(roomIds) do
        local room = rooms[roomId]
        table_insert(roomIdsByTemplate[room.RoomTemplateId], roomId)
        if (room.RiskTier or 0) >= 3 then
            table_insert(riskRoomIds, roomId)
        end
    end

    return {
        RoomIdsByTemplate = roomIdsByTemplate,
        HighRiskRoomIds = riskRoomIds,
    }
end

local function buildLandmarkNodes(roomIds, rooms)
    local nodes = {}
    for _, roomId in ipairs(roomIds) do
        local room = rooms[roomId]
        if (room.LandmarkWeight or 0) >= 3 then
            table_insert(nodes, {
                RoomId = roomId,
                RoomTemplateId = room.RoomTemplateId,
                LandmarkWeight = room.LandmarkWeight,
                Position = room.Position,
            })
        end
    end
    return nodes
end

local function buildAttempt(seed, config)
    local roomCount = math.max(3, config.RoomCount or DEFAULT_ROOM_COUNT)
    local roomSpacing = config.RoomSpacing or 40
    local doorLeafChance = config.DoorLeafChance or DEFAULT_DOOR_LEAF_CHANCE
    local random = Random.new(seed)

    local rooms = {}
    local roomsByAxialKey = {}
    local blockedAxialKeys = {}
    local roomIds = {}
    local edgesByKey = {}
    local frontier = {}
    local frontierIndexByKey = {}

    local function registerRoom(room)
        rooms[room.Id] = room
        roomsByAxialKey[axialKey(room.Grid.Q, room.Grid.R)] = room.Id
        table_insert(roomIds, room.Id)
    end

    local function connectRooms(roomA, directionFromA, roomB)
        local directionFromB = oppositeDirection(directionFromA)

        if
            roomA.Neighbors[directionFromA] == roomB.Id
            and roomB.Neighbors[directionFromB] == roomA.Id
        then
            return
        end

        roomA.Neighbors[directionFromA] = roomB.Id
        roomB.Neighbors[directionFromB] = roomA.Id

        local edgeRoomA, edgeRoomB = roomA, roomB
        local edgeDirectionFromA, edgeDirectionFromB = directionFromA, directionFromB
        if roomA.Id > roomB.Id then
            edgeRoomA, edgeRoomB = roomB, roomA
            edgeDirectionFromA, edgeDirectionFromB = directionFromB, directionFromA
        end

        local edgeKey = edgeRoomA.Id .. '|' .. edgeRoomB.Id
        edgesByKey[edgeKey] = {
            RoomA = edgeRoomA.Id,
            RoomB = edgeRoomB.Id,
            DirectionFromA = edgeDirectionFromA,
            DirectionFromB = edgeDirectionFromB,
        }

        removeFrontier(frontier, frontierIndexByKey, roomA.Id, directionFromA)
        removeFrontier(frontier, frontierIndexByKey, roomB.Id, directionFromB)
    end

    local quotas = buildPrefabQuotas(roomCount)

    local startTypeId = pickWeightedType(random, quotas, START_TYPE_IDS)
    if not startTypeId then
        error('MazeBuilder failed to pick a start room prefab', 0)
    end

    local startDefinition = HexRoomPrefabs.getDefinition(startTypeId)
    local startRotation = random:NextInteger(0, 5)
    local startDirections = rotateDirections(startDefinition.OpenDirections, startRotation)
    local startDoorMask = HexRoomPrefabs.computeDoorMask(startDirections)
    local startRoom = createRoom(
        'Room_001',
        0,
        0,
        roomSpacing,
        startTypeId,
        startRotation,
        startDirections,
        startDoorMask
    )
    startRoom.Kind = 'Camp'
    registerRoom(startRoom)
    quotas[startTypeId] -= 1

    local startExitDirection = startDirections[random:NextInteger(1, #startDirections)]
    startRoom.StartExternalDirection = startExitDirection

    do
        local direction = HEX_DIRECTIONS[startExitDirection]
        blockedAxialKeys[axialKey(direction.Q, direction.R)] = true
    end

    for _, directionIndex in ipairs(startDirections) do
        if directionIndex ~= startExitDirection then
            addFrontier(frontier, frontierIndexByKey, startRoom.Id, directionIndex)
        end
    end

    while #roomIds < roomCount do
        local frontierEntry = popRandomFrontier(frontier, frontierIndexByKey, random)
        if not frontierEntry then
            return nil, 'InsufficientExpansionFrontier'
        end

        local sourceRoom = rooms[frontierEntry.RoomId]
        if not sourceRoom then
            continue
        end

        if sourceRoom.Neighbors[frontierEntry.Direction] ~= nil then
            continue
        end

        local direction = HEX_DIRECTIONS[frontierEntry.Direction]
        local targetQ = sourceRoom.Grid.Q + direction.Q
        local targetR = sourceRoom.Grid.R + direction.R
        local targetKey = axialKey(targetQ, targetR)
        local opposite = oppositeDirection(frontierEntry.Direction)

        local existingRoomId = roomsByAxialKey[targetKey]
        if existingRoomId then
            local existingRoom = rooms[existingRoomId]
            if
                existingRoom
                and bit32_band(existingRoom.DoorMask, HEX_DIRECTION_BITMASKS[opposite]) ~= 0
                and existingRoom.Neighbors[opposite] == nil
            then
                connectRooms(sourceRoom, frontierEntry.Direction, existingRoom)
            end
            continue
        end

        local candidate = enumeratePlacementCandidates(
            random,
            quotas,
            rooms,
            roomsByAxialKey,
            blockedAxialKeys,
            targetQ,
            targetR,
            opposite
        )

        if not candidate then
            continue
        end

        local roomId = if #roomIds < 9
            then 'Room_00' .. (#roomIds + 1)
            elseif #roomIds < 99 then 'Room_0' .. (#roomIds + 1)
            else 'Room_' .. (#roomIds + 1)

        local newRoom = createRoom(
            roomId,
            targetQ,
            targetR,
            roomSpacing,
            candidate.TypeId,
            candidate.RotationSteps,
            candidate.OpenDirections,
            candidate.DoorMask
        )
        registerRoom(newRoom)
        quotas[candidate.TypeId] -= 1

        connectRooms(sourceRoom, frontierEntry.Direction, newRoom)

        for _, directionIndex in ipairs(newRoom.OpenDirections) do
            local neighborDirection = HEX_DIRECTIONS[directionIndex]
            local neighborQ = newRoom.Grid.Q + neighborDirection.Q
            local neighborR = newRoom.Grid.R + neighborDirection.R
            local neighborRoomId = roomsByAxialKey[axialKey(neighborQ, neighborR)]

            if neighborRoomId then
                local neighborRoom = rooms[neighborRoomId]
                local oppositeDirectionIndex = OPPOSITE_DIRECTIONS[directionIndex]
                if
                    neighborRoom
                    and bit32_band(
                        neighborRoom.DoorMask,
                        HEX_DIRECTION_BITMASKS[oppositeDirectionIndex]
                    ) ~= 0
                    and neighborRoom.Neighbors[oppositeDirectionIndex] == nil
                    and newRoom.Neighbors[directionIndex] == nil
                then
                    connectRooms(newRoom, directionIndex, neighborRoom)
                end
            elseif newRoom.Neighbors[directionIndex] == nil then
                addFrontier(frontier, frontierIndexByKey, newRoom.Id, directionIndex)
            end
        end
    end

    for _, room in pairs(rooms) do
        room.Kind = 'Loot'
    end

    local campRoomId = startRoom.Id
    local extractionRoomId = selectExtractionRoom(rooms, campRoomId)
    rooms[campRoomId].Kind = 'Camp'
    rooms[extractionRoomId].Kind = 'Extraction'
    finalizeRoomConnectivity(rooms)

    local doorwayKeys = {}
    for edgeKey in pairs(edgesByKey) do
        table_insert(doorwayKeys, edgeKey)
    end
    table_sort(doorwayKeys)

    local doorways = {}
    for _, edgeKey in ipairs(doorwayKeys) do
        local edge = edgesByKey[edgeKey]
        doorways[edgeKey] = {
            Id = edgeKey,
            RoomA = edge.RoomA,
            RoomB = edge.RoomB,
            DirectionFromA = edge.DirectionFromA,
            DirectionFromB = edge.DirectionFromB,
            HasDoorLeaves = random:NextNumber() < doorLeafChance,
        }
    end

    local externalDoorways = {}

    local valid, reason = validateRoomConnections(rooms)
    if not valid then
        return nil, reason
    end

    local mainPath = buildMainPath(rooms, campRoomId, extractionRoomId)
    local loopMetadata = buildLoopMetadata(rooms, doorways, campRoomId)
    if loopMetadata.LoopCount < 1 then
        return nil, 'LoopingFacilityRequired'
    end

    local assignmentMetadata =
        assignRoomTemplates(rooms, campRoomId, extractionRoomId, mainPath, loopMetadata)

    enrichDoorwayMetadata(rooms, doorways, loopMetadata)
    local orderedRoomIds = sortedRoomIds(rooms)
    local macroGraph =
        buildMacroGraph(orderedRoomIds, rooms, mainPath, loopMetadata, assignmentMetadata)

    return {
        Seed = seed,
        Rooms = rooms,
        Doorways = doorways,
        MainPath = mainPath,
        CampRoomId = campRoomId,
        ExtractionRoomId = extractionRoomId,
        ExternalDoorways = externalDoorways,
        MacroGraph = macroGraph,
        PlacedRooms = buildPlacedRooms(orderedRoomIds, rooms),
        PlacedPassages = buildPlacedPassages(doorways, externalDoorways),
        SearchDistribution = buildSearchDistribution(orderedRoomIds, rooms),
        LandmarkNodes = buildLandmarkNodes(orderedRoomIds, rooms),
    }
end

function MazeBuilder.build(seed, config)
    config = config or {}

    local maxAttempts = math_max(1, config.MaxGenerationAttempts or DEFAULT_MAX_ATTEMPTS)
    for attempt = 1, maxAttempts do
        local attemptSeed = seed + ((attempt - 1) * 131)
        local maze, reason = buildAttempt(attemptSeed, config)
        if maze then
            return maze
        end

        if attempt == maxAttempts then
            error(
                string.format(
                    'MazeBuilder failed after %d attempts (%s)',
                    maxAttempts,
                    tostring(reason)
                ),
                0
            )
        end
    end
end

return MazeBuilder
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="45">
            <Properties>
              <string name="Name">MazePassageTemplates</string>
              <string name="Source"><![CDATA[local MazePassageTemplates = {}

MazePassageTemplates.EndpointType = table.freeze({
    Hall = 'hall',
    Service = 'service',
    Bulkhead = 'bulkhead',
    Exit = 'exit',
})

local function freezeList(values)
    return table.freeze(values)
end

local DEFINITIONS_BY_ID = {
    IndustrialHall = table.freeze({
        Id = 'IndustrialHall',
        EndpointType = MazePassageTemplates.EndpointType.Hall,
        Width = 6,
        Height = 14,
        WallThicknessMultiplier = 1,
        AccentColor = Color3.fromRGB(118, 124, 132),
    }),
    ServiceSpine = table.freeze({
        Id = 'ServiceSpine',
        EndpointType = MazePassageTemplates.EndpointType.Service,
        Width = 5,
        Height = 13,
        WallThicknessMultiplier = 0.9,
        AccentColor = Color3.fromRGB(96, 134, 158),
    }),
    BulkheadConnector = table.freeze({
        Id = 'BulkheadConnector',
        EndpointType = MazePassageTemplates.EndpointType.Bulkhead,
        Width = 7,
        Height = 14,
        WallThicknessMultiplier = 1.35,
        AccentColor = Color3.fromRGB(154, 120, 84),
    }),
    ExitSpur = table.freeze({
        Id = 'ExitSpur',
        EndpointType = MazePassageTemplates.EndpointType.Exit,
        Width = 6,
        Height = 14,
        WallThicknessMultiplier = 1.05,
        AccentColor = Color3.fromRGB(112, 136, 154),
    }),
}

local ALLOWED_ENDPOINT_TYPES = table.freeze({
    [MazePassageTemplates.EndpointType.Hall] = freezeList({
        MazePassageTemplates.EndpointType.Hall,
        MazePassageTemplates.EndpointType.Service,
        MazePassageTemplates.EndpointType.Bulkhead,
        MazePassageTemplates.EndpointType.Exit,
    }),
    [MazePassageTemplates.EndpointType.Service] = freezeList({
        MazePassageTemplates.EndpointType.Hall,
        MazePassageTemplates.EndpointType.Service,
        MazePassageTemplates.EndpointType.Bulkhead,
    }),
    [MazePassageTemplates.EndpointType.Bulkhead] = freezeList({
        MazePassageTemplates.EndpointType.Hall,
        MazePassageTemplates.EndpointType.Service,
        MazePassageTemplates.EndpointType.Bulkhead,
    }),
    [MazePassageTemplates.EndpointType.Exit] = freezeList({
        MazePassageTemplates.EndpointType.Hall,
        MazePassageTemplates.EndpointType.Service,
        MazePassageTemplates.EndpointType.Bulkhead,
    }),
})

function MazePassageTemplates.getDefinition(archetypeId)
    return DEFINITIONS_BY_ID[archetypeId]
end

function MazePassageTemplates.getAllowedEndpointTypes(endpointType)
    return ALLOWED_ENDPOINT_TYPES[endpointType] or ALLOWED_ENDPOINT_TYPES.hall
end

function MazePassageTemplates.resolveDoorwayArchetype(roomA, roomB, isLoopDoorway)
    if roomA.RoomCategory == 'BulkheadGate' or roomB.RoomCategory == 'BulkheadGate' then
        return DEFINITIONS_BY_ID.BulkheadConnector
    end

    if
        roomA.RoomCategory == 'LandmarkFacility'
        or roomB.RoomCategory == 'LandmarkFacility'
        or roomA.RoomCategory == 'ShortcutLoop'
        or roomB.RoomCategory == 'ShortcutLoop'
        or isLoopDoorway == true
    then
        return DEFINITIONS_BY_ID.ServiceSpine
    end

    return DEFINITIONS_BY_ID.IndustrialHall
end

function MazePassageTemplates.resolveExternalArchetype(_room)
    return DEFINITIONS_BY_ID.ExitSpur
end

return MazePassageTemplates
]]></string>
