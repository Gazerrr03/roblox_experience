      <Item class="ModuleScript" referent="116">
        <Properties>
          <string name="Name">RunTerminal</string>
          <string name="Source"><![CDATA[local RunTerminal = {}
RunTerminal.__index = RunTerminal

function RunTerminal.new(kind, part)
    -- 先找直接的 ProximityPrompt 子对象
    local prompt = part:FindFirstChildOfClass('ProximityPrompt')
    if prompt == nil then
        -- 尝试找名为 'Prompt' 或 'prompt' 的子对象
        for _, name in ipairs({'Prompt', 'prompt', 'PROMPT'}) do
            local namedPrompt = part:FindFirstChild(name, true)
            if namedPrompt then
                if namedPrompt:IsA('ProximityPrompt') then
                    prompt = namedPrompt
                    break
                elseif namedPrompt:IsA('Model') or namedPrompt:IsA('Folder') then
                    -- 可能在子目录里
                    prompt = namedPrompt:FindFirstChildOfClass('ProximityPrompt')
                    if prompt then
                        break
                    end
                end
            end
        end
    end
    if prompt == nil then
        warn(string.format('[RunTerminal] WARNING: %s has no ProximityPrompt, terminal disabled', tostring(kind)))
        return setmetatable({
            Kind = kind,
            Part = part,
            Prompt = nil,
            Disabled = true,
        }, RunTerminal)
    end

    warn(string.format('[RunTerminal] %s: found ProximityPrompt "%s"', kind, prompt.Name))

    return setmetatable({
        Kind = kind,
        Part = part,
        Prompt = prompt,
    }, RunTerminal)
end

function RunTerminal:bind(callback)
    if self.Disabled then
        warn(string.format('[RunTerminal] %s is disabled, cannot bind', self.Kind))
        return function() end
    end
    warn(string.format('[RunTerminal] Binding %s prompt...', self.Kind))
    return self.Prompt.Triggered:Connect(function(player)
        warn(string.format('[RunTerminal] %s triggered by %s', self.Kind, player.DisplayName))
        callback(player)
    end)
end

function RunTerminal:isPlayerNear(player, distanceBuffer)
    local character = player.Character
    local rootPart = character and character:FindFirstChild('HumanoidRootPart')
    if not rootPart or not rootPart:IsA('BasePart') then
        return false
    end

    local maxDistance = self.Prompt.MaxActivationDistance + (distanceBuffer or 0)
    return (rootPart.Position - self.Part.Position).Magnitude <= maxDistance
end

return RunTerminal
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="117">
        <Properties>
          <string name="Name">RunToMazeTransition</string>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService('ReplicatedStorage')
local TeleportService = game:GetService('TeleportService')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Shared = require(Packages:WaitForChild('Shared'))

local DefaultSessionConfig = Shared.Config.SessionConfig
local DefaultContract = Shared.Session.CampMazeSessionContract
local DefaultAvailability = Shared.Session.MazeEntryAvailability
local DefaultDiagnostics = Shared.Util.TeleportDiagnostics

local RunToMazeTransition = {}
RunToMazeTransition.__index = RunToMazeTransition

RunToMazeTransition.FailureCode = table.freeze({
    ReserveServerFailed = 'ReserveServerFailed',
    TeleportAsyncFailed = 'TeleportAsyncFailed',
})

local function buildReservedServerTeleportOptions(accessCode, teleportData)
    local teleportOptions = Instance.new('TeleportOptions')
    teleportOptions.ReservedServerAccessCode = accessCode
    teleportOptions:SetTeleportData(teleportData)
    return teleportOptions
end

function RunToMazeTransition.new(options)
    local resolved = options or {}

    return setmetatable({
        TeleportService = resolved.TeleportService or TeleportService,
        SessionConfig = resolved.SessionConfig or DefaultSessionConfig,
        Contract = resolved.Contract or DefaultContract,
        Availability = resolved.Availability or DefaultAvailability,
        Diagnostics = resolved.Diagnostics or DefaultDiagnostics,
        ForceFreshServerForDiagnostics = resolved.ForceFreshServerForDiagnostics == true,
    }, RunToMazeTransition)
end

function RunToMazeTransition:enter(params)
    local currentSession = self.Contract.normalizeCampSession(params.CampSession)
    local mazeTeleportSnapshot = self.Diagnostics.captureSnapshot({
        TargetKey = 'Maze',
        TargetPlaceId = self.SessionConfig.PlaceIds.Maze,
    })

    local mazeAccessCode = currentSession.MazeAccessCode
    if self.ForceFreshServerForDiagnostics and mazeAccessCode ~= nil then
        mazeAccessCode = nil
    end

    if mazeAccessCode == nil then
        local reserved, reserveResult = pcall(function()
            return self.TeleportService:ReserveServer(self.SessionConfig.PlaceIds.Maze)
        end)

        if not reserved then
            return {
                Ok = false,
                FailureCode = RunToMazeTransition.FailureCode.ReserveServerFailed,
                Reason = self.Diagnostics.formatFailure(
                    'ReserveServer',
                    reserveResult,
                    mazeTeleportSnapshot
                ),
                ReasonCode = RunToMazeTransition.FailureCode.ReserveServerFailed,
                CurrentSession = currentSession,
            }
        end

        mazeAccessCode = reserveResult
    end

    local nextSession = self.Contract.markPlayerEntered(currentSession, params.EnteringPlayer)
    nextSession.MazeAccessCode = mazeAccessCode
    nextSession.GateOpen = params.GateOpen == true

    local teleportData = self.Contract.buildRunToMazeTeleportData({
        SessionConfig = params.SessionConfig,
        CampSession = nextSession,
        EnteringPlayer = params.EnteringPlayer,
        EntryReason = params.EntryReason or 'maze_gate',
        PlayerInventory = params.PlayerInventory,
        PendingUgcMonsterPayload = params.PendingUgcMonsterPayload,
    })

    local teleportOptions = buildReservedServerTeleportOptions(mazeAccessCode, teleportData)
    local success, message = pcall(function()
        self.TeleportService:TeleportAsync(
            self.SessionConfig.PlaceIds.Maze,
            { params.Player },
            teleportOptions
        )
    end)
    if not success then
        return {
            Ok = false,
            FailureCode = RunToMazeTransition.FailureCode.TeleportAsyncFailed,
            Reason = self.Diagnostics.formatFailure('TeleportAsync', message, mazeTeleportSnapshot),
            ReasonCode = RunToMazeTransition.FailureCode.TeleportAsyncFailed,
            CurrentSession = currentSession,
        }
    end

    return {
        Ok = true,
        NextSession = nextSession,
        Reason = 'Maze teleport target is ready.',
        ReasonCode = self.Availability.ReasonCode.TeleportReady,
    }
end

return RunToMazeTransition
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="118">
        <Properties>
          <string name="Name">RunWorldBuilder</string>
          <string name="Source"><![CDATA[local Workspace = game:GetService('Workspace')

local RunScene = require(script.Parent.RunScene)
local RunStaticWorldContract = require(script.Parent.RunStaticWorldContract)
local RunStaticWorldValidator = require(script.Parent.RunStaticWorldValidator)
local RunSpawnPoint = require(script.Parent.RunSpawnPoint)

local RunWorldBuilder = {}

local function stabilizeVisualModel(model)
    if model == nil then
        return
    end

    for _, descendant in ipairs(model:GetDescendants()) do
        if descendant:IsA('BasePart') then
            descendant.Anchored = true
            descendant.CanCollide = false
            descendant.CanTouch = false
            descendant.CanQuery = true
            descendant.AssemblyLinearVelocity = Vector3.zero
            descendant.AssemblyAngularVelocity = Vector3.zero
        end
    end
end

local function prepareRunTerrain(root)
    local terrainRoot = root:FindFirstChild('RunTerrain_Main')
    if terrainRoot == nil or not terrainRoot:IsA('Model') then
        return
    end

    stabilizeVisualModel(terrainRoot:FindFirstChild('Scene'))
    stabilizeVisualModel(terrainRoot:FindFirstChild('Sci-Fi Space Ship'))
end

function RunWorldBuilder.build()
    local staticWorldRoot = Workspace:FindFirstChild(RunStaticWorldContract.RootName)
    if staticWorldRoot == nil then
        error(
            string.format(
                'Workspace is missing required authored root "%s".',
                RunStaticWorldContract.RootName
            ),
            0
        )
    end

    if not (staticWorldRoot:IsA('Folder') or staticWorldRoot:IsA('Model')) then
        error('RunStaticWorld must be a Folder or Model.', 0)
    end

    prepareRunTerrain(staticWorldRoot)
    RunStaticWorldValidator.validate(staticWorldRoot)

    return RunScene.new(staticWorldRoot)
end

RunWorldBuilder.SpawnTarget = RunSpawnPoint.Kind

return RunWorldBuilder
]]></string>
        </Properties>
      </Item>
    </Item>
  </Item>
