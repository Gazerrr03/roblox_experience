		<Item class="Script" referent="RBX3D9D64692D1042F1921C413C10299A6C">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local base = script.Parent.Handle
local p = script.Parent:GetChildren()
for i = 1, #p do
    if p[i].ClassName == "Part" or p[i].ClassName == "WedgePart" then
		local w = Instance.new("Weld", p[i])
