local DEFAULT_ASSET_IDS = table.freeze({
    ModelAssetId = MonsterAssetIds.DefaultModelAssetId,
    ChaseLoopSoundAssetId = MonsterAssetIds.DefaultChaseLoopSoundAssetId,
