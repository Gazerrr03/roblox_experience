        <Item class="ModuleScript" referent="61">
          <Properties>
            <string name="Name">Network</string>
            <string name="Source"><![CDATA[return {
    Remotes = require(script.Remotes),
}
]]></string>
          </Properties>
          <Item class="ModuleScript" referent="62">
            <Properties>
              <string name="Name">Remotes</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService('ReplicatedStorage')
local RunService = game:GetService('RunService')

local Remotes = {}

Remotes.Scope = table.freeze({
    Lobby = 'Lobby',
    Run = 'Run',
    Maze = 'Maze',
})

local REMOTE_NAMES_BY_SCOPE = table.freeze({
    [Remotes.Scope.Lobby] = {
        'LobbyAction',
        'LobbyState',
    },
    [Remotes.Scope.Run] = {
        'RunAction',
        'RunState',
        'RunPrivateState',
        'ShowNarrative',
        'GetInventory',
        'EquipItem',
        'UseItem',
        'UseItemFunction',
        'GetInteractables',
        'GetItemData',
        'ItemUsageFeedback',
    },
    [Remotes.Scope.Maze] = {
        'MazeAction',
        'MazeState',
        'MazePrivateState',
    },
})

local ALL_REMOTE_NAMES = {
    'LobbyAction',
    'LobbyState',
    'RunAction',
    'RunState',
    'RunPrivateState',
    'ShowNarrative',
    'GetInventory',
    'EquipItem',
    'UseItem',
    'UseItemFunction',
    'GetInteractables',
    'GetItemData',
    'ItemUsageFeedback',
    'MazeAction',
    'MazeState',
    'MazePrivateState',
}

local function assertServer(operationName)
    if RunService:IsClient() then
        error(string.format('%s can only be called on the server.', operationName), 0)
    end
end

local function ensureContainer()
    local container = ReplicatedStorage:FindFirstChild('Remotes')
    if container then
        return container
    end

    container = Instance.new('Folder')
    container.Name = 'Remotes'
    container.Parent = ReplicatedStorage
    return container
end

-- 需要使用RemoteFunction的remote名称
local REMOTE_FUNCTION_NAMES = {
    'GetInventory',
    'GetInteractables',
    'GetItemData',
}

local function ensureRemote(container, name)
    local remote = container:FindFirstChild(name)
    if remote then
        return remote
    end

    -- 使用 table.find 检查是否需要创建 RemoteFunction
    local isFunction = table.find(REMOTE_FUNCTION_NAMES, name) ~= nil

    if isFunction then
        remote = Instance.new('RemoteFunction')
    else
        remote = Instance.new('RemoteEvent')
    end
    remote.Name = name
    remote.Parent = container
    return remote
end

local function waitForContainer(timeoutSeconds)
    if timeoutSeconds == nil then
        return ReplicatedStorage:WaitForChild('Remotes')
    end

    return ReplicatedStorage:WaitForChild('Remotes', timeoutSeconds)
end

local function waitForRemote(container, name, timeoutSeconds)
    if timeoutSeconds == nil then
        return container:WaitForChild(name)
    end

    return container:WaitForChild(name, timeoutSeconds)
end

function Remotes.ensure()
    assertServer('Remotes.ensure')

    local container = ensureContainer()
    local resolved = {}

    for _, name in ipairs(ALL_REMOTE_NAMES) do
        resolved[name] = ensureRemote(container, name)
    end

    return resolved
end

function Remotes.ensureScope(scope)
    assertServer('Remotes.ensureScope')

    local remoteNames = REMOTE_NAMES_BY_SCOPE[scope]
    if remoteNames == nil then
        error(string.format('Unknown remote scope %q', tostring(scope)), 0)
    end

    local container = ensureContainer()
    local resolved = {}

    for _, name in ipairs(remoteNames) do
        resolved[name] = ensureRemote(container, name)
    end

    return resolved
end

function Remotes.waitForScope(scope, timeoutSeconds)
    local remoteNames = REMOTE_NAMES_BY_SCOPE[scope]
    if remoteNames == nil then
        error(string.format('Unknown remote scope %q', tostring(scope)), 0)
    end

    local startTime = os.clock()
    local function getRemainingTimeout()
        if timeoutSeconds == nil then
            return nil
        end

        local elapsed = os.clock() - startTime
        local remaining = timeoutSeconds - elapsed
        if remaining < 0 then
            return 0
        end

        return remaining
    end

    local container = waitForContainer(getRemainingTimeout())
    if container == nil then
        error('Timed out waiting for ReplicatedStorage.Remotes.', 0)
    end

    local resolved = {}

    for _, name in ipairs(remoteNames) do
        local remote = waitForRemote(container, name, getRemainingTimeout())
        if remote == nil then
            error(string.format('Timed out waiting for remote %s.', name), 0)
        end

        resolved[name] = remote
    end

    return resolved
end

return Remotes
]]></string>
            </Properties>
          </Item>
        </Item>
        <Item class="ModuleScript" referent="63">
          <Properties>
            <string name="Name">Runtime</string>
            <string name="Source"><![CDATA[return {
    ControlStateService = require(script.ControlStateService),
    FormalLocomotion = require(script.FormalLocomotion),
    HexMazeWorldRenderer = require(script.HexMazeWorldRenderer),
    InventoryService = require(script.InventoryService),
    MazeDebugWorldComposer = require(script.MazeDebugWorldComposer),
    MazeFormalWorldComposer = require(script.MazeFormalWorldComposer),
    MazeLightingProfile = require(script.MazeLightingProfile),
    MazeModuleAssetContract = require(script.MazeModuleAssetContract),
    MazeWorldScanner = require(script.MazeWorldScanner),
    MazeWorldShellBuilder = require(script.MazeWorldShellBuilder),
    MonsterRuntime = require(script.MonsterRuntime),
    MonsterService = require(script.MonsterService),
    PlayerService = require(script.PlayerService),
    PlayerStateService = require(script.PlayerStateService),
    TeleportInventoryHydrator = require(script.TeleportInventoryHydrator),
}
]]></string>
          </Properties>
          <Item class="ModuleScript" referent="64">
            <Properties>
              <string name="Name">ControlStateService</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService('ReplicatedStorage')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Gameplay = require(Packages:WaitForChild('Gameplay'))

local ControlState = Gameplay.ControlState

local ControlStateService = {}
ControlStateService.__index = ControlStateService

local function buildDefaultSummary()
    return ControlState.new():getSummary()
end

function ControlStateService.new()
    return setmetatable({
        ByUserId = {},
        DefaultSummary = buildDefaultSummary(),
    }, ControlStateService)
end

function ControlStateService:addPlayer(player)
    local state = ControlState.new()
    self.ByUserId[player.UserId] = state
    return state
end

function ControlStateService:removePlayer(player)
    self.ByUserId[player.UserId] = nil
end

function ControlStateService:get(player)
    return self.ByUserId[player.UserId]
end

function ControlStateService:getSummary(player)
    local state = self:get(player)
    if not state then
        return table.clone(self.DefaultSummary)
    end

    return state:getSummary()
end

function ControlStateService:requestSprintStart(player, playerStateSummary)
    local state = self:get(player)
    if not state then
        return false, 'MissingControlState'
    end

    return state:requestSprintStart(playerStateSummary)
end

function ControlStateService:requestSprintStop(player)
    local state = self:get(player)
    if not state then
        return false, 'MissingControlState'
    end

    return state:requestSprintStop()
end

function ControlStateService:syncPlayerState(player, playerStateSummary)
    local state = self:get(player)
    if not state then
        return false, 'MissingControlState'
    end

    return true, state:syncPlayerState(playerStateSummary)
end

function ControlStateService:reset()
    table.clear(self.ByUserId)
end

return ControlStateService
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="65">
            <Properties>
              <string name="Name">FormalLocomotion</string>
              <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService('ReplicatedStorage')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Gameplay = require(Packages:WaitForChild('Gameplay'))

local MODE = Gameplay.ControlState.Mode

local FormalLocomotion = {}

FormalLocomotion.Mode = MODE
FormalLocomotion.WalkSpeed = 16
FormalLocomotion.SprintWalkSpeed = 24

function FormalLocomotion.summarize(playerStateSummary, controlStateSummary)
    local playerState = playerStateSummary or {}
    local controlState = controlStateSummary or {}
    local isDead = playerState.IsDead == true
    local canSprint = not isDead and playerState.CanSprint == true

    local mode = MODE.Walk
    if not isDead and controlState.Mode == MODE.Sprint then
        mode = MODE.Sprint
    end

    local walkSpeed = FormalLocomotion.WalkSpeed
    if isDead then
        walkSpeed = 0
    elseif mode == MODE.Sprint then
        walkSpeed = FormalLocomotion.SprintWalkSpeed
    end

    return {
        Mode = mode,
        WalkSpeed = walkSpeed,
        CanSprint = canSprint,
    }
end

function FormalLocomotion.formatStatus(playerStateSummary, movementSummary)
    local playerState = playerStateSummary or {}
    local movement = movementSummary or {}

    if playerState.IsDead then
        return 'Disabled'
    end

    if movement.CanSprint then
        return 'Ready'
    end

    return 'Recovering'
end

function FormalLocomotion.applyToHumanoid(humanoid, movementSummary)
    if not humanoid then
        return
    end

    humanoid.WalkSpeed = (movementSummary and movementSummary.WalkSpeed)
        or FormalLocomotion.WalkSpeed
end

return FormalLocomotion
