      <Item class="ModuleScript" referent="100">
        <Properties>
          <string name="Name">CampHouseBuilder</string>
          <string name="Source"><![CDATA[local HOUSE_WIDTH = 44
local HOUSE_DEPTH = 30
local HOUSE_HEIGHT = 18
local WALL_THICKNESS = 2
local DOOR_GAP = 12

local CampHouseBuilder = {}

function CampHouseBuilder.build(worldFolder, createPart, createPromptPart)
    local houseFolder = Instance.new('Folder')
    houseFolder.Name = 'CampHouse'
    houseFolder.Parent = worldFolder

    createPart({
        Name = 'CampFloor',
        Size = Vector3.new(HOUSE_WIDTH, 1, HOUSE_DEPTH),
        CFrame = CFrame.new(0, -0.5, 0),
        Color = Color3.fromRGB(86, 73, 61),
        Material = Enum.Material.WoodPlanks,
    }, houseFolder)

    createPart({
        Name = 'Foundation',
        Size = Vector3.new(HOUSE_WIDTH + 8, 2, HOUSE_DEPTH + 8),
        CFrame = CFrame.new(0, -1.5, 0),
        Color = Color3.fromRGB(63, 67, 74),
        Material = Enum.Material.Slate,
    }, houseFolder)

    createPart({
        Name = 'BackWall',
        Size = Vector3.new(HOUSE_WIDTH, HOUSE_HEIGHT, WALL_THICKNESS),
        CFrame = CFrame.new(0, HOUSE_HEIGHT / 2, -(HOUSE_DEPTH / 2)),
        Color = Color3.fromRGB(122, 103, 84),
        Material = Enum.Material.WoodPlanks,
    }, houseFolder)

    createPart({
        Name = 'LeftWall',
        Size = Vector3.new(WALL_THICKNESS, HOUSE_HEIGHT, HOUSE_DEPTH),
        CFrame = CFrame.new(-(HOUSE_WIDTH / 2), HOUSE_HEIGHT / 2, 0),
        Color = Color3.fromRGB(122, 103, 84),
        Material = Enum.Material.WoodPlanks,
    }, houseFolder)

    createPart({
        Name = 'RightWall',
        Size = Vector3.new(WALL_THICKNESS, HOUSE_HEIGHT, HOUSE_DEPTH),
        CFrame = CFrame.new(HOUSE_WIDTH / 2, HOUSE_HEIGHT / 2, 0),
        Color = Color3.fromRGB(122, 103, 84),
        Material = Enum.Material.WoodPlanks,
    }, houseFolder)

    local frontWallWidth = (HOUSE_WIDTH - DOOR_GAP) / 2
    createPart({
        Name = 'FrontWallLeft',
        Size = Vector3.new(frontWallWidth, HOUSE_HEIGHT, WALL_THICKNESS),
        CFrame = CFrame.new(
            -((DOOR_GAP / 2) + (frontWallWidth / 2)),
            HOUSE_HEIGHT / 2,
            HOUSE_DEPTH / 2
        ),
        Color = Color3.fromRGB(122, 103, 84),
        Material = Enum.Material.WoodPlanks,
    }, houseFolder)

    createPart({
        Name = 'FrontWallRight',
        Size = Vector3.new(frontWallWidth, HOUSE_HEIGHT, WALL_THICKNESS),
        CFrame = CFrame.new(
            (DOOR_GAP / 2) + (frontWallWidth / 2),
            HOUSE_HEIGHT / 2,
            HOUSE_DEPTH / 2
        ),
        Color = Color3.fromRGB(122, 103, 84),
        Material = Enum.Material.WoodPlanks,
    }, houseFolder)

    createPart({
        Name = 'Roof',
        Size = Vector3.new(HOUSE_WIDTH + 4, 2, HOUSE_DEPTH + 4),
        CFrame = CFrame.new(0, HOUSE_HEIGHT + 1, 0),
        Color = Color3.fromRGB(74, 52, 42),
        Material = Enum.Material.WoodPlanks,
    }, houseFolder)

    local doorLeft = createPart({
        Name = 'DoorLeft',
        Size = Vector3.new(DOOR_GAP / 2, HOUSE_HEIGHT - 2, 1.5),
        CFrame = CFrame.new(-(DOOR_GAP / 4), (HOUSE_HEIGHT - 2) / 2, HOUSE_DEPTH / 2),
        Color = Color3.fromRGB(91, 66, 45),
        Material = Enum.Material.Wood,
    }, houseFolder)

    local doorRight = createPart({
        Name = 'DoorRight',
        Size = Vector3.new(DOOR_GAP / 2, HOUSE_HEIGHT - 2, 1.5),
        CFrame = CFrame.new(DOOR_GAP / 4, (HOUSE_HEIGHT - 2) / 2, HOUSE_DEPTH / 2),
        Color = Color3.fromRGB(91, 66, 45),
        Material = Enum.Material.Wood,
    }, houseFolder)

    local _, gatePrompt = createPromptPart({
        Name = 'GateSwitch',
        Size = Vector3.new(3, 5, 3),
        CFrame = CFrame.new(0, 2.5, (HOUSE_DEPTH / 2) - 5),
        Color = Color3.fromRGB(93, 196, 176),
        Material = Enum.Material.Metal,
        ActionText = 'Open Gate',
        ObjectText = 'Temple Gate',
    }, houseFolder)

    local _, shopPrompt = createPromptPart({
        Name = 'ShopTerminal',
        Size = Vector3.new(4, 5, 4),
        CFrame = CFrame.new(-(HOUSE_WIDTH / 2) + 8, 2.5, -4),
        Color = Color3.fromRGB(77, 147, 196),
        Material = Enum.Material.Metal,
        ActionText = 'Inspect',
        ObjectText = 'Temple Shop (Soon)',
    }, houseFolder)

    local _, loadoutPrompt = createPromptPart({
        Name = 'LoadoutBench',
        Size = Vector3.new(6, 3, 3),
        CFrame = CFrame.new((HOUSE_WIDTH / 2) - 9, 1.5, -2),
        Color = Color3.fromRGB(208, 176, 94),
        Material = Enum.Material.WoodPlanks,
        ActionText = 'Inspect',
        ObjectText = 'Loadout Bench (Soon)',
    }, houseFolder)

    local _, sellPrompt = createPromptPart({
        Name = 'SalvageTerminal',
        Size = Vector3.new(4, 5, 4),
        CFrame = CFrame.new((HOUSE_WIDTH / 2) - 9, 2.5, 6),
        Color = Color3.fromRGB(196, 121, 77),
        Material = Enum.Material.Metal,
        ActionText = 'Exchange',
        ObjectText = 'Salvage Exchange',
    }, houseFolder)

    local _, objectivePrompt = createPromptPart({
        Name = 'ObjectiveBoard',
        Size = Vector3.new(6, 4, 1.5),
        CFrame = CFrame.new(0, 5, -(HOUSE_DEPTH / 2) + 2),
        Color = Color3.fromRGB(67, 112, 65),
        Material = Enum.Material.WoodPlanks,
        ActionText = 'Review',
        ObjectText = 'Book of Sand Board',
        MaxActivationDistance = 12,
    }, houseFolder)

    createPart({
        Name = 'UgcLabBlockBase',
        Size = Vector3.new(5, 2, 4),
        CFrame = CFrame.new(-(HOUSE_WIDTH / 2) + 10, 1, 6),
        Color = Color3.fromRGB(48, 60, 82),
        Material = Enum.Material.Metal,
    }, houseFolder)

    local _, ugcLabPrompt = createPromptPart({
        Name = 'UgcLabConsole',
        Size = Vector3.new(4, 3.5, 3),
        CFrame = CFrame.new(-(HOUSE_WIDTH / 2) + 10, 2.75, 6),
        Color = Color3.fromRGB(93, 196, 176),
        Material = Enum.Material.Neon,
        ActionText = 'Open',
        ObjectText = 'UGC Lab',
        KeyboardKeyCode = Enum.KeyCode.E,
    }, houseFolder)

    createPart({
        Name = 'MeetingTable',
        Size = Vector3.new(10, 1, 5),
        CFrame = CFrame.new(0, 2.5, -4),
        Color = Color3.fromRGB(109, 84, 64),
        Material = Enum.Material.Wood,
    }, houseFolder)

    for _, offsetX in ipairs({ -8, 8 }) do
        createPart({
            Name = 'BenchSeat',
            Size = Vector3.new(8, 1, 2),
            CFrame = CFrame.new(offsetX, 1.5, 5),
            Color = Color3.fromRGB(104, 82, 63),
            Material = Enum.Material.Wood,
        }, houseFolder)
    end

    local function openGate()
        doorLeft.CFrame = CFrame.new(-(DOOR_GAP / 2) - 3, (HOUSE_HEIGHT - 2) / 2, HOUSE_DEPTH / 2)
        doorRight.CFrame = CFrame.new((DOOR_GAP / 2) + 3, (HOUSE_HEIGHT - 2) / 2, HOUSE_DEPTH / 2)
        gatePrompt.ActionText = 'Gate Open'
        doorLeft.CanCollide = false
        doorRight.CanCollide = false
    end

    return {
        ShopPrompt = shopPrompt,
        SellPrompt = sellPrompt,
        ObjectivePrompt = objectivePrompt,
        LoadoutPrompt = loadoutPrompt,
        UgcLabPrompt = ugcLabPrompt,
        GatePrompt = gatePrompt,
        OpenGate = openGate,
    }
end

return CampHouseBuilder
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="101">
        <Properties>
          <string name="Name">InteractableObjectsSetup</string>
          <string name="Source"><![CDATA[--!strict
local ItemFunctionality = require(script.Parent.ItemFunctionality)

--#region Module

local InteractableObjectsSetup = {}

-- 设置地图中的可交互对象
function InteractableObjectsSetup.setupInteractables(outdoorFolder: Folder)
    -- ====================
    -- 攀爬点 (绳索)
    -- ====================

    -- 洞穴遗迹区的攀爬墙
    local climbWall1 = outdoorFolder:FindFirstChild('CaveRuinsZone')
    if climbWall1 then
        for _, child in ipairs(climbWall1:GetDescendants()) do
            if
                child:IsA('Part')
                and (string.find(child.Name, 'Wall') or string.find(child.Name, 'Climb'))
            then
                ItemFunctionality.registerInteractable(child, 'Climbable', {
                    Height = 10,
                })
            end
        end
    end

    -- 古代遗迹区的高墙
    local climbWall2 = outdoorFolder:FindFirstChild('AncientRuinsZone')
    if climbWall2 then
        for _, child in ipairs(climbWall2:GetDescendants()) do
            if child:IsA('Part') and string.find(child.Name, 'Wall') then
                ItemFunctionality.registerInteractable(child, 'Climbable', {
                    Height = 8,
                })
            end
        end
    end

    -- ====================
    -- 跨越点 (绳索)
    -- ====================

    -- 洞穴入口的断层
    local gap1 = outdoorFolder:FindFirstChild('CaveRuinsZone')
    if gap1 then
        local gapMarker = gap1:FindFirstChild('GapMarker')
        if gapMarker and gapMarker:IsA('Part') then
            ItemFunctionality.registerInteractable(gapMarker, 'Crossable', {
                TargetCFrame = gapMarker.CFrame * CFrame.new(0, 0, 20), -- 跨越后的位置（相对于gapMarker）
            })
        end
    end

    -- ====================
    -- 可撬开的箱子/门 (撬棍)
    -- ====================

    -- 古代遗迹区的锁住箱子
    local ancientRuins = outdoorFolder:FindFirstChild('AncientRuinsZone')
    if ancientRuins then
        for _, child in ipairs(ancientRuins:GetDescendants()) do
            if
                child:IsA('Part')
                and (string.find(child.Name, 'Chest') or string.find(child.Name, 'Door'))
            then
                -- 检查是否已经有锁
                if child:FindFirstChild('Lock') == nil then
                    -- 添加锁部件
                    local lock = Instance.new('Part')
                    lock.Name = 'Lock'
                    lock.Size = Vector3.new(0.5, 0.5, 0.5)
                    lock.Color = Color3.fromRGB(112, 112, 112)
                    lock.Material = Enum.Material.Metal
                    lock.CanCollide = false
                    lock.Anchored = true
                    lock.Parent = child

                    -- 注册为可撬开
                    ItemFunctionality.registerInteractable(child, 'Pryable', {
                        RequiredItem = 'Crowbar',
                    })
                end
            end
        end
    end

    -- ====================
    -- 隐藏通道 (手电筒)
    -- ====================

    -- 洞穴内部的黑暗区域
    local cave = outdoorFolder:FindFirstChild('CaveZone')
    if cave then
        for _, child in ipairs(cave:GetDescendants()) do
            if
                child:IsA('Part')
                and (string.find(child.Name, 'Dark') or string.find(child.Name, 'Hidden'))
            then
                ItemFunctionality.registerInteractable(child, 'FlashlightRequired', {
                    DarknessLevel = 0.8,
                })
            end
        end
    end

    print('可交互对象设置完成')
end

return InteractableObjectsSetup
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="102">
        <Properties>
          <string name="Name">InventoryService</string>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService('ReplicatedStorage')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Gameplay = require(Packages:WaitForChild('Gameplay'))

local Inventory = Gameplay.Inventory

local InventoryService = {}
InventoryService.__index = InventoryService

function InventoryService.new(capacity: number)
    return setmetatable({
        Capacity = capacity,
        ByUserId = {},
    }, InventoryService)
end

function InventoryService:addPlayer(player)
    self.ByUserId[player.UserId] = Inventory.new(self.Capacity)
end

function InventoryService:removePlayer(player)
    self.ByUserId[player.UserId] = nil
end

function InventoryService:get(player)
    return self.ByUserId[player.UserId]
end

function InventoryService:pickup(player, itemDef)
    local inventory = self:get(player)
    if not inventory then
        return false, 'MissingInventory'
    end

    return inventory:add(itemDef)
end

function InventoryService:deposit(player)
    local inventory = self:get(player)
    if not inventory then
        return 0
    end

    local totalValue = inventory:getTotalValue()
    inventory:clear()
    return totalValue
end

function InventoryService:reset()
    for _, inventory in pairs(self.ByUserId) do
        inventory:clear()
    end
end

function InventoryService:getSummary(player)
    local inventory = self:get(player)
    if not inventory then
        return {
            Weight = 0,
            Count = 0,
            Value = 0,
        }
    end

    return {
        Weight = inventory.Weight,
        Count = #inventory.Order,
        Value = inventory:getTotalValue(),
    }
end

return InventoryService
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="103">
        <Properties>
          <string name="Name">ItemFunctionality</string>
          <string name="Source"><![CDATA[--!strict
--#region Services

local ReplicatedStorage = game:GetService('ReplicatedStorage')
local TweenService = game:GetService('TweenService')
local CollectionService = game:GetService('CollectionService')

--#endregion

--#region Requires

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Shared = require(Packages:WaitForChild('Shared'))
local Remotes = Shared.Network.Remotes.waitForScope(Shared.Network.Remotes.Scope.Run)

local ItemService = require(script.Parent.ItemService)

--#endregion

--#region Module

local ItemFunctionality = {}

-- 玩家道具状态
ItemFunctionality.ActiveEffects = {}

-- ====================
-- 道具 1: 手电筒
-- ====================

-- 切换手电筒开关
function ItemFunctionality.toggleFlashlight(player: Player): boolean
    local itemData = ItemService.getItemData(player, 'Flashlight')
    if not itemData or not itemData.IsEquipped then
        return false
    end

    local character = player.Character
    if not character then
        return false
    end

    local head = character:FindFirstChild('Head')
    if not head then
        return false
    end

    -- 查找或创建手电筒光源
    local flashlightLight = head:FindFirstChild('FlashlightLight')
    local isNewLight = false

    if flashlightLight then
        flashlightLight.Enabled = not flashlightLight.Enabled
    else
        flashlightLight = Instance.new('SpotLight')
        flashlightLight.Name = 'FlashlightLight'
        flashlightLight.Color = Color3.fromRGB(255, 255, 240)
        flashlightLight.Brightness = 2
        flashlightLight.Range = 50
        flashlightLight.Angle = 45
        flashlightLight.Face = Enum.NormalId.Front
        flashlightLight.Parent = head
        isNewLight = true
    end

    if isNewLight then
        -- 刚创建时默认开启
        flashlightLight.Enabled = true
    end

    return flashlightLight.Enabled
end

-- ====================
-- 道具 2: 绳索
-- ====================

-- 攀爬高处
function ItemFunctionality.climbWithRope(player: Player, climbTarget: BasePart): boolean
    local itemData = ItemService.getItemData(player, 'Rope')
    if not itemData or not itemData.IsEquipped then
        return false
    end

    local character = player.Character
    if not character then
        return false
    end

    local humanoid = character:FindFirstChild('Humanoid')
    if not humanoid then
        return false
    end

    -- 验证距离(防止远程交互攻击)
    local characterPosition = character.HumanoidRootPart.Position
    local distance = (climbTarget.Position - characterPosition).Magnitude
    local MAX_INTERACTION_DISTANCE = 15 -- 最大交互距离

    if distance > MAX_INTERACTION_DISTANCE then
        warn(player.Name .. ' 尝试从过远的距离使用绳索: ' .. tostring(distance))
        return false
    end

    -- 获取攀爬高度(使用交互对象的属性而非硬编码)
    local climbHeight = climbTarget:GetAttribute('Height') or 5

    -- 攀爬动画效果
    humanoid:ChangeState(Enum.HumanoidStateType.Climbing)

    -- 使用 TweenService 实现平滑攀爬,保留原始朝向
    local targetPosition = climbTarget.Position + Vector3.new(0, climbHeight, 0)
    local targetCFrame = CFrame.new(targetPosition, character.HumanoidRootPart.Position)
    local climbTween = TweenService:Create(
        character.HumanoidRootPart,
        TweenInfo.new(2, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut),
        { CFrame = targetCFrame }
    )
    climbTween:Play()

    -- 2秒后恢复正常状态
    task.delay(2, function()
        humanoid:ChangeState(Enum.HumanoidStateType.Freefall)
    end)

    return true
end

-- 跨越断层
function ItemFunctionality.crossWithRope(player: Player, crossTarget: CFrame): boolean
    local itemData = ItemService.getItemData(player, 'Rope')
    if not itemData or not itemData.IsEquipped then
        return false
    end

    local character = player.Character
    if not character then
        return false
    end

    -- 验证距离(防止远程交互攻击)
    local characterPosition = character.HumanoidRootPart.Position
    local targetPosition = crossTarget.Position
    local distance = (targetPosition - characterPosition).Magnitude
    local MAX_INTERACTION_DISTANCE = 20 -- 跨越距离可以稍大一些

    if distance > MAX_INTERACTION_DISTANCE then
        warn(player.Name .. ' 尝试从过远的距离使用绳索跨越: ' .. tostring(distance))
        return false
    end

    -- 播放跨越动画
    local humanoid = character:FindFirstChild('Humanoid')
    if humanoid then
        humanoid.PlatformStand = true
    end

    -- 使用 Tween 跨越,保留原始朝向
    local currentLookVector = character.HumanoidRootPart.CFrame.LookVector
    local targetCFrame = CFrame.new(crossTarget.Position, crossTarget.Position + currentLookVector)
    local crossTween = TweenService:Create(
        character.HumanoidRootPart,
        TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
        { CFrame = targetCFrame }
    )
    crossTween:Play()

    -- 1.5秒后恢复正常
    task.delay(1.5, function()
        if humanoid then
            humanoid.PlatformStand = false
        end
    end)

    return true
end

-- 套住怪物
function ItemFunctionality.tetherMonster(player: Player, targetModel: Model): boolean
    local itemData = ItemService.getItemData(player, 'Rope')
    if not itemData or not itemData.IsEquipped then
        return false
    end

    local humanoid = targetModel:FindFirstChild('Humanoid')
    if not humanoid then
        return false
    end

    -- 创建绳索视觉效果
    local character = player.Character
    if not character then
        return false
    end

    -- 验证距离(防止远程交互攻击)
    local characterPosition = character.HumanoidRootPart.Position
    local targetPosition = targetModel.HumanoidRootPart.Position
    local distance = (targetPosition - characterPosition).Magnitude
    local MAX_INTERACTION_DISTANCE = 25 -- 套怪物的距离可以稍大一些

    if distance > MAX_INTERACTION_DISTANCE then
        warn(player.Name .. ' 尝试从过远的距离套住怪物: ' .. tostring(distance))
        return false
    end

    local ropeVisual = Instance.new('Part')
    ropeVisual.Name = 'TetherRope'
    ropeVisual.Size = Vector3.new(0.1, 0.1, 1)
    ropeVisual.Color = Color3.fromRGB(139, 90, 43)
    ropeVisual.Material = Enum.Material.Fabric
    ropeVisual.Anchored = true
    ropeVisual.CanCollide = false
    ropeVisual.Parent = workspace -- 设置父级，使绳索可见

    -- 绳索两端的位置
    -- 使用约束连接玩家和目标
    local ropeConstraint = Instance.new('RopeConstraint')
    ropeConstraint.Name = 'TetherConstraint'
    ropeConstraint.Visible = true
    ropeConstraint.Length = 0
    ropeConstraint.Restitution = 0
    ropeConstraint.Thickness = 0.1
    ropeConstraint.Color = Color3.fromRGB(139, 90, 43)

    local attachment1 = Instance.new('Attachment')
    attachment1.Parent = character.HumanoidRootPart

    local attachment2 = Instance.new('Attachment')
    attachment2.Parent = targetModel.HumanoidRootPart

    ropeConstraint.Attachment0 = attachment1
    ropeConstraint.Attachment1 = attachment2
    ropeConstraint.Parent = character.HumanoidRootPart

    -- 固定怪物 2 秒
    local originalWalkSpeed = humanoid.WalkSpeed
    humanoid.PlatformStand = true
    humanoid.WalkSpeed = 0

    -- 2 秒后释放
    task.delay(2, function()
        humanoid.PlatformStand = false
        humanoid.WalkSpeed = originalWalkSpeed -- 恢复原始速度
        ropeConstraint:Destroy()
        attachment1:Destroy()
        attachment2:Destroy()
        ropeVisual:Destroy()
    end)

    return true
end

-- ====================
-- 道具 3: 撬棍
-- ====================

-- 撬开箱子/门
function ItemFunctionality.pryOpen(player: Player, targetPart: BasePart): boolean
    local itemData = ItemService.getItemData(player, 'Crowbar')
    if not itemData or not itemData.IsEquipped then
        return false
    end

    -- 验证距离(防止远程交互攻击)
    local character = player.Character
    if not character or not character.HumanoidRootPart then
        return false
    end

    local characterPosition = character.HumanoidRootPart.Position
    local targetPosition = targetPart.Position
    local distance = (targetPosition - characterPosition).Magnitude
    local MAX_INTERACTION_DISTANCE = 10 -- 撬开的距离需要比较近

    if distance > MAX_INTERACTION_DISTANCE then
        warn(player.Name .. ' 尝试从过远的距离撬开: ' .. tostring(distance))
        return false
    end

    -- 检查目标是否已被撬开
    if targetPart:GetAttribute('PriedOpen') then
        return false
    end

    -- 撬棍动画
    -- 创建撬棍视觉提示
    local crowbarVisual = Instance.new('Part')
    crowbarVisual.Name = 'CrowbarAnimation'
    crowbarVisual.Size = Vector3.new(0.2, 4, 0.2)
    crowbarVisual.Color = Color3.fromRGB(120, 120, 120)
    crowbarVisual.Material = Enum.Material.Metal
    crowbarVisual.CanCollide = false
    crowbarVisual.Anchored = true

    local pryTargetPosition = targetPart.Position + Vector3.new(0, 1, 0)
    crowbarVisual.CFrame = CFrame.new(pryTargetPosition) * CFrame.Angles(math.rad(45), 0, 0)
    crowbarVisual.Parent = workspace

    -- 撬动动画
    local pryTween = TweenService:Create(
        crowbarVisual,
        TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.InOut),
        { CFrame = crowbarVisual.CFrame * CFrame.Angles(math.rad(-30), 0, 0) }
    )
    pryTween:Play()

    -- 撬开效果
    task.delay(0.5, function()
        -- 标记为已撬开
        targetPart:SetAttribute('PriedOpen', true)

        -- 移除目标(如果是锁)
        local lock = targetPart:FindFirstChild('Lock')
        if lock then
            lock:Destroy()
        end

        -- 或者移动目标(如果是门/盖)
        if targetPart.Name == 'ChestLid' then
            local openTween = TweenService:Create(
                targetPart,
                TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                {
                    CFrame = targetPart.CFrame
                        * CFrame.Angles(math.rad(-45), 0, 0)
                        * CFrame.new(0, 0.5, 0.5),
                }
            )
            openTween:Play()
        end

        -- 移除视觉提示
        crowbarVisual:Destroy()
    end)

    return true
end

-- ====================
-- 交互检测系统
-- ====================

-- 检测玩家周围的交互对象（优化版：使用标签系统）
function ItemFunctionality.detectInteractableObjects(player: Player, range: number): { BasePart }
    local interactables = {}
    local character = player.Character

    if not character or not character.HumanoidRootPart then
        return interactables
    end

    local playerPos = character.HumanoidRootPart.Position

    -- 使用CollectionService获取所有带有Interactable标签的对象，性能更好
    for _, object in ipairs(CollectionService:GetTagged('Interactable')) do
        if object:IsA('BasePart') then
            local distance = (object.Position - playerPos).Magnitude
            if distance <= range then
                table.insert(interactables, object)
            end
        end
    end

    return interactables
end

-- 注册可交互对象
function ItemFunctionality.registerInteractable(
    part: BasePart,
    interactionType: string,
    options: { [string]: any }
)
    -- 使用标签系统而不是属性，提升性能
    CollectionService:AddTag(part, 'Interactable')
    CollectionService:AddTag(part, interactionType)

    if options then
        for key, value in pairs(options) do
            part:SetAttribute(key, value)
        end
    end
end

-- ====================
-- 网络事件处理
-- ====================

-- 使用道具功能
Remotes.UseItemFunction.OnServerEvent:Connect(
    function(player: Player, itemName: string, target: any, actionType: string)
        local success = false

        if itemName == 'Flashlight' and actionType == 'toggle' then
            success = ItemFunctionality.toggleFlashlight(player)
        elseif itemName == 'Rope' then
            if actionType == 'climb' and target then
                success = ItemFunctionality.climbWithRope(player, target)
            elseif actionType == 'cross' and target then
                success = ItemFunctionality.crossWithRope(player, target)
            elseif actionType == 'tether' and target then
                success = ItemFunctionality.tetherMonster(player, target)
            end
        elseif itemName == 'Crowbar' and actionType == 'pry' and target then
            success = ItemFunctionality.pryOpen(player, target)
        end

        if success then
            print(player.Name .. ' 使用了 ' .. itemName .. ' 功能: ' .. actionType)
        else
            warn(player.Name .. ' 使用 ' .. itemName .. ' 功能失败: ' .. actionType)
        end
    end
)

-- 查询附近的可交互对象
Remotes.GetInteractables.OnServerInvoke = function(player: Player, range: number): { BasePart }
    return ItemFunctionality.detectInteractableObjects(player, range or 10)
end

return ItemFunctionality
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="104">
        <Properties>
          <string name="Name">ItemService</string>
          <string name="Source"><![CDATA[--!strict
--#region Types

export type PlayerData = {
    Inventory: { [string]: ItemData },
}

export type ItemData = {
    Name: string,
    Type: string,
    Description: string,
    IsEquipped: boolean,
    IsActive: boolean,
}

--#endregion

--#region Services

local Players = game:GetService('Players')
local ReplicatedStorage = game:GetService('ReplicatedStorage')

--#endregion

--#region Requires

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Shared = require(Packages:WaitForChild('Shared'))
local Remotes = Shared.Network.Remotes.waitForScope(Shared.Network.Remotes.Scope.Run)

--#endregion

--#region Module

local ItemService = {}

-- 道具定义
ItemService.Items = {
    BurningTorch = {
        Name = '燃烧的火把',
        Type = 'Tool',
        Description = '点燃倒塌的灯塔',
        IsEquipped = false,
        IsActive = false,
    },
    Flashlight = {
        Name = '手电筒',
        Type = 'Tool',
        Description = '照亮黑暗区域',
        IsEquipped = false,
        IsActive = false,
    },
    Rope = {
        Name = '绳索',
        Type = 'Tool',
        Description = '攀爬高处、跨越断层、固定怪物',
        IsEquipped = false,
        IsActive = false,
    },
    Crowbar = {
        Name = '撬棍',
        Type = 'Tool',
        Description = '撬开锁住的箱子/门',
        IsEquipped = false,
        IsActive = false,
    },
}

-- 玩家数据存储
ItemService.PlayerData = {}

-- 初始化玩家数据
function ItemService.initPlayer(player: Player)
    ItemService.PlayerData[player.UserId] = {
        Inventory = {},
    }
end

-- 清理玩家数据
function ItemService.cleanupPlayer(player: Player)
    ItemService.PlayerData[player.UserId] = nil
end

-- 检查玩家是否拥有道具
function ItemService.hasItem(player: Player, itemName: string): boolean
    local data = ItemService.PlayerData[player.UserId]
    if not data then
        return false
    end
    return data.Inventory[itemName] ~= nil
end

-- 获得道具
function ItemService.giveItem(player: Player, itemName: string): boolean
    if not ItemService.Items[itemName] then
        warn('Item not found: ' .. itemName)
        return false
    end

    local data = ItemService.PlayerData[player.UserId]
    if not data then
        return false
    end

    -- 如果已经拥有该道具，不重复获得
    if data.Inventory[itemName] then
        return false
    end

    -- 创建道具数据
    local itemData = table.clone(ItemService.Items[itemName])
    data.Inventory[itemName] = itemData

    print(player.Name .. ' 获得了道具: ' .. itemName)
    return true
end

-- 装备道具
function ItemService.equipItem(player: Player, itemName: string): boolean
    local data = ItemService.PlayerData[player.UserId]
    if not data or not data.Inventory[itemName] then
        return false
    end

    -- 卸下其他已装备的道具
    for _, item in data.Inventory do
        if item.IsEquipped then
            item.IsEquipped = false
        end
    end

    -- 装备指定道具
    data.Inventory[itemName].IsEquipped = true
    return true
end

-- 卸下道具
function ItemService.unequipItem(player: Player, itemName: string): boolean
    local data = ItemService.PlayerData[player.UserId]
    if not data or not data.Inventory[itemName] then
        return false
    end

    data.Inventory[itemName].IsEquipped = false
    return true
end

-- 激活道具（如手电筒开关）
function ItemService.toggleItemActive(player: Player, itemName: string): boolean
    local data = ItemService.PlayerData[player.UserId]
    if not data or not data.Inventory[itemName] then
        return false
    end

    local currentState = data.Inventory[itemName].IsActive
    data.Inventory[itemName].IsActive = not currentState

    return not currentState -- 返回新的状态
end

-- 获取道具状态
function ItemService.getItemData(player: Player, itemName: string): ItemData?
    local data = ItemService.PlayerData[player.UserId]
    if not data then
        return nil
    end
    return data.Inventory[itemName]
end

-- 获取玩家背包
function ItemService.getInventory(player: Player): { [string]: ItemData }
    local data = ItemService.PlayerData[player.UserId]
    if not data then
        return {}
    end
    return data.Inventory
end

-- 初始化服务
-- 处理新加入的玩家
Players.PlayerAdded:Connect(function(player)
    ItemService.initPlayer(player)
end)

-- 处理脚本加载时已在场的玩家
for _, player in ipairs(Players:GetPlayers()) do
    ItemService.initPlayer(player)
end

-- 处理玩家离开
Players.PlayerRemoving:Connect(function(player)
    ItemService.cleanupPlayer(player)
end)

-- ==================== 网络事件处理 ====================

-- 获取背包数据
Remotes.GetInventory.OnServerInvoke = function(player: Player): { [string]: ItemData }
    return ItemService.getInventory(player)
end

-- 获取单个道具数据
Remotes.GetItemData.OnServerInvoke = function(player: Player, itemName: string): ItemData?
    return ItemService.getItemData(player, itemName)
end

-- 装备/卸下道具
Remotes.EquipItem.OnServerEvent:Connect(function(player: Player, itemName: string, equip: boolean)
    if equip then
        local success = ItemService.equipItem(player, itemName)
        if success then
            print(player.Name .. ' 装备了: ' .. itemName)
        end
    else
        local success = ItemService.unequipItem(player, itemName)
        if success then
            print(player.Name .. ' 卸下了: ' .. itemName)
        end
    end
end)

-- 使用道具
Remotes.UseItem.OnServerEvent:Connect(function(player: Player, itemName: string)
    local success = ItemService.toggleItemActive(player, itemName)
    if success then
        local itemData = ItemService.getItemData(player, itemName)
        if itemData then
            print(
                player.Name
                    .. ' 使用了: '
                    .. itemName
                    .. ' (状态: '
                    .. tostring(itemData.IsActive)
                    .. ')'
            )
        end
    end
end)

return ItemService
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="105">
        <Properties>
          <string name="Name">LocalDebugMazeWorldBuilder</string>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService('ReplicatedStorage')

local Packages = ReplicatedStorage:WaitForChild('Packages')
local Shared = require(Packages:WaitForChild('Shared'))

local LocalDebugMazeWorldBuilder = {}

local LOCAL_DEBUG_MAZE_WORLD_NAME = 'LocalDebugMazeWorld'
local DEFAULT_ORIGIN_OFFSET = Vector3.new(0, 0, 420)

function LocalDebugMazeWorldBuilder.build(seed, config, originOffset)
    return Shared.Runtime.MazeDebugWorldComposer.build(seed, config, {
        WorldName = LOCAL_DEBUG_MAZE_WORLD_NAME,
        OriginOffset = originOffset or DEFAULT_ORIGIN_OFFSET,
        IncludeRoomMarkers = true,
        RoomMarkerTransparency = 0.55,
        ReturnObjectText = 'Return To Camp (Local Debug)',
        ReturnMaxActivationDistance = 14,
    })
end

return LocalDebugMazeWorldBuilder
]]></string>
        </Properties>
