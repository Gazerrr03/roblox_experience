-- 更新商品详情显示
local function updateShopDetail(item)
    selectedShopItem = item
    if item then
        shopDetailName.Text = item.Name or '未知商品'
        shopDetailIconLabel.Text = item.IconLabel or '?'
        shopDetailPrice.Text = string.format('价格: %d 书页', item.Price or 0)

        local stock = item.Stock or 0
        if stock <= 0 then
            shopDetailStock.Text = '当前库存: 库存不足'
            shopDetailStock.TextColor3 = Color3.fromRGB(255, 80, 80)
            shopBuyButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
            shopBuyButton.Text = '无法购买'
        else
            shopDetailStock.Text = string.format('当前库存: %d', stock)
            shopDetailStock.TextColor3 = Theme.Text
            shopBuyButton.BackgroundColor3 = Theme.Accent
            shopBuyButton.Text = '立即购买'
        end

        -- 道具类型
        local itemType = item.Type or 'misc'
        local typeText = '道具类型: '
        if itemType == 'tool' then
            typeText = typeText .. '工具'
            shopDetailType.Text = typeText
            shopDetailType.TextColor3 = Theme.Text
            if item.Consumable then
                shopDetailDurability.Text = '特殊: 需消耗电池'
                shopDetailDurability.TextColor3 = Theme.Warning
            else
                shopDetailDurability.Text = '特殊: 非消耗品，有耐久度'
                shopDetailDurability.TextColor3 = Theme.Accent
            end
        elseif itemType == 'consumable' then
            typeText = typeText .. '消耗品'
            shopDetailType.Text = typeText
            shopDetailType.TextColor3 = Theme.Text
            local healAmount = item.HealAmount or 50
            shopDetailDurability.Text = string.format('特殊: 使用后恢复 %d 生命值', healAmount)
            shopDetailDurability.TextColor3 = Color3.fromRGB(80, 255, 120)
        else
            typeText = typeText .. '杂物'
            shopDetailType.Text = typeText
            shopDetailType.TextColor3 = Theme.Text
            shopDetailDurability.Text = ''
        end

        -- 描述
        shopDetailDesc.Text = item.Description or '暂无描述'
        shopBuyButton.Visible = true
    else
        shopDetailName.Text = '请选择商品'
        shopDetailIconLabel.Text = '?'
        shopDetailPrice.Text = ''
        shopDetailStock.Text = ''
        shopDetailType.Text = ''
        shopDetailDurability.Text = ''
        shopDetailDesc.Text = '点击左侧商品查看详情'
        shopBuyButton.Visible = false
    end
end

-- 购买按钮点击
shopBuyButton.MouseButton1Click:Connect(function()
    if selectedShopItem and selectedShopItem.Stock and selectedShopItem.Stock > 0 then
        Remotes.RunAction:FireServer({
            Type = 'RequestPurchaseItem',
            ItemId = selectedShopItem.Id,
        })
    end
end)

