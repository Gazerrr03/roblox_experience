              <string name="Source">local MazePassageTemplates = require(script.Parent.MazePassageTemplates)

local MazeRoomTemplates = {}

local function freezeRange(minDepth, maxDepth)
    return table.freeze({
        Min = minDepth,
        Max = maxDepth,
    })
