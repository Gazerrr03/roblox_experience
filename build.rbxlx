-- 设置当前模态面板
local function setActiveModal(nextModal)
    activeModal = nextModal
    local showModal = nextModal ~= nil

    modalBackdrop.Visible = showModal
    if shopPanel then shopPanel.Visible = nextModal == 'Shop' end
    if sellPanel then sellPanel.Visible = nextModal == 'Sell' end
    if objectivePanel then objectivePanel.Visible = nextModal == 'Objective' end

    syncMouseMode()
end

