{
  "name": "roblox-experience-tests",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Packages": {
        "$className": "Folder",
        "Shared": {
          "$path": "../packages/shared/src"
        },
        "Gameplay": {
          "$path": "../packages/gameplay/src"
        },
        "UI": {
          "$path": "../packages/ui/src"
        }
      },
      "Assets": {
        "$className": "Folder",
        "ToolTemplates": {
          "$className": "Folder",
          "ToolFlashlight": {
            "$className": "Model",
            "Handle": {
              "$className": "Part",
              "$properties": {
                "Anchored": true,
                "CanCollide": false,
                "Size": [0.2, 0.35, 0.2]
              }
            }
          },
          "ToolCrowbar": {
            "$className": "Model",
            "Handle": {
              "$className": "Part",
              "$properties": {
                "Anchored": true,
                "CanCollide": false,
                "Size": [0.15, 0.55, 0.12]
              }
            }
          },
          "ToolPotion": {
            "$className": "Model",
            "Handle": {
              "$className": "Part",
              "$properties": {
                "Anchored": true,
                "CanCollide": false,
                "Size": [0.25, 0.45, 0.25]
              }
            }
          }
        }
      },
      "PlaceModules": {
        "$className": "Folder",
        "Run": {
          "$path": "../places/run/src/ServerScriptService/Run"
        },
        "Maze": {
          "$path": "../places/maze/src/ServerScriptService/Maze"
        }
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$path": "src"
    }
  }
}
